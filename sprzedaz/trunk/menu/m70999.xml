<script>
<![CDATA[
'CFileDrive
#include "50211"
'getUserDirectory()
#include "50212"

function xxfopen

if (not checkUserDirectory()) then
	exit function
end if

dim idObj : idObj = 361813
dim strTmpPath : strTmpPath = getUserDirectory() + "\" + "FVAT_" + cstr(idObj) + ".pdf"

dim strHostURL : strHostURL = "http://localhost:8024/"
'get
dim oHTTPMod : set oHTTPMod = doc_.getmodule(60217)

dim strURL: strURL = oHTTPMod.prepare_get_invoice_url(strHostURL, "bela", idObj)

dim oHTTPStream : set oHTTPStream = oHTTPMod.get_http_stream(strURL)

'save
dim pSO : set pSO = doc_.createstreamobj
pSO.attach oHTTPStream
pSO.save strTmpPath
set pSO = nothing

'open
dim WshShell: Set WshShell = CreateObject("WScript.Shell")
WshShell.Run """"+ strTmpPath + """"

'msgbox oHTTPMod.get_http_text("https://nxm.com.pl")

end function
]]>
</script>
