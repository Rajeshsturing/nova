	end if
	fopen=true		
end function

function navigate_portfel()
	doc_.getmodule(PAGE_FORM_WEB).navigate "www.portfel.pl"
end function

#include "50122"
#include "50203"



function makeMessage()

	dim strMessage,i
	strMessage = "Chcielibyśmy otrzymywac następujace informacje:" + vbNewLine + vbNewline

	for i=1 to 7	
		if mid(page_.ctrl(100).value,i,1)="1" then
			strMessage = strMessage + " -" + page_.ctrl(100+i).text	+ vbNewLine
		end if
	next

	strMessage = vbNewLine + strMessage + "			" + getCurrentFirma().strNazwa
	makeMessage = strMessage
end function

#include "50226"

function send()

	dim pNavoMapi
	set pNavoMapi=new CNavoMAPI

	if (not pNavoMapi.connect()) then
		exit function
	end if

	dim pMail
	set pMail = pNavoMapi.getMAIL()

	strTo = "XXXXXX"

	dim pEmailModule
	set pEmailModule=doc_.getmodule(PAGE_FORM_EMAIL)

	dim bResult

	if pEmailModule is nothing then
		bREsult = false
	else
		bResult=pEmailModule.send_email(pMail, strTo, "Sonda", makeMessage(), nothing)
	end if	

	if bResult then
		MessageBox "Ankieta została pomyślnie wysłana.", "Sonda", vbOkOnly, vbInformation
	else
		MessageBox "Nie udało się wysłać ankiety. Spróbuj ponownie.", "Sonda", vbOkOnly, vbInformation
	end if

end function


]]>
