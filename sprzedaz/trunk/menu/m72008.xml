<?xml version="1.0" encoding="windows-1250" ?>
<page>
<!--
	Otwieranie zapisanej strony w formacie NXP
-->
<config>
<secidread>UAR_CMDID(CMDID_OPEN_PAGE_EXT)</secidread>

<script><![CDATA[


#include "50203"
#include "50516"
#include "50211"
#include "50101"
#include "50123"

function fopen(): fopen = false

	if not std_fopen() then
		exit function
	end if
		
	'pobierz sciezke do pliku
	dim strPath : strPath=SelectFile("c:\", "*.nxp", "")

	if (strPath="") then
		exit function
	end if

	dim pFso, bOK
	set pFso=CFileDrive(bOK)

	'czy udalo sie CreateObject dla FileSystemObject
	if (not bOK) then
		view_message 6189, 0 
		exit function
	end if
	
	'stream
	dim pSo
	set pSo=doc_.createstreamobj()

	'brak pliku
	if (not pFso.isFile(strPath)) then
		view_message1 6060, 0, strPath
		exit function
	end if

	'attach i dekoduj
#ifdef _DEBUG
	msgbox "DEBUG: w debug plik ma być odkodowany"
	pSo.attach CStr( strPath )
#else	
	pSo.attachcoded CStr( strPath )
#endif

	'otwieramy strone na podstawie stream'a
	if (len(strPath)>0) then
		dim pHli
		set pHli=doc_.createhlistr("varCmd=CMD_OPEN_STATIC_PAGE")
		set pHli.prop(GVAR_DESTPAGE)=pSo.getstream()

		dim pPage:set pPage=doc_.getpagehli(pHli)
		if (pPage is nothing) then
			exit function
		end if

		pPage.domodalauto()
	end if
end function

]]></script>
</config>
<header>
</header>
<body>
</body>
<footer>
</footer>
</page>
