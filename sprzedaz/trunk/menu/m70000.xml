sub init_fiskkas_pooling()
	dim pM60224 : set pM60224 = doc_.getmodule(60224)
	dim pSettings: set pSettings = pM60224.new_fiskkas_settings()
	pSettings.from_registry "HKLM_KASA_TYPE_MODE_SETTINGS"
	
	if pSettings.m_cOnline = "1" then
		doc_.timer TIMERID_POOL_FISKKAS,"varCmd=CMD_OPEN_STATIC_PAGE varDestPage=20601 varNewThread=1", 30
	end if

end sub
'------------------------------------------------------------------------
' Funkcja wolana na uruchomienie aplikacji
'------------------------------------------------------------------------
function Application_InitInstance()

	'ładowanie "sprawdzaczy" :)

	'co 15 minut
	doc_.timer TIMERID_SLOWTIMER,"varCmd=CMD_OPEN_STATIC_PAGE varDestPage=PAGE_MODULE_TIMER varNewThread=1", 900

	'uruchomienie timera przypominającego o zadaniach
	doc_.timer TIMERID_TASKS,"varCmd=CMD_OPEN_STATIC_PAGE varDestPage=20159 varNewThread=1", 300


	'----------------------------------------------------------
	'
	' przeniesione na host
	' nalezy ustawic w nxm.ebnet.mod.nxm_mod_settings wartosc enable_stock_precomputation = true
	'
	'if getCurrentUser().strLogin = "Administrator" then
	'	  'uruchomienie timera sprawdzajacego GM
	'  doc_.timer TIMERID_GM_CHECK,"varCmd=CMD_OPEN_STATIC_PAGE varDestPage=60230 varNewThread=1", 60
	'end if
	'----------------------------------------------------------

	'kasa fiskalna
	init_fiskkas_pooling

	'............................................................
	'Otwieramy okno startowe
	'............................................................

	dim nStartingCmdId : nStartingCmdId = getuserprofileLong(USERPROF_STARTING_CMDID)

	if nStartingCmdId <> 0 then
		dim pCmdHLI : set pCmdHLI = doc_.getmodule(60164).get_hyperlink_for_cmdid(nStartingCmdId)
		if not pCmdHLI is nothing then
			doc_.postcommand pCmdHLI.getstring()
		end if
	end if
	
end function

'------------------------------------------------------------------------
' Nie zmianiac - wolno edytiowac init i exit instance
'------------------------------------------------------------------------
function fopen()
	Application_InitInstance
	fopen=false
end function

function fclose()
	fclose=true
end function

