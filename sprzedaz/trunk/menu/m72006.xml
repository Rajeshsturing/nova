#include "h1000.h"

<?xml version="1.0" encoding="windows-1250" ?>
<page>
<config>
<script>
<![CDATA[
'strona zawiera funkcje pomocnicze przydatne przy instalacji
'check mdac
function is_mdac_26
	on error resume next
	dim adoconn : set adoconn = createobject("ADODB.Connection.2.6")
	is_mdac_26 = isobject(adoconn)
end function

'install mdac
function install_mdac(byref instses)
	install_mdac = false
	dim sysobj: set sysobj = doc_.system
	'znajdź media source
	dim strMediaSrc: strMediaSrc = sysobj.registry(hKey_LocalMachine,"SOFTWARE\NAVO\NAVO2002\Setup","MediaSource")
	if strMediaSrc = "" then
		exit function
	end if
	'to_do
	install_mdac = true
end function

'check mssql2000
function is_mssql2000
	on error resume next
	dim sqldmo : set sqldmo = createobject("SQLDMO.SQLServer2.8.0")
	is_mssql2000 = isobject(sqldmo)
end function

'install msde80
function install_msde80(byref instses)
	install_msde80 = false
	dim sysobj: set sysobj = doc_.system

	'znajdź root instalacji
	dim strInstRoot: strInstRoot = sysobj.registry(hKey_LocalMachine,"SOFTWARE\NAVO\NAVO2002\Setup","InstallationRoot")
	if strInstRoot = "" then
		exit function
	end if
	'znajdź media source
	dim strMediaSrc: strMediaSrc = sysobj.registry(hKey_LocalMachine,"SOFTWARE\NAVO\NAVO2002\Setup","MediaSource")
	if strMediaSrc = "" then
		exit function
	end if

	dim strTargetDir : strTargetDir = left(sysobj.windir,1) + ":\Program Files\Microsoft SQL Server\Mssql$NAVO2002\Binn\"
	dim strDataDir : strDataDir = strInstRoot + "Database\"
	dim strLogName : strLogName = strTargetDir + "msde80setuplog.txt"
	dim strArgs : strArgs = "TARGETDIR=""" + strTargetDir + """ DATADIR=""" + strDataDir +_ 
	""" INSTANCENAME=""NAVO2002"" COLLATION=""SQL_Polish_Cp1250_CI_AS"" SAPASSWORD=""clio2000"" /L*v """ +_
	strLogName + """ /qb "
	
	msgbox strArgs
	msgbox strMediaSrc
	dim exitcode: exitcode = sysobj.execute(strMediaSrc+"components\msde80\setup.exe",_
		strMediaSrc+"components\msde80\",strArgs,true,true)
	install_msde80 = (exitcode = 0)
end function

]]>
</script>
</config>
