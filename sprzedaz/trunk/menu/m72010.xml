<?xml version="1.0" encoding="windows-1250" ?>
<!-- lista okien w systemie -->
<page>
<config>
<title>Lista okien</title>
<script>
<![CDATA[

#include "50101"

function fopen
#ifdef _ABAKUS
  if HARUI_FREE(UAR_OGRANICZONY_DOSTEP_DANE_KLIENTA) then
    fopen = false
    exit function
  end if
#endif	
	dim strTitle:strTitle = "QUICK_ACCESS_TITLE"
	dim bFound:bFound=false
	dim pagestack
	dim page_id
	for each pagestack in doc_
		if not pagestack.gettoppage is nothing then
			if pagestack.gettoppage.topelement.title=strTitle then
				page_id = pagestack.gettoppage.iid
				bFound=true
			end if
		end if
	next
	if bFound then
		doc_.postcommand("varCmd=9005 vn5040="+cstr(page_id))
	else
		doc_.postcommand("varCmd=CMD_OPEN_RECORD_PAGE varDestPage=70006 varNewThread=1")
	end if
	fopen=false
end function
]]>
</script>
</config>
