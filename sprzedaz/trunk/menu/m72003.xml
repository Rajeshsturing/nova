<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE' width='10000'>
<config>
<startpos>center</startpos>
<title>Deinstalacja serwera</title>
<script>
<![CDATA[

#include "50203"
#include "50122"

dim strUnInKey
dim strAppName

function do_uninstall_server
	do_uninstall_server = false

	if (not doc_.getmodule(72001).do_uninstall_client()) then
		MessageBox "Nie udało się odinstalować klienta " + strUnInKey + " z tego komputera", "Deinstalacja przerwana", vbOKOnly, vbInformation
		exit function
	end if
	
	dim instses : set instses = createobject("navoinstall.session")
	instses.setlogname strUnInKey + " Serwer Setup.txt"
	instses.addlogmsg "Removing " + strUnInKey + " Serwer from the local computer..."

	dim sysobj: set sysobj = doc_.system

	'usuwanie aplikacji
	dim appdb
	set appdb = createobject("navoappdb.appdbmanager")
	appdb.drop strUnInKey

	'---- W TYM MIEJSCU JUŻ NIE MA APLIKACJI ---- 
	'---- I NIE MOŻNA SIĘ ODWOŁYWAĆ DO JEJ MODUŁÓW ----

	'usuwanie registry - uninstall
	sysobj.delregistrykey hKey_LocalMachine,strUnInKey

	instses.addlogmsg "Removing " + strUnInKey + " Serwer: success"

	do_uninstall_server = true
end function

function on_uninstall_server()
	if (not do_uninstall_server()) then
		MessageBox "Nie udało się odinstalować serwera " + strUnInKey + " z tego komputera", "Deinstalacja przerwana", vbOKOnly, vbInformation
	end if

	doc_.postcommand "varCmd=CMD_GOBACK"
end function

function fopen()
	strAppName=trans_.var(GVAR_APPLICATION)
	strUnInKey = "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\" + strAppName + " Serwer"

	page_.topelement.title = "Deinstalacja serwera " + strAppName
	page_.ctrl(10).text = "Naciśnij przycisk 'Odinstaluj' aby odinstalować serwer aplikacji " + strAppName

	page_.ctrl(2).focus=true
	fopen=true
end function

function fback()
	fback = std_fback()
	doc_.postcommand "varCmd=CMD_QUIT"
end function

]]>
</script>
</config>
