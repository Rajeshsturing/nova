#include "h1000.h"
#include "h1001.h"

<?xml version="1.0" encoding="windows-1250" ?>
<!-- lista okien w systemie -->
<page  style='STYLE_PAGE'>
<config>
<title>Prześlij obiekt</title>
<script>
<![CDATA[

function activate(byref hli)
	dim pPage
	set pPage = hli.prop(5000)

	nTypeId=pPage.root.type
	nIdObj=pPage.rootidobj

	page_.goback
end function

function HasObject(byref pPage):HasObject=false
	if (not pPage.root is nothing) then
		HasObject=true
	end if
end function

dim strAsText

function dynamic_as_text(byref pObj)
	strAsText=""

	on error resume next
	
	dim strCode
	strCode="strAsText=pObj." + pObj.getobjdef.tablename + "_as_text()"

	Execute strCode

	dynamic_as_text=strAsText
end function

function load_list

	dim pPageStack
	dim tab:set tab = doc_.afc.new_tb(page_).attach(page_.ctrl(100)).removeall
	
	for each pPageStack in doc_
	
		if not pPageStack.gettoppage is nothing then
			
			dim pPage
			set pPage=pPageStack.gettoppage

			'jezeli strona dziala na obiekcie
			if ( HasObject(pPage) ) then

				dim bDisable
				bDisable=false

				if (pPage.root.isnew) then
					bDisable=true
				end if				


				'ustaw skrot
				dim pHli : set pHli = doc_.createhlistr("varFunctionHLI='activate'")
				set pHli.prop(5000) = pPageStack.gettoppage
				tab.newrow.newcell.addtexthli pPageStack.gettoppage.topelement.title , pHli
				tab.element.width = clng(MAXIMIZE_SIZE)


				tab.newcell.addtexthli pPage.root.getobjdef.humanname , pHli
				tab.element.disable=bDisable
				tab.element.width = clng(MAXIMIZE_SIZE)				

				tab.newcell.addtexthli "",pHli

				dim pPageRoot
				set pPageRoot=trans_.getobj(pPage.root.type, pPage.rootidobj)
				
				if (not pPageRoot is nothing) then
					tab.element.text = dynamic_as_text(pPageRoot)
				end if

				set pPageRoot=nothing

				tab.element.disable=bDisable
				tab.element.width = clng(MAXIMIZE_SIZE)

			end if

		end if

	next

end function

dim nTypeId
dim nIdObj

function fopen()
	nTypeId=0
	nIdObj=0

	load_list

	fopen = true
end function

function getTypeId()
	getTypeId=nTypeId
end function

function getIdObj()
	getIdObj=nIdObj
end function

]]>
</script>
</config>
<header>
</header>
<body>
	<text forecolor='black' align = 'center' width='max' fontsize='4' bold='true'>Wybierz obiekt z okna</text><br/>
	<t></t><br/><br/>
	
	<table name='t100'>
		<thead>
			<tr style='STYLE_TABLE_HEADER'>
				<td>
					<t bold='true'>Nazwa okna</t>
				</td>
				<td>
					<t bold='true'>Typ obiektu</t>
				</td>
				<td>
					<t bold='true'>Opis obiektu</t>
				</td>
			</tr>
		</thead>
		<tbody style='STYLE_TABLE_BODY'>
		</tbody>
	</table>
	
	<t/><br/>
	<button style='STYLE_BUTTON' href='varFunction="load_list"'>Odśwież</button>
</body>
<footer>
</footer>
</page>
