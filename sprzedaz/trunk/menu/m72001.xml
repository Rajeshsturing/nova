#include "h1000.h"

<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE' width='10000'>
<config>
<startpos>center</startpos>
<title>Deinstalacja klienta</title>
<script>
<![CDATA[

#include "50203"
#include "50122"

dim strUnInKey
dim strAppName

function fopen()
	strAppName=trans_.var(GVAR_APPLICATION)

	strUnInKey = "SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\" + strAppName
	
	page_.topelement.title = "Deinstalacja klienta " + strAppName
	page_.ctrl(10).text = "Naciśnij przycisk 'Odinstaluj' aby odinstalować klienta aplikacji " + strAppName + " z tego komputera"

	fopen = true
end function

function fback()
	fback = std_fback()
	doc_.postcommand "varCmd=CMD_QUIT"
end function

function do_uninstall_client(): do_uninstall_client = false

	dim pPrerforming
	set pPrerforming = doc_.performing("Deinstalacja klienta aplikacji """ + strAppName + """ . . .")
	
	dim instses
	set instses = createobject("navoinstall.session")

	instses.setlogname strAppName + " Setup log.txt"
	instses.removeshortcut "NAVO Enterprise 2015", strAppName
	instses.removeshortcut "NAVO Enterprise 2015","Szablon importu danych"
	instses.removeshortcut "NAVO Enterprise 2015","Odzyskiwanie bazy danych"
	instses.removeshortcut "@desktop@", strAppName
	instses.removegroup    "NAVO Enterprise 2015",false	'nie usunie jeśli coś jeszcze zostało

	'Usuwanie registry - uninstall
	dim sysobj: set sysobj = doc_.system
	sysobj.delregistrykey hKey_LocalMachine,strUnInKey

	set pPrerforming = nothing
	do_uninstall_client = true
end function

function on_uninstall_client()
	if do_uninstall_client() then
		MessageBox "Deinstalacja zakończyła się pomyślnie.", "Deinstalacja zakończona", vbOKOnly, vbInformation
	else
		MessageBox "Nie udało się odinstalować klienta " + strAppName + " z tego komputera", "Deinstalacja nieudana", vbOKOnly, vbInformation
	end if

	doc_.postcommand "varCmd=CMD_GOBACK"
end function


]]>
</script>
</config>
<header>
</header>
