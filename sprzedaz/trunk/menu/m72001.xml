		<tr style='STYLE_ROW_BTN' width='max'>
			<td align='center'>
				<button style='STYLE_BUTTON' name='t1' href='varFunction="on_uninstall_client"'>Odinstaluj</button><t/>
				<button style='STYLE_BUTTON' name='t2' href='varCmd=CMD_GOBACK'>Anuluj</button>
			</td>
		</tr>

		</tbody></table>
		
	</body>
