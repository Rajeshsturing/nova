<script>
<![CDATA[

#include "50100"
#include "50203"
#include "50122"

'SelectFile
#include "50123"

dim strFileName

'-----------------------------------------------------------------------------
' Import obiektów z pliku 
'-----------------------------------------------------------------------------
function importXML(byval strFileName)
	dim pImportHelper : set pImportHelper =  doc_.getmodule(60211) 
	importXML = pImportHelper.import_nxd_file_2_EB( strFileName )
end function

dim pPrerformingImp
set pPrerformingImp = nothing
dim strOldTextImp

'-----------------------------------------------------------------------------
' Event: Torzymy performing
'-----------------------------------------------------------------------------
function Import_CreatePerforming(byref pExpMan, byval strText)
	if (pPrerformingImp is nothing) then
		page_.updateview
		set pPrerformingImp = doc_.performing( strText )
		strOldTextImp=strText
		exit function
	end if

	pPrerformingImp.text = strText
	strOldTextImp=strText
end function

'-----------------------------------------------------------------------------
' Event: Niszczymy performing
'-----------------------------------------------------------------------------
function Import_DestroyPerforming(byref pExpMan)
	set pPrerformingImp = nothing
	strOldTextImp = ""
end function



function fopen()
	'Inicjacja systemu
	dim bSystemInit
	bSystemInit=doc_.getmodule(60121).system_init()

	if (not bSystemInit) then
		doc_.postcommand "varCmd=CMD_QUIT"
		exit function
	end if
	
	dim bRes
	strFileName = trans_.var(APPVAR_FILENAME)
		
	if MessageBox("Czy na pewno chcesz importować dane klienta?", "Import wizytówki", vbYesNo, vbInformation)=vbYes then
		bRes = (importXML(strFileName) = 0)
		if bRes then
			MessageBox "Zaimportowano klienta", "Import wizytówki", vbOkOnly, vbInformation
		else
			MessageBox "Wystąpił błąd podczas importu", "Import wizytówki", vbOkOnly, vbInformation
		end if
	end if
end function

function import()
	strFileName = trans_.var(APPVAR_FILENAME)	
	importXML strFileName
end function


]]>
</script>
