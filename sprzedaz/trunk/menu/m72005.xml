		[THIS_FILE]
	#endif
	</title>

<script>
<![CDATA[

'--------------------------------------------------------------------------
' (c) NAVO 2003 Ltd.
' Spikowski Piotr
'
' Wybór pozycji menu
'--------------------------------------------------------------------------

'menu_insert2table
#include "50635"

#define TABLE_MENU_ROOT		100

dim g_pOutlookBar	'Reprezentuje wszystkie opcjie outlookbar'a
set g_pOutlookBar = nothing

dim g_bCurrentUser	'Czy edycja odbywa sie dla aktualnie zalogowanego
g_bCurrentUser = true

function fopen(): fopen = false
	'Wstawiamy do naszej strony menu rezprezentowane przez
	'poszczegolne wiersze tabelki
	menu2table

	fopen = true
end function

'--------------------------------------------------------------------------
' Kopiuj odpowiednie pozycje menu na nasza strone tzn. wstawiaj pozycje
' menu na strone
'--------------------------------------------------------------------------
private function menu2table()
	menu_insert2table TABLE_MENU_ROOT, _
		"Ta  pozycja menu nie może być dodana", _
		"Kliknij aby dodać pozycję menu"
end function

'--------------------------------------------------------------------------
' Zmienia lub dodaje pozycję na pasku szybkiego dostępu
'--------------------------------------------------------------------------
function menu_addchangeitem(byref pHli)
	page_.result = CLng(pHli.prop(102)) 'CommandIID
	page_.goback
end function


]]>
</script>
