<?xml version="1.0" encoding="windows-1250" ?>

<!-- FAKTURA VAT -->
#include "h1240"

#define TEXT1 Informujemy o płatnościach .....
#define TEXT2 Na podstawie § 13, ust. 3 Rozporządzenia Rady Ministrów z dnia 21.11.75 r w sprawie postępowania arbitrażowego (Dz. U. Nr 39, poz. 209) - art. 476 Kodeksu Cywilnego (Dz. U. Z 1964 r nr 16, poz. 93 z późn. zm.) wzywamy do uregulowania należnej nam sumy według poniższego zestawienia.
#define TEXT3 Ponawiamy wezwanie do zapłaty 
#define TEXT4 Ostateczne wezwanie sądowne.

#define TEXT21 w ciągu 5 dni od daty otrzymania niniejszego wezwania


#define TYTULINF INFORMACJA O SALDZIE
#define TYTULWEZ WEZWANIE DO ZAPŁATY
#define TYTULWEZ2 PONOWNE WEZWANIE DO ZAPŁATY
#define TYTULOSTA OSTATECZNE WEZWANIE DO ZAPŁATY

#define FIRMA_MIASTO					<% so.write util_.Firma_Miasto %>
#define	FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma.pBank1.strNazwa %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma.strRachunek1 %>
#define FIRMA_FAX						<% so.write util_.firma.strfax%>
#define UZYTKOWNIK_REJESTRACYJNY		<% so.write util_.Uzytkownik_Nazwa%>
#define FIRMA_NAZWA						<% so.write util_.Firma.strNazwa%>

#define KLIENT_FIRMA_NAZWA				<% so.write root_.strNazwa%>
#define KLIENT_KOD_POCZTOWY				<% so.write root_.strKod%>

#define DOKUMENT_NUMER					<% so.write root_.text %>
#define TRANSAKCJA						<%so.write pC("strSymTrans")%>
#define TERMIN_PLATNOSC					<%so.write pC("dDataWym")%>
#define WARTOSC_FAKTURY					<%so.write doc_.afc.display.money(pC("curWn"),pC("strSkrot")) %>

#define DZISIEJSZA_DATA					<% so.write util_.Biezaca_Data%>

#macro POZ_LP(_n_)						<%so.write cstr(_n_)%>
#macro SUMA_ZAPLATY(_cur_,_wal_)		<%so.write doc_.afc.display.money(_cur_,_wal_)%>
#macro SUMA_ZAPLATY_SLOWNIE(_cur_)		<%so.write doc_.afc.display.slownie(abs(_cur_))%>


#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>


<page style='36' margins='700,700,700,700'>
<config>
	<title colspan='6'>Wydruk dokumentu DOKUMENT_NUMER                                                        _</title>
<script><![CDATA[ 
#include "h1250.h"

function fprint 
	fprint = doc_.getmodule(60182).fprint_on_dpc_org_kopia(page_.get_this,CTRLID_ORGKOPIA) 
end function

VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body >
	<table>
		<tbody>
			<tr>
			<!-- pierwszy wiersz -->				
				<td colspan='5' align='right'>
					    <t>FIRMA_MIASTO DZISIEJSZA_DATA </t>
				</td>
			</tr>
			<tr>
				<td colspan='5' align='left'>
					<text>KLIENT_FIRMA_NAZWA </text>
				</td>
			</tr>
			<tr>
				<td colspan='5' align='left'>
					<t>KLIENT_KOD_POCZTOWY</t>	
				</td>
			</tr>
			<tr>
				<td colspan='5' align='right'>
				</td>
			</tr>
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)
			<!-- tr wiersz -->
			<tr>
				<td colspan='5' align='center'>
				<t bold='true' fontsize='8'>
				<%if trans_.isvar(6002) then%>
					<%if trans_.var(6002)=1 then%>
						TYTULINF
					<% end if	
					if trans_.var(6002)=2 then%>
						TYTULWEZ
					<% end if	
					if trans_.var(6002)=3 then%>
						TYTULWEZ2
					<% end if	
					if trans_.var(6002)=4 then%>
						TYTULOSTA
					<% end if%>					
				<%else%>
				TYTULINF
				<%end if%>
				</t>
				</td>
			</tr>
			
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)
			<!-- trzevi wiersz -->
			<tr>
				<td colspan='5'>
				<text>
				<%if trans_.isvar(6002) then%>
					<%if trans_.var(6002)=1 then%>
						TEXT1
					<% end if	
					if trans_.var(6002)=2 then%>
						TEXT2
					<% end if	
					if trans_.var(6002)=3 then%>
						TEXT3
					<% end if	
					if trans_.var(6002)=4 then%>
						TEXT4
					<% end if%>					
				<%else%>
				TEXT1
				<%end if%>
				</text>
				</td>
			</tr>	
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)
			<tr>
				<td colspan='5'>
					 <text>	Wymienioną sumę prosimy przekazać na nasz rachunek w banku FIRMA_RACHUNEK_BANKOWY_BANK , konto nr FIRMA_RACHUNEK_BANKOWY_NUMER  TEXT21</text>
				</td>
			</tr>	
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)
			<tr	>
				<td colspan='5'>
					<table border='1'>
						<thead bold='true'>
							<tr backcolor='#E0E0E0'>
								<td>
									<t> LP </t>
								</td>
								<td>
									<t> Transakcja </t>
								</td>
								<td>
									<t> Termin płatności</t>
								</td>
								<td align='right'>
									<t> Wartość</t>
								</td>
								<td align='right'>	
								<t> Pozostało do zapłaty </t>
								</td>
							</tr>
						</thead>
						<tbody>
						<%
						dim curSuma: curSuma=ccur(0.0)
						dim curPoz: curPoz=ccur(0.0)
						dim nLP : nLP=0
						dim strWyb
					if trans_.isvar(6001) then
					strWyb="and t.idobj in ("+trans_.var(6001)+"0)"
					else
					strWyb=""
					end if
						dim przetermCzyWszyskie: przetermCzyWszyskie="1=1"
						if trans_.isvar(6002) then
							if trans_.var(6002)>1 then
								przetermCzyWszyskie="t.curWn>t.curMa"
							end if
						end if						
					
						dim pC : set pC = trans_.createadors("select * from n5transakcja t join  " +_
						"n5jednostka w on t.pWaluta=w.idobj where "+przetermCzyWszyskie+" "+strWyb+" and wrefPodmiot_wrt=10108 and wrefPodmiot=" + cstr(root_.idobj) + " and t.dDataWym < " + trans_.afc.convert.date2SQL(util_.Biezaca_Data()))
						
						do while not pC.EOF
						
						nLP=nLP+1
						%>
							<tr>
								<td>
									<t> POZ_LP(nLP)</t>
								</td>
								<td>
									<t> TRANSAKCJA</t>
								</td>
								<td>
									<t> TERMIN_PLATNOSC</t>
								</td>
								<td align='right'>
									<t> WARTOSC_FAKTURY</t>
								</td>
								<td align='right'>
									<t> <%curPoz=ccur(pC("curWn"))-ccur(pC("curMa"))
									so.write doc_.afc.display.money(curPoz,pC("strSkrot"))
									curSuma=curSuma+curPoz
									dim waluta: waluta=pC("strSkrot")
									%>
									</t>
								</td>
							</tr>
							<%
							pC.MoveNext
							loop
							%>		
						</tbody>
					</table>
				</td>	
			</tr>
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)	
			<tr>
				<td colspan='5' align='left'>
					<t> Łącznie do zapłaty : SUMA_ZAPLATY(curSuma,waluta) </t>
				</td>
			</tr>	
			ROW_SEPARATOR(5)
			<tr>
				<td colspan='5' align='left'>
					<t> Słownie : SUMA_ZAPLATY_SLOWNIE(curSuma) </t>
				</td>
			</tr>
			ROW_SEPARATOR(5)
			<tr>
				<td colspan='5' align='left'>
				<%dim zn:zn="y"
				  dim zn2:zn2="e"
				if nLP=1 then
				zn="a"
				zn2="a"
				end if
				%>
					<t> Jeżeli w/w faktur<%so.write zn%> został<%so.write zn%> już uregulowan<%so.write zn2%>, potwierdzenie wpłaty proszę przefaksować na numer : FIRMA_FAX</t>
				</td>
			</tr>
			ROW_SEPARATOR(5)
			<tr>
				<td colspan='5' align='left'>
					<t> UZYTKOWNIK_REJESTRACYJNY</t>
				</td>
			</tr>
			<tr>
				<td colspan='5' align='left'>
					<t>FIRMA_NAZWA</t>
				</td>
			</tr>	
			ROW_SEPARATOR(5)
			ROW_SEPARATOR(5)		
		</tbody>
	</table>
</body>
<footer>
</footer>
</page>
