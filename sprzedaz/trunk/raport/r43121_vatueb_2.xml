<body>
<p width='X_PICTURE_WIDTH'>

<picture position='0,0' print='true'  scalingmode='1' image='80957' width='X_PICTURE_WIDTH' height='Y_PICTURE_HEIGHT' />

<!-- pole 1 : pozycje WNT -->
<%	dim pozycja
	dim  iter, itern
	iter = 1: itern = 1
	for each pozycja in root_.vtue_listWNT
	if iter => clng(trans_.var(2)) and iter <= clng(trans_.var(2)) + 35 then
	so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE1) +"," + CStr(Y_POLE1 + (itern*690)) + "'> " + StretchDoKratki(CStr(pozycja.pvtue_strKodKraju)) + "</t>" 
	so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE1 + 1450) +"," + CStr(Y_POLE1 + (itern*690)) + "'> " + CStr(pozycja.pvtue_strNIPKontr) + "</t>" 
	so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='r" + CStr(X_POLE1 + 1500) +"," + CStr(Y_POLE1 + (itern*690) + 60) + "'> " + cstr(liczba(pozycja.pvtue_curKwota)) + "</t>" 
		if cstr(pozycja.pvtue_cT3S) = "1" then
		so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE1 + 15350) +"," + CStr(Y_POLE1 + (itern*690) - 60) + "'>X</t>" 
			else
		so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE1 + 15350) +"," + CStr(Y_POLE1 + (itern*690) - 60) + "'> </t>" 
		end if
		itern = itern + 1	
	end if
	iter = iter + 1
	if iter > clng(trans_.var(2)) + 35 then exit for
	next
	%>


</p>
