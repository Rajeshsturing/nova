#include "50101"

dim tabOption
dim result

function frefresh()
	fill_results 
end function

function init(byref strOpt)
result=strOpt

	tabOption = Split(result,",")
	dim iter
	for iter = 3 to ubound(tabOption)-1
		if iter <> ubound(tabOption) -1 then
			if tabOption(iter)=1 then
				page_.ctrl(iter-2).value="1"
			else
				page_.ctrl(iter-2).value="0"
			end if
		else
			if tabOption(iter)=1 then
				page_.ctrl(121).value="1"
			else
				page_.ctrl(121).value="0"
			end if 
		end if
	next

end function

function fclose()
	trans_.var(303) = cstr(result)
	page_.result=clng(1)
	page_.goback		'		- zamyka okno
end function


function fopen() : fopen = true

end function

