<page backcolor='white' width='21000' height='29700'>
<config>
	<title>
VAT UE strona 1
#ifdef _DEBUG
[THIS_FILE]
#endif
</title>
<script><![CDATA[
<%
'funkcje pomocne przy ukladaniu napisów - do deklaracji
#include "50514"

'dopełnienie zerami na początku do liczby długości n
function strDopZero(byval iNr, byval n)
  dim iter
  dim nLiczba : nLiczba = 1
  for iter = 1 to n
    nLiczba = nLiczba * 10
  next  
  strDopZero = Right(CStr(nLiczba + iNr),n)
end function

%>

]]></script>
</config>
<header>
</header>
<body>
<p width='X_PICTURE_WIDTH'>

<picture position='0,0' print='true'  scalingmode='1' image='80962' width='X_PICTURE_WIDTH' height='Y_PICTURE_HEIGHT' />
<!--pole nr. 1  --> 
WTPFXY(1A,StretchDoKratki(replace(replace(root_.vtue_strNIPPlatnik,"-","")," ","")),VTUE_FONT_WYSOKOSC)
<!-- pole 4, 5, 6 : miesiac, kwartał, rok --> 
<% if clng(DateDiff("d",root_.vtue_dDataOd,root_.vtue_dDataDo)) > 31 then %>
  WTPFXY(4B,StretchDoKratki(CStr(root_.vtue_lKwartal)),VTUE_FONT_WYSOKOSC)
<% else %>
  WTPFXY(4A,StretchDoKratki(strDopZero(month(root_.vtue_dDataOd),2)),VTUE_FONT_WYSOKOSC)
<% end if %>
WTPFXY(4C,StretchDoKratki(CStr(year(root_.vtue_dDataOd))),VTUE_FONT_WYSOKOSC)
<!-- pole 7 : urząd skarbowy  -->
WTPFXY(7,root_.vtue_strUS,VTUE_FONT_WYSOKOSC)
<!-- pole 8A i 8B : Rodzaj podatnika -->
<% if root_.vtue_eTypPlatnika = 1 then %>
	WTPFXY(8A,"X",5)
<% else %>
	WTPFXY(8B,"X",5)
<% end if %>
<!-- B.1(pole 9) Nazwa pełna / nazwisko.... -->
<%
if root_.vtue_eTypPlatnika = 1 then
  'płatnik nie będący osobą fizyczną
  dim nLen: nLen = 60
  dim text: text = root_.vtue_strNazwaPlatnik
  if Len(text) > nLen then
    so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE9) +"," + CStr(Y_POLE9) + "'> " + Left(text,nLen) + "</t>"
    so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE9) +"," + CStr(Y_POLE9 + 500) + "'> " + Mid(text,nLen+1) + ", " + FIRMA_REGON + "</t>"
  else
    so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE9) +"," + CStr(Y_POLE9) + "'> " + text + ", " + FIRMA_REGON + "</t>"
  end if
else
  'osoba fizyczna
  so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE9) +"," + CStr(Y_POLE9) + "'> " + root_.vtue_strNazwiskoPlatnik + " " + root_.vtue_strImiePlatnik + ", " + trans_.afc.display.fulldate(root_.vtue_dDataUrPlatnik) + "</t>"
end if
%>

<!-- pole 10 : Kraj WTPFXY(10,root_.vtue_strKrajPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 11 : Województwo WTPFXY(11,root_.vtue_strWojewodztwoPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 12 : Powiat WTPFXY(12,root_.vtue_strPowiatPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 13 : Gmina WTPFXY(13,root_.vtue_strGminaPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 14 : ulica WTPFXY(14,root_.vtue_strUlicaPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 15 : nr domu WTPFXY(15,root_.vtue_strNrDomuPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 16 : nr lokalu WTPFXY(16,root_.vtue_strNrLokaluPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 17 : miejscowość WTPFXY(17,root_.vtue_strMiejscowoscPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 18 : kod pocztowy WTPFXY(18,root_.vtue_strKodPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pole 19 : poczta WTPFXY(19,root_.vtue_strPocztaPlatnik,VTUE_FONT_WYSOKOSC) -->
<!-- pozycje WDT WEWNĄTRZWSPÓLNOTOWE DOSTAWY TOWARÓW -->
<%	dim pozycja
	dim iter: iter = 1
	for each pozycja in root_.vtue_listWDT
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE20) +"," + CStr(Y_POLE20 + (iter*698)) + "'> " + StretchDoKratki(CStr(pozycja.pvtue_strKodKraju)) + "</t>" 
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE20 + 1600) +"," + CStr(Y_POLE20 + (iter*698)) + "'> " + CStr(pozycja.pvtue_strNIPKontr) + "</t>" 
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='r" + CStr(X_POLE20 + 1800) +"," + CStr(Y_POLE20 + (iter*698) + 30) + "'> " + cstr(liczba(pozycja.pvtue_curKwota)) + "</t>"
		if cstr(pozycja.pvtue_cT3S) = "1" then
			so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE20 + 15350) +"," + CStr(Y_POLE20 + (iter*698) - 60) + "'>X</t>" 
		else
			so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE20 + 15350) +"," + CStr(Y_POLE20 + (iter*698) - 60) + "'> </t>" 
		end if	
		iter = iter + 1
		if iter = 13 then exit for      
	next
	%>

<!-- pozycje WNT WEWNĄTRZWSPÓLNOTOWE NABYCIE TOWARÓW -->
<%
	iter = 1
	for each pozycja in root_.vtue_listWNT
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE21) +"," + CStr(Y_POLE21 + (iter*698)) + "'> " + StretchDoKratki(CStr(pozycja.pvtue_strKodKraju)) + "</t>" 
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE21 + 1600) +"," + CStr(Y_POLE21 + (iter*698)) + "'> " + CStr(pozycja.pvtue_strNIPKontr) + "</t>" 
		so.write "<t font='Courier New' fontsize='" + CStr(VTUE_FONT_WYSOKOSC) + "' position='r" + CStr(X_POLE21 + 2100) +"," + CStr(Y_POLE21 + (iter*698) + 30) + "'> " + cstr(liczba(pozycja.pvtue_curKwota)) + "</t>"
		if cstr(pozycja.pvtue_cT3S) = "1" then
			so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE21 + 15350) +"," + CStr(Y_POLE21 + (iter*698) - 60) + "'>X</t>" 
		else
			so.write "<t font='Courier New' fontsize='" + CStr(5) + "' position='" + CStr(X_POLE21 + 15350) +"," + CStr(Y_POLE21 + (iter*698) - 60) + "'> </t>" 
		end if	
		iter = iter + 1
    		if iter = 6 then exit for
	next
	%>

</p>
