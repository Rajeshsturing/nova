<!-- B.1(pole 8) Nazwa pełna / nazwisko.... -->

<%

dim nLen:nLen = 65
dim nRows:nRows = 2
dim strLine:strLine = "a"
dim text:text = util_.Platnik_Nazwa(root_)

dim iter
for iter = 0 to nRows - 1
	strLine = left(text,nLen)	
	if (len(text) - nLen) < 0 then
		nLen = len(text)
	end if
	text = right(text , len(text) - nLen)
	so.write "<t font='Courier New' fontsize='" + CStr(PIT11_FONT_WYSOKOSC) + "' position='" + CStr(X_POLE8) +"," + CStr(Y_POLE8 + (iter*500)) + "'> " + strLine + "</t>" 
next

%>




