#include "50101"
function fopen()
	
	if not HARUI(UAR_CMDID(CMDID_RAPORT_ZADANIA_WYKRES_ILOSC)) then
		fopen = false
		exit function
	end if

dim query		
	query="SELECT nNumer,strNazwa,a=1,b='zlecone',c=(select Count(*)  from n5zadanie where month(dDataZlec)=nNumer and year(dDataZlec)=year(GETDATE())) FROM n5miesiac UNION SELECT nNumer,strNazwa,2,'do odbioru',(select Count(*)  from n5zadanie where month(dDataPow)=nNumer and year(dDataPow)=year(GETDATE())) FROM n5miesiac UNION SELECT nNumer,strNazwa,3,'wykonywane',(select Count(*)  from n5zadanie where month(dDataRozp)=nNumer and year(dDataRozp)=year(GETDATE())) FROM n5miesiac UNION SELECT nNumer,strNazwa,4,'zamknięte',(select Count(*)  from n5zadanie where month(dDataZamk)=nNumer and year(dDataZamk)=year(GETDATE())) FROM n5miesiac UNION SELECT nNumer,strNazwa,5,'zakończone',(select Count(*)  from n5zadanie where month(dDataZakon)=nNumer and year(dDataZakon)=year(GETDATE())) FROM n5miesiac ORDER BY nNumer,a"

	dim pPage : set pPage = doc_.getmodule(60141)
	
	if not pPage.showChart_SQL(109, query, true, false, "Ilosc zadan wg statusu wg miesiecy", "", 20, 20, false) then
		exit function
	end if
	doc_.pushpage pPage
	pPage.fill
	pPage.domodal
	pPage.activate
	doc_.poppage
	fopen=false
end function

]]>
