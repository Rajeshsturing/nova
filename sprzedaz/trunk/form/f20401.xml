<script>
<![CDATA[

#include "50203"

dim strOptionsCache

function fopen()


	dim strOptions
	strOptions=getuserprofile(20400)
	strOptionsCache=strOptions

	page_.ctrl(502).value=mid(strOptionsCache,4,1)
	page_.ctrl(503).value=mid(strOptionsCache,5,1)
	page_.ctrl(504).value=mid(strOptionsCache,6,1)
	page_.ctrl(505).value=mid(strOptionsCache,7,1)
	page_.ctrl(506).value=mid(strOptionsCache,8,1)
	page_.ctrl(507).value=mid(strOptionsCache,9,1)
	page_.ctrl(508).value=mid(strOptionsCache,10,1)

	fopen=true
end function

function makeStringProfile()
	dim strValue:strValue=mid(getuserprofile(20400),1,3)
	strValue = strValue + page_.ctrl(502).value
	strValue = strValue + page_.ctrl(503).value
	strValue = strValue + page_.ctrl(504).value
	strValue = strValue + page_.ctrl(505).value
	strValue = strValue + page_.ctrl(506).value
	strValue = strValue + page_.ctrl(507).value
	strValue = strValue + page_.ctrl(508).value
	strValue = strValue + mid(getuserprofile(20400),11,1)
	makeStringProfile = strValue
end function

function my_save()
	my_save=true
	if (strOptionsCache<>makeStringProfile and not isEmpty(strOptionsCache)) then

		dim pSubTrans
		set pSubTrans=trans_.createsubtran()
		
			setuserprofile 20400, makeStringProfile
			my_save = trans_.saveobjects()

		set pSubTrans=nothing

	end if
end function

function fsave()
	dim bResult
	bResult = my_save()
	if bResult then
		fsave = true
		page_.goback
	else
		fsave = false
	end if
end function

function fback()
	fback=std_fback()
end function

function fok()
	if not fsave() then
		fok = false
	else
		fok = true
		page_.goback
	end if
end function

function fcancel()
	trans_.discard
	page_.goback
	fcancel = true
end function



]]>
</script>

