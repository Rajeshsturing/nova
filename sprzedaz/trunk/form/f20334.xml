#include "50209"

function c##CTRL_CHECKBOX_DEDYK##_ongetdata(byref oCtrl): c##CTRL_CHECKBOX_DEDYK##_ongetdata=true	
	oCtrl.value = container().m_bDedyk
end function
function c##CTRL_CHECKBOX_DEDYK##_ondataentered(byref oCtrl, byval newValue):c##CTRL_CHECKBOX_DEDYK##_ondataentered=true	
