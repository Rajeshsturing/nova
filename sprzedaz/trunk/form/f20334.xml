end function
function c##CTRL_CHECKBOX_PRZYDZIAL##_ondataentered(byref oCtrl, byval newValue):c##CTRL_CHECKBOX_PRZYDZIAL##_ondataentered=true	
	container().m_nPrzydzial = newValue
	c##CTRL_CHECKBOX_PRZYDZIAL##_ondataentered=true
end function

]]>
