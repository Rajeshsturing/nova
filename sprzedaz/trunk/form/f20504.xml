function init_form(byval strSubject, byval strZlecajacy, byval strData, byval strBody)
	page_.ctrl(1).text = strSubject 
	page_.ctrl(2).text = strZlecajacy 
	page_.ctrl(3).text = strData 

	if len(strBody) > clng(255) then
		page_.ctrl(4).text = left(strBody, 255)
		page_.ctrl(100).disable = false
	else
		page_.ctrl(4).text = strBody
		page_.ctrl(100).disable = true
	end if 
	
	m_strSubject = strSubject
	m_strZlecajacy = strZlecajacy
	m_strBody = strBody


	init_form = true
end function

function fopen()
	fopen=true
end function

