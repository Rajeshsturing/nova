<?xml version="1.0" encoding="windows-1250" ?>
<page style='10'>
<config>
<title>Kreator faktur abonamentowych - Krok 2</title>
<startpos>center</startpos>
<script>
<![CDATA[

#include "50209"
#include "50200"

function choose_dok(): choose_dok=true
	
#ifdef _DEBUG
	trans_.message 7000 , 0 , "todo - where przy wybieraniu faktur"
#endif
	dim choice : choice = fire_choice_list( TYPEID_N5SPRZEDAZ,"","","","","")
	if choice <> 0 then
		set container().fak = trans_.getobj(TYPEID_N5SPRZEDAZ, choice)
		container().fak_idobj = container().fak.idobj
	end if

end function

function is_empty()
	is_empty = true
	if container().fak is nothing then
		exit function
	end if
	is_empty = false
end function

function show_fak
	doc_.getmodule(60129).form_domodal TYPEID_N5SPRZEDAZ,container().fak.idobj,USAGE_VIEW
end function

#define CTRL_FAKTURA		7


function c##CTRL_FAKTURA##_ongetdata(byref oCtrl): c##CTRL_FAKTURA##_ongetdata=true
	if not container().fak is nothing then
		oCtrl.text = container().fak.strNrDok
		oCtrl.tip="Kliknij aby obejrzeć szczegóły"
		oCtrl.disable = false
	else
		oCtrl.tip=""
		oCtrl.disable = true
	end if
end function

function c##CTRL_FAKTURA##_ondataentered(byref oCtrl, byval newValue):c##CTRL_FAKTURA##_ondataentered=false	
	c##CTRL_FAKTURA##_ondataentered=true
end function

function is_empty()
	is_empty = container().fak is nothing
end function

]]>
</script>
</config>
<body>

XFORMMWIZZARDBEGIN(80827)

<tr>
	<td keepline='true'>
		<t width='min' tip='Kliknij aby wybrać wzorzec dokumentu' bold='true' href='varFunction="choose_dok"'>Wzorzec dokumentu</t>
	</td>
	<td keepline='true'>
		<t width='min' size='20' name='e##CTRL_FAKTURA' href='varFunction="show_fak"'>
		<transfer mode='custom'/>
		</t>
	</td>
</tr>


XFORMMWIZZARDEND


</body>
</page>
