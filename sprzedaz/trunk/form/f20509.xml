#macro VB_PRICES_DESC(_ctrl_,_glob_prof_)			\
function c##_ctrl_##_ongetdata(byref oCtrl): c##_ctrl_##_ongetdata=true	\
	oCtrl.text=getglobprofile(_glob_prof_)	\
	if oCtrl.text="" then					\
		'chowamy caly wiersz bo nie ma po co pokazywac	\
		oCtrl.parent.parent.hide = true					\
	end if											\
end function


#macro XW_PRICEROW(_ctrl_desc_,_nr_)				\
	<tr>											\
		<td>										\
			<t name='_ctrl_desc_'>					\
				<transfer mode='custom'/>			\
			</t>									\
		</td>										\
		XW_CHECKOBX(CTRLID_CENA##_nr_##N,)			\
		XW_CHECKOBX(CTRLID_CENA##_nr_##B,)			\
	</tr>


#macro VB_PRICES_SET(_nr_)	\
VB_PRICES_DESC(CTRLID_CENA##_nr_##_DESC,GLOBPROF_CENA##_nr_##_NAME)	\
VBW_CHECKBOX_TRANSFER(CTRLID_CENA##_nr_##N,m_bCena##_nr_##N)	\
VBW_CHECKBOX_TRANSFER(CTRLID_CENA##_nr_##B,m_bCena##_nr_##B)	



