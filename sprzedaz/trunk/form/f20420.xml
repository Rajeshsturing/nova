function fsave()
	dim bIsNew

	bIsNew = page_.root.isnew

	fsave = std_fsave()
		
	if bIsNew and fsave then
		MessageBox "Szablon nie posiada jeszcze żadnych uprawnień - możesz mu je nadać korzystając z opcji dostępnych na formularzu.","Uprawnienia", vbOkOnly, vbInformation 
	end if
end function


function EditRights()

#ifdef _DEBUG
	trans_.message 1002 , 0 , "TODO - uprawnienie specjalne - nadawnie uprawnień"
#endif

''	if not HARUI(UAR_N5UZYTKOWNIK_READ) then
'		exit function
'	end if

	if page_.root.isnew then
		'"Aby nadawać uprawnienia tego użytkownika musisz go najpierw zapisać. W celu zapisu kliknij na ""Zapisz"""
		view_message 6190, 0
		exit function
	end if

	'Na raportach hierarchicznych...
	dim pHli
	set pHli = doc_.createhlistr("varCmd=CMD_OPEN_STATIC_PAGE varDestPage=43005 varNewThread=1 appvarParamIdobj="+cstr(page_.root.idobj))

	dim pPage:set pPage=doc_.getpagehli(pHli)
	set pPage=nothing
end function


function CopyRightsUsr()

	if page_.root.isnew then
		'"Aby nadawać uprawnienia tego użytkownika musisz go najpierw zapisać. W celu zapisu kliknij na ""Zapisz"""
		view_message 6190, 0
		exit function
	end if

	doc_.getmodule(60138).copyRightsFromUser(page_.root.idobj)
	
end function

function CopyRightsTmp()

	if page_.root.isnew then
		'"Aby nadawać uprawnienia tego użytkownika musisz go najpierw zapisać. W celu zapisu kliknij na ""Zapisz"""
		view_message 6190, 0
		exit function
	end if

	doc_.getmodule(60138).copyRightsFromTemplate(page_.root.idobj)
	
end function


function fopen()
	if not std_fopen() then
		fopen = false
		exit function
	end if	
end function

function EditOutlookBar()

	if page_.root.isnew then
		'"Aby nadawać uprawnienia tego użytkownika musisz go najpierw zapisać. W celu zapisu kliknij na ""Zapisz"""
		view_message 6190, 0
		exit function
	end if

	dim pHli
	set pHli = doc_.createhlistr("varCmd=CMD_OPEN_STATIC_PAGE varDestPage=PAGE_SETUP_OUTLOOKBAR varModalRes4='" + CStr(page_.root.IdObj) + "'")

	dim pPage
	set pPage=doc_.getpagehli(pHli)

	if (not pPage is nothing) then
		pPage.domodalauto()
	end if

	set pPage=nothing
end function



