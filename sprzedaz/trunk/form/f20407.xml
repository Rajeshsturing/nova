<script>
<![CDATA[

#include "50203"
#include "50202"

dim nRow : nRow = clng(0)
dim tab

function fopen()
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_NAME) then
		page_.ctrl(1).text=trans_.var(APPVAR_UNKNOWN_SENDER_NAME)
	end if
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_SUBJECT) then
		page_.ctrl(2).text=trans_.var(APPVAR_UNKNOWN_SENDER_SUBJECT)
	end if
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_BODY) then
		page_.ctrl(3).text=trans_.var(APPVAR_UNKNOWN_SENDER_BODY)
	end if
	FillTable
end function



function FillTable()

	dim pNewHli

	dim strQuery
	
	if trans_.isvar(APPVAR_SENDER_ADRESS) then	
		dim strAdress:strAdress = trans_.var(APPVAR_SENDER_ADRESS) 
	else
		exit function
	end if
	
	strQuery ="select idobj as idobj, '10108' as TYPE, 'KLIENT' as strTYPE, strNazwa as Nazwa, strEmail as Mail from n5klient where strEmail = '" + cstr(strAdress) + "' " + _
				" UNION select p.idobj as idobj, '10112' as TYPE, 'PRACOWNIK KLIENTA'as strTYPE, (P.strNazwisko + ' ' +  P.strImie + ' (klient: '+ K.strNazwa+')') as Nazwa, P.strEmail as Mail from n5klient_pracownik P join n5Klient K on P.pKlient= K.idobj where P.strEmail = '" + cstr(strAdress) + "' "+_
				" UNION SELECT idobj as idobj,'10109' as TYPE, 'PRACOWNIK'as strTYPE, (strNazwisko + ' '+ strImie) as Nazwa, strEmail as Mail from n5pracownik  where strEmail = '" + cstr(strAdress) + "'"

	dim oRecordset
	set oRecordset=trans_.createadors(strQuery)

	dim nPos: nPos=1
	dim idobj
	
	set tab = doc_.afc.new_tb(page_).attach(page_.ctrl(ID_TABLE_RESULTS)).removeall

	while not oRecordset.eof

		tab.newrow


		dim n
		for n=0 to 1
			dim nCell:nCell=n+1
			idobj=cstr(oRecordset.fields(1).value)+";"+cstr(oRecordset.fields(0).value)
			if (n=0) then

				CreateHli pNewHli, idobj
				tab.newcell.addtexthli oRecordset.fields(3).value , pNewHli				

			else
				tab.newcell.addtext oRecordset.fields(2).value				
			end if
		next

		oRecordset.movenext
		nPos=nPos+1
	wend

	set oRecordset=nothing

end function


'tworzymy nowy skrot dla listy wynikow
function CreateHli(byref pNewHli, byval idobj)
		set pNewHli=doc_.createhli()
		pNewHli.prop(GVAR_FUNCTIONHLI)="Return_Results"
		pNewHli.prop(PROP_VAL_HLI_IDOBJ)=CStr(idobj)
end function

function Return_Results(byref pHli)
	dim Result:Result=pHli.prop(PROP_VAL_HLI_IDOBJ)
		
	trans_.var(APPVAR_SENDER_ID) = cstr(Result)
	page_.result = true
	page_.goback 
end function
]]>
</script>

