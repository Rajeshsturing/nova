function fsave()
	fsave=std_fsave()
end function

function fback()
	fback=std_fback()
end function

function fok()
	if not fsave() then
		fok = false
	else
		fok = true
		page_.goback
	end if
end function

function fcancel()
	trans_.discard
	page_.goback
	fcancel = true
end function
