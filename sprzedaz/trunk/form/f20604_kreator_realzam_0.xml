#define CTRL_ZAM		1


<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_WIZZARD_PAGE' width='SIZE_WIZZARD_PAGE'>
<config>
<title>Kreator realizacji zamówienia - wybór zamówienia</title>
<startpos>center</startpos>
<script>
<![CDATA[
#include "50209"

'fire_chlist
#include "50200"


function c##CTRL_ZAM##_ongetdata(byref oCtrl): c##CTRL_ZAM##_ongetdata=true
	oCtrl.disable = true
	if not container().zam is nothing then
		oCtrl.text = container().zam.text
		oCtrl.disable = true
	else
		oCtrl.text = "<kliknij z prawej>"
	end if

end function


function show_zam
	if not container().zam is nothing then
		doc_.getmodule(60129).form_domodal TYPEID_N5ZAMOWIENIE,container().zam.idobj,USAGE_VIEW
	end if
end function


function choose_zam()

	dim choice : choice = fire_choice_list( TYPEID_N5ZAMOWIENIE,"","","","","")

	if choice <> 0 then
		set container().zam = trans_.getobj(TYPEID_N5ZAMOWIENIE, choice)
	end if

end function



]]>
</script>
</config>
<body>

XFORMMWIZZARDBEGIN(80827)

<tr>
	<td keepline='true'>
		<t  bold='true' href='varFunction="show_zam"'>Zamówienie</t>
		<t size='1'/>
		QXE_EDIT_CUSTOM(CTRL_ZAM,20)
		QXE_PICTURE_ACTION(-1,PICTURE_CHOICE_N5MAGAZYN,varFunction="choose_zam",Wybór zamówienia)
		
	</td>
</tr>


XFORMMWIZZARDEND

</body>
</page>
