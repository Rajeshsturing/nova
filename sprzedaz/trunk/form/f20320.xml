#include "h1223.h"

#define ID_CHOICE_LIST		101
#define ID_RAPORT			102

<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE'>
<!--
Kreator oferty / cennika
-->
<config>

	<title>
	Kreator oferty / cennika (krok 2)
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>

<startpos>center</startpos>

<script><![CDATA[

#include "50209"
#include "50200"

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.value=container().nProductsRange
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	container().nProductsRange=oCtrl.value

	select case container().nProductsRange
		case 1
			page_.ctrl(ID_RAPORT).hide=true
			page_.ctrl(ID_CHOICE_LIST).hide=true

		case 2 'lista
			page_.ctrl(ID_RAPORT).hide=true
			page_.ctrl(ID_CHOICE_LIST).hide=false
		case 3 'raport
			page_.ctrl(ID_RAPORT).hide=false
			page_.ctrl(ID_CHOICE_LIST).hide=true
	end select

	c1_ondataentered=true
end function

'---------------------------------------------------------------------------
' LISTA WYBORU
'---------------------------------------------------------------------------
function choose_list(): choose_list=true

	dim pUtilPage:set pUtilPage=doc_.getmodule(60106)
	dim strWhere:strWhere="nTypeId=TYPEID_N5PRODUKT"  + " and "	+ pUtilPage.GetWHERE_ForCheckRights(STDR_READ,TYPEID_CHOICELIST,"choicelist",trans_.var(GVAR_USER))  

	trans_.var(APPVAR_CHOICELIST_TYPEID) = clng(TYPEID_N5PRODUKT)
		
	dim choice : choice = fire_choice_list( TYPEID_CHOICELIST, "", "", strWhere, "", "")
	
	if choice <> 0 then
		set container().pChoiceList=trans_.getobj(TYPEID_CHOICELIST, choice)
		if not container().pChoiceList is nothing then
			page_.ctrl(3).text=container().pChoiceList.strNazwa
		end if
	end if
end function

function c2_ongetdata(byref oCtrl): c2_ongetdata=true
	if (not container().pChoiceList is nothing) then
		oCtrl.text=container().pChoiceList.strNazwa
	else
		oCtrl.text="<kliknij z lewej>"
	end if
end function

function c2_ondataentered(byref oCtrl, byval newValue)
	c1_ondataentered=false
end function

'---------------------------------------------------------------------------
' RAPORT
'---------------------------------------------------------------------------

function choose_rap(): choose_rap=true


	trans_.var(APPVAR_SEARCH_TYPEID) = clng(TYPEID_N5PRODUKT)
	trans_.var(APPVAR_SEARCH_KIND) = "R"

	dim choice : choice = fire_choice_list( TYPEID_SEARCHTYPE, "Wybór raportu produktów", "Nazwa", "ResultTypeId=TYPEID_N5PRODUKT", "", "")

	if choice <> 0 then
		set container().pRaport=trans_.getobj(TYPEID_SEARCHTYPE, choice)
		if not container().pRaport is nothing then
			page_.ctrl(3).text=container().pRaport.Nazwa
		end if
	end if
end function

function c3_ongetdata(byref oCtrl): c3_ongetdata=true
	if (not container().pRaport is nothing) then
		oCtrl.text=container().pRaport.Nazwa
	else
		oCtrl.text="<kliknij z lewej>"
	end if
end function

function c3_ondataentered(byref oCtrl, byval newValue)
	c3_ondataentered=false
end function


]]></script>
</config>

<body>

<table style='STYLE_TABLE'>
<tbody>
<tr>
<td>
<picture image='PICTURE_WIZZARD_OFFER_STEP2' width='WIDTH_FOR_WIZZARD' height='HEIGHT_FOR_WIZZARD'/>
</td>		
<td>




<table style='STYLE_TABLE'>
	<tbody>
	<tr colspan='2'>
		<td>
			<t bold='true'>Wybór zakresu produktów</t>
		</td>
	</tr>

	<tr colspan='2'>
		<td>
			<radio name='e1'>
				<transfer mode='custom'/>
				<t>wszystkie dostępne</t>
				<t>lista wyboru</t>
				<t>uruchom raport</t>
			</radio>
		</td>
	</tr>
	</tbody>
</table>

<table style='STYLE_TABLE'>
	<tbody>
	<tr name="e##ID_CHOICE_LIST">
		<td keepline='true' width='min'>
			<picture image='PICTURE_CHOICE_N5CHOICELIST' width='SIZE_FOR_12PX' height='SIZE_FOR_12PX'/>
			<t href='varFunction="choose_list"' >Lista wyboru</t>
		</td>
		<td>			
			<edit size='30' name='e2' style='STYLE_CTRL'>
				<transfer mode='custom'/>
			</edit>
		</td>
	</tr>

	<tr name="e##ID_RAPORT">
		<td keepline='true' width='min'>
			<picture image='PICTURE_CHOICE_N5RAPORT' width='SIZE_FOR_12PX' height='SIZE_FOR_12PX'/>
			<t href='varFunction="choose_rap"' >Raport</t>
		</td>
		<td>			
			<edit size='30' name='e3' style='STYLE_CTRL'>
				<transfer mode='custom'/>
			</edit>
		</td>
	</tr>

XFORMMWIZZARDEND

