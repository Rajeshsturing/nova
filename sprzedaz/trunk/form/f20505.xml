	<title>
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	Podaj użytkownika rejestrującego płatność
	</title>
<script><![CDATA[


#include "50203"
#include "50122"

#define VAR_ALL		1
#define VAR_THIS	2


dim pUser
dim g_All

'-----------------------------------------------------------------------------
'
' Wywołaj tę funkcję przed otwarciem formularza
'
'-----------------------------------------------------------------------------
function init_form(byval strSubject, byval strZlecajacy, byval strData, byval strBody)
	page_.ctrl(1).text = strSubject 
	page_.ctrl(2).text = strZlecajacy 
	page_.ctrl(3).text = strData 
	page_.ctrl(4).text = strBody 
	page_.ctrl(210).value = cstr(1)
	g_All = cstr(1)

	init_form = true
end function

function fopen()
	set pUser = nothing
	g_All = false
	fopen=true
end function

function c210_ondataentered(oCtrl, newValue)
  c210_ondataentered=true
	g_All = newValue
end function

function c210_ongetdata(byref oCtrl)
  c210_ongetdata=true
end function


function on_button_zapisz()
	if g_All then
		page_.result=clng(VAR_ALL)
	else
		page_.result=clng(VAR_THIS)
	end if
	
	page_.goback 
end function

function fclose():fclose=false
	if pUser is nothing then 
		MessageBox "Musisz wybrać użytkownika rejestrującego płatność", "Uwaga", vbOkOnly, vbInformation
		exit function
	else
		fclose = true
	end if
end function

function get_results(byref UserId)
	if pUser is nothing then
		get_results = false
	else
		get_results = true
	end if
		UserId = pUser.idobj
end function

function choose_user(): choose_user=true
	
	dim choice : choice = fire_choice_list( TYPEID_N5UZYTKOWNIK,"","","eAktywny = 1","","")
	if choice <> 0 then
		set pUser = trans_.getobj(TYPEID_N5UZYTKOWNIK, choice)
		page_.ctrl(5).text=pUser.strNazwa
	end if

end function
]]>
</script>
</config>

