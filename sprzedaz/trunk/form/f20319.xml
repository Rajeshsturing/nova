<script><![CDATA[

#include "50209"

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	dim strText
	strText="Zostanie wykonana operacja "

	select case container().nTypOperacji
		case 1
			strText=strText+"sumy"
		case 2
			strText=strText+"iloczynu"
		case 3
			strText=strText+"różnicy"
	end select 

	strText=strText+" na następujących listach wyboru:"
	oCtrl.text=strText
end function

function c3_ongetdata(byref oCtrl): c3_ongetdata=true
	if (not container().pListaB is nothing) then
		oCtrl.text=container().pListaB.strNazwa
	end if
end function

function c4_ongetdata(byref oCtrl): c4_ongetdata=true
	dim strNazwa
	strNazwa="<nie podałeś nazwy dla listy A>"

	if len(trim(container().pListaA.strNazwa))>0 then
		strNazwa=container().pListaA.strNazwa
	end if

	oCtrl.text=strNazwa
end function

]]></script>
