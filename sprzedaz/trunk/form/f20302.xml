function makeSODScript():makeSODScript = true
	dim stdobjdef
	dim flddef
	dim strScript
	dim strValue
	dim strVersion
	dim IdObj:IdObj = clng(1)
	dim IdGrupy:IdGrupy = clng(2) '2, bo 1 dla grupy głównej
	strVersion = cstr(APP_NAME)
	dim strInsert:strInsert = " insert into n5sod (IdObj, VersionId, strNazwa, pSODGroup, nSecId, nIdent, strKod) values "
	
	strScript = "-- skrypt generujący SOD" + vbCrLf + vbCrLf
	strScript = strScript + "-- Usuń stare wpisy" + vbCrLf 
	strScript = strScript + "delete n5securityobj" + vbCrLf + "go" + vbCrLf 
	strScript = strScript + "delete n5sod" + vbCrLf + "go" + vbCrLf 
	strScript = strScript + "delete n5sodgroup" + vbCrLf + "go" + vbCrLf + vbCrLf
	
	strScript = strScript + "-- Wstaw główną grupę" + vbCrLf  
	strScript = strScript + "insert into n5sodgroup (IdObj, VersionId, strNazwa, pSODGroup) values (1, 1, 'Wszystkie uprawnienia', 0)" + vbCrLf + "go" + vbCrLf + vbCrLf
	

	strScript = strScript + "-- Wstaw obiekty" + vbCrLf  
	for each stdobjdef in doc_.stdobjdef
		
		'if not stdobjdef.child then
			strScript = strScript + vbCrLf+ "-- " + stdobjdef.humanname + " " + cstr(stdobjdef.typeid) +vbCrLf	
			
			strScript = strScript + "insert into n5sodgroup (IdObj, VersionId, strNazwa, pSODGroup) values (" + cstr(IdGrupy) +", 1, '"+ stdobjdef.humanname + "', 1)" + vbCrLf + "go" + vbCrLf + vbCrLf
			
			strValue = cstr(clng(stdobjdef.typeid)*clng(10) + clng(STDR_READ) )  
			strScript = strScript +_
			strInsert + "(" + cstr(IdObj) + ", 1, 'Odczyt', " + cstr(IdGrupy) + ",  " + strValue + ", 0, '" + strVersion + "')" + vbCrLf + "go" + vbCrLf
			IdObj = IdObj + clng(1)
			
			strValue = cstr(clng(stdobjdef.typeid)*clng(10) + clng(STDR_INSERT)) 	
			strScript = strScript +_
			strInsert + "(" + cstr(IdObj) + ", 1, 'Tworzenie', " + cstr(IdGrupy) + ",  " + strValue + ", 0, '" + strVersion + "')" + vbCrLf + "go" + vbCrLf
			IdObj = IdObj + clng(1)
			
			strValue = cstr(clng(stdobjdef.typeid)*clng(10) + clng(STDR_UPDATE)) 	
			strScript = strScript +_
			strInsert + "(" + cstr(IdObj) + ", 1, 'Edycja', " + cstr(IdGrupy) + ",  " + strValue + ", 0, '" + strVersion + "')" + vbCrLf + "go" + vbCrLf
			IdObj = IdObj + clng(1)
		
			strValue = cstr(clng(stdobjdef.typeid)*clng(10) + clng(STDR_DELETE)) 	
			strScript = strScript +_
			strInsert + "(" + cstr(IdObj) + ", 1, 'Usuwanie', " + cstr(IdGrupy) + ",  " + strValue + ", 0, '" + strVersion + "')" + vbCrLf + "go" + vbCrLf
			IdObj = IdObj + clng(1)
			
			IdGrupy = IdGrupy+1
		'end if
	next

	dim so:	set so = doc_.createstreamobj()
	so.write strScript
	so.save "C:\script.sql"

	set so = doc_.createstreamobj()

	dim so_preload: set so_preload = doc_.createstreamobj()

	so_preload.write "<?xml version=""1.0"" encoding=""windows-1250""?>" + vbNewline
	so_preload.write vbTab + "<neipckg>" + vbNewline
	so_preload.write vbTab + vbTab + "<neimsg>" + vbNewline

	so_preload.write vbTab + vbTab + vbTab + "<neio>" + vbNewline
	so_preload.write vbTab + vbTab + vbTab + vbTab + "<typeid>8001</typeid>" + vbNewline
	so_preload.write vbTab + vbTab + vbTab + vbTab + "<idobj>1</idobj>" + vbNewline
	so_preload.write vbTab + vbTab + vbTab + vbTab + "<fformat vt='3'>3</fformat>" + vbNewline
	so_preload.write vbTab + vbTab + vbTab + vbTab + "<fmsgtype vt='3' />" + vbNewline
	so_preload.write vbTab + vbTab + vbTab + vbTab + "<fdescription vt='8' />" + vbNewline
	so_preload.write vbTab + vbTab + vbTab +"</neio>" + vbNewline
	
	generate_sodgroup so_preload , "Wszystkie uprawnienia" , 1 , 0
	generate_sodgroup so_preload , "Opcje menu" , 2 , 1

	exp_menu doc_.GetMenuObj,so , so_preload

	so_preload.write vbTab + vbTab + "</neimsg>" + vbNewline
	so_preload.write vbTab + "</neipckg>" + vbNewline

	so.save "C:\menu.xml"
	so_preload.save "C:\cmdid_sod.xml"

	msgbox "done"
end function



sub generate_sodgroup(byref so , byval nazwa , byref id_sodgroup , byval id_parent)
	so.write vbTab + vbTab + vbTab + "<neio>" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<typeid>TYPEID_N5SODGROUP</typeid>" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<idobj>"+cstr(id_sodgroup)+"</idobj>" + vbNewline		
		so.write vbTab + vbTab + vbTab + vbTab + "<f_leave_sub vt='3' />" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<f_save_now vt='3' />" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<f_enter_sub vt='3' />" + vbNewline
		if id_parent > 0 then
			so.write vbTab + vbTab + vbTab + vbTab + "<fpsodgroup vt='3'>"+cstr(id_parent)+"</fpsodgroup>" + vbNewline
		else
			so.write vbTab + vbTab + vbTab + vbTab + "<fpsodgroup vt='3'/>" + vbNewline
		end if
		so.write vbTab + vbTab + vbTab + vbTab + "<f_versionid vt='3'>1</f_versionid>" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<fstrnazwa vt='8'><![CDA"+"TA["+cstr(nazwa) + "]"+"]></fstrnazwa>" + vbNewline
		so.write vbTab + vbTab + vbTab + vbTab + "<fstrkod vt='8'><![CDA"+"TA[EB]"+"]></fstrkod>" + vbNewline
	so.write vbTab + vbTab + vbTab + "</neio>" + vbNewline	
end sub

'parentem na razie jest grupa "Opcje menu"
dim g_sodgroup_parent:g_sodgroup_parent = 2
'biezace id grupy
dim g_sodgroup_id:g_sodgroup_id = 2

Sub exp_menu(byref pMenuObj,byref pSO , byref so2)
    Dim pChildNode
	For Each pChildNode In pMenuObj.node(0)
		exp_menu_node pChildNode,pSO,0,so2,g_sodgroup_parent,""
	Next
End Sub



sub exp_menu_node(byref pMenuNode,byref pSO,byval nIndent , byref so2 , byval parent , byval parent_text)

	dim bHasChild:bHasChild = false
	dim bHasCmdId:bHasCmdId = false

	bHasCmdId = (pMenuNode.hli.prop(PROPC_CMD_IID) > 0 ) 
	bHasChild = (pMenuNode.count > 0)
    
    Dim strMenuText: strMenuText = ""
    strMenuText = Replace(pMenuNode.hli.prop(PROPC_LABEL), "&", "")
	dim cmdid
	cmdid = pMenuNode.hli.prop(PROPC_CMD_IID)

	if strMenuText = "" then
		exit sub
	end if

	if parent_text <> "" then
		strMenuText = parent_text + " - " + strMenuText
	end if

	dim iter
	for iter = 0 to nIndent
		pso.write vbTab
	next 

	pso.write cstr(nIndent) + ":"
    

    If bHasChild Then

		pso.write  strMenuText 
		pso.write " -ma dzieci;"

		if bHasCmdId then
			pso.write " -ma cmdid: " + cstr(cmdid) + ";"
		else
			pso.write " -nie ma cmdid;"	
			'jezeli ma dzieci i nie ma cmdid to robimy grupe
			pso.write " GRUPA"
			g_sodgroup_id = g_sodgroup_id + 1
			generate_sodgroup so2 , strMenuText , g_sodgroup_id , parent			
		end if


		pso.write  vbCrLf

        Dim pChildNode
		dim parent_id:parent_id = g_sodgroup_id
        For Each pChildNode In pMenuNode
            exp_menu_node pChildNode,pSO,nIndent + 1 , so2 , parent_id , strMenuText
        Next

    Else

		pso.write  strMenuText
		pso.write " -nie ma dzieci"
		if bHasCmdId then
			pso.write " -ma cmdid: " + cstr(cmdid) + ";"
			pso.write " LINK"
			' tutaj mozemy generowaz sod!
			if cmdid > 1000 and cmdid < 3000 then
				trans_.message 1002 , 0 , Replace(pMenuNode.hli.prop(PROPC_LABEL), "&", "")
				generate_sod so2 , Replace(pMenuNode.hli.prop(PROPC_LABEL), "&", "") , g_sod_id , g_sodgroup_id , cmdid
				g_sod_id = g_sod_id + 1
			end if
		else
			pso.write " -nie ma cmdid;"	
		end if
		pso.write  vbCrLf

    End If
	

end sub

dim g_sod_id:g_sod_id = 1


sub generate_sod(byref so , byval nazwa , byval sod_id , byval parent , byval action)
	so.write vbTab + vbTab + vbTab + "<neio>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<typeid>TYPEID_N5SOD</typeid>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<idobj>"+cstr(sod_id)+"</idobj>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<fnident vt='3' />" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<fpsodgroup vt='3'>"+cstr(parent)+"</fpsodgroup>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<f_versionid vt='3'>1</f_versionid>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<fstrnazwa vt='8'><![CDA"+"TA["+cstr(nazwa)+"]"+"]></fstrnazwa>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<fnsecid vt='3'>"+cstr(action)+ cstr(STDR_READ) + "</fnsecid>" + vbNewline	
	so.write vbTab + vbTab + vbTab + vbTab + "<fstrkod vt='8'><![CDA"+"TA[EB]"+"]></fstrkod>" + vbNewline	
	so.write vbTab + vbTab + vbTab + "</neio>" + vbNewline		
end sub


