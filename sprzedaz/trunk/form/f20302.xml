dim pPrerformingXML
set pPrerformingXML = nothing

dim strOldXMLText

'-----------------------------------------------------------------------------
' Event: Torzymy performing
'-----------------------------------------------------------------------------
function XMLExport_CreatePerforming(byref pExpMan, byval strToDisplay)

	strToDisplay = "PRELOAD " + strToDisplay
	
	if (strOldXMLText=strToDisplay) then
		exit function
	end if

	if (pPrerformingXML is nothing) then
		page_.updateview
		set pPrerformingXML = doc_.performing( strToDisplay )
		strOldXMLText = strToDisplay
		exit function
	end if

	pPrerformingXML.text = strToDisplay
	strOldXMLText = strToDisplay
end function

'-----------------------------------------------------------------------------
' Event: Niszczymy performing
'-----------------------------------------------------------------------------
function XMLExport_DestroyPerforming(byref pExpMan)
	set pPrerformingXML = nothing
	strOldXMLText = ""
end function

