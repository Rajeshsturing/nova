function exWizytowka()
	dim pOutStream
	set pOutStream = doc_.createstreamobj

	dim pWorkersArr
	set pWorkersArr = trans_.afc.new_navoarray()
	
	dim pRecordset
	set pRecordset = trans_.createadors("select * from n5pracownik")

	while (not pRecordset.EOF)
		pWorkersArr.Add CLng(pRecordset.fields(0).value)
		pRecordset.movenext
	wend

	doc_.getmodule(60269).ExportBusinessCard pWorkersArr, pOutStream

	pOutStream.save "c:\Wizytowka.xml"
end function

