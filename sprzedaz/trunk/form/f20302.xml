'---------------------------------------------------------------------------------
' Eksportuje PUBLIKACJE
'---------------------------------------------------------------------------------
function exPreloadPUB(byref pExportFilter)

	dim pObjectDef
	set pObjectDef = doc_.stdobjdef.getobjdef( TYPEID_N5DPC )

	dim pFieldDef
	set pFieldDef = pObjectDef.field( pObjectDef.getfieldindex("ePubType") )

	dim nEnum: nEnum = 0
	while (pFieldDef.enumvalue(nEnum) <> "")
		nEnum = nEnum + 1

		dim nPublikacja
		nPublikacja = trans_.findobjid(TYPEID_N5DPC, "ePubType=" + CStr(nEnum))

		if (nPublikacja=0) then
			dim pNewObj
			set pNewObj = trans_.newobj( TYPEID_N5DPC )

			pNewObj.n5dpc_init_with_defaults CLng(nEnum)

			if (not trans_.SaveObjects) then
				MsgBox "Nie udalo sie zaapisac wygenerowanej PUBLIKACJI!!"
				exit function
			end if
		else
			trans_.message 6000, 0, "PUBLIKACJA O TYPIE " + CStr(nEnum) + " JUZ ISTNIEJE"
		end if

	wend

	pExportFilter.exportset TYPEID_N5DPC, ""

	'ePubType
	'TYPEID_N5DPC
end function

