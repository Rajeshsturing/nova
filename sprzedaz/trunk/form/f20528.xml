	</title>
<startpos>center</startpos>
<script>
<![CDATA[

#include "50203"

dim pAktywne
dim pBilansowe

function fopen()
	set pAktywne=getuserprofileObj(USERPROF_PLANKONT_AKTYWNE)
	set pBilansowe=getuserprofileObj(USERPROF_PLANKONT_BILANSOWE)

	fopen=true
end function

function fsave()
	fsave=std_fsave()
end function

function fback()
	fback=std_fback()
end function

'---------------------------------------------------------------------
'wymiana z kontrolkami
'---------------------------------------------------------------------	

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.value=CStr(pAktywne.Wartosc)
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	pAktywne.Wartosc=CStr(newValue)
	c1_ondataentered=true
end function

function c2_ongetdata(byref oCtrl): c2_ongetdata=true
	oCtrl.value=CStr(pBilansowe.Wartosc)
end function

function c2_ondataentered(byref oCtrl, byval newValue)
	pBilansowe.Wartosc=CStr(newValue)
	c2_ondataentered=true
end function

function fcancel()
	trans_.discard
	page_.goback
	fcancel = true
end function

function fback()
	page_.goback
	fback = true
end function

function fok(): fok = false
	if (trans_.saveobjects()) then
		fok = true
		page_.goback
	end if
end function

]]>
</script>

