<!--
ALWAYS MANUAL
Konfiguracja event log'a
-->
<config>
	
	<title>
	Konfiguracja logowania zmian
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>

	<startpos>center</startpos>

<script>
<![CDATA[

#include "50100"
#include "50203"

dim g_strEventOptions
dim g_nOfOptions

function fopen()
	g_nOfOptions = enum2checkbox_items(TYPEID_N5EVENTLOG, 1, 1)
	g_strEventOptions = getglobprofile( GLOBPROF_EVENTLOG_OPTIONS )

	if (g_strEventOptions="") then
		dim i
		for i=1 to g_nOfOptions
			g_strEventOptions = g_strEventOptions + "1"
		next
	end if

	c1_ondataentered page_.ctrl(1), g_strEventOptions
	fopen = true
end function

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	g_strEventOptions = oCtrl.value
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	oCtrl.value = newValue
	c1_ondataentered=true
end function

function fok()
	setglobprofile GLOBPROF_EVENTLOG_OPTIONS, g_strEventOptions
	
	if (trans_.saveobjects()) then
		page_.goback
	end if
end function

function fcancel()
	page_.goback
end function

]]>
</script>
</config>

