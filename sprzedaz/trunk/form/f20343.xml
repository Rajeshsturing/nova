QXR_SEPARATOR(1)

<tr>
	QXC_BUTTON(-1,30,tryb zaawansowany,varFunctionHLI="advanced" vn1=WIZZARD_CMD_END,1)
	<td>
	</td>
</tr>

#endif

XFORMMWIZZARDEND

</body>
