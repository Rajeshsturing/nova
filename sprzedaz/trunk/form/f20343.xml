#if vn105 = KREATOR_REAL_ZAM_WLASNE
 #define F2_MODE KREATOR_REAL_ZAM_WLASNE
#else
 #define F2_MODE KREATOR_REAL_ZAM_OBCE
#endif

<?xml version="1.0" encoding="windows-1250" ?>

<page style='STYLE_WIZZARD_PAGE' width='SIZE_WIZZARD_PAGE'>

<config>
<title>Kreator realizacji zamówienia - podsumowanie</title>
<startpos>center</startpos>
<script>
<![CDATA[
#include "50209"

#define CTRL_RULE		101
#define CTRL_DOK		102

function c##CTRL_RULE##_ongetdata(byref oCtrl): c##CTRL_RULE##_ongetdata=true
	select case container().rule 
		case 1:
			oCtrl.text = "Zaniechanie realizacji gdy czegoś brak na magazynie " + cstr(container().mag.strNazwa)
		case 2:
			oCtrl.text = "Realizacja takiej ilości, jaka jest na na magazynie '" + cstr(container().mag.strNazwa) + "'"
		case 3:
			oCtrl.text = "Zawsze realizowane"
	end select
end function

function c##CTRL_DOK##_ongetdata(byref oCtrl): c##CTRL_DOK##_ongetdata=true
	select case container().dok 
		case 1:
			oCtrl.text = "Utworzenie nowej faktury lub dostawy"
		case 2:
			oCtrl.text = "Dodanie pozycji do faktury " + cstr(container().fak.strNrDok)
		case 3:
			if container().m_iF2Mode = KREATOR_REAL_ZAM_WLASNE then
					oCtrl.text = "Utworzenie zestawu faktura + PZ"
				else
					oCtrl.text = "Utworzenie zestawu faktura + WZ"
				end if
		case 4:
				if container().m_iF2Mode = KREATOR_REAL_ZAM_WLASNE then
					oCtrl.text = "Utworzenie nowego dokumentu PZ"
				else
					oCtrl.text = "Utworzenie nowego dokumentu WZ"
				end if
	end select
end function


function advanced(hli)
	container().run_advanced
	WizzardStep hli	
end function


]]>
</script>
</config>
<body>

XFORMMWIZZARDBEGIN(80827)

<tr>
	<td>
		<t bold='true'>Podsumowanie</t>
	</td>
</tr>

<tr>
	<td>
		<table style='STYLE_TABLE_BODY' name='t100'>
			<thead>
				<tr style='STYLE_TABLE_HEADER'>
					<td colspan='2'>
						<t>Pozycje</t>
					</td>
				</tr>							
			</thead>

			<tbody>
			</tbody>
		</table>
	</td>
</tr>


QXR_SEPARATOR(1)
XFORMMWIZZARD_TEXT(Reguła realizacji zamówienia)

<tr>
	<td>
		<text name='CTRL_RULE'>
			<transfer mode='custom'/>
		</text>
	</td>
</tr>


QXR_SEPARATOR(1)
XFORMMWIZZARD_TEXT(Dokument docelowy)

<tr>
	<td>
		<text name='CTRL_DOK'>
			<transfer mode='custom'/>
		</text>
	</td>
</tr>

