<config>

	<title>
	Kreator operacji na zbiorach list wyboru (krok 2)
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>

<startpos>center</startpos>

<script><![CDATA[

#include "50209"
#include "50200"

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.text=container().strOperacji
end function

function c3_ongetdata(byref oCtrl): c3_ongetdata=true
	if (not container().pListaB is nothing) then
		oCtrl.text=container().pListaB.strNazwa
	else
		oCtrl.text="<wybierz listę wyboru>"
	end if
end function

function choose_list(): choose_list=true
	dim strSQLWhere 
	dim pUtilPage:set pUtilPage=doc_.getmodule(60106)
	strSQLWhere = "nTypeId = " + CStr(container().nTypeId) + " and " +  pUtilPage.GetWHERE_ForCheckRights(STDR_READ,TYPEID_CHOICELIST,"choicelist",trans_.var(GVAR_USER))  
	
	dim idObj: idObj=fire_choice_list( TYPEID_CHOICELIST, "", "", strSQLWhere, "", "")

	if idObj>0 then
		set container().pListaB=trans_.getobj(TYPEID_CHOICELIST,idObj)
	end if
end function

function c4_ongetdata(byref oCtrl): c4_ongetdata=true
	dim strNazwa
	strNazwa="<nie podałeś nazwy dla listy A>"

	if len(trim(container().pListaA.strNazwa))>0 then
		strNazwa=container().pListaA.strNazwa
	end if

	oCtrl.text=strNazwa
end function

]]></script>
</config>

<body>


XFORMMWIZZARDBEGIN(PICTURE_WIZZARD_CHOICELIST_STEP2)

		<tr>
			<td colspan='2'>
				<text bold='true'>Wybór zbioru</text>
			</td>
		</tr>
		<tr>
