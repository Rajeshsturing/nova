dim strNazwa
dim strNIP
dim strMiejsc
dim strUlica


function info_from_uni(byval rs)
	dim strKlient
	strKlient = trim(cstr(rs.fields("nazwa").value)) + ", " + trim(cstr(rs.fields("miejscowosc").value)) + ", " + trim(cstr(rs.fields("ulica").value)) + ", NIP: " + trim(cstr(rs.fields("NIP").value))
	info_from_uni = strKlient
end function

function info_from_sprzed(byval rs)
	dim strKlient
	strKlient = trim(cstr(rs.fields("nazwa").value)) + ", " + trim(cstr(rs.fields("miejsc").value)) + ", " + trim(cstr(rs.fields("ulica").value)) + ", NIP: " + trim(cstr(rs.fields("NIP").value))
	info_from_sprzed = strKlient
end function

function process_clients(byval rs , byval bSprzed)
	dim hli
	dim pBody
	set pBody=doc_.afc.new_tb(page_).attach( page_.ctrl(90) ).removeall'page_.ctrl(90).body		
	'pBody.removeall
	dim nRow:nRow = 1
	dim pRow,str,strFName,strID
	while not rs.eof
		if bSprzed then
			str = info_from_sprzed(rs)
			strFName = "show_klient_sprzed"
			strID = "idKontra"
		else
			str = info_from_uni(rs)
			strFName = "show_klient_uni"
			strID = "idobj"
		end if
		pBody.newrow.newcell.addtexthli str , doc_.createhlistr("varFunctionHLI="""+ strFName +""" vs1=" + cstr(rs.fields(strID).value))
		'set pRow = pBody.insertnewrow(nRow)
		'set hli = doc_.createhlistr("varFunctionHLI="""+ strFName +""" vs1=" + cstr(rs.fields(strID).value))		
		'AddCellHli str , pRow, 1 , hli
		'nRow = nRow + 1
		rs.movenext
	wend
end function

function show_klient_sprzed(hli)
	clear_tables()
	dim query:query = "select idkontra,nazwa from kontrahent where idkontra=" + cstr(hli.prop(1))
	set rs = conn.Execute( query )
	info_from_sprzed_on_client
	find_kon
end function

function show_klient_uni(hli)
	clear_tables()
	dim query:query = "select idobj,nazwa from unifirma where idobj=" + cstr(hli.prop(1))
	set rs = conn.Execute( query )
	info_from_uni_on_client
	find_kon
end function



function get_params()
	strNazwa =   trans_.afc.convert.DoubleApostrophe(page_.ctrl(10).text)
	strNIP =     trans_.afc.convert.DoubleApostrophe(page_.ctrl(11).text)
	strMiejsc =  trans_.afc.convert.DoubleApostrophe(page_.ctrl(12).text)
	strUlica =   trans_.afc.convert.DoubleApostrophe(page_.ctrl(13).text)
end function



function get_where_sprzed
	get_where_sprzed = " where nazwa like '%" + strNazwa + "%' and NIP like '%" + strNip + "%' and Miejsc like '%" + strMiejsc + "%' and Ulica like '%" + strUlica + "%'"
end function

function get_where_uni
	get_where_uni = " where nazwa like '%" + strNazwa + "%' and NIP like '%" + strNip + "%' and Miejscowosc like '%" + strMiejsc + "%' and Ulica like '%" + strUlica + "%'"
end function

function get_where_kon
	get_where_kon = " where n5klient.strNazwa like '%" + strNazwa + "%' and strNip like '%" + strNip + "%' and n5miejscowosc.strNazwa like '%" + strMiejsc + "%' and strUlica like '%" + strUlica + "%'"
end function


dim conn
dim rs:set rs = nothing
dim bSprzed:bSprzed=true

function find_sprzed

	

	get_params()
	clear_tables()

	bSprzed=true


	dim pTempExportManager
	set pTempExportManager = new CADOExportManager

	pTempExportManager.m_bOnlyLogonTest = true	

	if pTempExportManager.connectSQL("main", "navo_firma", "sa", "") then
		set conn = pTempExportManager.getConnection()
	else
		exit function
	end if


	find_kon

	dim query:query = "select count(*) from kontrahent " +  get_where_sprzed
	set rs = conn.Execute( query )
	dim i:i=clng(rs.fields(0).value)


	if i = 0 then
		page_.ctrl(500).text = "Nie znaleziono rekordów"
		page_.ctrl(500).forecolor = rgb(255,0,0)		
		set rs = nothing
		exit function
	elseif i > 1 then		
		page_.ctrl(500).text = "Znaleziono kilka rekordów"
		page_.ctrl(500).forecolor = rgb(255,0,0)
		query = "select * from kontrahent " +  get_where_sprzed + " order by nazwa "
		set rs = conn.Execute( query )
		process_clients rs,true
		set rs = nothing		
		exit function
	end if

	query = "select idkontra,nazwa from kontrahent " + get_where_sprzed
	set rs = conn.Execute( query )
	info_from_sprzed_on_client
	find_kon

end function


function info_from_sprzed_on_client

	dim query

	dim id:id = clng(rs.fields(0).value)
	page_.ctrl(500).text = cstr(rs.fields(1).value)
	page_.ctrl(500).forecolor = rgb(0,0,0)		

	query = "" +_
		" select artykul.nazwa,sprzedaz.DataSprz , artykul.TowarUsl as T " +_
		" from sprzedaz " +_
		" join pozsprzedaz on sprzedaz.idtrans =  pozsprzedaz.idtrans " +_
		" join artykul on pozsprzedaz.idart = artykul.idart " +_
		" where idkontra= " + cstr(id) + " order by 2 desc "
	set rs = conn.Execute( query )

	dim pBody
	set pBody=doc_.afc.new_tb(page_).attach( page_.ctrl(100) ).removeall

	dim pBody2
	set pBody2=doc_.afc.new_tb(page_).attach( page_.ctrl(200) ).removeall

	dim dateStart,dateEnd
	while not rs.eof

		dim prow,prow2
	
		set pRow= pBody.newrow.row
		set pRow2=pBody2.newrow.row

		pBody.newcell.addtext cstr(rs.fields(0).value)
		pBody.newcell.addtext cstr(rs.fields(1).value)

		
		dateStart = rs.fields(1).value
		dateEnd   = dateserial(year(dateStart),month(dateStart)+3,day(dateStart))

		dim cell

		page_.ctrl(15).text = "Gwarancje"
		if trim(cstr(rs.fields("T")))="T" then
			if srvDate <= dateEnd and srvDate => dateStart then
				pBody2.newcell.addtext cstr(rs.fields(0).value)
				pBody2.newcell.addtext "do " + cstr(dateEnd)
				pBody2.element.forecolor = rgb(255,0,0)
			else
				pBody2.newcell.addtext cstr(rs.fields(0).value)
				pBody2.element.strike = true
				pBody2.newcell.addtext "do " + cstr(dateEnd)
				pBody2.element.strike = true					
			end if
		end if

		rs.movenext

	wend

	query = "select * from kontrahent where idkontra=" + cstr(id)
	set rs = conn.Execute( query )


end function


function old_SetStrikeThrough(byref pStatic , byval bST)
	dim nFontInx : nFontInx = pStatic.font
	dim strFontName, nFontSize, bFontBold, bFontItalic, bFontStrikeThrough
	'doc_.inx2font nFontInx, strFontName, nFontSize, bFontBold, bFontItalic, bFontStrikeThrough
	bFontStrikeThrough = bST
	'nFontInx = doc_.font2inx(strFontName, nFontSize, bFontBold, bFontItalic, bFontStrikeThrough)
	pStatic.font = nFontInx
end function


function old_AddCellST(byval strValue, byref pRow, byref nCell)
	'dodaj dokladeni jedna komorke
	dim pCell
	set pCell=pRow.insertnewcell(nCell)
	nCell=nCell+1

	'wstaw tekst message'a
	dim pStatic
	set pStatic=pCell.addnew(CTRL_TYPE_STATIC,-1)
	pStatic.text=strValue
	SetStrikeThrough pStatic,true
	set AddCellST = pCell
end function


function old_AddCellRED(byval strValue, byref pRow, byref nCell)
	'dodaj dokladeni jedna komorke
	dim pCell
	set pCell=pRow.insertnewcell(nCell)
	nCell=nCell+1

	'wstaw tekst message'a
	dim pStatic
	set pStatic=pCell.addnew(CTRL_TYPE_STATIC,-1)
	pStatic.forecolor = rgb(255,0,0)

	pStatic.text=strValue
	set AddCellRED = pCell
end function


function find_uni

	clear_tables()
	get_params()

	bSprzed=false

	dim pTempExportManager
	set pTempExportManager = new CADOExportManager

	pTempExportManager.m_bOnlyLogonTest = true	

	if pTempExportManager.connectSQL("main", "navo", "sa", "") then
		set conn = pTempExportManager.getConnection()
	else
		exit function
	end if

	find_kon

	dim query:query = "select count(*) from unifirma " +  get_where_uni
	set rs = conn.Execute( query )
	dim i:i=clng(rs.fields(0).value)

	if i = 0 then
		page_.ctrl(500).text = "Nie znaleziono rekordów"
		page_.ctrl(500).forecolor = rgb(255,0,0)		
		set rs = nothing
		exit function
	elseif i > 1 then		
		page_.ctrl(500).text = "Znaleziono kilka rekordów"
		page_.ctrl(500).forecolor = rgb(255,0,0)
		query = "select * from unifirma " +  get_where_uni
		set rs = conn.Execute( query )
		process_clients rs,false
		set rs = nothing		
		exit function
	end if

	query = "select idobj,nazwa from unifirma " +  get_where_uni
	set rs = conn.Execute( query )
	info_from_uni_on_client
	find_kon


end function


function info_from_uni_on_client

	dim query
	dim id:id = clng(rs.fields(0).value)
	page_.ctrl(500).text = cstr(rs.fields(1).value)
	page_.ctrl(500).forecolor = rgb(0,0,0)		

	query = "" +_
	" select kod,nazwa,unilicencja.idobj from unilicencja " +_
	" join uniprodukt on uniprodukt.idobj = unilicencja.pUniprodukt " +_
	" where pUniFirma=" + cstr(id) + " order by 2 "

	set rs = conn.Execute( query )
	dim pBody
	set pBody=doc_.afc.new_tb(page_).attach( page_.ctrl(100) ).removeall'page_.ctrl(90).body		
	
	dim lic_str
	while not rs.eof
		
		pBody.newrow.newcell.addtext cstr(rs.fields(0).value)
		pBody.newcell.addtext cstr(rs.fields(1).value)		
		if lic_str="" then
			lic_str= cstr(rs.fields(2).value)
		else
			lic_str = lic_str + "," + cstr(rs.fields(2).value)
		end if
		rs.movenext
	wend

	if lic_str<> "" then

		page_.ctrl(15).text = "Wykupione pakiety pomocy"
		
		set pBody=doc_.afc.new_tb(page_).attach( page_.ctrl(200) ).removeall

		query = " select nazwa,dDataStart,dDataEnd from pakietpomocy " +_
				" join uniprodukt on pakietpomocy.idnazwa=uniprodukt.idobj " +_
				" where idlicencja in ( " + lic_str + ")" + " order by 3 desc "
		set rs = conn.Execute( query )
		dim dateStart,dateEnd
		while not rs.eof
			dateStart = rs.fields(1).value
			dateEnd   = rs.fields(2).value

			pBody.newrow

			if srvDate <= dateEnd and srvDate => dateStart then
				pBody.newcell.addtext cstr(rs.fields(0).value)
				pBody.newcell.addtext cstr(dateStart)
				pBody.element.forecolor = rgb(255,0,0)
				pBody.newcell.addtext cstr(dateEnd)
				pBody.element.forecolor = rgb(255,0,0)			
			else
				pBody.newcell.addtext cstr(rs.fields(0).value)
				pBody.element.strike = true
				pBody.newcell.addtext cstr(dateStart)
				pBody.element.strike = true
				pBody.newcell.addtext cstr(dateEnd)
				pBody.element.strike = true
			end if
			rs.movenext
		wend
	end if

	query = "select * from unifirma where idobj=" + cstr(id)
	set rs = conn.Execute( query )
end function


function add_new
	
	dim page_hli: set page_hli = doc_.getmodule(60129).prepare_form_open_command(TYPEID_N5KLIENT,0,USAGE_EDIT)
	
	if page_hli is nothing then
		exit function
	end if
	dim page : set page = doc_.getpagehli(page_hli)
	if page is nothing then
		exit function
	end if

	dim miasto,kod
	if not page is nothing and  not rs is nothing then
		page.root.strNazwa = cstr(trim(rs.fields("nazwa").value))
		page.root.strNIP = cstr(trim(rs.fields("NIP").value))
		page.root.strUlica = cstr(trim(rs.fields("Ulica").value))
		page.root.strTel1 = cstr(trim(rs.fields("tel1").value))
		page.root.strTel2 = cstr(trim(rs.fields("tel2").value))
		page.root.strTel3 = cstr(trim(rs.fields("tel3").value))
		page.root.strFax = cstr(trim(rs.fields("fax").value))
		page.root.strEmail = cstr(trim(rs.fields("email").value))
		if bSprzed then
			page.root.strIndeks = cstr(trim(rs.fields("indeks").value))
			kod=cstr(trim(rs.fields("kod").value))
			miasto = cstr(trim(rs.fields("miejsc").value))
		else
			page.root.strWWW = cstr(trim(rs.fields("www").value))
			kod=cstr(trim(rs.fields("kodpocztowy").value))
			miasto = cstr(trim(rs.fields("miejscowosc").value))
		end if
		dim idm:idm = trans_.findobjid(TYPEID_N5MIEJSCOWOSC,"strNazwa like '" + trans_.afc.convert.DoubleApostrophe(miasto) + "'")
		if idm > 0 then
			set page.root.pMiejscowosc = trans_.getobj(TYPEID_N5MIEJSCOWOSC,idm)
		end if
		page.root.strKod = kod
	end if

	if not page is nothing then
		page.domodalauto()
	end if

end function


function find_kon
	dim rs2:set rs2 = trans_.createadors("select n5klient.idobj as id , n5klient.strNazwa as nazwa , * from n5klient join n5miejscowosc on  n5miejscowosc.idobj=n5klient.pMiejscowosc " + get_where_kon )
	dim hli
	dim pBody
	set pBody=doc_.afc.new_tb(page_).attach( page_.ctrl(300) ).removeall'page_.ctrl(90).body		

	while not rs2.eof
		set hli = doc_.createhlistr("varFunctionHLI=std_openform_object_hli vn1=TYPEID_N5KLIENT vn2="+cstr(rs2.fields("id").value))
		pBody.newrow.newcell.addtexthli trim(cstr(rs2.fields("nazwa").value)), hli		
		rs2.movenext
	wend
end function

function clear_tables()
	page_.ctrl(100).body.removeall
	page_.ctrl(200).body.removeall
	page_.ctrl(300).body.removeall
	page_.ctrl(90).body.removeall
end function


