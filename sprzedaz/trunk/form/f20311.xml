<script><![CDATA[

#include "50100"

dim nSeconds			'przez jaki okres ma byc owtarta strona AD

function fopen():fopen=false
	' modul nie uzywany
	' teraz sluzy do podmiany na pelne menu
	doc_.setmenu clng(MENU_FULL_TREE)
exit function

	'reklama została otwarta - czasowo wyłącz timer bo
	'mozemy miec tylko jeden obiekt timer'a
	doc_.timer 1, "", 0

	'ukrywaj pelne menu
	doc_.setmenu clng( IDPAGE_MENU )

	'ma byc otwarta przez ...
#ifdef _DEBUG
	nSeconds=CLng(5)
#else
	nSeconds=CLng( AD_TIME_SEC )
#endif

	'ustaw timer uruchamiany co 1 sek. by zmienijszac nSeconds
	doc_.timer 1, "varFunction=counter", 1

	fopen=true
end function

function fclose():fclose=false

	'nie wolno jeszcze zamykac tej strony gdyz user
	'nie odczekał wymaganego czasu
	if (nSeconds>0) then
		exit function
	end if

	'przywracamy menu
	doc_.setmenu MENU_FULL_TREE

	'zaznacz, ze strona nie jest juz otwarta tzn. uruchom ponownie
	'timer by reklama pokazala sie nastepny raz
	StartAdvertisement

	fclose=true
end function

function counter()
	dim strCount
	
	if (nSeconds>5) then
		strCount=CStr( nSeconds )
	else
		select case nSeconds
			case 5
				strCount="pięć"
			case 4
				page_.ctrl(2).text = "Przygotuj się !" 
				strCount="cztery"
			case 3
				page_.ctrl(2).text = "Przygotuj się !!!!" 
				strCount="trzy"
			case 2
				page_.ctrl(2).text = "Gotowy ?" 
				strCount="dwa"
			case 1
				page_.ctrl(2).text = "Start" 
				strCount="jeden"
		end select
	end if

	page_.ctrl(1).text= strCount 

	nSeconds=nSeconds-1

	if (nSeconds=-1) then
		page_.goback
	end if
end function

]]></script>
