<script><![CDATA[

#include "50210"

dim nImport

function fopen()
	nImport=clng(3)	'szybka firma
	page_.cmdenabled CMD_NEWFORM, false
	page_.cmdenabled CMD_SAVEFORM, false
	page_.cmdenabled CMD_DELETEFORM, false
	page_.cmdenabled CMD_ENABLEEDIT, false
	fopen=true
end function

function disableNavoFirmaChoice()
	nImport=clng(2)	'demo
	page_.ctrl(3).disable=true
	page_.ctrl(4).disable=true
end function

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.value=nImport
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	nImport=oCtrl.value
	c1_ondataentered=true
end function

function getImportType()
	getImportType=nImport
end function


]]></script>
