<script>

<!--
	Czy zapisać korespondencję do bazy?
-->

<![CDATA[
#include "50203"
#include "50225"

#define VAR_STOP_READING	0
#define VAR_SKIP_MAIL		1
#define VAR_RETURN_SAVE		2

dim nTypeId
dim nObjectId
dim StdObj

function fopen()
	page_.result=clng(VAR_STOP_READING)
	fopen = true
end function

function init_form(byval sender_type, byval sender_id, byval subject, byval body)
	
	'page_.ctrl(1).text= cstr(trans_.var(APPVAR_SENDER_ADRESS)) + " (" + cstr(trans_.var(APPVAR_UNKNOWN_SENDER_NAME)) + ")"
	dim pSender:set pSender = trans_.getobj(sender_type, sender_id)
	if pSender is nothing then
		if trans_.isvar(APPVAR_UNKNOWN_SENDER_NAME) then
			page_.ctrl(1).text= cstr(trans_.var(APPVAR_SENDER_ADRESS)) + " (" + cstr(trans_.var(APPVAR_UNKNOWN_SENDER_NAME)) + ")"
		end if
	else
		select case sender_type
			case TYPEID_N5KLIENT
				page_.ctrl(1).text= cstr(pSender.strNazwa) + " (Klient)"
			case TYPEID_N5KLIENT_PRACOWNIK
				page_.ctrl(1).text= cstr(pSender.strImie) + " " + cstr(pSender.strNazwisko) + " (Pracownik klienta '" + cstr(pSender.pKlient.strNazwa) + "')"
			case TYPEID_N5PRACOWNIK
				page_.ctrl(1).text= cstr(pSender.strImie) + " " + cstr(pSender.strNazwisko) + " (Pracownik)"
		end select
	end if
	
	page_.ctrl(2).text = subject
	
	dim strBody:strBody = body
	if len(strBody) > clng(512) then
		page_.ctrl(3).text= left(strBody, 512)
		page_.ctrl(100).disable = false
	else
		page_.ctrl(3).text = strBody
		page_.ctrl(100).disable = true
	end if
	
end function

function Break
	page_.result=clng(VAR_STOP_READING)
	page_.goback 
end function

function Cancel
	page_.result=clng(VAR_SKIP_MAIL)
	page_.goback 
end function

function show_body
	show_long_msg cstr(trans_.var(APPVAR_UNKNOWN_SENDER_SUBJECT)), cstr(trans_.var(APPVAR_UNKNOWN_SENDER_BODY))
end function

function SaveMail
	page_.result=clng(VAR_RETURN_SAVE)
	page_.goback 
end function

'"
]]>

</script>
