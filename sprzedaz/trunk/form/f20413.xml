function c200_ongetdata(byref oCtrl)	
	dim strNapis
	if container().m_bExportFirm and container().m_bExportWorkers then
		strNapis = "Dane firmowe i dane pracowników"
		hideWorkersList(false)
	end if
	if container().m_bExportFirm and not container().m_bExportWorkers then
		strNapis = "Dane firmowe"
		hideWorkersList(true)
	end if
	if container().m_bExportWorkers and not container().m_bExportFirm then
		strNapis = "Dane pracowników"
	end if
	oCtrl.text = strNapis
	c200_ongetdata=true
end function
function c200_ondataentered(ctrl, value)	
	c200_ondataentered = true
end function


function c201_ongetdata(byref oCtrl)		
	dim strNapis
	if container().m_bRunWizzard then
		strNapis = "Uruchomienie kreatora wysyłki"
	end if
	if container().m_bToFile then
		strNapis = "Zapis dokumentu jako "" " + container().m_strFileName + """"
	end if
	if container().m_bToFile and container().m_bRunWizzard then
		strNapis = "Zapis dokumentu jako """ + container().m_strFileName + """" + "  i uruchomienie kreatora wysyłki"
	end if
	oCtrl.text = strNapis
	c201_ongetdata=true
end function
function c201_ondataentered(ctrl, value)	
	c201_ondataentered = true
end function


function printWorkersList	
	dim p,i,pPracownik
	p = container().m_pItems.count()
	dim tab:set tab = doc_.afc.new_tb(page_).attach(page_.ctrl(500)).removeall
	if p>0 then		
		for i = 0 to p-1
			set pPracownik = trans_.getobj(TYPEID_N5PRACOWNIK, container().m_pItems.Value(i))
			if not pPracownik is nothing then
				tab.newrow.newcell.addtext pPracownik.strNazwisko + " " + pPracownik.strImie
			end if
		next	
	else
		tab.newrow.newcell.addtext "brak"
	end if
end function

function hideWorkersList(bHide)
	page_.ctrl(300).hide = bHide
	page_.ctrl(301).hide = bHide
	page_.ctrl(500).hide = bHide
end function

function wyswietl_strone		
	container().m_pStream.save container().m_strTempFileName
	doc_.getmodule(PAGE_FORM_WEB).navigate container().m_strTempFileName
end function


]]>
</script>

