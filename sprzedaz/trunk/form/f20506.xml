<script>
<![CDATA[

#include "50203"

dim pStatus
dim pDate
dim pSubject
dim pWykonawca
dim pZlecajacy

function fopen()
	set pStatus=getuserprofileObj(USERPROF_TASKRAP_STATUS)
	set pDate=getuserprofileObj(USERPROF_TASKRAP_DATE)
	set pSubject=getuserprofileObj(USERPROF_TASKRAP_SUBJECT)
	set pWykonawca=getuserprofileObj(USERPROF_TASKRAP_WYKONAWCA)
	set pZlecajacy=getuserprofileObj(USERPROF_TASKRAP_ZLECAJACY)

	fopen=true
end function

function fsave()
	fsave=std_fsave()
end function

function fback()
	fback=std_fback()
end function

'---------------------------------------------------------------------
'wymiana z kontrolkami
'---------------------------------------------------------------------	

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.value=CStr(pStatus.Wartosc)
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	pStatus.Wartosc=CStr(newValue)
	c1_ondataentered=true
end function

function c2_ongetdata(byref oCtrl): c2_ongetdata=true
	oCtrl.value=CStr(pDate.Wartosc)
end function

function c2_ondataentered(byref oCtrl, byval newValue)
	pDate.Wartosc=CStr(newValue)
	c2_ondataentered=true
end function

function c3_ongetdata(byref oCtrl): c3_ongetdata=true
	oCtrl.value=CStr(pSubject.Wartosc)
end function

function c3_ondataentered(byref oCtrl, byval newValue)
	pSubject.Wartosc=CStr(newValue)
	c3_ondataentered=true
end function

function c4_ongetdata(byref oCtrl): c4_ongetdata=true
	oCtrl.value=CStr(pWykonawca.Wartosc)
end function

function c4_ondataentered(byref oCtrl, byval newValue)
	pWykonawca.Wartosc=CStr(newValue)
	c4_ondataentered=true
end function

function c5_ongetdata(byref oCtrl): c5_ongetdata=true
	oCtrl.value=CStr(pZlecajacy.Wartosc)
end function

function c5_ondataentered(byref oCtrl, byval newValue)
	pZlecajacy.Wartosc=CStr(newValue)
	c5_ondataentered=true
end function

]]>
</script>

