	<title>
	Kreator wizytówki - Wybór pracowników
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>
<startpos>center</startpos>
<script>
<![CDATA[

#include "50209"

dim ctrlId

function filltable

	dim cursor,pPracownik,i,pHli
	i = 1	
	ctrlID = PAGE_CHECKBOX_ID
	dim tab:set tab = doc_.afc.new_tb(page_).attach(page_.ctrl(500)).removeall
	set cursor = trans_.createrawcursor(TYPEID_N5PRACOWNIK, "eAktywny=1" , "strNazwisko,strImie" , "")
	for each pPracownik in cursor		
		tab.newrow.newcell.addctrl CTRL_TYPE_CHECKBOX , clng(ctrlId)
		dim text
		set text = tab.element.addnew(CTRL_TYPE_STATIC, ctrlid + 1000)
		text.value = pPracownik.strNazwisko + " " +  pPracownik.strImie
		tab.element.value="0"
		set pHli = doc_.createhli()
		pHli.prop(GVAR_IDOBJ_VAR) = pPracownik.idobj
		set tab.element.userprop = pHli
		i = i+1			
		ctrlId = ctrlId + 1
	next

	if i>10 then
		page_.ctrl(CHECK_BUTTONS ).hide=false
	else
		page_.ctrl(CHECK_BUTTONS ).hide=true
	end if

end function

function change_check(strValue)
	dim i,pCtrl
	for i = PAGE_CHECKBOX_ID to ctrlId + 10
		set pCtrl = page_.trygetctrl(i)
		if not pCtrl is nothing then
			if strValue<>"" then
				pCtrl.value=strValue
			else
				if pCtrl.value="1" then
					pCtrl.value="0"
				else
					pCtrl.value="1"
				end if
			end if
		end if
	next
end function

function on_button_nothing
	change_check("0")
end function

function on_button_all
	change_check("1")
end function

function on_button_reverse
	change_check("")
end function

function getworkers
	dim ctrlId
	ctrlId = PAGE_CHECKBOX_ID
	container().m_pItems.RemoveAll()
	while not page_.trygetctrl(ctrlId) is nothing
		if page_.ctrl(ctrlId).value = "1" then
			container().m_pItems.Add(page_.ctrl(ctrlId).userprop.prop(GVAR_IDOBJ_VAR))			
		end if
		ctrlId = ctrlId + 1
	wend                       
end function


function fillTableFromContainer	
	filltable()
	dim ctrlId
	ctrlId = PAGE_CHECKBOX_ID
	while not page_.trygetctrl(ctrlId) is nothing
		if container().m_pItems.exists(page_.ctrl(ctrlId).userprop.prop(GVAR_IDOBJ_VAR)) then		
			page_.ctrl(ctrlId).value="1"
		else
			page_.ctrl(ctrlId).value="0"
		end if
		ctrlId = ctrlId + 1
	wend                       
end function


]]>
</script>

</config>

