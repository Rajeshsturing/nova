<script>

<!--
	Dodanie nieznanego nadawcy
-->

<![CDATA[

#include "50225"
#include "50122"
#include "50200"

#define VAR_STOP_READING	0
#define VAR_SKIP_MAIL		1
#define VAR_RETURN_OK		2
#define VAR_CHECK_SENDER	3

dim nTypeId
dim nObjectId
dim StdObj

function fopen()
	
	page_.result=clng(VAR_STOP_READING)
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_NAME) then
		page_.ctrl(1).text= cstr(trans_.var(APPVAR_SENDER_ADRESS)) + " (" + cstr(trans_.var(APPVAR_UNKNOWN_SENDER_NAME)) + ")"
	end if
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_SUBJECT) then
		page_.ctrl(2).text=trans_.var(APPVAR_UNKNOWN_SENDER_SUBJECT)
	end if
	if trans_.isvar(APPVAR_UNKNOWN_SENDER_BODY) then
		dim strBody:strBody = trans_.var(APPVAR_UNKNOWN_SENDER_BODY)
		
		if len(strBody) > clng(512) then
			page_.ctrl(3).text= left(strBody, 512)
			page_.ctrl(100).disable = false
		else
			page_.ctrl(3).text = trans_.var(APPVAR_UNKNOWN_SENDER_BODY)
			page_.ctrl(100).disable = true
		end if

	end if

end function


function Retry
	page_.result=clng(VAR_RETURN_OK)
	page_.goback 
end function

function Break
	page_.result=clng(VAR_STOP_READING)
	page_.goback 
end function

function Cancel
	page_.result=clng(VAR_SKIP_MAIL)
	page_.goback 
end function

function show_body
'	page_.ctrl(3).text = trans_.var(APPVAR_UNKNOWN_SENDER_BODY)	
'	page_.ctrl(100).disable = true
	show_long_msg cstr(trans_.var(APPVAR_UNKNOWN_SENDER_SUBJECT)), cstr(trans_.var(APPVAR_UNKNOWN_SENDER_BODY))
end function


function link_adress:link_adress = true
	choice(true)
end function

function choice_sender:choice_sender = true
	choice(false)
end function



function choice(byval bChange):choice=true

	'Wybór typu nadawcy'
	nTypeId = clng(0)
	nObjectId = clng(0)
	
	dim pPageSuggest
	set pPageSuggest=doc_.getmodule(43002)

	dim tempObj: set tempObj =trans_.newobj(TYPEID_N5SENDEMAIL)

	dim nObjectId
	nObjectId = pPageSuggest.wildref_choose(TYPEID_N5SENDEMAIL, "wpNadawca", "strNazwisko;strNazwisko;strNazwa", "")

	tempObj.ignore = true
	
	if (nObjectId>0) then

		nTypeId = pPageSuggest.getTypeID()
		
			dim pTran:set pTran=trans_.createsubtran()
			set StdObj = trans_.getobj(nTypeId, nObjectId)
			if StdObj is nothing then
				exit function
			end if
			dim strObjEmail:strObjEmail = trim(StdObj.strEmail)

			if bChange then	
				'Sprawdzenie, czy wybrany obiekt ma adres mailowy
				'Jeżeli wybrany obiekt ma już adres mailowy różny od przychodzącego
				if (strObjEmail <> "" and strObjEmail <> trim(trans_.var(APPVAR_SENDER_ADRESS)) )then
					
					dim strField:strField = ""
					dim strType:strType = ""
					
					select case nTypeId
						case TYPEID_N5KLIENT_PRACOWNIK
							strField= " " + cstr(StdObj.strImie) + " " + cstr(StdObj.strNazwisko)
							strType = "Pracownik klienta: '"

						case TYPEID_N5PRACOWNIK
							strField= " " + cstr(StdObj.strImie) + " " + cstr(StdObj.strNazwisko)
							strType = "Pracownik: '"

						case TYPEID_N5KLIENT
							strField= " " + cstr(StdObj.strNazwa)
							strType = "Klient: '"
					end select
					
					
					dim strText:strText = cstr(strType) + cstr(strField) + "' posiada adres poczty elektronicznej ("+ cstr(StdObj.strEmail) + ") " + _
					" Czy chcesz aby adres został zamieniony na " + cstr(trans_.var(APPVAR_SENDER_ADRESS)) + " ?"
					dim Res:Res = MessageBox (strText, "Uwaga", vbYesNo, vbQuestion)
					if Res <> vbYes then
						trans_.discard
						set pTran = nothing
						exit function
					end if
				end if
				
				'Ustawienie aktualnego maila
				StdObj.strEmail = cstr(trans_.var(APPVAR_SENDER_ADRESS))

				
				if not trans_.saveobjects() then
					MessageBox "Fail update Email", "Uwaga", vbOKOnly, vbInformation
				end if
				trans_.discard
				set pTran = nothing
				page_.result=clng(VAR_RETURN_OK)
				page_.goback 
				'exit function
			else 'Jeżeli bez zmiany adresu
				page_.result=clng(VAR_CHECK_SENDER)
				page_.goback 
			end if
			
	end if
end function 

function return_obj: set return_obj = nothing
	set return_obj = StdObj
end function

'"
]]>

</script>
