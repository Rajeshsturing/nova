<startpos>center</startpos>

<script><![CDATA[

#include "50202"
#include "50203"
#include "50209"

function c1_ongetdata(byref oCtrl): c1_ongetdata=true

	dim strDesc
	strDesc="Zostanie stworzona oferta zawierająca "
	
	select case container().nProductsRange
		case 1
			strDesc=strDesc+"wszystkie produkty dostępne."
		case 2
			strDesc=strDesc+"produkty z listy wyboru """ + container().pChoiceList.strNazwa + """."
		case 3
			strDesc=strDesc+"produkty z raportu """ + container().pRaport.Nazwa + """."
	end select

	oCtrl.value=strDesc
end function

function c1_ondataentered(byref oCtrl, byval newValue)
	c1_ondataentered=false
end function

function c2_ongetdata(byref oCtrl): c2_ongetdata=true

	dim strDesc
	strDesc="Wyniki zostaną posortowane "
	
	select case container().nProductsRange
		case 1, 2
			select case container().nGroupBy
				case 1
					strDesc=strDesc+"alfabetycznie wg. nazw produktów."
				case 2
					strDesc=strDesc+"alfabetycznie wg. nazw grup produktów."
			end select
		case 3
			strDesc=strDesc+"zgodnie z kryteriami znajdującymi się w definicji raportu."
	end select

	oCtrl.value=strDesc
end function

function c2_ondataentered(byref oCtrl, byval newValue)
	c1_ondataentered=false
end function

function c3_ongetdata(byref oCtrl): c3_ongetdata=true

	dim strDesc
	strDesc="Rezultaty zostaną przygotowane w formie "


	select case container().nForm
		case 1
			strDesc=strDesc+"strony HTML."
		case 2
			strDesc=strDesc+"pliku Word'a."
		case 3
			strDesc=strDesc+"pliku Excel'a."
	end select


	oCtrl.value=strDesc
end function

function c3_ondataentered(byref oCtrl, byval newValue)
	c3_ondataentered=false
end function

#include "50201"
#include "50212"
#include "50211"


#include "50516"
#include "50305"

function View_local()
	View_local=CreateOffer(true, container(), page_.get_this)
end function


