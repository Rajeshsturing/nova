#include "h1000.h"
#include "h1240.h"
#include "h1230.h"
#include "h1200.h"

#define ID_WEB_CONTROL		1001
#define ID_URL_CONTROL		1002

<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE' width='max' height='max' margins='0,0,0,0'>
<!--
WEB
-->
<config>
	
	<title>
	WEB 
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>

<script>
<![CDATA[

'------------------------------------------------------------------------
'rozpoczyna nawigacje od danej strony
'------------------------------------------------------------------------
function navigate(byval strUrl)
	dim pPage
	set pPage=doc_.getmodule(PAGE_FORM_WEB)

	if pPage is nothing then
		exit function
	end if


	strUrl=trim(strUrl)
	if (len(strUrl)=0) then
		strUrl="about:Brak adresu strony WWW"
	end if

	pPage.ctrl(ID_WEB_CONTROL).value=strUrl

	navigate=pPage.domodalauto()
	set pPage=nothing
end function

]]></script>

</config>
<body>

<web width='max' height='20000' name="w##ID_WEB_CONTROL">http://www.navo.com.pl</web>

</body>
</page>
