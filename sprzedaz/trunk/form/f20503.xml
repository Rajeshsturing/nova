#define VAR_IGNORE_THIS		0
#define VAR_IGNORE_ALL		1
#define VAR_SAVE_THIS		2

#define ID_TABLE_RESULTS	1000
dim g_All:g_All = clng(0)
dim nRow:nRow = clng(0)

'-----------------------------------------------------------------------------
'
' Wywołaj tę funkcję przed otwarciem formularza
'
'-----------------------------------------------------------------------------
function init_form(byval strData, byval strKwota, byval strKlient, byval strOpisNew, byval strOpis, byval nMulti)
	dim pOpisArr
	
	strOpis = Replace(strOpis, ";;", ";")
	set pOpisArr = trans_.afc.new_navoarray()
	pOpisArr.Separate strOpis, ";"
	
	page_.ctrl(1).text = strData 
	page_.ctrl(2).text = strKwota
	page_.ctrl(3).text = strKlient 
	page_.ctrl(4).text = strOpisNew
	
	select case nMulti
		case clng(1)
			page_.ctrl(10).text = "W bazie znajduje się taka sama płatność:"
		case clng(2)
			page_.ctrl(10).text = "W bazie znajdują się " + cstr(nMulti) + " podobne płatności:"
		case clng(3)
			page_.ctrl(10).text = "W bazie znajdują się " + cstr(nMulti) + " podobne płatności:"
		case clng(4)
			page_.ctrl(10).text = "W bazie znajdują się " + cstr(nMulti) + " podobne płatności:"
		case else
			page_.ctrl(10).text = "W bazie znajduje się " + cstr(nMulti) + " podobnych płatności:"
	end select
	
	
	dim pBodyTable:set pBodyTable=page_.ctrl(ID_TABLE_RESULTS).body
	dim pRow

	dim tab:set tab = doc_.afc.new_tb(page_).attach(page_.ctrl(ID_TABLE_RESULTS)).removeall

	dim i
	dim y
	for i=0 to (nMulti-1) 'ilosc wpisów
		'wstaw wpis
		for y = clng(1) to clng(4) '
			
			tab.newrow
			select case y 
				case clng(1)
					tab.newcell.addtext "Data transakcji"
					SetStaticStyle tab.element , true , false
					tab.newcell.addtext strData
				case clng(2)
					tab.newcell.addtext "Kwota"
					SetStaticStyle tab.element , true , false
					tab.newcell.addtext strKwota
				case clng(3)
					tab.newcell.addtext "Płatnik"
					SetStaticStyle tab.element , true , false
					tab.newcell.addtext strKlient
				case clng(4)
					tab.newcell.addtext "Opis"
					SetStaticStyle tab.element , true , false
					tab.newcell.addtext pOpisArr.Value(i)
			end select
		next 
		tab.newrow.newcell.addtext ""
	next 
	init_form = true
end function




function fopen()
	fopen=true
end function


function on_button_pomin()
	page_.result=clng(VAR_IGNORE_THIS)
	page_.goback 
end function

function on_button_zapisz()
	page_.result=clng(VAR_SAVE_THIS)
	page_.goback 
end function

function on_button_pomin_all()
	page_.result=clng(VAR_IGNORE_ALL)	
	page_.goback 
end function

]]>
</script>
