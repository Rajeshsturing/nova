<startpos>center</startpos>

<script><![CDATA[

#include "50209"

function typ_oper(byval nTyp)
	select case nTyp
		case 1
			container().strOperacji="Operacja sumy zostanie wykonana na niżej podanych listach wyboru (zbiorach)"
		case 2
			container().strOperacji="Operacja iloczynu zostanie wykonana na niżej podanych listach wyborów (zbiorach)"
		case 3
			container().strOperacji="Operacja różnicy zostanie wykonana na niżej podanych listach wyborów (zbiorach)"
	end select
end function

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	typ_oper container().nTypOperacji
	oCtrl.value=container().nTypOperacji
end function

function c1_ondataentered(byref oCtrl, byval newValue): c1_ondataentered=false
	typ_oper clng(newValue)
	container().nTypOperacji=clng(newValue)
end function

]]></script>
</config>

<body>

XFORMMWIZZARDBEGIN(PICTURE_WIZZARD_CHOICELIST_STEP3)


