<typeid>TYPEID_N5WIZZARDEMAIL</typeid>

<script><![CDATA[

#include "50209"

function c##CTRL_DATASOURCE##_ongetdata(byref oCtrl): c##CTRL_DATASOURCE##_ongetdata=true
	select case container().m_nDest
		case 1:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Wszyscy aktywni klienci "
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Wszyscy aktywni pracownicy "
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Wszyscy aktywni pracownicy klienta "
			end select
		case 2:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Lista wyboru dla klientów : " + container().m_strName
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Lista wyboru dla pracowników : " + container().m_strName
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Lista wyboru dla pracowników klienta : " + container().m_strName
			end select
		case 3:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Raport dla klientów : " + container().m_strName
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Raport dla pracowników : " + container().m_strName
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Raport dla pracowników klienta : " + container().m_strName
			end select
	end select
end function


]]></script>
</config>

