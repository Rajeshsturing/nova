<script><![CDATA[

#include "50200"


function save_settings


		dim pSubTrans
		set pSubTrans=trans_.createsubtran()
		

		save_settings = trans_.saveobjects()

		set pSubTrans=nothing

end function


function fok
	page_.result = 1
	page_.goback
end function


function fcancel
	page_.result = 0
	page_.goback
end function


dim fak:set fak = nothing

function choose_dok(): choose_dok=true
	
	dim choice : choice = fire_choice_list( TYPEID_N5SPRZEDAZ,"","","","","")

	if choice <> 0 then
		set fak = trans_.getobj(TYPEID_N5SPRZEDAZ , choice)
	else
		set fak = nothing
	end if

end function


function c300_ongetdata(byref oCtrl): c300_ongetdata=true
	if not fak is nothing then
		oCtrl.text = fak.strNrDok
	else
		oCtrl.text = "<brak>"
	end if
end function

function get_fak_id
	if fak is nothing then
		get_fak_id = 0	
	else
		get_fak_id = fak.idobj
	end if
end function

function let_change
	let_change = page_.ctrl(301).value = "1"
end function


]]></script>
