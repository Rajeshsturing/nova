<?xml version="1.0" encoding="windows-1250" ?>
<page>

<!--
ALWAYS MANUAL
Wybór stawki VAT
-->

<config>

	<title>
	</title>
<startpos>center</startpos>

<script>
<![CDATA[

function fopen()
	fopen = true
	if trans_.isvar(APPVAR_BAD_VAT_TEXT) then
		page_.ctrl(1).text= cstr(trans_.var(APPVAR_BAD_VAT_TEXT)) 
	end if
	page_.ctrl(10).value = clng(1)
	page_.result = clng(5)
end function

function Return_Res()
	select case page_.ctrl(10).value
		case clng(1):
			page_.result = clng(5)
		case clng(2):
			page_.result = clng(4)
		case clng(3): '0%
			page_.result = clng(1)
		case clng(4): 'Zwolniony
			page_.result = clng(2)
		case clng(5): 'Nie podlega
			page_.result = clng(3)
	end select
	page_.goback
end function

]]>
</script>

</config>

<body>
	<p>
		<t width='max' style='STYLE_FORMTITLE'>Wybierz stawkę VAT</t>
		<br/>
	</p>

	<text name='e1'>
	</text>

	<table style='STYLE_TABLE'>
	<tbody>
		<tr>
					<td>
						<radio name='e10'>
							<t>22.00 %</t>
							<t>7.00 %</t>
							<t>3.00 %</t>
							<t>0.00 %</t>
							<t>zwolniony</t>
							<t>nie podlega</t>
						</radio>
