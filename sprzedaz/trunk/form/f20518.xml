function c##CTRLID_PRICE1##_ongetdata(ctrl):c##CTRLID_PRICE1##_ongetdata = true
		format_ctrl ctrl , GLOBPROF_CENA1_NAME
end function
function c##CTRLID_PRICE2##_ongetdata(ctrl):c##CTRLID_PRICE2##_ongetdata = true
		format_ctrl ctrl , GLOBPROF_CENA2_NAME
end function
function c##CTRLID_PRICE3##_ongetdata(ctrl):c##CTRLID_PRICE3##_ongetdata = true
		format_ctrl ctrl , GLOBPROF_CENA3_NAME
end function
