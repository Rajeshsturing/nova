function format_ctrl(byref ctrl , byval nr)
	ctrl.text = getglobprofile(nr)
	if ctrl.text = "" then
		ctrl.disable = true
		ctrl.text = "brak"
	end if
end function




function std_choose_opak(byref hli)

	if page_.root.wpProdGrupa is nothing then
		exit function
	end if


	if page_.root.wpProdGrupa.type <> TYPEID_N5PRODUKT then
		exit function
	end if

	dim lp_opak: lp_opak = choose_opakowanie_lp_where(page_.root.wpProdGrupa,"")
	
	if lp_opak <> 0 then
		set page_.root.pOpak =  page_.root.wpProdGrupa.listOpakowania.get( lp_opak )
	end if

end function


function c##CTRLID_OPAK##_ongetdata(byref oCtrl)
	if (not page_.root.pOpak is nothing) then
		oCtrl.value = page_.root.pOpak.text
	else
		oCtrl.value = "Wybierz z listy --->"
	end if
	c##CTRLID_OPAK##_ongetdata=true
end function

function c##CTRLID_OPAK##_ondataentered(byref oCtrl, byval newValue)
	if (newValue="") then
		set page_.root.pOpak =  nothing
	end if
	c##CTRLID_OPAK##_ondataentered = true
end function





'--------------------------------------------------------------------
' KLIENCI
'--------------------------------------------------------------------

function WildRef_4():WildRef_4=true
	dim pPageSuggest
	set pPageSuggest=doc_.getmodule(43002)

	dim nObjectId
	nObjectId = pPageSuggest.wildref_choose(page_.root, "wpKlientGrupa", "strNazwa;strNazwa", "eAktywny=1;")

	if (nObjectId>0) then
		set page_.root.wpKlientGrupa=trans_.getobj(pPageSuggest.getTypeID(), nObjectId)
	end if

end function

function c4_ongetdata(byref oCtrl): c4_ongetdata=true
	if page_.root.wpKlientGrupa is nothing then
		oCtrl.text = "<wszyscy klienci>"
		page_.ctrl(41).image = CLng(PICTURE_CHOICE_N5GRUPAKLIENT)
	else
		dim strText:strText=""

		select case page_.root.wpKlientGrupa.type
			
		case TYPEID_N5KLIENT
			strText=page_.root.wpKlientGrupa.n5klient_as_text()
			page_.ctrl(41).image = CLng(PICTURE_CHOICE_N5KLIENT)

		case TYPEID_N5GRUPAKLIENT
			strText=page_.root.wpKlientGrupa.n5grupaklient_as_text()
			page_.ctrl(41).image = CLng(PICTURE_CHOICE_N5GRUPAKLIENT)

		end select

		oCtrl.text = strText
	end if
end function

function c4_ondataentered(ctrl, value)
	c4_ondataentered=true
end function

