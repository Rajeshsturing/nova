function c9_ongetdata(byref oCtrl)
	oCtrl.value = page_.root.eTyp
	c9_analyse_text
	c9_ongetdata = true
end function

function c9_ondataentered(ctrl, value)
	page_.root.eTyp = CLng(value)
	c9_analyse_text
	c9_ondataentered=true
end function

function c9_analyse_text()
	page_.ctrl(81).text = enum2str(TYPEID_N5POLRAB, 9, page_.root.eTyp)

	if (page_.root.eTyp=1 or page_.root.eTyp=2) then
		page_.ctrl(CTRLID_CENAKONCOWA).unit = page_.root.polrab_pWalutaCeny.strSkrot
	else
		page_.ctrl(CTRLID_CENAKONCOWA).unit = "%"		
	end if
end function

function fopen()
	if not std_fopen() then
		fopen = false
		exit function
	end if

	if (trans_.var( GVAR_USE_CUSTOM_PRICES )=0) then
		'Nie uaktywniono korzystania ze zdefiniowanych
		'cen i rabatów
		MessageBoxAndForget "Polityka rabatowa firmy nie jest uaktywniona. Zdefiniowane rabaty nie będą automatycznie pojawiały się na dokumentach sprzedaży.", "Polityka rabatowa", vbOkOnly, vbInformation, USERPROF_MSGBOX_CUSTOM_PROCES
	end if

	c9_ondataentered page_.ctrl(9), page_.root.eTyp
	fopen = true
end function



function c##CTRLID_CENAKONCOWA##_ongetdata(byref pCtrl): c##CTRLID_CENAKONCOWA##_ongetdata=true 
