<config>

	<title>
	Kreator wysyłki (krok 2)
	#ifdef _DEBUG
	[THIS_FILE]
	#endif
	</title>

<startpos>center</startpos>
<typeid>TYPEID_N5WIZZARDEMAIL</typeid>

<script><![CDATA[

#include "50209"
#include "50200"

function list_edit_element(byref pHli): list_edit_element=false

	dim pParent
	set pParent=page_.root

	'numer elementu
	dim nRow: nRow=CLng(pHli.prop(PROPC_ROW))

	if not pParent.listDokumenty.exists(nRow) then
		exit function
	end if


	'wskaznik na 
	dim pChild
	set pChild=pParent.listDokumenty.get(nRow).pDokument


	if (pChild is nothing) then
		exit function
	end if
			
	doc_.getmodule(60129).form_domodal pChild.type, pChild.idobj , USAGE_VIEW

	list_edit_element=true

end function

]]></script>
</config>

<body>

XFORMMWIZZARDBEGIN(PICTURE_WIZZARD_WYSYLKA_STEP2)

<tr>
	<td width='min'>
		<t>Tytuł</t>
	</td>
	<td>
		<edit size='40' style='STYLE_CTRL'>
			<transfer mode='edit_field'>
				<field>strTytul</field>
			</transfer>
		</edit>
	</td>
</tr>

<tr>
	<td colspan='2'>
		<t>Treść</t>
	</td>
</tr>
<tr>
	<td colspan='2'>
		<multiline width='11000' name='e9' size='42' style='STYLE_CTRL'>
			<transfer mode='edit_field'>
				<field>strTresc</field>
			</transfer>
		</multiline>
	</td>
</tr>

<tr>
	<td colspan='2'>
		<checkbox name='c5'><t>Treść jest szablonem</t>
			<transfer mode='edit_field'>
				<field>cSzablon</field>
			</transfer>
		</checkbox>
	</td>
</tr>

<tr>
	<td colspan='2'>

		<grid name='e6' >
		<transfer mode='grid_list'>
			<field>listDokumenty</field>
		</transfer>

		<thead>
		<tr style='STYLE_TABLE_HEADER'>
			<td><t>LP</t></td>
			<td><t size='50'>Nazwa dokumentu</t></td>
			<td><t></t></td>
		</tr>
		</thead>

		<tbody>
			<tr style='STYLE_TABLE_BODY'>

				SXC_LP
				SXC_EDIT_REF(-1,40,PICTURE_CHOICE_N5DOKUMENT,listDokumenty,pDokument,strTematDokum,CRSR_DEFAULT)
				<td>
					XF_BUTTON(varFunctionHLI="list_edit_element",Edycja)
				</td>

			</tr>
		</tbody>

		</grid>

	</td>
</tr>
						
XFORMMWIZZARDEND

