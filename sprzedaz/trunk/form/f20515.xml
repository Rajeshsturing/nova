#define CTRL_LABEL_WIDTH				5
#define CTRL_LABEL_HEIGHT				6
#define CTRL_COUNT_LABELS_ON_PAGE		7
#define CTRL_COUNT_COLUMNS				8
#define CTRL_START_PRINT_PAGE			9
#define CTRL_STOP_PRINT_PAGE			12
#define CTRL_LEFT_MARGIN				10
#define CTRL_UP_MARGIN					11
#define CTRL_DATASOURCE					13


<?xml version="1.0" encoding="windows-1250" ?>
<page style='10'>
<config>
<title>Kreator etykiet - Krok 3</title>
<startpos>center</startpos>
<script>
<![CDATA[
#include "50209"

function c##CTRL_LABEL_WIDTH##_ongetdata(byref oCtrl): c##CTRL_LABEL_WIDTH##_ongetdata=true
	oCtrl.value= cstr(container().m_nLabelWidth) + " mm"
end function

function c##CTRL_LABEL_HEIGHT##_ongetdata(byref oCtrl): c##CTRL_LABEL_HEIGHT##_ongetdata=true
	oCtrl.value= cstr(container().m_nLabelHeight) + " mm"
end function

function c##CTRL_COUNT_LABELS_ON_PAGE##_ongetdata(byref oCtrl): c##CTRL_COUNT_LABELS_ON_PAGE##_ongetdata=true
	oCtrl.value= cstr(container().m_nCountLabelsOnPage)
end function

function c##CTRL_COUNT_COLUMNS##_ongetdata(byref oCtrl): c##CTRL_COUNT_COLUMNS##_ongetdata=true
	oCtrl.value= cstr(container().m_nCountColumns)
end function

function c##CTRL_START_PRINT_PAGE##_ongetdata(byref oCtrl): c##CTRL_START_PRINT_PAGE##_ongetdata=true
	oCtrl.value= cstr(container().m_nStartPrintRow)
end function

function c##CTRL_STOP_PRINT_PAGE##_ongetdata(byref oCtrl): c##CTRL_STOP_PRINT_PAGE##_ongetdata=true
	oCtrl.value= cstr(container().m_nStopPrintRow)
end function

function c##CTRL_LEFT_MARGIN##_ongetdata(byref oCtrl): c##CTRL_LEFT_MARGIN##_ongetdata=true
	oCtrl.value= cstr(container().m_nLeftMargin) + " mm"
end function

function c##CTRL_UP_MARGIN##_ongetdata(byref oCtrl): c##CTRL_UP_MARGIN##_ongetdata=true
	oCtrl.value= cstr(container().m_nUpMargin) + " mm"
end function

function c##CTRL_DATASOURCE##_ongetdata(byref oCtrl): c##CTRL_DATASOURCE##_ongetdata=true
	select case container().m_nDest
		case 1:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Wszyscy aktywni klienci "
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Wszyscy aktywni pracownicy "
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Wszyscy aktywni pracownicy klienta "
			end select
		case 2:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Lista wyboru dla klientów : " + container().m_strName
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Lista wyboru dla pracowników : " + container().m_strName
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Lista wyboru dla pracowników klienta : " + container().m_strName
			end select
		case 3:
			select case container().m_nTypeID
				case TYPEID_N5KLIENT:
					oCtrl.text = "Raport dla klientów : " + container().m_strName
				case TYPEID_N5PRACOWNIK:
					oCtrl.text = "Raport dla pracowników : " + container().m_strName
				case TYPEID_N5KLIENT_PRACOWNIK:
					oCtrl.text = "Raport dla pracowników klienta : " + container().m_strName
			end select
	end select
end function


]]>
</script>
</config>
<body>

