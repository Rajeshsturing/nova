<startpos>center</startpos>
<typeid>TYPEID_N5WIZZARDEMAIL</typeid>

<script><![CDATA[

#include "50209"

function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	oCtrl.value=CStr(page_.root.cWysylkaEmail)
end function

function c1_ondataentered(byref oCtrl, byval newValue)

	if (newValue="1") then
		page_.ctrl(20).hide=false
		page_.ctrl(21).hide=false
	else
		page_.ctrl(20).hide=true
		page_.ctrl(21).hide=true
	end if


	page_.root.cWysylkaEmail=CStr(newValue)
	c1_ondataentered=true
end function

function fopen()
	c1_ondataentered page_.ctrl(1), page_.root.cWysylkaEmail

end function

]]></script>
</config>

<body>

XFORMMWIZZARDBEGIN(PICTURE_WIZZARD_WYSYLKA_STEP3)

