function c1_ongetdata(byref oCtrl): c1_ongetdata=true
	dim strZgoda:strZgoda="0"
	if (container().bWyrazamZgode) then
		strZgoda="1"
	end if
	oCtrl.value=strZgoda
end function

function c1_ondataentered(ctrl, value): c1_ondataentered=false
	dim bZgoda:bZgoda=false
	
	if (value="1") then
		bZgoda=true
	end if

	container().bWyrazamZgode=bZgoda
	c1_ondataentered=true
end function


]]></script>
