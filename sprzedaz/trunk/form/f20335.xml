#define CTRL_COUNT_CLIENTS	100
#define CTRL_COUNT_WYK	101
#define CTRL_DEDYK		102
#define CTRL_PRZYDZIAL		103
#define CTRL_MAX_TASK		104
#define CTRL_MIN_TASK		105

<?xml version="1.0" encoding="windows-1250" ?>
<page style='10'>
<config>
<title>Kreator przydziału zadań - Krok 5</title>
<startpos>center</startpos>
<script>
<![CDATA[
#include "50209"

function c##CTRL_DEDYK##_ongetdata(byref oCtrl): c##CTRL_DEDYK##_ongetdata=true
	if container().m_bDedyk  then
		oCtrl.hide = false
		oCtrl.text = "Przy przydziale wykonawców preferowani są pracownicy dedykowani dla danej firmy"
	else
		oCtrl.hide = true
	end if		
end function

function c##CTRL_PRZYDZIAL##_ongetdata(byref oCtrl): c##CTRL_PRZYDZIAL##_ongetdata=true
	if container().m_nPrzydzial = 1  then
		oCtrl.text = "Zadania zostaną przydzielone równomiernie - każdemu z wybranych wykonawców zostanie zlecona podobna liczba zadań"
	else
		oCtrl.text = "Zadania zostaną przydzielone według ilości zadań juz im zleconych - wykonawcy posiadający już dużą ilość zadań nie bądą obciążani nowymi"
	end if		
end function


]]>
</script>
</config>
<body>

XFORMMWIZZARDBEGIN(80845)

<tr>
	<td colspan='2'>
		<t bold='true'>Podsumowanie</t>
	</td>
</tr>

<tr>
	<td>
		<t bold='true'>Ilość klientów</t>
	</td>
	<td>
		<t name='c##CTRL_COUNT_CLIENTS'>		
		</t>
	</td>
</tr>

<tr>
	<td>
		<t bold='true'>Ilość wykonawców</t>
	</td>
	<td>
		<t name='c##CTRL_COUNT_WYK'>
		</t>
	</td>
</tr>

<tr hide='true'>
	<td>
		<t bold='true'>Maksymalna ilość przydzielonych zadań</t>
	</td>
	<td>
		<t name='c##CTRL_MAX_TASK'>
		</t>
	</td>
</tr>

<tr hide='true'>
	<td>
		<t bold='true'>Minimalna ilość przydzielonych zadań</t>
	</td>
