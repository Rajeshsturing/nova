<?xml version="1.0" encoding="windows-1250" ?>

<!-- Zadanie notatka -->
#include "h1000"
#include "h1240"

#define SHOW_INDEX
#comment SHOW_PKWIU
#comment SHOW_RABAT


#define CTRLID_ORGKOPIA					101

#macro DATE(_v_)						nx_.display.fulldate(_v_)
#macro DATE_TIME(_dt_,_tm_)				nx_.display.fulldate(_dt_) + " " + nx_.display.fulltime(_tm_)

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>

#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define MIEJSCOWOSC_FIRMA				<% so.write util_.Firma_Miasto%>
#define DOKUMENT_DATA_WYDRUKU			<% so.write doc_.afc.display.fulldate(trans_.var(GVAR_TODAY)) %>

#define DOKUMENT_TEMAT					<% so.write root_.strTemat %>
#define DOKUMENT_TYP					<% if not root_.pTypDzialania is nothing then so.write root_.pTypDzialania.text end if %>

#define DOKUMENT_ZLECAJACY				<% if not root_.pZlecajacy is nothing then so.write root_.pZlecajacy.text end if %>
#define DOKUMENT_WYKONAWCA				<% if not root_.pWykonawca is nothing then so.write root_.pWykonawca.text end if %>
#define DOKUMENT_TRESC					<% so.write root_.strOpis %>

#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

<!-- musi byc obiekt! -->
#define KLIENT_OBIEKT_NAZWA				<% so.write root_.zad_pKLOB.klob_strNazwa %>
#define KLIENT_OBIEKT_ULICA_NUMER		<% so.write root_.zad_pKLOB.klob_strUlica + " " + root_.zad_pKLOB.klob_strNrDomu + "/" + root_.zad_pKLOB.klob_strNrLokalu %>
#define KLIENT_OBIEKT_KOD_MIASTO		<% so.write root_.zad_pKLOB.klob_strKod + " " + root_.zad_pKLOB.klob_pMiejscowosc.strNazwa %>

<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>

#define FIRMA_TELEFON_LABEL				<% so.write util_.Firma_Telefon_Label %>
#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_TELEFON_HIDE				<% so.write util_.Firma_Telefon_Hide %>

#define FIRMA_FAX_LABEL					<% so.write util_.Firma_Fax_Label %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_FAX_HIDE					<% so.write util_.Firma_Fax_Hide %>



#define KLIENT_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient) %>
#define KLIENT_TELEFON					<% so.write util_.Klient_Telefon(root_.pKlient) %>
#define KLIENT_TELEFON_HIDE				<% so.write util_.Klient_Telefon_Hide(root_.pKlient) %>

#define KLIENT_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient) %>
#define KLIENT_TELEFON_KOM				<% so.write util_.Klient_Telefon_Kom(root_.pKlient) %>
#define KLIENT_TELEFON_KOM_HIDE			<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient) %>

#define KLIENT_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient) %>
#define KLIENT_FAX						<% so.write util_.Klient_Fax(root_.pKlient) %>
#define KLIENT_FAX_HIDE					<% so.write util_.Klient_Fax_Hide(root_.pKlient) %>


#define ZADANIE_TEMAT					<% so.write root_. %>

<page style='36' margins='700,700,700,700' border='0' font='Verdana'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"


VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<!-- naglowek -->
			<td>
				<table>
					<tbody>
						<tr>
							<td>
								<t><![CDATA[FIRMA_NAZWA]]></t>
							</td>
							<td width='max' />
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_FIRMA, DOKUMENT_DATA_WYDRUKU]]></t>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		<tr>
			<td border='1' align='center' bold='true' fontsize='6'>
				<text><![CDATA[DOKUMENT_TEMAT]]></text>
			</td>
		</tr>
		ROW_SEPARATOR(1)	

		<tr>
			<td border='1'><t bold='true' fontsize='5'><![CDATA[Dane podstawowe]]></t></td>
		</tr>	
		<tr>
			<td border='1'>
				<table border='0'>
					<tbody>
						<%if not root_.pKlient is nothing then%>
						<tr>
							<td><t bold='true'>Klient</t></td><td colspan='3'><t><![CDATA[KLIENT_NAZWA]]></t></td>
						</tr>
						<tr>
							<td></td><td colspan='3'><t><![CDATA[KLIENT_ULICA_NUMER]]></t></td>
						</tr>
						<tr>
							<td></td><td colspan='3'><t><![CDATA[KLIENT_KOD_MIASTO]]></t></td>
						</tr>
						ROW_SEPARATOR(4)	
						<%if not root_.zad_pKLOB is nothing then%>
						<tr>
							<td><t bold='true'>Obiekt</t></td><td colspan='3'><t><![CDATA[KLIENT_OBIEKT_NAZWA]]></t></td>
						</tr>
						<tr>
							<td></td><td colspan='3'><t><![CDATA[KLIENT_OBIEKT_ULICA_NUMER]]></t></td>
						</tr>
						<tr>
							<td></td><td colspan='3'><t><![CDATA[KLIENT_OBIEKT_KOD_MIASTO]]></t></td>
						</tr>
						<%end if%>
						<%end if%>
						ROW_SEPARATOR(4)
						<tr>
							<td><t bold='true'>Zlecający:</t></td><td><t><![CDATA[DOKUMENT_ZLECAJACY]]></t></td>
							<td><t bold='true'>Typ:</t></td><td><t><![CDATA[DOKUMENT_TYP]]></t></td>
						</tr>
						<tr>
							<td><t bold='true'>Wykonawca:</t></td><td><t><![CDATA[DOKUMENT_WYKONAWCA]]></t></td>
							<td><t bold='true'>Status:</t></td><td><t><![CDATA[<% so.write root_.n5zadanie_getStatusName()%>]]></t></td>
						</tr>
						ROW_SEPARATOR(4)
						<tr>
							<td><text bold='true'>Termin rozpoczęcia:</text></td><td><text><![CDATA[<% so.write root_.n5zadanie_get_termin_rozp_desc()%>]]></text></td>
							<td><text bold='true'>Termin zakończenia:</text></td><td><text><![CDATA[<% so.write root_.n5zadanie_get_termin_zakon_desc()%>]]></text></td>
						</tr>
						ROW_SEPARATOR(4)
						<tr>
							<td><t bold='true'>Data zlecenia:</t></td>
								<td><t><![CDATA[<%so.write DATE_TIME(root_.dDataZlec,root_.tCzasZlec)%>]]></t></td>
							<td><t bold='true'>Data zakończenia:</t></td>
								<td><t><![CDATA[<%so.write DATE_TIME(root_.dDataZakon,root_.tCzasZakon)%>]]></t></td>
						</tr>
						<tr>
							<td><t bold='true'>Data zamknięcia:</t></td>
								<td><t><![CDATA[<%so.write DATE_TIME(root_.dDataZamk,root_.tCzasZamk)%>]]></t></td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		<tr>
			<td border='1'><t bold='true' fontsize='5'><![CDATA[Opis]]></t></td>
		</tr>	
		<tr>
			<td border='1'><text><![CDATA[DOKUMENT_TRESC]]></text></td>
		</tr>
		<% if root_.listZalaczniki.exists(1) then %>
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<table border='0'>
					<tbody>
						<tr>
							<td colspan='2' border='1'><t bold='true' fontsize='5'><![CDATA[Załączniki:]]></t></td>
						</tr>
						<%dim oZalacznik, iter
						iter = 1
						for each oZalacznik in root_.listZalaczniki%>
						<tr border='1'>
							<td width='min' align='right'><t><%so.write cstr(iter)%></t></td>
							<td ><text><![CDATA[<%so.write oZalacznik.text%>]]></text></td>
						</tr>
						<%
						iter = iter + 1
						next%>
					</tbody>
				</table>
			</td>
		</tr>
		<%end if%>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr valign='bottom'>
			<td>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
	<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
</footer>
</page>
