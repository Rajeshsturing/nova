<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Podsumowanie wartości magazynu wg grup produktów

RAPTEMPLATE_MAG_PODSUMOWANIE_WG_GRUP

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
VB_PRINT_LANDSCAPE_COMMON
VB_PRINTPREV_LANDSCAPE_COMMON


<%
function query_current()

query_current = "select 'c_mag'=TAB_n5magazyn.strNazwa, " + _
"'c_wartosc'=sum(r##ound(TAB_n5stanmag.gms_curIlosc * TAB_n5stanmag.gms_curCena,2)) " + _
"from n5gmstan as TAB_n5stanmag  " + _
"inner join n5magazyn as TAB_n5magazyn on TAB_n5stanmag.gms_pMag = TAB_n5magazyn.IdObj  " + _
"inner join n5produkt as TAB_n5produkt on TAB_n5stanmag.gms_pProd = TAB_n5produkt.IdObj  " + _
"where TAB_n5produkt.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) and %1 and %3 and %4 and TAB_n5produkt.eRodzaj=1 " + _
"group by TAB_n5magazyn.strNazwa " + _
"order by c_mag " 

end function

function query_any()

query_any = "select 'c_mag'=TAB_n5magazyn.strNazwa, " + _
"'c_wartosc'=sum(gmo_curWartosc),'c_id_mag'=max(TAB_n5magazyn.IdObj) " + _
"from n5gmop as TAB_n5stanmag  " + _
"inner join n5magazyn as TAB_n5magazyn on TAB_n5stanmag.gmo_pMag = TAB_n5magazyn.IdObj  " + _
"inner join n5produkt as TAB_n5produkt on TAB_n5stanmag.gmo_pProd = TAB_n5produkt.IdObj  " + _
"where TAB_n5produkt.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) and %1 and %3 and %4 and NUMOPBORDER and TAB_n5produkt.eRodzaj=1 " + _
"group by TAB_n5magazyn.strNazwa " + _
"order by c_mag " 

end function

function get_value_grupa(byval nIdMag, byval nIdGrupaProd): get_value_grupa = ccur(0.0)
  dim strSQL
  strSQL = "select 'c_wartosc'=sum(gmo_curWartosc) " + _
           "from n5gmop as TAB_n5stanmag  " + _
           "inner join n5magazyn as TAB_n5magazyn on TAB_n5stanmag.gmo_pMag = TAB_n5magazyn.IdObj  " + _
           "inner join n5produkt as TAB_n5produkt on TAB_n5stanmag.gmo_pProd = TAB_n5produkt.IdObj  " + _
           "where TAB_n5produkt.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) and %1 and %3 and %4 and NUMOPBORDER and TAB_n5produkt.eRodzaj=1 " + _
           "and TAB_n5magazyn.idobj = " + CStr(nIdMag) + " and TAB_n5produkt.pGrupaProd = " + CStr(nIdGrupaProd) + " " +_
           "group by TAB_n5magazyn.strNazwa "

            strSQL = rapeng_.query_apply_actual_param(strSQL, pParamArray)
#ifdef APPCONFIG_GM_RAPORT_BY_DATE
            strSQL = Replace(strSQL, "NUMOPBORDER", "TAB_n5stanmag.gmo_nNumOp in (select om2.gmo_nNumOp from view_operacje_magazynowe om2 where om2.dDataOp <= START_DATE ) ")
            strSQL = Replace(strSQL, "START_DATE",trans_.afc.convert.date2SQL(pRaportMomentParam.first_value))			
#else
            strSQL = Replace(strSQL, "NUMOPBORDER", "TAB_n5stanmag.gmo_nNumOp " + doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRaportMomentParam,nDummy))

#endif            
            dim oRS: set oRS = trans_.createadors(strSQL)
            if not oRS.EOF then
              get_value_grupa = ccur(oRS(0).value)
            end if
end function
%>
<%
dim pRaportMomentParam
dim utilProdHierarchy : set utilProdHierarchy = doc_.getmodule(60246)
dim pProdHierarchy : set pProdHierarchy = utilProdHierarchy.new_prod_hierarchy()

dim pParamArray
dim pGrupaParam

dim pGrupaIdObjArray
dim pGrupaNazwaArray
dim pGrupaSumaArray

function default_param()
	set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("TAB_n5magazyn.idobj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")
	set pRaportMomentParam = doc_.afc.rap.param.new_date("Analizowany moment").bindexpr("")
	if trans_.isvar(APPVAR_RAPORT_FROM_OUTSIDE) then
		pRaportMomentParam.first_value = trans_.var(1007)
		pRaportMomentParam.mode = clng(1)
	end if
	pParamArray.add pRaportMomentParam
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("TAB_n5produkt.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("TAB_n5produkt.strIndeks")
	set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy").bindexpr("t_grupy.strNazwa")
	'pParamArray.add doc_.getmodule(43025).new_filtr_grupa_prod("TAB_n5produkt.pGrupaProd")

	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'><t>&nbsp;</t>RXE_LP</td>
	<td>
		<t>&nbsp;</t>RXE_AUTO_TEXT(c_mag)
	</td>
<%
  'magazyn
  dim nIdMag: nIdMag = clng(pRec("c_id_mag").value)
  dim iter
  for iter = 0 to pGrupaIdObjArray.UpperIndex()
    dim curWartosc: curWartosc = ccur(0.0)
    curWartosc = get_value_grupa(nIdMag, pGrupaIdObjArray.value(iter))
    pGrupaSumaArray.value(iter) = pGrupaSumaArray.value(iter) + curWartosc
%>
	<td align='right'>
    <t><% so.write rapeng_.process_number(doc_.afc.display.quantity(curWartosc,"",2)) %></t>
	</td>
<%
  next
%>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wartosc,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>&nbsp;LP</t></td>
	<td width='max'>
		<text>&nbsp;Nazwa&nbsp;magazynu</text>
	</td>
<%
  dim iter
  for iter = 0 to pGrupaNazwaArray.UpperIndex()
%>
	<td width='min'>
		<text><% so.write pGrupaNazwaArray.value(iter) %></text>
	</td>
<%
  next
%>
	<td width='min'>
		<text>&nbsp;Razem</text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='2' />
<%
  dim iter
  for iter = 0 to pGrupaSumaArray.UpperIndex
%>
  <td style='27' align='right'>
		<t><%so.write doc_.afc.display.quantity(pGrupaSumaArray.value(iter),"",2)%></t>
	</td>    
<%
  next
%>  
	<td style='27' align='right'>
		<t><%so.write doc_.afc.display.quantity(pSection.counter(0).result,"",2)%></t>
	</td>
</tr>
</tfoot>
</table>
<%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex(getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_wartosc")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),"DUMMY") then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pProdHierarchy.fill_on_prodgrupa_param pGrupaParam
	set pPerf = nothing


	rapeng_.write_actual_param so,rapeng_.get_raport_param()

  dim strSQL: strSQL = "select tmp_group_idobj from #tmp_prod_hierarchy"
  set pGrupaIdObjArray = doc_.afc.new_navoarray()
  set pGrupaNazwaArray = doc_.afc.new_navoarray()
  set pGrupaSumaArray = doc_.afc.new_navoarray()
  dim oRS: set oRS = trans_.createadors(strSQL)
  do while not oRS.EOF
    pGrupaIdObjArray.add clng(oRS(0).value)
    pGrupaNazwaArray.add trans_.getobj(TYPEID_N5GRUPAPRODUKTOW,clng(oRS(0).value)).strNazwa
    pGrupaSumaArray.add ccur(0.0)
    oRS.movenext 
  loop

	if false and pRaportMomentParam.first_value = trans_.var(GVAR_TODAY) then
		.ReplaceQueryParam "DUMMY",rapeng_.query_apply_actual_param(query_current(), rapeng_.get_raport_param())
	else
		.ReplaceQueryParam "DUMMY",rapeng_.query_apply_actual_param(query_any(), rapeng_.get_raport_param())

		dim nDummy
		'.ReplaceQueryParam "NUMOPBORDER", _
		'	"TAB_n5stanmag.gmo_nNumOp " + doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRaportMomentParam,nDummy)
		
		#ifdef APPCONFIG_GM_RAPORT_BY_DATE
		
		.ReplaceQueryParam "NUMOPBORDER", _
		"TAB_n5stanmag.gmo_nNumOp in (select om2.gmo_nNumOp from view_operacje_magazynowe om2 where om2.dDataOp <= START_DATE ) "
		.ReplaceQueryParam "START_DATE",trans_.afc.convert.date2SQL(pRaportMomentParam.first_value)			
		#else
		.ReplaceQueryParam "NUMOPBORDER", _
			"TAB_n5stanmag.gmo_nNumOp " + doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRaportMomentParam,nDummy)
		
		#endif
	end if

	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

pProdHierarchy.manual_done() : set pProdHierarchy = nothing
set utilProdHierarchy = nothing

%>
</body>
<footer>
</footer>
</page>
