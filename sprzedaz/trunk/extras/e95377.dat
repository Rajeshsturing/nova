<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_RAPORT_DEKRETOW
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Raport dekretów

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'id_dowod'=vl.p_idobj,'nr_dowodu'=vl.p_strnrdok,'data_ksieg'=vl.c_ddataksieg, " + vbNewLine +_
        "'wn'=vl.c_curwn,'ma'=vl.c_curma,'opis'=vl.c_stropis,'symbol'=k.strSymbol " + vbNewLine +_
        "from vlist_n5dowodksieg_listDekret vl " + vbNewLine +_
        "inner join n5konto k on vl.c_pkonto = k.IdObj " + vbNewLine +_
        "left join n5transakcja t on vl.c_ptransakcja = t.IdObj " + vbNewLine +_
        "where %1 and %2 and %3 and %4 and %5"
end function
%>
<%
dim g_custom_param_class:set g_custom_param_class = doc_.getmodule(43030) 

function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	dim custom_param
	set custom_param = g_custom_param_class.new_custom("Symbol").bindexpr("k.strSymbol")
	custom_param.ExtraXML = "<radio name='r13' border='0'>"+_
													"<transfer mode='custom'>"+_
													"</transfer>"+_
													"<table><tbody><tr><td width='3300'><t>Wszystko</t>										</td>																									</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Dokładnie</t>									</td>	<td><edit width='2000' name='e151'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_	
												  "<table><tbody><tr><td width='3300'><t>Początek</t>										</td>	<td><edit width='2000' name='e161'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Zawiera</t>										</td>	<td><edit width='2000' name='e171'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Zakres od</t>									</td>	<td><edit width='2000' name='e182'><transfer mode='custom'/></edit>	</td><td><t> do </t></td><td><edit width='2000' name='e183'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Tylko konta</t>								</td>	<td><edit width='5000' name='e181'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Konta rozpoczynające się	</t>	</td>	<td><edit width='5000' name='e191'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Konta zawierające</t>					</td>	<td><edit width='5000' name='e192'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"</radio> "+_
													"<br/> "+_
													"<t></t><br/> "+_
													"<text bold='true' name='t199'></text><br/> "
	custom_param.Add2CtrlTable 13
		custom_param.Add2CtrlTable 151
			custom_param.Add2CtrlTable 161
				custom_param.Add2CtrlTable 171
					custom_param.Add2CtrlTable 181
					custom_param.Add2CtrlTable 182
					custom_param.Add2CtrlTable 183
						custom_param.Add2CtrlTable 191
						custom_param.Add2CtrlTable 192
custom_param.ExtraINIT =	"page_.ctrl(13).value = clng(1) " + vbCrLf + _
													" page_.ctrl(151).disable = true " + vbCrLf + _
													" page_.ctrl(161).disable = true " + vbCrLf + _
													" page_.ctrl(171).disable = true " + vbCrLf + _
													" page_.ctrl(181).disable = true " + vbCrLf + _
													" page_.ctrl(182).disable = true " + vbCrLf + _
													" page_.ctrl(183).disable = true " + vbCrLf + _
													" page_.ctrl(191).disable = true " + vbCrLf + _
													" page_.ctrl(192).disable = true " 
	pParamArray.add custom_param  
  
  pParamArray.add doc_.afc.rap.param.new_text("Numer dowodu").bindexpr("vl.p_strnrdok")
  pParamArray.add doc_.afc.rap.param.new_currency("Kwota Wn").bindexpr("vl.c_curwn")
  pParamArray.add doc_.afc.rap.param.new_currency("Kwota Ma").bindexpr("vl.c_curma")
  'transakcja
  dim pParamTrans : set pParamTrans = doc_.afc.rap.param.new_choice("Transakcja").bindexpr("t.IdObj")
  with pParamTrans
    .multiple = true
    .names.add "Tak"
    .values.add 1
    .selected.add true
    .names.add "Nie"
    .values.add 2
    .selected.add True
  end with
  pParamArray.add pParamTrans  

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
  dim strDesc: strDesc = pActualParam.value(iter).get_desc()
  if strDesc <> "" and strDesc <> "' (1=1) '" then 
    bAnyWritten = true
	  so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + strDesc + "]"+"]></text><br/>"
  end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='3'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%> 
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>RXE_LP</td>
  <td>
    RXE_T_LINK_FORM_VCC(TYPEID_N5DOWODKSIEG,id_dowod,nr_dowodu)
  </td>
  <td>
    RXE_TEXT(symbol)
  </td>    
	<td>
		RXE_DATE(data_ksieg)
	</td>  
	<td align='right'>
    RXE_QUANTITY_CVV(wn,"",2)
  </td> 
	<td align='right'>
    RXE_QUANTITY_CVV(ma,"",2)
  </td>   
  <td>
    RXE_TEXT(opis)
  </td>  
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>  
	<td width='min'>
		<text><![CDATA[Numer dowodu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Symbol]]></text>
	</td>   
	<td width='min'>
		<text><![CDATA[Data księgowania]]></text>
	</td> 
	<td width='2000'>
		<t><![CDATA[Kwota Wn]]></t>
	</td> 
	<td width='2000'>
		<t><![CDATA[Kwota Ma]]></t>
	</td> 
	<td width='8000'>
		<text><![CDATA[Opis dekretu]]></text>
	</td>    
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='6' bold='true'>Kryteria selekcji:</t><br/>
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	write_actual_param rapeng_.get_raport_param()
  
  .ReplaceQueryParam "(t.IdObj IN ('1','2'))","(1=1)"
  .ReplaceQueryParam "(t.IdObj = '1')","vl.c_ptransakcja > 0"
  .ReplaceQueryParam "(t.IdObj = '2')","vl.c_ptransakcja = 0"
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

%>
</body>
<footer>
</footer>
</page>
