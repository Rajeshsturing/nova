<?xml version="1.0" encoding="windows-1250" ?>
<!-- 19.02.2013 ankieta toral -->

<!--

RAPTEMPLATE_ANKIETA_TORAL

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Ankieta

#define PARAM_NR_POW_GOSPOD    2
#define PARAM_NR_PROFIL_PROD   3
#define PARAM_NR_RODZAJ_OPALU  4

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
	query = "select 'uzytkownik'=u.strNazwa,'data_wyst'=at.ank_dDataWyst,'klient'=k.strNazwa," + vbNewLine +_
          "'miejsc'=m.strNazwa,'id_klient'=k.IdObj,'klient_type'=TYPEID_N5KLIENT," + vbNewLine +_
          "'profil_roslin'=case when at.ank_cProfilRoslinny = 1 then 'roślinny' else '' end," + vbNewLine +_
          "'profil_zwierz'=case when at.ank_cProfilZwierzecy = 1 then 'zwierzęcy' else '' end," + vbNewLine +_
          "'profil_inny'=case when at.ank_cProfilInny = 1 then at.ank_strExtra1 else '' end," + vbNewLine +_
          "'pow_gosp'=case when at.ank_ePowGosp = 1 then '0-50' else" + vbNewLine +_
          "           case when at.ank_ePowGosp = 2 then '50-100' else" + vbNewLine +_
		      "       case when at.ank_ePowGosp = 3 then '100-150' else" + vbNewLine +_
		      "       case when at.ank_ePowGosp = 4 then 'powyżej 150 (' + at.ank_strPowGospOpis + ')' end end end end," + vbNewLine +_
          "'kontakt_sms'=case when at.ank_cKontaktSms = 1 then 'sms' else '' end," + vbNewLine +_
          "'kontakt_tel'=case when at.ank_cKontaktTel = 1 then 'telefon' else '' end," + vbNewLine +_
          "'kontakt_list'=case when at.ank_cKontaktList = 1 then 'list' else '' end," + vbNewLine +_
          "'kontakt_mail'=case when at.ank_cKontaktMail = 1 then 'e-mail' else '' end," + vbNewLine +_
          "'kontakt_inne'=case when at.ank_cKontaktInne = 1 then at.ank_strKontakt else '' end" + vbNewLine +_
          "from n5ankieta_toral at" + vbNewLine +_
          "inner join n5uzytkownik u on at.ank_pUzytRej = u.Idobj" + vbNewLine +_
          "inner join n5klient k on at.ank_pKlient = k.IdObj" + vbNewLine +_
          "inner join n5miejscowosc m on k.pMiejscowosc = m.IdObj" + vbNewLine +_
          "where at.IdObj in (select p_idobj from vlist_n5ankieta_toral_ank_ListPozycje" + vbNewLine +_
          "where %14 and c_pank_pmaszyna in %6" +vbNewLine +_
          "and %1 and %2 and ([POW_GOSP]) and ([PROF_PROD]) and ([RODZAJ_OPALU]) and %7 and %8 and %9" + vbNewLine +_
          "and %10 and %11 and %12 and %13 and %15 and %16"
end function
%>

<%
function default_param()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa użytkownika").bindexpr("u.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")  
	dim pParamPowGosp: set pParamPowGosp = doc_.afc.rap.param.new_choice("Powierzchnia gospodarstwa")
	with pParamPowGosp
		.multiple = true
		.names.add "0-50"
		.values.add 1
		.selected.add True
		.names.add "50-100"
		.values.add 2
		.selected.add True
		.names.add "100-150"
		.values.add 3
		.selected.add True
		.names.add "powyżej 150"
		.values.add 4
		.selected.add True    
	end with
	pParamArray.add pParamPowGosp  
  
	dim pParamProProd: set pParamProProd = doc_.afc.rap.param.new_choice("Profil produkcji")
	with pParamProProd
		.multiple = true
		.names.add "roślinny"
		.values.add 1
		.selected.add True
		.names.add "zwierzęcy"
		.values.add 2
		.selected.add True
		.names.add "inny"
		.values.add 3
		.selected.add True   
	end with
	pParamArray.add pParamProProd 
  
	dim pParamOpal: set pParamOpal = doc_.afc.rap.param.new_choice("Rodzaj opału")
	with pParamOpal
		.multiple = true
		.names.add "węgiel"
		.values.add 1
		.selected.add True
		.names.add "miał"
		.values.add 2
		.selected.add True
		.names.add "inny"
		.values.add 3
		.selected.add True   
	end with
	pParamArray.add pParamOpal   
  
  dim pParamFactory: set pParamFactory = doc_.afc.rap.param
	dim pParamMasz: set pParamMasz = pParamFactory.new_choice("Posiadane maszyny").bindexpr("")
	doc_.afc.rap.param.init_on_query pParamMasz, trans_ ,"select masz_strNazwa,IdObj from n5maszyna_toral order by masz_strNazwa"
	pParamArray.add pParamMasz
  
  pParamArray.add doc_.afc.rap.param.new_text("Ulica").bindexpr("k.strUlica")
  pParamArray.add doc_.afc.rap.param.new_text("Nr domu").bindexpr("k.strNrDomu")
  pParamArray.add doc_.afc.rap.param.new_text("Kod pocztowy").bindexpr("k.strKod")
  pParamArray.add doc_.afc.rap.param.new_text("Poczta").bindexpr("k.strPoczta")
  pParamArray.add doc_.afc.rap.param.new_text("Miejscowość").bindexpr("m.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_text("Telefon").bindexpr("k.strTel1")
  pParamArray.add doc_.afc.rap.param.new_text("E-mail").bindexpr("k.strEmail")
  pParamArray.add doc_.afc.rap.param.new_text("Marka maszyny").bindexpr("c_pank_strmarka")
  pParamArray.add doc_.afc.rap.param.new_text("Usługi serwisowe").bindexpr("at.ank_strPotUslugiSerw")
  pParamArray.add doc_.afc.rap.param.new_text("Usługi").bindexpr("at.ank_strPotUslugi")
  
	set default_param = pParamArray
end function
%>
<%
'--------------------------------------------
'Generuje filtr dla Powierzchnia gospodarstwa
'--------------------------------------------
function getFiltrPowGosp(): getFiltrPowGosp = ""
  dim iter
  for iter = 0 to pParamArray.value(PARAM_NR_POW_GOSPOD).selected.upperIndex
    if pParamArray.value(PARAM_NR_POW_GOSPOD).selected.value(iter) then
      getFiltrPowGosp = getFiltrPowGosp + "at.ank_ePowGosp = " + CStr(iter + 1) + " or "
    end if
  next
  if Len(getFiltrPowGosp) > 4 then
    getFiltrPowGosp = Mid(getFiltrPowGosp,1,Len(getFiltrPowGosp) - 4)
  end if
end function

'-----------------------------------
'Generuje filtr dla Profil produkcji
'-----------------------------------
function getFiltrProfProd(): getFiltrProfProd = ""
  dim iter
  for iter = 0 to pParamArray.value(PARAM_NR_PROFIL_PROD).selected.upperIndex
    if pParamArray.value(PARAM_NR_PROFIL_PROD).selected.value(iter) then
      if iter = 0 then
        getFiltrProfProd = getFiltrProfProd + "at.ank_cProfilRoslinny = 1 or "
      end if
      if iter = 1 then
        getFiltrProfProd = getFiltrProfProd + "at.ank_cProfilZwierzecy = 1 or "
      end if      
      if iter = 2 then
        getFiltrProfProd = getFiltrProfProd + "at.ank_cProfilInny = 1 or "
      end if
    end if
  next
  if Len(getFiltrProfProd) > 4 then
    getFiltrProfProd = Mid(getFiltrProfProd,1,Len(getFiltrProfProd) - 4)
  end if
end function

function getRodzajOpalu(): getRodzajOpalu = ""
  dim iter
  dim bWegiel: bWegiel = false
  dim bMial: bMial = false
  dim bInny: bInny = false
  for iter = 0 to pParamArray.value(PARAM_NR_RODZAJ_OPALU).selected.upperIndex
    if pParamArray.value(PARAM_NR_RODZAJ_OPALU).selected.value(iter) then
      if iter = 0 then
        getRodzajOpalu = getRodzajOpalu + "at.ank_cOpalWegiel = 1 or "
        bWegiel = true
      end if
      if iter = 1 then
        getRodzajOpalu = getRodzajOpalu + "at.ank_cOpalMial = 1 or "
        bMial = true
      end if      
      if iter = 2 then
        getRodzajOpalu = getRodzajOpalu + "at.ank_cOpalInny = 1 or "
        bInny = true
      end if
    end if
  next
  if Len(getRodzajOpalu) > 4 then
    getRodzajOpalu = Mid(getRodzajOpalu,1,Len(getRodzajOpalu) - 4)
  end if
  if bWegiel and bMial and bInny then
    getRodzajOpalu = "1=1"
  end if
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
    RXE_AUTO_TEXT(uzytkownik)
</td>
</tr>

<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
<tr fontsize='4'>
</tr>
<tr border='0'><td colspan='10' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td width='min'>
    RXE_DATE(data_wyst)
	</td>
	<td>
    RXE_AUTOTEXT_LINK_FORM_CCC(klient_type,id_klient,klient)
	</td>
	<td>
    RXE_TEXT(miejsc)
	</td>
	<td>
    <text><![CDATA[<%so.write cstr(pRec("profil_roslin")) + vbNewLine + cstr(pRec("profil_zwierz")) + vbNewLine + cstr(pRec("profil_inny")) %>]]></text>
	</td>
	<td>
    RXE_TEXT(pow_gosp)
	</td>
	<td>
	  <text><![CDATA[<%so.write cstr(pRec("kontakt_sms")) + vbNewLine + cstr(pRec("kontakt_tel")) + vbNewLine + cstr(pRec("kontakt_list")) + vbNewLine + cstr(pRec("kontakt_mail")) + vbNewLine + cstr(pRec("kontakt_inne"))  %>]]></text>
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data]]></text>
	</td>
	<td width='6000'>
		<text><![CDATA[Klient]]></text>
	</td>
	<td width='3000'>
		<text><![CDATA[Miejscowość]]></text>
	</td>
	<td width='2500'>
		<text><![CDATA[Profil produkcji]]></text>
	</td>
	<td width='2500'>
		<text><![CDATA[Powierzchnia gospodarstwa]]></text>
	</td>
	<td width='2500'>
		<text><![CDATA[Preferowana forma kontaktu]]></text>
	</td>  
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>  
<p><t size='2'/></p>
  
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  .add_group_section 0,getref("section_header_1"),getref("section_footer_1")
  
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
  'pobierz filtry
  dim strPowGosp: strPowGosp = getFiltrPowGosp()
  dim strProfProd: strProfProd = getFiltrProfProd()
  dim strRodzajOpalu: strRodzajOpalu = getRodzajOpalu() 
  
  .ReplaceQueryParam "in ( IN", "in"
  .ReplaceQueryParam "in ( = ","="
  .ReplaceQueryParam "[POW_GOSP]", strPowGosp
  .ReplaceQueryParam "[PROF_PROD]", strProfProd
  .ReplaceQueryParam "[RODZAJ_OPALU]", strRodzajOpalu
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
end if
end with
%>
</body>
<footer>
</footer>
</page>
