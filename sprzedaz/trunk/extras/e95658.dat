<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Płatności, których nie udało się zaktualizować

#define ALLOWED_OPER_TYPE Przelew wychodzący zewnętrzny


-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>

<script>
<![CDATA[

<%
function query()
  query = "select * from #unident where text not like '%OPŁATY I PROWIZJE - PRZELEW DO INNEGO BANKU%'"
      
end function
  
%>

<%
function default_param()
  dim pParamArray
	set pParamArray = doc_.afc.new_navoarray()
 
	set default_param = pParamArray
  
end function
%>

<%
function write_actual_param(byref pActualParam)
  dim iter
  dim bAnyWritten : bAnyWritten = false
  if not pActualParam is nothing then
  for iter = 0 to pActualParam.upperIndex
  if pActualParam.value(iter).get_desc() <> "" then 
  bAnyWritten = true
	  so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
  end if
  next
  end if
  if not bAnyWritten then 
	  so.write "<t fontsize='4'>brak</t><br/>"
  end if
	  so.write "<br/>"
end function
%>


<%
function body_row(byref pSection,byref pRec)
  if pRapExec.RecNr mod 2 = 0 then
%>

<tr  bordercolor='white'>

<%
  else
%>

<tr bordercolor='white' style='37'>

<%
  end if
%>

<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td align='right'>
    RXE_TEXT(pos)		
	</td>
  <td>
    RXE_TEXT(text) 
  </td>
  <td>
    RXE_TEXT(err) 
  </td>
</tr>
<%
end function
%>

<%
function body_header(byref pSection,byref pRec)
  
%>

<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td>
    <text>Pozycja</text>
  </td>
  <td width ='max'>
    <text>Treść</text>
  </td>
  <td width ='max'>
    <text>Komunikat</text>
  </td>


  
</tr>
</thead>
<tbody>
  
<%
end function
%>

<%
function body_footer(byref pSection)
%>

</tbody>
<tfoot>
<tr style='21'>
  <td style='27' colspan='5'>
    <text>&nbsp;</text>
  </td>
</tr>
</tfoot>
</table>
  
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
  RAPORT_HEADER(3,0)
</p>
  <p>
  <t size='2'/>
  </p>

  <p>
    <text fontsize='7'><![CDATA[RAPORT_TITLE]]></text>
  </p><br/><br/>
  <p>
    <text fontsize='4'><![CDATA[Analizowany plik: ]]></text>
    <t>&nbsp;</t>
    <text fontsize='4' bold='true'><![CDATA[<% so.write cstr(rapeng_.get_raport_param().value(1)) %> ]]> </text>
  </p>
  <p>
    <text fontsize='4'><![CDATA[Operacji innego typu niż ALLOWED_OPER_TYPE jest]]> </text>
    <t>&nbsp;</t>
    <text fontsize='4' bold='true'><![CDATA[<% so.write cstr(rapeng_.get_raport_param().value(0)) %> ]]> </text>
    <text fontsize='4'><![CDATA[, nie uwzględniono ich w raporcie.]]> </text>
  </p>
  <p>
    <t fontsize='4'><![CDATA[W raporcie nie uzględniono OPŁATY I PROWIZJE - PRZELEW DO INNEGO BANKU]]> </t>
  </p>
  <br/><br/>
  
<%
dim pParamTypPro
  dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  if .prepare("RAPORT_TITLE",default_param(),default_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing


  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
  end if
  end if
  end with
  
  trans_.execsql "drop table #unident"
  
%>


</body>
<footer>
</footer>
</page>
