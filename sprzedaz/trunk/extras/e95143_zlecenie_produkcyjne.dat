<?xml version="1.0" encoding="windows-1250" ?>

#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#include "h1240"

<!-- Zlecenie produkcyjne -->
<!-- 14.09.2004 data wystawienia z bazy -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<%
dim where_magazyn

function daj_ilosc(IdProd)
dim rs
								
      set rs = trans_.createadors("select 'ilosc'=isnull(sum(gms_curilosc),0) from n5gmstan where gms_pProd="+cstr(IdProd)+" and "+where_magazyn)
      daj_ilosc = ccur(rs.fields("ilosc").value)
      
end function

Function parametry()
  dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("gms_pMag","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")
	set parametry = pParamArray
end function

dim tabela(10000,5)
dim iTabelaItems : iTabelaItems = clng(0)

%>






<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>

#define FIRMA_TELEFON_LABEL				<% so.write util_.Firma_Telefon_Label %>
#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_TELEFON_HIDE				<% so.write util_.Firma_Telefon_Hide %>

#define FIRMA_FAX_LABEL					<% so.write util_.Firma_Fax_Label %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_FAX_HIDE					<% so.write util_.Firma_Fax_Hide %>



#define KLIENT_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient) %>
#define KLIENT_TELEFON					<% so.write util_.Klient_Telefon(root_.pKlient) %>
#define KLIENT_TELEFON_HIDE				<% so.write util_.Klient_Telefon_Hide(root_.pKlient) %>

#define KLIENT_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient) %>
#define KLIENT_TELEFON_KOM				<% so.write util_.Klient_Telefon_Kom(root_.pKlient) %>
#define KLIENT_TELEFON_KOM_HIDE			<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient) %>

#define KLIENT_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient) %>
#define KLIENT_FAX						<% so.write util_.Klient_Fax(root_.pKlient) %>
#define KLIENT_FAX_HIDE					<% so.write util_.Klient_Fax_Hide(root_.pKlient) %>

#define KLIENT_JO_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON				<% so.write util_.Klient_Telefon(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_HIDE			<% so.write util_.Klient_Telefon_Hide(root_.pKlient_JO) %>

#define KLIENT_JO_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_KOM			<% so.write util_.Klient_Telefon_Kom(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_KOM_HIDE		<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient_JO) %>

#define KLIENT_JO_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient_JO) %>
#define KLIENT_JO_FAX					<% so.write util_.Klient_Fax(root_.pKlient_JO) %>
#define KLIENT_JO_FAX_HIDE				<% so.write util_.Klient_Fax_Hide(root_.pKlient_JO) %>



 
#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(root_.curSumaMag)%>
#define DOKUMENT_MAGAZYN_ZRODLOWY		<% if not root_.pMagZrod is nothing then so.write root_.pMagZrod.text end if %> 		
#define DOKUMENT_MAGAZYN_DOCELOWY		<% if not root_.pMagDocel is nothing then so.write root_.pMagDocel.text end if %> 		

#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_INDEKS						<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% so.write pozycja.pOpak.strNazwa %>
#define POZ_ILOSC						<% so.write QTY(pozycja.curIloscOpakPoz,pozycja.pOpak.pJednOpak) %>
#define POZ_MIN                         <% so.write pozycja.pOpak.curIloscMin %>

#define SUR_LP							<% so.write cstr(it_sur) %>
#define SUR_NAZWA						<% so.write cstr(pPozRecepta.pProdukt.strNazwa) %>
#define SUR_INDEKS						<% so.write cstr(pPozRecepta.pProdukt.strIndeks) %>
#define SUR_OPAKOWANIE					<% so.write cstr(pPozRecepta.pOpak.strNazwa) %>
#define SUR_ILOSC						<% so.write QTY(il_surowca,pPozRecepta.pOpak.pJednOpak) %>
#define SUR_MAG           <% so.write QTY((daj_ilosc(pPozRecepta.Pprodukt.IdObj) - il_surowca),pPozRecepta.pOpak.pJednOpak)%>


<page style='36' margins='500,500,500,500'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>	
</config>
<header>
</header>
<body>
<!-- ca-oťŠ -->
<%
dim PMod60108
dim Pparametry
set Pmod60108 = doc_.getmodule(60108)
set Pparametry = parametry()

if PMOd60108.show_raport_param_dialog (Pparametry,"Wybór magazynu") <>0 then
where_magazyn = Pparametry.Value(0).get_where_part(trans_)
 
%>

<table>
	<tbody>
		<tr>
			<td>
				<!-- nag-ˇwek -->
				<table >
					<tbody>
						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[Zlecenie produkcyjne nr DOKUMENT_NUMER]]> </t>
							</td>
						</tr>
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[Data: DOKUMENT_DATA_WYSTAWIENIA]]> </t>
							</td>
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						

<%if not root_.pKlient is nothing then%>
						<!-- Dane nabywcy - Klient - jednostka organizacyjna-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Klient:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<% if not root_.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><% if root_.pKlient.strKod<>"" then so.write root_.pKlient.strKod + " ," end if %></t>
								<t><% if root_.pKlient.pMiejscowosc.strNazwa<>"" then so.write " ..." + root_.pKlient.pMiejscowosc.strNazwa end if %></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr hide='KLIENT_JO_TELEFON_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_TELEFON_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_TELEFON]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_JO_TELEFON_KOM_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_TELEFON_KOM_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_TELEFON_KOM]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_JO_FAX_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_FAX_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_FAX]]></text>
							</td>
							<td>
							</td>							
						</tr>
						
						<% else %>
						<% if not root_.pKlient is nothing then %>
						
						<!-- Dane nabywcy - KLIENT -->
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><% if root_.pKlient.strKod<>"" then so.write root_.pKlient.strKod + " " end if %></t>	
								<t><% if root_.pKlient.pMiejscowosc.strNazwa<>"" then so.write root_.pKlient.pMiejscowosc.strNazwa end if %></t>
		
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
	
						<tr hide='KLIENT_TELEFON_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_TELEFON_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_TELEFON]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_TELEFON_KOM_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_TELEFON_KOM_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_TELEFON_KOM]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_FAX_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_FAX_LABEL]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_FAX]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% end if %>
						<% end if %>
						<% end if %>




					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		<%	
				
							dim iter,pozycja
							iter = 1
							
							dim pM : set pM = doc_.getmodule(60234)
				
							dim curIloscWyrobuDoZrobienia
							dim dblKrotnoscRecepty : dblKrotnoscRecepty = cdbl(1.0)
							dim zamiana
						
							for each pozycja in root_.listPozycje 
							pM.convert_il_wyrobu_na_krotnosc _
								pozycja.pProdukt.idobj, pozycja.pOpak.idobj, _
								pozycja.curIloscOpakPoz,pozycja.pRecepta,dblKrotnoscRecepty
						
						%>	
		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td  colspan='5' bold='true' align='center'><t>Wyrób</t>
							</td>
						</tr>
						<tr backcolor='#E0E0E0'>
							<td width='min'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa wyrobu</text>
							</td>
							<td>
								<text>Indeks</text>
							</td>
							#ifdef _HJORT
							<td>
								<text>Limit produktu</text>
							</td>
							#endif							
							<td>
								<text>Opakowanie / odmiana</text>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td width='min'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text>
							</td>
							<td>
								<text><![CDATA[POZ_INDEKS]]></text>
							</td>
							 #ifdef _HJORT
							<td align='right'>
								<text ><![CDATA[POZ_MIN]]></text>
							</td>
							 #endif
							<td>
								<text><![CDATA[POZ_OPAKOWANIE]]></text>								
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
						</tr>
						<tr backcolor='#E0E0E0'>
							<td  colspan='5' bold='true' align='center'><t>Surowce</t>
							</td>
						</tr>
						<tr backcolor='#E0E0E0'>
							<td width='min' bold='true'>
								<t>LP</t>
							</td>
							<td bold='true'>
								<text>Nazwa surowca</text>
							</td>
							<td bold='true'>
								<text>Indeks</text>
							</td>							
							<td bold='true'>
								<text>Opakowanie / odmiana</text>
							</td>
							<td align='right' bold='true'>
								<text>Ilość produkcja</text>
							</td>
							<td align='right' bold='true'>
								<text>Ilość na magazynie</text>
							</td>
							<td align='right' bold='true'>
								<text>Ilość Magazyn-Produkcja</text>
							</td>
						</tr>
						<%	
							dim it_sur 
							dim pPozRecepta 
							dim il_surowca
							dim curIloscMag
						
							it_sur = 1

							for each pPozRecepta in pozycja.pRecepta.listSurowce
								il_surowca = dblKrotnoscRecepty * pPozRecepta.curIloscOpak 
								curIloscMag = daj_ilosc(pPozRecepta.pProdukt.IdObj)
								
								dim iterTabela
								dim iFoundIndex : iFoundIndex = -1
								for iterTabela = 0 to iTabelaItems
									if tabela(iterTabela,4) = pPozRecepta.pProdukt.idobj then
										iFoundIndex = iterTabela
										exit for
									end if
								next
								if iFoundIndex = -1 then
									iFoundIndex = iTabelaItems
									iTabelaItems = iTabelaItems + 1
									tabela(iFoundIndex,1) = ccur(0.0)
								end if
								tabela(iFoundIndex,0) = pPozRecepta.pProdukt.strNazwa
								tabela(iFoundIndex,1) = tabela(iFoundIndex,1) + il_surowca
								tabela(iFoundIndex,2) = curIloscMag
								set tabela(iFoundIndex,3) = pPozRecepta.pOpak.pJednOpak
								tabela(iFoundIndex,4) = pPozRecepta.pProdukt.idobj
						%>
					
						<tr>
							<td width='min'>
								<t><![CDATA[SUR_LP]]></t>
							</td>
							<td>
								<t><![CDATA[SUR_NAZWA]]></t>
							</td>
							<td>
								<t><![CDATA[SUR_INDEKS]]></t>
							</td>
							<td>
								<t><![CDATA[SUR_OPAKOWANIE]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[SUR_ILOSC]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write QTY(curIloscMag,pPozRecepta.pOpak.pJednOpak) %>]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[SUR_MAG]]></t>
							</td>
						</tr>
						<%	it_sur = it_sur + 1 
							next
						%>
					</tbody>				
				</table>
			</td>
		</tr>	
		
		ROW_SEPARATOR(1)

		<%		
							iter = iter + 1
							next
		%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center' colspan='5' bold='true'>
								<t>Podsumowanie surowców</t>
							</td>
			         	</tr>
				     	<tr backcolor='#E0E0E0'>
							<td>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa surowca</text>
							</td>
							<td>
								<text>Ilość do produkcji</text>
							</td>							
							<td>
								<text>Ilość na magazynie</text>
							</td>
							<td align='right'>
								<text>Ilość Magazyn-Produkcja</text>
							</td>
						</tr>
					</thead>
					<tbody>
            
        <% dim i : i=0
      for i=0 to iTabelaItems - 1      
      %>
	         	<tr bold='false'>
					<td width='min'>
						<t><![CDATA[<% so.write cstr(i+1) %>]]></t>
					</td>
					<td align='left'>	
						<text><![CDATA[	<% so.write cstr(tabela(i,0)) %>]]></text>
					</td>							
					<td align='right'>	
						<t><![CDATA[	<% so.write QTY(tabela(i,1),tabela(i,3)) %>]]></t>
					</td>							
					<td align='right'>	
						<t><![CDATA[	<% so.write QTY(tabela(i,2),tabela(i,3)) %>]]></t>
					</td>							
						<td align='right'>	
						<t><![CDATA[	<% so.write QTY(tabela(i,2) - tabela(i,1),tabela(i,3)) %>]]></t>
					</td>					
				</tr>
						<% 
            next %>
				</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<table>
					<tbody>				
