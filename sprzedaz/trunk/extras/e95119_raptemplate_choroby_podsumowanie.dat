<?xml version="1.0" encoding="windows-1250" ?>
<!--

#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Choroby - podsumowanie
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

'"select 'c_0'=t_1.strNazwisko,'c_1'=t_1.strImie,'c_2'=t_1.strPESEL,'c_3'=t_0.dDataRej,'c_4'=t_1.strNazwisko,'c_5'=t_1.strImie,'c_6'=t_1.strPESEL,'c_7'=t_0.dDataOd,'c_8'=t_0.dDataDo from n5plchoroba as t_0 inner join n5pracownik as t_1 on t_0.pPracownik = t_1.IdObj where  %1  and  %2  order by c_0,c_1,c_2,c_3"
function query()
query = "select " + _
"	'c_0'= t_1.strNazwisko , " + vbNewLine + _
"	'c_1'= t_1.strImie , " + vbNewLine + _
"	'c_2'= t_1.strPESEL , " + vbNewLine + _
"	'c_3'= max(t_0.dDataRej), " + vbNewLine + _
"	'c_4'=t_1.strNazwisko, " + vbNewLine + _
"	'c_5'=t_1.strImie, " + vbNewLine + _
"	'c_6'=t_1.strPESEL, " + vbNewLine + _
"	'c_9'= sum ( 1 + convert( int ,  (t_0.dDataDo - t_0.dDataOd)) ) " + vbNewLine + _
"	from n5plchoroba as t_0 inner join n5pracownik as t_1 on t_0.pPracownik = t_1.IdObj  " + vbNewLine + _
"	where (%1) and (%2)  " + vbNewLine + _
"	group by t_1.strNazwisko,t_1.strImie , t_1.strPESEL " + vbNewLine + _
"	order by c_0,c_1,c_2,c_3 " + vbNewLine
end function

%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("t_1.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data rejestracji").bindexpr("t_0.dDataRej")

	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTO_TEXT(c_4)
	</td>
	<td>
		RXE_AUTO_TEXT(c_5)
	</td>
	<td>
		RXE_AUTO_TEXT(c_6)
	</td>

	<td align='right'>
		RXE_AUTO_TEXT(c_9)
	</td>	

</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Nazwisko]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Imie]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Numer PESEL]]></text>
	</td>
	<td width='min' align='right'>
		<text><![CDATA[Liczba dni]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
