<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_OBROTY_WG_KLINTOW

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Obroty według klientów

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
#ifdef _ALMA_TREND
dim g_pCustParamDateRange : set g_pCustParamDateRange = doc_.getmodule(43035) 
#endif

function query()
	query = "select 'k_indeks'=max(k.strIndeks),'k_nazwa'=max(k.strNazwa),'jo_nazwa'=isnull(max(jo.strNazwa),'[CENTRALA]'), " + vbNewLine +_
			"'k_rodzaj_prod'=max(k.kli_strRodzajProd),'k_wielkosc'=max(k.strCecha3),'k_type'=10108,'k_idobj'=k.IdObj, " + vbNewLine +_
			"'plat_sposob'=isnull(max(plat.strNazwa),''),'k_limit_kred'=max(k.curLimitKred),'k_nip'=max(k.strNIP), " + vbNewLine +_
			"'wlim_waluta'=max(wlim.strSkrot),'jo_idobj'=isnull(jo.idobj,0), " + vbNewLine +_
			"'jo_ulica'=isnull(max(jo.strUlica),max(k.strUlica)),'jo_nr_domu'=isnull(max(jo.strNrDomu),max(k.strNrDomu)), " + vbNewLine +_
			"'jo_nr_lokalu'=isnull(max(jo.strNrLokalu),max(k.strNrLokalu)),'jo_kod'=isnull(max(jo.strKod),max(k.strKod)), " + vbNewLine +_
			"'jo_poczta'=isnull(max(jo.strPoczta),max(k.strPoczta)),'jo_miejscowosc'=isnull(max(mj.strNazwa),max(mk.strNazwa)), " + vbNewLine +_ 
			"'os_obsug_nazw'=isnull(max(prac.strNazwisko),''),'os_obsug_imie'=isnull(max(prac.strImie),''), " + vbNewLine +_
			"'gk_nazwa'=max(gk.strNazwa), " + vbNewLine +_
			"'wartosc_sprz'=sum(trs_curWartSP),'wartosc_zak'=-sum(trs_curWartMag),'zysk'=sum(trs_curWartSP) + sum(trs_curWartMag) " + vbNewLine +_
			"from #tmp_rentowsp " + vbNewLine +_ 
			"inner join n5sprzedaz as sprz on trs_pSprz = sprz.idobj " + vbNewLine +_
			"inner join n5klient as k on sprz.pKlient = k.IdObj " + vbNewLine +_
			"inner join n5miejscowosc mk on k.pMiejscowosc = mk.idobj " + vbNewLine +_
			"left outer join n5sposplat plat on k.pSposobPlatnosci = plat.idobj " + vbNewLine +_
			"inner join n5jednostka wlim on k.pWalutaLimitu = wlim.idobj " + vbNewLine +_
			"left join n5pracownik as prac on  k.pPracownik = prac.Idobj " + vbNewLine +_
			"inner join n5grupaklient as gk on k.pGrupaKlient = gk.IdObj " + vbNewLine +_
			"left outer join n5_klient_jedn_org jo on sprz.pKlient_JO = jo.idobj " + vbNewLine +_
			"left outer join n5miejscowosc mj on jo.pMiejscowosc = mj.idobj " + vbNewLine +_
			"inner join n5rejestrdok as t_3 on sprz.pRejestrDok = t_3.IdObj " + vbNewLine +_
			"where sprz.pRozlVAT <> 0 and %2 and %3 and %4 and %5 and %6 and %7 and %8 and %9 and %10 and %11 " + vbNewLine +_
			"group by k.idobj,jo.idobj " + vbNewLine +_
			"order by k_indeks,k_nazwa,wartosc_sprz desc,zysk desc"
end function
%>

<%
dim curSumaNaleznAll: curSumaNaleznAll = ccur(0)
dim curSumaNaleznPrzet: curSumaNaleznPrzet = ccur(0)

function body_row(byref pSection,byref pRec)
	'miejsce dostawy => adres jednostki organizacyjnej lub adres klienta gdy brak jednostki
	dim strAdres, strNrLokalu, strAdresPoczta
	strNrLokalu = ""
	if trim(pRec("jo_nr_lokalu").value) <> "" then
		strNrLokalu = "/" + pRec("jo_nr_lokalu").value 
	end if 
	strAdresPoczta = ""
	if pRec("jo_poczta").value = pRec("jo_miejscowosc").value then
		strAdresPoczta = pRec("jo_kod").value + " " + pRec("jo_poczta").value
	else
		strAdresPoczta = pRec("jo_miejscowosc").value + ", " + pRec("jo_kod").value + " " + pRec("jo_poczta").value	
	end if
	strAdres = pRec("jo_ulica").value + " " + pRec("jo_nr_domu").value + strNrLokalu + ", " + strAdresPoczta

  'średni termin płatności
  dim strSQL, oRS, curSrTermin
  strSQL = "select isnull(avg(datediff(day,s.dDataWyst,vl.p_ddataoper)),0) " + vbNewLine +_
           "from n5sprzedaz s " + vbNewLine +_
           "	inner join n5transakcja t on s.pTransakcja = t.idobj " + vbNewLine +_
           "	inner join vlist_n5platnosc_listpozycje vl on vl.c_ptransakcja = t.idobj " + vbNewLine +_
           "	inner join n5klient k on s.pKlient = k.idobj " + vbNewLine +_
           "where %1 and k.idobj = " + cstr(pRec("k_idobj").value) + " and t.eStatus = N5TRANSAKCJA_ZAMKNIETA"
  strSQL = rapeng_.query_apply_actual_param(strSQL, pParamArray)
  strSQL = Replace(strSQL,"psp.p_ddatawyst","s.dDataWyst")
  set oRS = trans_.createadors(strSQL)
  if oRS.RecordCount > clng(0) then
    curSrTermin = ccur(oRS(0).value)
  end if
  
  'należności wszystkie i przeterminowane
  dim pKlient: set pKLient = trans_.getobj(TYPEID_N5KLIENT,clng(pRec("k_idobj").value))
  dim pMod: set pMod = doc_.getmodule(60161)
  dim strWhereOkres: strWhereOkres = "%1"
  strWhereOkres = rapeng_.query_apply_actual_param(strWhereOkres, pParamArray)
  strWhereOkres = Replace(strWhereOkres,"psp.p_ddatawyst","s.dDataWyst") + " and "
  dim curNaleznAll: curNaleznAll = pMod.get_nal_zob_ext_okres(pKlient,false,N5TRANSAKCJA_NALEZNOSC,clng(pRec("jo_idobj").value),strWhereOkres)
  dim curNaleznPrzet: curNaleznPrzet = pMod.get_nal_zob_ext_okres(pKlient,true,N5TRANSAKCJA_NALEZNOSC,clng(pRec("jo_idobj").value),strWhereOkres)
  
  curSumaNaleznAll = curSumaNaleznAll + curNaleznAll
  curSumaNaleznPrzet = curSumaNaleznPrzet + curNaleznPrzet
           
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_indeks)
  </td>
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_nazwa)
  </td>  
  <td>
    RXE_TEXT(jo_nazwa)
  </td>
  <td>
		<text>
			<![CDATA[<% so.write strAdres %>]]>
		</text>    
  </td>
	<td>
		RXE_TEXT(k_nip)
	</td>
	<td>
		RXE_TEXT(k_rodzaj_prod)
	</td>
	<td align='center'>
		RXE_TEXT(k_wielkosc)
	</td>
	<td>
		<text><![CDATA[<%so.write cstr(pRec("os_obsug_imie") + " " + pRec("os_obsug_nazw"))%>]]></text>
	</td>		
	<td>
		RXE_TEXT(gk_nazwa)
	</td>
	<td align='right'>
    <%
      'udział w sprzedaży
      dim curUdzialSprz: curUdzialSprz = ccur(0.0)
      if curWartSprz > ccur(0.0) then
        curUdzialSprz =  ccur(pRec("wartosc_sprz").value)/curWartSprz * 100
      end if
    %>
      RXE_QUANTITY_VVV(curUdzialSprz,"%",4)
	</td>
	<td>
    RXE_TEXT(plat_sposob)
  </td>
	<td align='right'>
    RXE_QUANTITY_CVV(k_limit_kred,"",2)
	</td>
	<td align='right'>
    RXE_QUANTITY_VVV(curSrTermin,"dni",0)
  </td>
	<td align='right'>
    RXE_QUANTITY_VVV(curNaleznAll,"",2)
	</td>
	<td align='right'>
    RXE_QUANTITY_VVV(curNaleznPrzet,"",2)	
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_sprz,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(zysk,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Indeks klienta]]></text>
	</td>
	<td width='3000'>
		<text><![CDATA[Nazwa klienta]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Jednostka org.]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Adres dostawy]]></text>
	</td>  
	<td width='min'>
		<t><![CDATA[NIP]]></t>
	</td>
	<td width='min'>
		<text><![CDATA[Rodzaj produkcji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wielkość firmy]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Osoba obsługująca]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Grupa klientów]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Udział w sprzedaży]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Termin płatności]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Limit kredytowy]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Średni termin płatności]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Zadłużenie]]></text>
	</td>		
	<td width='min'>
		<text><![CDATA[Zadłużenie przetermin.]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość obrotu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość dodana]]></text>
	</td>				
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='14' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaNaleznAll)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaNaleznPrzet)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
  dim strIdRokKsieg: strIdRokKsieg = ""
#ifdef _ALMA_TREND
	strIdRokKsieg = doc_.getmodule(60106).GetIdRokKsieg()
#endif 
  
	dim pM60233 : set pM60233 = doc_.getmodule(60233)
	dim pRentSP : set prentsp = pM60233.new_rent_sp()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	
	dim pParamOkres : set pParamOkres = pRentSP.get_okres_param()
#ifdef _ALMA_TREND
	pParamArray.add g_pCustParamDateRange.new_custom("Analizowany okres").bindexpr("psp.p_ddatawyst")
#else	  
	pParamArray.add pParamOkres
#endif  
	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " + strIdRokKsieg + " " +_	
		"order by strNazwa "
	pParamArray.add pParam2

	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("k.strIndeks")
  pParamArray.add doc_.afc.rap.param.new_text("Rodzaj produkcji").bindexpr("k.kli_strRodzajProd")
  pParamArray.add doc_.afc.rap.param.new_text("Wielkość firmy").bindexpr("k.strCecha3")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("gk.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa jedn. org. klienta").bindexpr("isnull(jo.strNazwa,'[CENTRALA]')")
  pParamArray.add doc_.afc.rap.param.new_text("Miejscowość dostawy").bindexpr("isnull(mj.strNazwa,mk.strNazwa)")
  pParamArray.add doc_.afc.rap.param.new_text("Ulica dostawy").bindexpr("isnull(jo.strUlica,k.strUlica)")
	
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
  'wylicza całkowita wartość sprzedaży
  dim curWartSprz: curWartSprz = ccur(0.0)
  dim strSQL: strSQL = "select isnull(sum(s.curSumaNetto - isnull(ks.curSumaNetto,0)),0) from n5sprzedaz s " + vbNewLine +_
                       "left outer join n5sprzedaz ks on s.pPopSprzed = ks.IdObj"
  dim oRS: set oRS = trans_.createadors(strSQL)
  if oRS.RecordCount > clng(0) then
    curWartSprz = ccur(oRS(0).value)
  end if
  
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("wartosc_sprz").add_sumator("zysk")

if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRentSP.fill_dok_handl_ex_uslugi rapeng_.get_raport_param().value(0).get_where_part(trans_),"","1"
		pRentSP.fill_dok_mag_related
#ifdef _ALMA_TREND  
		pRentSP.fill_dok_mag_ZZ
		pRentSP.fill_dok_mag_not_related
#endif     
	  set pPerf = nothing

	.ReplaceQueryParam "prac.strNazwisko is not null", "1=1"

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
