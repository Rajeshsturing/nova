<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Sprzedane kartony
#define ZAM_OBCE 32
#define CTRLID_NOWE_ZAMOW 1
#define FILTR_MAGAZYN 4
#define WYROBY_POZ_DO_REAL #wyroby_poz_do_real
#define NAGLOWEK <text><% so.write "&nbsp; &nbsp;" + replace(cstr(pRec("c_strNazwaKlient")), "&", "&amp;") %></text>


-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>

<script>
<![CDATA[

<%
function query()
  query = " select " + vbnewline +_
          " 'idSprzed'=v_s.p_idobj, " + vbnewline +_ 
          " v_s.p_strNrDok, " + vbnewline +_ 
          " max(v_s.p_ddatawyst), " + vbnewline +_ 
          " 'kartony'= sum(v_s.c_curIloscOpak/isnull(v_p.c_curIlosc,1.0)) " + vbnewline +_ 
          " from vlist_n5sprzedaz_listpozycje v_s " + vbnewline +_ 
          " left outer join vlist_n5produkt_listopakowania v_p on v_p.p_idobj=v_s.c_pProdukt and v_p.c_erodzaj=2 " + vbnewline +_ 
          " join n5klient on v_s.p_pKlient = n5klient.idobj" + vbnewline +_ 
          " where %1 and %2 and %3" + vbnewline +_ 
          " group by v_s.p_idobj, v_s.p_strNrDok"
      
end function
  
%>

<%
function default_param()
  dim pParamArray
	set pParamArray = doc_.afc.new_navoarray()

  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("v_s.p_ddatawyst")
	pParamArray.add doc_.afc.rap.param.new_text("Kontrahent").bindexpr("n5klient.strNazwa")
  dim pParam1: Set pParam1= doc_.afc.rap.param.new_choice("Nazwa rejestru").bindexpr("v_s.p_prejestrdok")
	doc_.afc.rap.param.init_on_query pParam1, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_WDT) order by strNazwa "
	pParamArray.add pParam1
 
	set default_param = pParamArray
  
end function
%>

<%
function write_actual_param(byref pActualParam)
  dim iter
  dim bAnyWritten : bAnyWritten = false
  if not pActualParam is nothing then
  for iter = 0 to pActualParam.upperIndex
  if pActualParam.value(iter).get_desc() <> "" then 
  bAnyWritten = true
	  so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
  end if
  next
  end if
  if not bAnyWritten then 
	  so.write "<t fontsize='4'>brak</t><br/>"
  end if
	  so.write "<br/>"
end function
%>


<%
function body_row(byref pSection,byref pRec)
  if pRapExec.RecNr mod 2 = 0 then
%>

<tr  bordercolor='white'>

<%
  else
%>

<tr bordercolor='white' style='37'>

<%
  end if
%>

<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,idSprzed,p_strNrDok)
	</td>
  <td align='right'>
    RXE_QUANTITY_CVV(kartony,"", 2)
  </td>
</tr>
<%
end function
%>

<%
function body_header(byref pSection,byref pRec)
  
%>

<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td>
    <text>Numer dokumentu</text>
  </td>
  <td>
    <text>Liczba kartonów</text>
  </td>

  
</tr>
</thead>
<tbody>
  
<%
end function
%>

<%
function body_footer(byref pSection)
%>

</tbody>
<tfoot>
<tr style='21'>
  <td style='27' colspan='3'>
    <text>&nbsp;</text>
  </td>
  <td style='27' width='min'  align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
</tr>
</tfoot>
</table>
  
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
  RAPORT_HEADER(3,0)
</p>
  <p>
  <t size='2'/>
  </p>

  <p>
    <text fontsize='7'><![CDATA[RAPORT_TITLE]]></text>
  </p><br/><br/>
  
<%
dim pParamTypPro
%>
   
  <t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
  
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("kartony")
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

  dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())

  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
  end if
  end if
  end with
  
%>


</body>
<footer>
</footer>
</page>
