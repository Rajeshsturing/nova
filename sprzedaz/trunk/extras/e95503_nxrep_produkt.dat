<?xml version="1.0" encoding="windows-1250"?>
<!--
TYPEID_N5PRODUKT
TYPEID_N5OPAKOWANIE_PRODUKTU

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1231.h"

#macro DISPLAY_CENA(_typeid_,_field_)		\
                                        \
function display_##_typeid_##_##_field_##(byref oASP,byref oEVal,byval strCEA,byref pOpak)		\
	set display_##_typeid_##_##_field_ = display_price_always_cur(oASP,strCEA,pOpak._field_,pOpak.pWaluta)	\
end function  \

#define NXREP_PROD_IDENT	strIndeks
#define NXREP_PROD_IDENT2	strNazwa

-->
<nxapprep>
	<objects>
		<object typeid="TYPEID_N5PRODUKT">
			<fields>
				<embedded>
					<name>strNazwa</name>
					<display usage="suggestion_text">
						<![CDATA[
function nx_fill_suggestion(byref pProdukt)
	nx_fill_suggestion = pProdukt.strNazwa + " (" + pProdukt.strIndeks + ")"
end function					
]]>
					</display>
				</embedded>
				<embedded>
					<name>strIndeks</name>
					<display usage="suggestion_text">
						<![CDATA[
function nx_fill_suggestion(byref pProdukt)
	nx_fill_suggestion = pProdukt.strIndeks + " (" + pProdukt.strNazwa + ")"
end function					
]]>
					</display>
				</embedded>
				<ref>
					<name>pJednostkaEwid</name>
					<fixed_condition>
						<![CDATA[{0}.eTyp=N5JEDNOSTKA_MIARY]]>
					</fixed_condition>
				</ref>
			</fields>
			<raports>
				<raport title="@browser_##TYPEID_N5PRODUKT##@">
					<columns>
						<column>
							<header>Indeks produktu</header>
							<path>
								<embedded>NXREP_PROD_IDENT</embedded>
							</path>
						</column>


						<column>
							<header>Oznaczenie producenta</header>
							<path>
								<embedded>strCecha1</embedded>
							</path>
						</column>



						<column>
							<header>Nazwa produktu</header>
							<path>
								<embedded>NXREP_PROD_IDENT2</embedded>
							</path>
						</column>




						<column>
							<path>
								<list>listOpakowania</list>
								<embedded>curCenaNetto1</embedded>
							</path>
						</column>
						<column>
							<path>
								<list>listOpakowania</list>
								<embedded>curCenaBrutto1</embedded>
							</path>
						</column>
						<column>
							<path>
								<list>listOpakowania</list>
								<embedded>curCenaNetto2</embedded>
							</path>
						</column>
						<column>
							<path>
								<list>listOpakowania</list>
								<embedded>curCenaBrutto2</embedded>
							</path>
						</column>
						<column>
							<path>
								<list>listOpakowania</list>
								<embedded>curCenaBrutto3</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order>
							<path>
								<embedded>strIndeks</embedded>
							</path>
						</order>
					</orders>
				</raport>
				<raport title="@fuzzy_##TYPEID_N5PRODUKT##@">
					<filters>
						<filter>
							<path>
								<embedded>strIndeks</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strNazwa</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<list>listOpakowania</list>
								<embedded>strEAN</embedded>
							</path>
						</filter>
					</filters>
				</raport>
			</raports>
			<default_search_field>NXREP_PROD_IDENT</default_search_field>
		</object>
		<object typeid="TYPEID_N5OPAKOWANIE_PRODUKTU">
			<fields>
				<embedded >
					<name>curCenaNetto1</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto1)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaNetto2</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto2)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaNetto3</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto3)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaNetto4</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto4)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaNetto5</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto5)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaNetto6</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaNetto6)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto1</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto1)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto2</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto2)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto3</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto3)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto4</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto4)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto5</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto5)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<embedded >
					<name>curCenaBrutto6</name>
					<display usage="browser">
						<![CDATA[
						DISPLAY_CENA(TYPEID_N5OPAKOWANIE_PRODUKTU,curCenaBrutto6)
            ]]>
						<using>display_price_smart_cur</using>
					</display>
				</embedded>
				<ref>
					<name>pWaluta</name>
					<fixed_condition>
						<![CDATA[{0}.eTyp=N5JEDNOSTKA_WALUTA]]>
					</fixed_condition>
				</ref>
			</fields>
		</object>
	</objects>
</nxapprep>