<?xml version="1.0" encoding="windows-1250" ?>

<!-- Korekta wartosciowa zakupu -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto %>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(root_.curSumaMag)%>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi%>
#define DOKUMENT_POWIAZANY_NR			<% if not root_.wrefDokHandl is nothing then so.write root_.wrefDokHandl.strNrDok end if  %>
#define DOKUMENT_MAGAZYN				<%so.write root_.pMagDocel.strNazwa%>

#define DOSTAWCA_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define DOSTAWCA_NIP					<% so.write util_.Klient_NIP(root_.pKlient) %>
#define DOSTAWCA_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta end if end if%>
#define DOSTAWCA_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define DOSTAWCA_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>


#define JEDNOSTKA_ORG_NAZWA				<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define JEDNOSTKA_ORG_KOD_MIASTO		<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta end if end if%>
#define JEDNOSTKA_ORG_ULICA_NUMER		<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define DOSTAWCA_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>





#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_CENA_DOSTAWY				<% so.write MONEY(pozycja.curCenaMag) %>
#define POZ_WARTOSC						<% so.write MONEY(pozycja.curWartMag) %>
#define POZ_MAGAZYN						<% if not pozycja.pMagZrod is nothing then so.write pozycja.pMagZrod.text end if %>
#define POZ_CENA_DOSTAWY_POP			<% so.write MONEY(pozycja.pDokMag.curCenaMag) %>
#define POZ_WARTOSC_POP					<% so.write MONEY(pozycja.curWartMag) %>

#define POZ_IDX							<% so.write cstr(rs.fields("p_strIndeks").value) %>

#define POZ_TOWAR_ID					<% 'so.write util_.Produkt_Nazwa(rs.fields("pProdZrod").value) %>
#define POZ_TOWAR_RS					<% so.write cstr(rs.fields("p_strNazwa").value) %>
#define POZ_OPAKOWANIE_RS				<% if cstr(rs.fields("c_strNazwa").value) <> "Podstawowe" then so.write " (" +  cstr(rs.fields("c_strNazwa").value) + ")" end if %>
#define POZ_ILOSC_RS					<% so.write doc_.afc.display.quantity(ccur(rs.fields("ilosc").value),"",clng(rs.fields("nDokladnosc").value) - 1 ) %>
#define POZ_JM_RS						<% so.write rs.fields("strSkrot").value %>
#define POZ_CENA_DOSTAWY_RS				<% so.write MONEY(curWart/curIlosc) %>
#define POZ_WARTOSC_RS					<% so.write MONEY(curWart) %>
#define POZ_CENA_DOSTAWY_POP_RS			<% so.write MONEY( curWartPop/curIlosc ) %>
#define POZ_WARTOSC_POP_RS				<% so.write MONEY(curWartPop)%>

#define POZ_MAGAZYN_RS					<% if not isNull(rs.fields("magazyn_nazwa").value) then so.write cstr(rs.fields("magazyn_nazwa").value) end if %>

#define DOKUMENT_WARTOSC_RS				<% 'so.write MONEY(curSuma)%>





<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Korekta wartościowa zakupu nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>
						
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[Do: DOSTAWCA_NAZWA]]> </t>
							</td>
						</tr>
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[Data: DOKUMENT_DATA_WYSTAWIENIA]]> </t>
							</td>
						</tr>
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[Magazyn przyjęcia: DOKUMENT_MAGAZYN]]> </t>
							</td>
						</tr>

					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)














		ROW_SEPARATOR(1)







		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa towaru / usługi</text>
							</td>							
							<td align='right'>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>						
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena dostawy przed korektą</text>
							</td>
							<td align='right'>
								<text>Wartość przed korektą</text>
							</td>
							<td align='right'>
								<text>Cena dostawy po korekcie</text>
							</td>
							<td align='right'>
								<text>Wartość po korekcie</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%	
							dim iter
							if doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then

								dim curSuma:curSuma = ccur(0)
								dim curWartPop : curWartPop= ccur(0)
								dim curWart : curWart = ccur(0)
								dim curCenaPop : curCenaPop = ccur(0)
								dim curCena : curCena = ccur(0)
								dim curIlosc : curIlosc = ccur(0)


								dim rs
								set rs = trans_.createadors("select 'wart_dod'=max(gmo_curWartosc), 'wart_min'=min(gmo_curWartosc), 'ilosc'=max(gmo_curIlosc) , " + _
								" 'p_strIndeks'=max(p_strIndeks), 'p_strNazwa'=max(p_strNazwa), 'c_strNazwa'=max(c_strNazwa), "+ _
								" 'strSkrot'=max(strSkrot), 'nDokladnosc'=max(nDokladnosc)  from n5gmop " + _
								" join vlist_n5produkt_listOpakowania on gmo_pProd = p_idobj and gmo_pOpak = c_idobj   " + _ 
								" join n5jednostka on vlist_n5produkt_listOpakowania.c_pJednOpak = n5jednostka.idobj   " + _ 
								" left join n5magazyn on n5magazyn.idobj = gmo_pMag  " + _ 
								" where gmo_nNumOp = " + cstr(root_.nNumOper) + _ 
								" and gmo_pMag =  " + cstr(root_.pMagZrod.idobj) + _
								" group by gmo_nNumOp, gmo_nLP "+_
								" order by gmo_nLP")
								
								iter = 1
								while not rs.eof

									curSuma = curSuma - ccur(rs.fields("wart_dod").value)
									curIlosc = abs(ccur(rs.fields("ilosc").value))
									curWartPop = abs(ccur(rs.fields("wart_min").value))
									curWart = ccur(rs.fields("wart_dod").value)
									




						%>
						<tr>
							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE_RS]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC_RS]]></t>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_JM_RS]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_POP_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_POP_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_RS]]></t>
							</td>

						</tr>
						<%			
								iter = iter + 1
								rs.movenext
								wend
								trans_.saveobjects
							else
						%>

								<tr border='1' fontsize='5' forecolor='red' bold='true'><td><t>Uwaga! Niepoprawny stan magazynu</t></td></tr>

						<% end if %>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='5' bordercolor='transparent'>
							</td>
							<td colspan='3'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC]]></t>
							</td>							
						</tr>	
					</tfoot>					
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td width='min' align='center'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby zatwierdzającej operację</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
