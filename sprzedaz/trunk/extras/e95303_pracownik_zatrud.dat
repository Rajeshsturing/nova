<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_PRACOWNIK_ZATRUDNIENIA

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE Zatrudnienia wg wydziałów

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()
	query = "select 'j_wydzial'=max(j.strNazwa),'p_stanowisko'=case when p.strStanowisko='' then '<brak>' else p.strStanowisko end, " + vbNewLine +_
          "'p_ilosc'=count(p.strStanowisko) " + vbNewLine +_ 
          "from n5pracownik p " + vbNewLine +_
          "	inner join n5jedn_org j on p.pJednostkaOrg = j.idobj " + vbNewLine +_
          "	inner join n5plumowa u on u.pPracownik = p.idobj " + vbNewLine +_
          "where (u.dDataOd is not null) and (u.dDataDo is not null) and " + vbNewLine +_ 
          "	(u.dDataDo >= " + trans_.afc.convert.date2SQL(CDate(trans_.var(GVAR_TODAY))) + " or u.dDataDo = {d '1899-12-31'}) " + vbNewLine +_
          " and [DATAOD] %1 and %2 and %3 " + vbNewLine +_
          "group by p.strStanowisko " + vbNewLine +_
          "order by j_wydzial,p_stanowisko"
end function
%>
<%
function default_param()
	dim pParamArray: set pParamArray = doc_.afc.new_navoarray()
  pParamArray.add doc_.afc.rap.param.new_date("Analizowany moment").bindexpr("")
  pParamArray.add doc_.afc.rap.param.new_text("Stanowisko").bindexpr("p.strStanowisko")  
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Wydział").bindexpr("j.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_,"select strNazwa, idobj from n5jedn_org order by strNazwa"
	pParamArray.add pParam2
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='4'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
    RXE_TEXT(j_wydzial)
  </td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='4' />
</tr>
<tr fontsize='4'>
	<td style='27' colspan='3' />
	<td style='27' align='right'> 
     RXE_QUANTITY_VVV(pSection.counter(0).result,"",0)
	</td>
</tr>
<tr border='0'><td colspan='4' /></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT(p_stanowisko)
	</td>
  <td align='right'>
    <t>
		RXF_QUANTITY_CVV(p_ilosc,"",0)
    </t>
	</td>  
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='6000'>
		<text><![CDATA[Stanowisko]]></text>
  </td>
  <td width='2500'>
    <text><![CDATA[Liczba zatrudnionych]]></text>
  </td>  
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='4' />
</tr>
<tr fontsize='6'>
  <td style='27' colspan='3' />
  <td style='27' align='right'>
    RXE_QUANTITY_VVV(pSection.counter(0).result,"",0)    
  </td>
</tr>
<tr border='0'>
  <td colspan='4' />
</tr>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("p_ilosc")
  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("p_ilosc")

if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing
  
  .ReplaceQueryParam "[DATAOD] ( =","(u.dDataOd <="

  rapeng_.write_actual_param so,rapeng_.get_raport_param()
  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
 end if 
end if
end with
%>
</body>
<footer>
</footer>
</page>
