<?xml version="1.0" encoding="windows-1250" ?>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>


#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write cstr(pos_.pia_pProdukt.strNazwa) %>
#define POZ_OPAKOWANIE					<% so.write cstr(pos_.pia_pOpak.strNazwa) %>
#define POZ_INDEKS						<% so.write cstr(pos_.pia_pProdukt.strIndeks) %>

#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto + "   " + util_.Dzisiaj%>

#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>

#define MAGAZYN							<% so.write " Magazyn: " +  cstr(root_.ia_pInwentaryzacja.im_pMagazyn.text) %>


<page style='36'>
<config>
	<title>Arkusz spisu z natury</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>


		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>

						ROW_SEPARATOR(1)		

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[Arkusz spisu z natury]]> </t>
							</td>
						</tr>
						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='4'><![CDATA[MAGAZYN]]> </t>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)


		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min'>
								<t>LP</t>
							</td>
							<td>
								<text>Produkt</text>
							</td>							
							<td>
								<text>Opakowanie</text>
							</td>
							<td>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>				
						</tr>
					</thead>
						
					<tbody>
						<%								
							dim elem,iter
							iter = 1
							dim pos_ 
							for each pos_ in root_.ia_listPozycje

						%>
						<tr>
							<td width='min'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text>
							</td>
							<td>
								<text><![CDATA[POZ_OPAKOWANIE]]></text>								
							</td>
							<td>
								<text><![CDATA[POZ_INDEKS]]></text>								
							</td>
							<td align='right'>
								<t size='10'><![CDATA[]]></t>
							</td>
						</tr>
						<%	
							iter = iter + 1	
							next
						%>
					</tbody>				
				</table>
			</td>
		</tr>

									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
