<?xml version="1.0" encoding="windows-1250" ?>


<!-- ZAKUP WNT - korekta -->
<!-- 26.06.2004 utworzenie -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->
<!-- 2.12.2004 adresy poprawka -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane nabywcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
 

<!-- Dane sprzedawcy -->
#define KLIENT_NAZWA			<% so.write util_.Klient_Nazwa(root_.pDostawca) %>
#define KLIENT_NIP			<% so.write util_.Klient_NIP(root_.pDostawca) %>
#define KLIENT_KOD_MIASTO		<% if root_.pDostawca.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pDostawca) else if root_.pDostawca.strPoczta<>"" and  root_.pDostawca.strPoczta<>root_.pDostawca.pMiejscowosc.strNazwa then so.write root_.pDostawca.strKod + " " + root_.pDostawca.strPoczta else if  root_.pDostawca.strPoczta=root_.pDostawca.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pDostawca) end if end if end if%>
#define KLIENT_ULICA_NUMER		<% so.write util_.Klient_Ulica(root_.pDostawca) %>
#define KLIENT_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pDostawca) %>
#define KLIENT_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pDostawca) %>
#define KLIENT_MIASTO					<% so.write root_.pDostawca.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pDostawca_JO) %>
#define KLIENT_JO_KOD_MIASTO		<% if root_.pDostawca_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pDostawca_JO) else if root_.pDostawca_JO.strPoczta<>"" and  root_.pDostawca_JO.strPoczta<>root_.pDostawca_JO.pMiejscowosc.strNazwa then so.write root_.pDostawca_JO.strKod + " " + root_.pDostawca_JO.strPoczta else if  root_.pDostawca_JO.strPoczta=root_.pDostawca_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pDostawca_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pDostawca_JO) %>
#define KLIENT_JO_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pDostawca_JO) %>
#define KLIENT_JO_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pDostawca_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pDostawca_JO.pMiejscowosc.strNazwa %>


<!-- Dane sprzedawcy - dokument oryginalny -->
#define DOK_ORG_KLIENT_NAZWA			<% so.write util_.Klient_Nazwa(root_.pPopZakup.pDostawca)%>
#define DOK_ORG_KLIENT_NIP				<% if not root_.pPopZakup is nothing then so.write util_.Klient_NIP(root_.pPopZakup.pDostawca) end if  %>
#define DOK_ORG_KLIENT_KOD_MIASTO		<% if root_.pPopZakup.pDostawca.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pPopZakup.pDostawca) else if root_.pPopZakup.pDostawca.strPoczta<>"" and  root_.pPopZakup.pDostawca.strPoczta<>root_.pPopZakup.pDostawca.pMiejscowosc.strNazwa then so.write root_.pPopZakup.pDostawca.strKod + " " + root_.pPopZakup.pDostawca.strPoczta else if  root_.pPopZakup.pDostawca.strPoczta=root_.pPopZakup.pDostawca.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pPopZakup.pDostawca) end if end if end if%>
#define DOK_ORG_KLIENT_ULICA_NUMER		<% if not root_.pPopZakup is nothing then so.write util_.Klient_Ulica(root_.pPopZakup.pDostawca)  end if %>
#define DOK_ORG_KLIENT_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pPopZakup.pDostawca) %>
#define DOK_ORG_KLIENT_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pPopZakup.pDostawca) %>
#define DOK_ORG_KLIENT_MIASTO			<% so.write root_.pPopZakup.pDostawca.pMiejscowosc.strNazwa %>

#define DOK_ORG_KLIENT_JO_NAZWA			<% if not root_.pPopZakup is nothing then so.write util_.Klient_Nazwa(root_.pPopZakup.pDostawca_JO) end if %>
#define DOK_ORG_KLIENT_JO_KOD_MIASTO	<% if root_.pPopZakup.pDostawca_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pPopZakup.pDostawca_JO) else if root_.pPopZakup.pDostawca_JO.strPoczta<>"" and  root_.pPopZakup.pDostawca_JO.strPoczta<>root_.pPopZakup.pDostawca_JO.pMiejscowosc.strNazwa then so.write root_.pPopZakup.pDostawca_JO.strKod + " " + root_.pPopZakup.pDostawca_JO.strPoczta else if  root_.pPopZakup.pDostawca_JO.strPoczta=root_.pPopZakup.pDostawca_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pPopZakup.pDostawca_JO) end if end if end if%>
#define DOK_ORG_KLIENT_JO_ULICA_NUMER	<% if not root_.pPopZakup is nothing then so.write util_.Klient_Ulica(root_.pPopZakup.pDostawca_JO) end if %>
#define DOK_ORG_KLIENT_JO_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pPopZakup.pDostawca_JO) %>
#define DOK_ORG_KLIENT_JO_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pPopZakup.pDostawca_JO) %>
#define DOK_ORG_KLIENT_JO_MIASTO		<% if not root_.pPopZakup is nothing then so.write root_.pPopZakup.pDostawca_JO.pMiejscowosc.strNazwa end if %>



<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_ZAKUPU			<% so.write doc_.afc.display.fulldate(root_.dDataZakupu) %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_URZAD_CELNY			<% if not root_.pUrzadCelny is nothing then so.write root_.pUrzadCelny.strNazwa end if%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(abs(root_.curSumaBrutto - root_.pPopZakup.curSumaBrutto)) %>
#define DOKUMENT_DO_ZAPLATY_OPIS		<% if root_.pPopZakup.curSumaBrutto - root_.curSumaBrutto > 0 then so.write "Do zwrotu: " else so.write "Do zapłaty: "   %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(abs(root_.curSumaBrutto - root_.pPopZakup.curSumaBrutto )) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_POWIAZANY				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_OBCY_NR				<% so.write root_.strNrDokObcy %>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>

#define DOK_ORG_DOKUMENT_NUMER				<% if not root_.pPopZakup is nothing then so.write root_.pPopZakup.text end if %>
#define DOK_ORG_DOKUMENT_DATA_ZAKUPU		<% if not root_.pPopZakup is nothing then so.write doc_.afc.display.fulldate(root_.pPopZakup.dDataWyst) end if  %>
#define DOK_ORG_DOKUMENT_TERMIN_PLATNOSCI	<% if not root_.pPopZakup is nothing then so.write doc_.afc.display.fulldate(root_.pPopZakup.dDataPlat) end if  %>
#define DOK_ORG_DOKUMENT_SPOSOB_PLATNOSCI	<% if not root_.pPopZakup is nothing then so.write util_.Dokument_Sposob_Platnosci(root_.pPopZakup)  end if %>
#define DOK_ORG_DOKUMENT_DO_ZAPLATY			<% if not root_.pPopZakup is nothing then so.write MONEY(root_.pPopZakup.curSumaBrutto) end if %>:
#define DOK_ORG_DOKUMENT_DO_ZAPLATY_SLOWNIE	<% if not root_.pPopZakup is nothing then so.write doc_.afc.display.slownie(root_.pPopZakup.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_NETTO		<% if not root_.pPopZakup is nothing then so.write MONEY(root_.pPopZakup.curSumaNetto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_VAT		<% if not root_.pPopZakup is nothing then so.write MONEY(root_.pPopZakup.curSumaVat) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_BRUTTO		<% if not root_.pPopZakup is nothing then so.write MONEY(root_.pPopZakup.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_POWIAZANY			<% if not root_.pPopZakup.pZamowienie is nothing then so.write root_.pPopZakup.pZamowienie.strNrDok end if  %>
#define DOK_ORG_DOKUMENT_OBCY_NR			<% so.write root_.pPopZakup.strNrDokObcy %>


<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_OPL_DOD_KRAJ				<% so.write MONEY(pozycja.curOplatyKraj) %>
#define POZ_OPL_DOD_ZAGR				<% so.write MONEY(pozycja.curOplatyZagr) + " " + root_.pWaluta.strSkrot%>
#define POZ_AKCYZA						<% so.write MONEY(pozycja.curAkcyza) %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNettoWal) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>



<!-- podsumowanie pozycji -->
#macro DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_VAT(_eVat_)			<% so.write util_.vat_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>

<!-- podsumowanie pozycji - dokument oryginalny-->
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_.pPopZakup) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_VAT(_eVat_)			<% so.write util_.vat_dla_stawki(_eVat_,root_.pPopZakup) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_.pPopZakup) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>


#define KWOTA_ROZNICA_NETTO_OPIS		<% so.write util_.Korekta_Roznica_Netto_Opis(root_) %>
#define KWOTA_ROZNICA_NETTO_WARTOSC		<% so.write util_.Korekta_Roznica_Netto_Wartosc(root_) %>
#define KWOTA_ROZNICA_VAT_OPIS			<% so.write util_.Korekta_Roznica_Vat_Opis(root_) %>
#define KWOTA_ROZNICA_VAT_WARTOSC		<% so.write util_.Korekta_Roznica_Vat_Wartosc(root_) %>


<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[KOREKTA NR DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[FAKTURY DOK_ORG_DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true'>Oryginał</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane nabywcy - FIRMA -->					
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'>BYŁO</t>
							</td>
						</tr>				
						
							
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

<% if not root_.pPopZakup is nothing then %>

						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Dostawca:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<!-- Dane sprzedawcy - Klient - jednostka organizacyjna-->
						<% if not root_.pPopZakup.pDostawca_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pPopZakup.pDostawca_JO.strPoczta<>"") and (root_.pPopZakup.pDostawca_JO.pMiejscowosc.strNazwa <> root_.pPopZakup.pDostawca_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_JO_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_JO_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

						<% else %>

						<!-- Dane sprzedawcy - KLIENT -->
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pPopZakup.pDostawca.strPoczta<>"") and (root_.pPopZakup.pDostawca.pMiejscowosc.strNazwa <> root_.pPopZakup.pDostawca.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_RACHUNEK_BANKOWY_NUMER]]></t>
