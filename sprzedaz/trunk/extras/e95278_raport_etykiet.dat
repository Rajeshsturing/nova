<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rozliczenie etykiet
#define TMP_SUMA_ETYK	#tmp_raport_etykiet


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_PROD_FIRST_EXPR		t_prod.strIndeks
#define C_FIELD_PROD_SECOND_EXPR	t_prod.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks produktu
#define C_FIELD_SECOND_HUMANNAME 	Nazwa produktu
#define C_FIELD_FIRST_ALIGN 		right
#define C_FIELD_SECOND_ALIGN 		left
#else
#define C_FIELD_PROD_FIRST_EXPR		t_prod.strNazwa
#define C_FIELD_PROD_SECOND_EXPR	t_prod.strIndeks
#define C_FIELD_FIRST_HUMANNAME 	Nazwa produktu
#define C_FIELD_SECOND_HUMANNAME 	Indeks produktu
#define C_FIELD_FIRST_ALIGN 		left
#define C_FIELD_SECOND_ALIGN 		right
#endif

N5DOKETYK_TYP_WYDANIE
N5DOKETYK_TYP_KONTROLA
N5DOKETYK_TYP_ZDANIE
N5DOKETYK_TYP_KASACJA
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim g_nWydane : g_nWydane = clng(0)
dim g_nZdane : g_nZdane = clng(0)
dim g_nKasacja : g_nKasacja = clng(0)

function query()
query = "select 'c_prod_first'=C_FIELD_PROD_FIRST_EXPR,'c_prod_second'=C_FIELD_PROD_SECOND_EXPR, " +_
"'c_wydanie'=sum(tmp_nWydane),'c_zdane'=sum(tmp_nZdane),'c_kasacja'=sum(tmp_nKasacja) " +_
"from n5produkt as t_prod " +_
"inner join TMP_SUMA_ETYK on t_prod.IdObj = TMP_SUMA_ETYK.tmp_pProd " +_
"inner join n5grupaproduktow as t_grprod on t_prod.pGrupaProd = t_grprod.IdObj " +_
"where %2  and  %3  and  %4  group by C_FIELD_PROD_FIRST_EXPR,C_FIELD_PROD_SECOND_EXPR order by c_prod_first"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("p_doet_ddatawyst")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_prod.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_prod.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_grprod.strNazwa")

	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTO_TEXT(c_prod_first)
	</td>
	<td>
		RXE_AUTO_TEXT(c_prod_second)
	</td>
	<td align='right'>
		RXE_T(c_wydanie)
	</td>
	<td align='right'>
		RXE_T(c_zdane)
	</td>
	<td align='right'>
		RXE_T(c_kasacja)
	</td>
	<td align='right'>
	<%
	dim nWydane : nWydane = clng(pRec("c_wydanie"))
	dim nZdane : nZdane = clng(pRec("c_zdane"))
	dim nKasacja : nKasacja = clng(pRec("c_kasacja"))
	
	g_nWydane = g_nWydane + nWydane
	g_nZdane = g_nZdane + nZdane
	g_nKasacja = g_nKasacja + nKasacja

	%>
		<t><%so.write cstr(nWydane - nZdane - nKasacja) %></t>
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wydane]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Zdane]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kasacja]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[W produkcji]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
	<tr border='0' bold='true'>
		<td colspan='3' />
		<td align='right'>
			<t><%so.write cstr(g_nWydane) %></t>
		</td>
		<td align='right'>
			<t><%so.write cstr(g_nZdane) %></t>
		</td>
		<td align='right'>
			<t><%so.write cstr(g_nKasacja) %></t>
		</td>
		<td align='right'>
			<t><%so.write cstr(g_nWydane - g_nZdane - g_nKasacja) %></t>
		</td>
	</tr>
</tbody>
</table>
<%
end function

sub initialize_raport
	trans_.execsql "create table TMP_SUMA_ETYK " + "(tmp_pProd integer not null,tmp_pOpak integer not null, " +_
	"tmp_nWydane integer not null,tmp_nZdane integer not null,tmp_nKasacja  integer not null)"
end sub
sub finalize_raport
	trans_.execsql "drop table TMP_SUMA_ETYK"
end sub
sub fill_raport(byref pOkresParam)
	trans_.execsql "insert into TMP_SUMA_ETYK select c_pdet_pWyrob,c_pdet_popak,count(*),0,0 " +_
	"from vlist_n5doketyk_doet_listPozycje where p_doet_etypoper=N5DOKETYK_TYP_WYDANIE and " +_
	pOkresParam.get_where_part(trans_) +_
	" group by c_pdet_pWyrob,c_pdet_popak"
	trans_.execsql "insert into TMP_SUMA_ETYK select c_pdet_pWyrob,c_pdet_popak,0,count(*),0 " +_
	"from vlist_n5doketyk_doet_listPozycje where p_doet_etypoper=N5DOKETYK_TYP_ZDANIE and " +_
	pOkresParam.get_where_part(trans_) +_
	" group by c_pdet_pWyrob,c_pdet_popak"
	trans_.execsql "insert into TMP_SUMA_ETYK select c_pdet_pWyrob,c_pdet_popak,0,0,count(*) " +_
	"from vlist_n5doketyk_doet_listPozycje where p_doet_etypoper=N5DOKETYK_TYP_KONTROLA and " +_
	pOkresParam.get_where_part(trans_) +_
	" group by c_pdet_pWyrob,c_pdet_popak"
end sub
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
initialize_raport
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	fill_raport rapeng_.get_raport_param().value(0)

	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
finalize_raport
%>
</body>
<footer>
</footer>
</page>
