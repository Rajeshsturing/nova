<?xml version="1.0" encoding="windows-1250" ?>

<!--

#include "h1203.h"

-->



<!-- Dowód księgowy -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro WALUTA_NAZWA(_unit_)				util_.nazwa_waluty(_unit_)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>

#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>
#define MIEJSCOWOSC_DATA_DZISIEJSZA     <% so.write util_.Firma_Miasto+ "   " + util_.Dzisiaj %>
<!-- Dane firmy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
  


<!-- Informacje na dowodzie -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_ZRODLOWY				<% if not root_.wrefDokZrod is nothing then  so.write root_.wrefDokZrod.text end if %>
#define DOKUMENT_DATA_REJESTRACJI		<% so.write doc_.afc.display.fulldate(root_.dDataRej) %>
#define DOKUMENT_DATA_KSIEGOWANIA		<% so.write doc_.afc.display.fulldate(root_.dDataKsieg) %>
#define DOKUMENT_OSOBA_WROWADZAJACA		<% so.write root_.pUzytRej.text %>
#define DOKUMENT_OPIS					<% so.write root_.strOpis %>
#define DOKUMENT_REJESTR_DOW_KS			<% so.write root_.pRejestrDok.text %>
#define GODZINA_WYDRUKU                 <% so.write cstr(FormatDateTime(Now(),3)) %>

<!-- Pozycje dowodu -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_KONTO						<% so.write pozycja.pKonto.strSymbol %>
#define POZ_OPIS						<% so.write podziel(pozycja.strOpis) %>
#define POZ_KWOTA_WN					<% if pozycja.curWn <> 0 then so.write MONEY(pozycja.curWn) end if%>
#define POZ_KWOTA_MA					<% if pozycja.curMa <> 0 then so.write MONEY(pozycja.curMa) end if%>
#define POZ_SYMBOL						<% if not pozycja.pTransakcja is nothing then so.write pozycja.pTransakcja.strSymTrans end if%>
#define POZ_KWALIFIKATOR				<% if not pozycja.pKwalifikator is nothing then so.write pozycja.pKwalifikator.strNazwa end if %>

<!-- Podsumowanie dowodu -->
#define PODSUM_WALUTA					<% so.write WALUTA_NAZWA(sum_unit) %>
#define PODSUM_WN						<% so.write MONEY(sum_wn) %>
#define PODSUM_MA						<% so.write MONEY(sum_ma) %>

<%
function podziel(byval opis)
	dim strLancuch : strLancuch = ""
	dim i 
	dim k 
        
    k = len(opis) / 25
    if (k=0) then
        podziel=opis
    else
        for i=0 to k
            strLancuch=" "+strLancuch+mid(opis,i*25+1,25)+" "
        next
        podziel=strLancuch
    end if

end function 
%>

<page style='36' margins='800,800,800,800'>

<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
</config>

<header>
</header>

<body>
<table>
	<tbody>
		<tr>
			<td>
				<table>
					<tbody>
						<tr>
							<td width='max'>
								<t fontsize='4'><![CDATA[FIRMA_NAZWA]]></t>
							</td>
							#ifdef _FRAM
							<td align='right'>
								<t fontsize='4'><![CDATA[MIEJSCOWOSC_DATA_DZISIEJSZA]]></t>
							</td>
							#else
							<td align='right'>
								<t fontsize='4'><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_REJESTRACJI]]></t>
							</td>
							#endif
						</tr>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td/>
						</tr>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td/>
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_MIASTO]]></t>								
							</td>							
							<td/>
						</tr>
						<%end if%>
	
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)

						<tr>
							<td colspan='2' align='center'>
								<t fontsize='8' bold='true'><![CDATA[Dowód księgowy]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='2' align='center'>
								<t fontsize='6' bold='true'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>

						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)

						<tr>
							<td >
							<table >
								<tbody>
									<tr>								
										<td width='min'>
											<t>Numer dokumentu:</t>
										</td>
										<td width='max'>
											<t><![CDATA[DOKUMENT_NUMER]]></t>
										</td>
									</tr>
									<tr>
										<td>
											<t>Dokument źródłowy:</t>
										</td>
										<td width='max'> 
											<t><![CDATA[DOKUMENT_ZRODLOWY]]></t>
										</td>
									
									</tr>
								</tbody>
							</table>
							</td>
							<td width='min'>
							<table >
								<tbody>
									<tr>								
										<td width='min'>
											<t>Data rejestracji:</t>
										</td>
										<td width='min'>
											<t><![CDATA[DOKUMENT_DATA_REJESTRACJI]]></t>
										</td>
									</tr>
									<tr>
										<td>
											<t>Data księgowania:</t>
										</td>
										<td width='min'>
											<t><![CDATA[DOKUMENT_DATA_KSIEGOWANIA]]></t>
										</td>
									
									</tr>
									#ifdef _FRAM
									<tr>
										<td>
											<t>Godzina wydruku: </t>
										</td>
										<td width='min'>
											<t><![CDATA[GODZINA_WYDRUKU]]></t>
										</td>
									
									</tr>
									#endif
									
									
								</tbody>
							</table>
							</td>

						</tr>
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<tr>
			<td >
				<%
				
				dim iter : iter = 1
				dim pozycja
				%>
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min'>
								<t>LP</t>
							</td>
							<td>
								<t>Konto</t>
							</td>
							<td align='right' width='1000' >
								<t>Kwota winien</t>
							</td>
							<td align='right' width='1000' >
								<t>Kwota ma</t>
							</td>
							<td>
								<t>Opis dekretu</t>
							</td>
							<td width='max'>
								<t>Symbol transakcji</t>
							</td>
							<td width='max'>
								<t>Kwalifikator</t>
							</td>

						</tr>
					</thead>
					<tbody>
						<% 
						for each pozycja in root_.listDekret %>
						<tr>
							<td align='right'>
								<t><![CDATA[POZ_LP]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_KONTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_KWOTA_WN]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_KWOTA_MA]]></t>
							</td>
							<td>
								<text><![CDATA[POZ_OPIS]]></text>
							</td>

							<td align='left'>
								<text><![CDATA[POZ_SYMBOL]]></text>
							</td>
							<td align='left'>
								<text><![CDATA[POZ_KWALIFIKATOR]]></text>
							</td>
							
						</tr>
						<%
							iter = iter + 1
							next
						%>
					</tbody>
					<tfoot>
						
							<%
							dim sum_iter : sum_iter = 0
							dim sum_unit
							dim sum_wn
							dim sum_ma
							dim sum_ref
							if not root_.pSumator is nothing then
							do while root_.pSumator.get_value(sum_iter, sum_unit, sum_wn, sum_ma, sum_ref)
							if sum_ref > 0 then
							%>
						<tr>
							<td align='right' width='4000' colspan='2' bordercolor='transparent'>
								<t bold='true'>Suma (</t>
								<t bold='true'><![CDATA[PODSUM_WALUTA]]></t>
								<t bold='true'>)</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[PODSUM_WN]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[PODSUM_MA]]></t>
							</td>
						</tr>
							<%
							end if
							sum_iter = sum_iter + 1
							loop
							end if
							%>
						
					</tfoot>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)

		<tr>
			<td >
				<table>
					<tbody>
						<tr>
							<td>
								<t bold='true'>Rejestr dowodów księgowych:</t>
							</td>
							<td>
								<t><![CDATA[DOKUMENT_REJESTR_DOW_KS]]></t>
							</td>

						</tr>
						<% if root_.strOpis<>"" then%>
						<tr>
							<td>
								<t bold='true'>Adnotacje:</t>

							</td>
							<td >
								<text><![CDATA[DOKUMENT_OPIS]]></text>
							</td>

						</tr>
						<%end if%>	
						ROW_SEPARATOR(1)
						
						
						<tr>
							<td width='min' >
								<t bold='true'>Wprowadzony przez:</t>
							</td>
							<td>
								<t><![CDATA[DOKUMENT_OSOBA_WROWADZAJACA]]></t>
							</td>
						

						</tr>

					</tbody>
				</table>
			
			</td>
		</tr>


	</tbody>
</table>
</body>

<footer>
</footer>

</page>
