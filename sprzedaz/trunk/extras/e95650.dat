#define POZ_WART_NETTO            <% so.write doc_.afc.display.money(oRS("s_wartnetto").value, "") %>
#define POZ_STAWKA_VAT            <% so.write strStawka(oRS("s_stawkavat").value) %>
#define POZ_WART_VAT              <% so.write doc_.afc.display.money(oRS("s_vat").value, "") %>
#define POZ_WART_BRUTTO           <% so.write doc_.afc.display.money(oRS("s_wartbrutto").value, "") %>

#define POZKOR_RABAT              <% so.write doc_.afc.display.quantity(oRS("k_rabat").value,"",4) %>
#define POZKOR_WART_NETTO         <% so.write doc_.afc.display.money(oRS("k_wartnetto").value, "") %>
#define POZKOR_CENA_NETTO         <% so.write doc_.afc.display.quantity(oRS("k_cenanetto").value, "",4) %>
