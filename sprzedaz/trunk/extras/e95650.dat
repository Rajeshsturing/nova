<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  dim pDefParam : set pDefParam = default_param()
	if .prepare("RAPORT_TITLE",pDefParam,rapeng_.get_raport_param(),query()) then
    strQuery = rapeng_.query_apply_actual_param(query(),pDefParam)  
    
    'nagłówek dokumentu
    naglowek
    so.write "<p><t></t></p><br></br><p><t></t></p><br></br>"
    'ustaw dane początkowe
    danePocz
    so.write "<p><t></t></p><br></br><p><t></t></p><br></br>"
   
    if not .perform then
     so.write "<p style='21'><text>Brak danych spełniających podane kryteria</text></p>"
	  end if
  end if
end with
%>
</body>
