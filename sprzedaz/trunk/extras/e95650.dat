          curBruttoSprz = ccur(pSprz.curBrutto17)
          curNettoKor = ccur(pKor.curNetto17)
          curVatKor = ccur(pKor.curVat17)
          curBruttoKor = ccur(pKor.curBrutto17)
		    case STAWKA_VAT_22: 
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto22)
          curVatSprz = ccur(pSprz.curVat22)
          curBruttoSprz = ccur(pSprz.curBrutto22)
          curNettoKor = ccur(pKor.curNetto22)
          curVatKor = ccur(pKor.curVat22)
