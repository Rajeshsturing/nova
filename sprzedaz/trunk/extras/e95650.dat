#define NABYWCA_MIEJSCOWOSC       <% so.write miejscNab %>
#define NABYWCA_KOD_POCZ          <% if (ucase(miejscNab) <> ucase(pocztaNab) and pocztaNab <> "") then so.write kodPoczNab + " " + pocztaNab else so.write kodPoczNab + " " + miejscNab end if %>
