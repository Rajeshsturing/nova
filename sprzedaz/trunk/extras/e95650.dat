#define DOKUMENT_KOR_SUMA_VAT     <% so.write doc_.afc.display.money(oRS("k_sumavat").value, "") %>
#define DOKUMENT_KOR_SUMA_BRUTTO  <% so.write doc_.afc.display.money(oRS("k_sumabrutto").value, "") %>
