		    case STAWKA_VAT_3:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto3)
          curVatSprz = ccur(pSprz.curVat3)
          curBruttoSprz = ccur(pSprz.curBrutto3)
          curNettoKor = ccur(pKor.curNetto3)
          curVatKor = ccur(pKor.curVat3)
          curBruttoKor = ccur(pKor.curBrutto3)
		    case STAWKA_VAT_4:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto4)
          curVatSprz = ccur(pSprz.curVat4)
          curBruttoSprz = ccur(pSprz.curBrutto4)
          curNettoKor = ccur(pKor.curNetto4)
          curVatKor = ccur(pKor.curVat4)
          curBruttoKor = ccur(pKor.curBrutto4)
		    case STAWKA_VAT_7:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto7)
          curVatSprz = ccur(pSprz.curVat7)
          curBruttoSprz = ccur(pSprz.curBrutto7)
          curNettoKor = ccur(pKor.curNetto7)
          curVatKor = ccur(pKor.curVat7)
          curBruttoKor = ccur(pKor.curBrutto7)
		    case STAWKA_VAT_12:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto12)
          curVatSprz = ccur(pSprz.curVat12)
          curBruttoSprz = ccur(pSprz.curBrutto12)
          curNettoKor = ccur(pKor.curNetto12)
          curVatKor = ccur(pKor.curVat12)
          curBruttoKor = ccur(pKor.curBrutto12)
		    case STAWKA_VAT_17:
