<page style='36'>
<config>
<title></title>
<script>
<![CDATA[

'VB_PRINT_LANDSCAPE_COMMON
'VB_PRINTPREV_LANDSCAPE_COMMON

<%

dim strQuery, strNrKor, pParamArray
'tytuł i data korekty
dim strTytul, dDataKor, strDopisek, strTypWydruku
'dane sprzedawcy
dim nazwaSprz, miejscSprz, nrDomuSprz, kodPoczSprz, pocztaSprz, telSprz, faxSprz, nipSprz
'dane nabywcy
dim nazwaNab, ulicaNab, nrDomuNab, miejscNab, kodPoczNab, pocztaNab, nipNab, indeksNaszaFirma
'numer faktury i data
dim strNrDokWithDate
'id dokumentów oryginalnych i korekt
dim pArrayIdDok : set pArrayIdDok = doc_.afc.new_navoarray()
dim pArrayIdKor : set pArrayIdKor = doc_.afc.new_navoarray()
'podsumowanie w stawce
dim pArrayVatSum : set pArrayVatSum = doc_.afc.new_navoarray()
'podsumowanie faktury
dim pArrayWartNetto : set pArrayWartNetto = doc_.afc.new_navoarray()
dim pArrayWartVat : set pArrayWartVat = doc_.afc.new_navoarray()
dim pArrayWartBrutto : set pArrayWartBrutto = doc_.afc.new_navoarray()
'podsumowanie korekty
dim pArrayWartNettoKor : set pArrayWartNettoKor = doc_.afc.new_navoarray()
dim pArrayWartVatKor : set pArrayWartVatKor = doc_.afc.new_navoarray()
dim pArrayWartBruttoKor : set pArrayWartBruttoKor = doc_.afc.new_navoarray()
'kwota do zwrotu
dim curDoZwrotu : curDoZwrotu = ccur(0)
dim iRowNr : iRowNr = clng(13)
dim iColNr : iColNr = clng(66)

'nagłowek wydruku
sub naglowek
  dim strSQL : strSQL = "select 'id_dok'=idobj from n5sprzedaz where strNrDok like '%" + pParamArray.value(0).first_value + "%'"
  dim oRS : set oRS = trans_.createadors(strSQL)
  if oRS.RecordCount <> 0 then
    dim idDok : idDok = clng(oRS("id_dok"))
    if idDok > 0 then
      dim pDok : set pDok = trans_.getobj(TYPEID_N5SPRZEDAZ,idDok)
      'data korekty
      dDataKor = pDok.dDataWyst
      strTytul = pDok.strUwagi
      'numer korekty zbiorczej
      dim i
      dim strNrOdw : strNrOdw = ""
      for i = Len(pDok.strNrDok) to 1 step -1
        strNrOdw = strNrOdw + Mid(pDok.strNrDok,i,1)
      next
      dim iPos : iPos = InStr(strNrOdw,"/")
      strNrKor = Mid(pDok.strNrDok,1,Len(pDok.strNrDok)-iPos)
      'dopisek
      strDopisek = ""
      if pParamArray.value(2).selected.value(1) then
        strDopisek = "DOTYCZY FAKTUR WYSTAWIONYCH W FORMIE ELEKTRONICZNEJ"
      end if
      'typ wydruku
      strTypWydruku = ""
      if pParamArray.value(3).selected.value(0) then
        strTypWydruku = "ORYGINAŁ"
      elseif pParamArray.value(3).selected.value(1) then
        strTypWydruku = "KOPIA"
      elseif pParamArray.value(3).selected.value(2) then
        strTypWydruku = "DUPLIKAT"
      else
        strTypWydruku = "KOMPENDIUM"
      end if  
    end if
  else
    exit sub
  end if 
%>    
  <!-- nagłówek -->
  <table>
    <tbody>
      <tr>
        <td bold='true' width='6500'>
          <text fontsize='5'>FAKTURA KORYGUJĄCA VAT Nr</text>
        </td>
        <td bold='true' width='10600'>
          <text fontsize='5'><![CDATA[DOKUMENT_NR_KOR_ZBIOR]]></text>
        </td>
        <td align='right' width='3000'>
          <text fontsize='5'><![CDATA[TYP_WYDRUKU]]></text>
        </td>
      </tr>
      <tr>
        <td colspan='2'>
          <text fontsize='2'><![CDATA[DOPISEK]]></text>
          <text fontsize='2'>&nbsp;</text>
        </td>
        <td align='right'>
<%
        if pParamArray.value(3).selected.value(2) then
%>          
          <text fontsize='2'><![CDATA[DATA_BIEZACA]]></text>
<%
        end if
%>  
        </td>        
      </tr>
      <tr>
        <td colspan='3'>
          <text fontsize='2' bold='true'>Tytuł korekty:</text>
        </td>
      </tr>
      <tr>
        <td colspan='3'>
          <text fontsize='2'><![CDATA[DOKUMENT_TYTUL_KOREKTY]]></text>
        </td>
      </tr>  
    </tbody>
  </table>
<%  
end sub
  
'wypełnij danymi początkowymi
sub danePocz
  'dane sprzedawcy
  if (trans_.isvar(GVAR_FIRMA)) then
    dim idFirmy : idFirmy = trans_.var(GVAR_FIRMA)
  end if
  if (idFirmy > 0) then
  dim pFirma : set pFirma = trans_.getobj(TYPEID_N5FIRMA, idFirmy)
    nazwaSprz = pFirma.strNazwa
    dim pMiejsc : set pMiejsc = trans_.getobj(TYPEID_N5MIEJSCOWOSC,pFirma.pMiejscowosc.idobj)
    miejscSprz = pMiejsc.strNazwa
    nrDomuSprz = pFirma.strNrDomu
    kodPoczSprz = pFirma.strKod
    pocztaSprz = pFirma.strPoczta
    telSprz = pFirma.strTel1
    faxSprz = pFirma.strFax
    nipSprz = pFirma.strNIP
  end if  
  'dane nabywcy z faktury
  dim strSQL
  if pParamArray.value(1).first_value = "" then
    pParamArray.value(1).first_value = "1344"
  end if
  strSQL = "select 'id_nab'=idobj from n5klient where strIndeks like '%" + pParamArray.value(1).first_value + "%'"
  dim oRS : set oRS = trans_.createadors(strSQL)
  if oRS.RecordCount <> 0 then
    dim idNab : idNab = clng(oRS("id_nab"))
    if idNab > 0 then
      dim pNab : set pNab = trans_.getobj(TYPEID_N5KLIENT,idNab)
    end if
    nazwaNab = pNab.strNazwa
    ulicaNab = pNab.strUlica
    nrDomuNab = pNab.strNrDomu
    set pMiejsc = trans_.getobj(TYPEID_N5MIEJSCOWOSC,pNab.pMiejscowosc.idobj)
    miejscNab = pMiejsc.strNazwa
    kodPoczNab = pNab.strKod
    pocztaNab = pNab.strPoczta  
    nipNab = pNab.strNIP
    indeksNaszaFirma = pNab.kli_strIndeksNaszaFirma
  else
    nazwaNab = ""
    ulicaNab = ""
    nrDomuNab = ""
    set pMiejsc = nothing
    miejscNab = ""
    kodPoczNab = ""
    pocztaNab = ""  
    nipNab = ""
    indeksNaszaFirma = ""    
  end if
%>    
  <!-- nagłówek -->
  <table>
    <tbody>
      <tr>
        <td fontsize='2' bold='true' width='8200'>
          <text>Sprzedawca</text>
        </td>
        <td fontsize='2' bold='true' width='8200'>
          <text>Nabywca</text>
        </td>
        <td fontsize='2' bold='true' width='3700'>
          <text>&nbsp;&nbsp;Miejscowość, data</text>
        </td>
      </tr>
      <tr>
        <td fontsize='2' width='8200'>
          <text><![CDATA[SPRZEDAWCA_NAZWA]]></text>
        </td>
        <td fontsize='2' width='8200'>
          <text><![CDATA[NABYWCA_NAZWA]]></text>
        </td>
        <td fontsize='2' width='3700'>
          <text>&nbsp;&nbsp;</text>
          <text><![CDATA[SPRZEDAWCA_MIEJSCOWOSC]]></text>
          <text><![CDATA[DOKUMENT_DATA_WYDRUKU]]></text>
        </td>
      </tr>
      <tr>
        <td fontsize='2' width='8200'>
          <text><![CDATA[SPRZEDAWCA_MIEJSCOWOSC SPRZEDAWCA_NR_DOMU]]></text>
          <text><![CDATA[SPRZEDAWCA_KOD_POCZ SPRZEDAWCA_POCZTA]]></text>
        </td>
        <td colspan='2' fontsize='2' width='8200'>
          <text><![CDATA[NABYWCA_ULICA NABYWCA_NR_DOMU]]></text>
        </td>
      </tr>
      <tr>
        <td fontsize='2' width='8200'>
          <text><![CDATA[SPRZEDAWCA_TELEFON]]></text>
          <text><![CDATA[SPRZEDAWCA_FAX]]></text>
        </td>
        <td fontsize='2' width='8200'>
          <text><![CDATA[NABYWCA_KOD_POCZ]]></text>
        </td>
        <td fontsize='2' bold='true' width='3700'>
          <text>&nbsp;&nbsp;</text>
          <text>Forma płatności:</text>
        </td>
      </tr>
      <tr>
        <td fontsize='2' width='8200' bold='true'>
          <text><![CDATA[SPRZEDAWCA_NIP]]></text>
        </td>
        <td fontsize='2' width='8200' bold='true'>
          <text><![CDATA[NABYWCA_NIP]]></text>
        </td>
        <td fontsize='2' width='3700'>
          <text>&nbsp;&nbsp;</text>          
          <text>KOMPENSATA</text>
        </td>
      </tr>
      <tr>
        <td colspan='3'>
          <text fontsize='1'><![CDATA[NABYWCA_INDEKS]]></text>
        </td>
      </tr>
    </tbody>
  </table>
<%  
end sub

function query()
query = "select 'id_dok'=idobj from n5sprzedaz where idobj in " +_
        "(select pPopSprzed from n5sprzedaz where %1)"
end function
%>
<%
function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa dokumentu").bindexpr("strNrDok")
  pParamArray.add doc_.afc.rap.param.new_text("Indeks nabywcy").bindexpr("")
  'dopisek
  dim pParamDopisek : set pParamDopisek = doc_.afc.rap.param.new_choice("Dopisek")
  with pParamDopisek
	  .multiple = false
    .names.add "brak"
    .values.add 1
    .selected.add true
    .names.add "dotyczy faktur w formie elektronicznej"
    .values.add 2
    .selected.add false
  end with  
  pParamArray.add pParamDopisek
  'typ wydruku
  dim pParamTyp : set pParamTyp = doc_.afc.rap.param.new_choice("Typ wydruku")
  with pParamTyp
	  .multiple = false
    .names.add "Oryginał"
    .values.add 1
    .selected.add true
    .names.add "Kopia"
    .values.add 2
    .selected.add false
    .names.add "Duplikat"
    .values.add 3
    .selected.add false
    .names.add "Kompendium"
    .values.add 4
    .selected.add false    
  end with  
  pParamArray.add pParamTyp  
	set default_param = pParamArray
end function

'zwraca stawkę vat w zależności od wartości enum
function strStawka(byval eVat)
	select case eVat
		case STAWKA_VAT_0:
			strStawka = "0"
		case STAWKA_VAT_ZWOLNIONY:
			strStawka = "Zw"
		case STAWKA_VAT_NIE_PODLEGA:
			strStawka = "np"
		case STAWKA_VAT_2:
			strStawka = "2"
		case STAWKA_VAT_3:
			strStawka = "3"
		case STAWKA_VAT_4:
			strStawka = "4"
		case STAWKA_VAT_7:
			strStawka = "7"
		case STAWKA_VAT_12:
			strStawka = "12"
		case STAWKA_VAT_17:
			strStawka = "17"
		case STAWKA_VAT_22: 
			strStawka = "22"
		case STAWKA_VAT_5: 
			strStawka = "5"
	end select
end function

'suma w stawce vat
sub sumaStawka(byval idSprz, byval idKor, byval eVat, byref pArrayVat)
  'dokument oryginalny i korekta
  if idSprz > 0 and idKor > 0 then
    dim pSprz : set pSprz = trans_.getobj(TYPEID_N5SPRZEDAZ,idSprz)
    dim pKor : set pKor = trans_.getobj(TYPEID_N5SPRZEDAZ,idKor)
    dim curNettoSprz, curVatSprz, curBruttoSprz, curNettoKor, curVatKor, curBruttoKor
    if not checkVat(eVat, pArrayVat) then
	    select case eVat
		    case STAWKA_VAT_0:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNetto0)
          curVatSprz = ccur(0)          
          curBruttoSprz = ccur(0)
          curNettoKor = ccur(pKor.curNetto0)
          curVatKor = ccur(0)
          curBruttoKor = ccur(0)
