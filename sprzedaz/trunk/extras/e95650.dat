#define ROZNICA_BRUTTO_RAZEM            <% so.write doc_.afc.display.money(curSumaBruttoRazemKor - curSumaBruttoRazem, "") %>

#define DOKUMENT_STAWKA_VAT                <% so.write strStawka(curSumaVat) + "%" %>
