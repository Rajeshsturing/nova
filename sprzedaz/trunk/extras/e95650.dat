#define SPRZEDAWCA_NAZWA          <% so.write nazwaSprz %>
#define SPRZEDAWCA_MIEJSCOWOSC    <% so.write miejscSprz %>
#define SPRZEDAWCA_NR_DOMU        <% so.write nrDomuSprz %>
#define SPRZEDAWCA_KOD_POCZ       <% so.write ", " + kodPoczSprz %>
