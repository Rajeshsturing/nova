#define ROZNICA_BRUTTO_RAZEM_ST            <% so.write doc_.afc.display.money(curSumaBruttoRazemKor - curSumaBruttoRazem, "") %>

#define DOKUMENT_DO_ZAPLATY				         <% so.write doc_.afc.display.money(abs(curDoZwrotu), "") %>
