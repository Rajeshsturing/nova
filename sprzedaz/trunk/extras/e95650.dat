#define POZKOR_WART_VAT           <% so.write doc_.afc.display.money(oRS("k_vat").value, "") %>
#define POZKOR_WART_BRUTTO        <% so.write doc_.afc.display.money(oRS("k_wartbrutto").value, "") %>

#comment Podsumowanie wydruku
#define DOKUMENT_NR_POD               <% so.write cstr(strNrDok) %>
#define DOKUMENT_DATA_WYST_POD        <% so.write doc_.afc.display.fulldate(dDataWyst) %>
