     'zapamiętaj kwoty do podsumowania w stawce
     addKwotaStawka eVat, pArrayVatSum, curNettoSprz, curVatSprz, curBruttoSprz, curNettoKor, curVatKor, curBruttoKor
    end if  
  end if
end sub

'zwraca true gdy dodano podsumowanie dla stawki eVat
function checkVat(byval eVat, byval pArrayVat) : checkVat = false
  dim iter
  for iter = 0 to pArrayVat.upperIndex
    if eVat = pArrayVat.value(iter) then
      checkVat = true
      exit function
    end if
  next
end function

'zapamiętuje kwoty w stawce
sub addKwotaStawka(byval eVat, byval pArrayVatSum, byval curNettoSprz, byval curVatSprz, byval curBruttoSprz, byval curNettoKor, byval curVatKor, byval curBruttoKor)
  dim iter
  for iter = 0 to pArrayVatSum.upperIndex
    if eVat = pArrayVatSum.value(iter) then
      pArrayWartNetto.value(iter) = pArrayWartNetto.value(iter) + curNettoSprz
      pArrayWartVat.value(iter) = pArrayWartVat.value(iter) + curVatSprz
      pArrayWartBrutto.value(iter) = pArrayWartBrutto.value(iter) + curBruttoSprz
      pArrayWartNettoKor.value(iter) = pArrayWartNettoKor.value(iter) + curNettoKor
      pArrayWartVatKor.value(iter) = pArrayWartVatKor.value(iter) + curVatKor
      pArrayWartBruttoKor.value(iter) = pArrayWartBruttoKor.value(iter) + curBruttoKor
      exit sub
    end if
  next
  pArrayVatSum.add eVat
  pArrayWartNetto.add curNettoSprz
  pArrayWartVat.add curVatSprz
  pArrayWartBrutto.add curBruttoSprz
  pArrayWartNettoKor.add curNettoKor
  pArrayWartVatKor.add curVatKor
  pArrayWartBruttoKor.add curBruttoKor
end sub

'funkcja zwraca nagłówek dokumentu wraz z datą
function strNaglowek(byval idDok) : strNaglowek = ""
  dim oDok, iter
  dim strNagl : strNagl = ""
  if idDok > 0 then
    set oDok = trans_.getobj(TYPEID_N5SPRZEDAZ,idDok)
    strNagl = oDok.strNrDok + " z dnia " + doc_.afc.display.fulldate(oDok.dDataWyst)
    for iter = 0 to 1
      dim idPopDok
      if not oDok.pPopSprzed is nothing then
        idPopDok = oDok.pPopSprzed.idobj
        if idPopDok > 0 then
          set oDok = trans_.getobj(TYPEID_N5SPRZEDAZ,idPopDok)
          strNagl = strNagl + " do " + oDok.strNrDok + " z dnia " + doc_.afc.display.fulldate(oDok.dDataWyst)
        end if
      else
        exit for
      end if  
    next
  end if
  strNaglowek = strNagl
end function 

'pojedynczy wiersz na podstawie idobj dokumentu sprzedazy
sub fillRow(byval idDok)
  if idDok > 0 then
    dim pDok : set pDok = trans_.getobj(TYPEID_N5SPRZEDAZ,idDok)
    dim strSQL : strSQL = "select 's_idobj'=s.p_idobj,'s_nrdok'=s.p_strnrdok,'s_datawyst'=s.p_ddatawyst,'p_nazwa'=p.strNazwa, " +_
                          "  'p_pkwiu'=p.strKodPKWiU,'j_skrot'=j.strSkrot,'s_ilosc'=s.c_curiloscopak,'s_cenabazowa'=s.c_curcenabazowanettowal, " +_
                          "  's_rabat'=s.c_currabat,'s_wartnetto'=s.c_curwartnetto,'s_stawkavat'=s.c_evat,'s_vat'=s.c_curvat, " +_
                          "  's_wartbrutto'=s.c_curwartbrutto,'k_idobj'=k.p_idobj,'k_rabat'=k.c_currabat,'k_wartnetto'=k.c_curwartnetto, " +_
                          "  'k_stawkavat'=k.c_evat,'k_cenanetto'=k.c_curcenanettowal,'k_vat'=k.c_curvat,'k_wartbrutto'=k.c_curwartbrutto, " +_
                          "  's_sumanetto'=s.p_cursumanetto,'s_sumavat'=s.p_cursumavat,'s_sumabrutto'=s.p_cursumabrutto, " +_
                          "  'k_sumanetto'=k.p_cursumanetto,'k_sumavat'=k.p_cursumavat,'k_sumabrutto'=k.p_cursumabrutto " +_
                          "from vlist_n5sprzedaz_listPozycje s " +_
                          "  inner join vlist_n5sprzedaz_listPozycje k on k.p_ppopsprzed = s.p_idobj and s.coll_lp = k.coll_lp " +_
                          "  inner join n5produkt p on s.c_pprodukt = p.idobj " +_
                          "  inner join n5jednostka j on p.pJednostkaEwid = j.idobj " +_
                          "where s.p_idobj = " + cstr(idDok)
    dim oRS : set oRS = trans_.createadors(strSQL)
'kompendium    
if not pParamArray.value(3).selected.value(3) then
  'numer dokumentu z datą
  strNrDokWithDate = strNaglowek(clng(oRS("s_idobj")))
%>
