          curBruttoSprz = ccur(0)
          curNettoKor = ccur(pKor.curNettoZw)
          curVatKor = ccur(0)
          curBruttoKor = ccur(0)
		    case STAWKA_VAT_NIE_PODLEGA:
          pArrayVat.add eVat
          curNettoSprz = ccur(pSprz.curNettoNp)
          curVatSprz = ccur(0)
          curBruttoSprz = ccur(0)
