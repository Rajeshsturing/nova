#define DOKUMENT_DO_ZAPLATY_SLOWNIE		     <% so.write doc_.afc.display.slownie(abs(curDoZwrotu)) %>

#define DOPISEK                         <% so.write strDopisek %>
#define TYP_WYDRUKU                     <% so.write strTypWydruku %>
