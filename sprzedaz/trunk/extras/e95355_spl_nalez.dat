<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ROZKLAD_PROC_SPLYWU_NALEZN

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rozkład procentowy spływu należności

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim pParamArray
dim curSumNal : curSumNal = CCur(1)

function query()
  query = "select 't_idobj'=t.IdObj,'t_symbol'=t.strSymTrans,'k_IdObj'=k.IdObj,'k_nazwa'=k.strNazwa,'t_kwota'=t.curWn-t.curMa, " + vbNewLine +_
	        "'t_data_wym'=t.dDataWym,'sp_nazwa'=sp.strNazwa,'ilosc_dni'=datediff(day,t.dDataWym," + doc_.afc.convert.date2SQL(trans_.var(GVAR_TODAY)) + ") " + vbNewLine +_ 
          "from n5sprzedaz s " + vbNewLine +_
	        "inner join n5transakcja t on s.pTransakcja = t.IdObj " + vbNewLine +_
	        "inner join n5klient k on s.pKlient = k.IdObj " + vbNewLine +_
	        "inner join n5sposplat sp on s.pSposobPlatnosci = sp.IdObj " + vbNewLine +_
          "where (t.curWn-t.curMa) > 0 and t.eTyp = N5TRANSAKCJA_NALEZNOSC and t.eStatus = N5TRANSAKCJA_OTWARTA " + vbNewLine +_
	        "and %1 and %2 " + vbNewLine + " and %3 and %4 " + vbNewLine +_
          "order by ilosc_dni desc"
end function
%>
<%
function sumNalezn()
  dim strSQL
  strSQL = "select sum(t.curWn-t.curMa) " + vbNewLine +_ 
           "from n5sprzedaz s " + vbNewLine +_
	         "inner join n5transakcja t on s.pTransakcja = t.IdObj " + vbNewLine +_
	         "inner join n5klient k on s.pKlient = k.IdObj " + vbNewLine +_
	         "inner join n5sposplat sp on s.pSposobPlatnosci = sp.IdObj " + vbNewLine +_
           "where (t.curWn-t.curMa) > 0 and t.eTyp = N5TRANSAKCJA_NALEZNOSC and t.eStatus = N5TRANSAKCJA_OTWARTA " + vbNewLine +_
	         "and %1 and %2 " + vbNewLine + " and %3 and %4"
  strSQL = doc_.getmodule(60108).query_apply_actual_param(strSQL,pParamArray)
  dim oRS : set oRS = trans_.createadors(strSQL)
  if oRS.recordCount > clng(0) then
    curSumNal = CCur(oRS(0).value)
  end if
end function
%>

<%
function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data rozpoczęcia").bindexpr("t.dDataRozp")
  pParamArray.add doc_.afc.rap.param.new_date_range("Termin płatności").bindexpr("t.dDataWym")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa kontrahenta").bindexpr("k.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_int("Dni spóźnienia").bindexpr("datediff(day,t.dDataWym," +_ 
                                            doc_.afc.convert.date2SQL(trans_.var(GVAR_TODAY)) + ")")
	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>RXE_LP</td>
  <td>
    RXE_T_LINK_FORM_VCC(TYPEID_N5TRANSAKCJA,t_idobj,t_symbol)
  </td> 
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,k_IdObj,k_nazwa)
  </td>
  <td align='right'>
    RXE_QUANTITY_CVV(t_kwota,"",2)
  </td>
  <td align='right'>
    RXE_QUANTITY_VVV(CCur(pRec("t_kwota").value)/curSumNal*100,"%",2)
  </td>
  <td>
    RXE_DATE(t_data_wym)
  </td>
  <td>
    RXE_TEXT(sp_nazwa)
  </td>
  <td align='right'>
    RXE_QUANTITY_CVV(ilosc_dni,"",0)
  </td>  
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
  <tr style='21'>
	  <td width='min'><t>LP</t></td>
	  <td width='2000'>
		  <text><![CDATA[Symbol transakcji]]></text>
	  </td>
	  <td width='6000'>
		  <text><![CDATA[Kontrahent]]></text>
	  </td>  
	  <td width='2000'>
		  <text><![CDATA[Kwota]]></text>
	  </td>
	  <td width='2300'>
		  <text><![CDATA[Procent ogółu należności]]></text>
	  </td>  
	  <td width='2000'>
		  <text><![CDATA[Termin płatności]]></text>
	  </td>  
	  <td width='2000'>
		  <text><![CDATA[Rodzaj zapłaty]]></text>
	  </td>  
	  <td width='1800'>
		  <text><![CDATA[Dni przeter minowane]]></text>
	  </td>  
  </tr>  
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
  <tfoot>
    <tr style='21'>
      <td style='27' colspan='3' align='right'>
        <t>Razem:</t>
      </td>
      <td style='27' align='right'>
        RXE_MONEY_VAR(pRapExec.body.counter(0).result)
      </td>
      <td style='27' colspan='4' />
    </tr>  
  </tfoot>
</table>
<%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("t_kwota")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
  sumNalezn()
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
