<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h" 
#define RAPORT_TITLE Zadania - aktywność 



#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_3.strIndeks
#define C_FIELD_SECOND_EXPR		t_3.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks produktu
#define C_FIELD_SECOND_HUMANNAME 	Nazwa produktu
#else
#define C_FIELD_FIRST_EXPR		t_3.strNazwa
#define C_FIELD_SECOND_EXPR		t_3.strIndeks
#define C_FIELD_FIRST_HUMANNAME		Nazwa produktu
#define C_FIELD_SECOND_HUMANNAME	Indeks produktu
#endif




-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

dim g_pUtilModule : set g_pUtilModule = doc_.getmodule(60158)

function query()
query = "select 'c_status'=t_zadanie.nStatus, 'c_wykonawca_indeks'=t_wyk.strIndeks, "+_
" 'c_temat'=t_zadanie.strTemat, "+_
" 'c_priorytet'=t_zadanie.ePriorytet, "+_
" 'c_6'=10119,'c_zadanie_idobj'=t_zadanie.IdObj, "+_
" 'c_klient'=isnull[t_klient.strNazwa,''],"+_
" 'c_ddata_zlec'=t_zadanie.dDataZlec, 'c_ddata_pow'=t_zadanie.dDataPow, "+_
" 'c_ddata_rozp'=t_zadanie.dDataRozp, 'c_ddata_zak'=t_zadanie.dDataZakon,  "+_
" 'c_ddata_zamk'=t_zadanie.dDataZamk,"+_
" 'c_typ_dzialania'=t_dzialanie.strNazwa, 'c_zlecajacy'=t_zlec.strIndeks "+_
" from n5zadanie as t_zadanie "+_
" left join n5klient as t_klient on t_zadanie.pKlient = t_klient.IdObj  "+_
" inner join n5wykonawca as t_wyk on t_zadanie.pWykonawca = t_wyk.IdObj   "+_
" inner join n5wykonawca as t_zlec on t_zadanie.pZlecajacy = t_zlec.IdObj "+_
" inner join n5typdzialania as t_dzialanie on t_zadanie.pTypDzialania = t_dzialanie.IdObj "+_
" where %1 and %2 and [ T1 %3  and  t_zadanie.dDataZlec<>{d '1899-12-31'} "+_
" or T2 %3 and t_zadanie.dDataPow<>{d '1899-12-31'} "+_
" or T3 %3 and t_zadanie.dDataRozp<>{d '1899-12-31'} "+_
" or T4 %3 and t_zadanie.dDataZakon<>{d '1899-12-31'} "+_
" or T5 %3 and t_zadanie.dDataZamk<>{d '1899-12-31'} ]"+_
" order by c_status,c_wykonawca_indeks "

end function
%>


<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Typ działania").bindexpr("t_dzialanie.strNazwa")
	
	
	'dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	'dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ działania").bindexpr("t_zadanie.pTypDzialania")
	'doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
	'	"select strNazwa , idobj from n5typdzialania order by strNazwa "
	'pParamArray.add pParam2
	
	
	

	pParamArray.add doc_.afc.rap.param.new_text("Wykonawca").bindexpr("t_wyk.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_date_range("Analizowany okres").bindexpr("DATA")
	
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='12'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	<t><% so.write g_pUtilModule.get_status_name(pRec("c_status"))%></t>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>

<tr border='0'><td colspan='12' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='12' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='11'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_wykonawca_indeks)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<!-- -->
<tr border='0'><td colspan='12' /></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='13' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_6,c_zadanie_idobj,c_temat)
	</td>
	<td>
		RXE_AUTO_TEXT(c_klient)
	</td>
	<td>
		RXE_AUTO_TEXT(c_typ_dzialania)
	</td>
	
	<td align='right'>
		RXE_DATE(c_ddata_zlec)
	</td>
	<td align='right'>
		RXE_DATE(c_ddata_pow)
	</td>
	<td align='right'>
		RXE_DATE(c_ddata_rozp)
	</td>

	<td align='right'>
		RXE_DATE(c_ddata_zak)
	</td>
	<td align='right'>
		RXE_DATE(c_ddata_zamk)
	</td>
	
	<td width='min' align='right'>
		RXE_AUTO_TEXT(c_zlecajacy)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>

<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Zadanie]]></text> 
	</td>

	<td  width='min'>
		<text><![CDATA[Klient]]></text> 
	</td>
	<td  width='min'>
		<text><![CDATA[Typ zadania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data zlecenia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data powiadomienia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data rozpoczęcia]]></text>
	</td>

	<td width='min'>
		<text><![CDATA[Data zakończenia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data zamknięcia]]></text>
	</td>
	
	<td width='min'>
		<text><![CDATA[Zlecający]]></text>
	</td>



</tr>

</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>

<!-- -->
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 1,getref("section_header_2"),getref("section_footer_2")
	

if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	'.ReplaceQueryParam "DATA","t_zadanie.dDataZlec"
	'.ReplaceQueryParam "t_zadanie.dDataZlec", "cos_innego"
	.ReplaceQueryParam "(",""
	.ReplaceQueryParam ")",""
	.ReplaceQueryParam "DATA",""
	.ReplaceQueryParam "T1","t_zadanie.dDataZlec"
	.ReplaceQueryParam "T2","t_zadanie.dDataPow"
	.ReplaceQueryParam "T3","t_zadanie.dDataRozp"
	.ReplaceQueryParam "T4","t_zadanie.dDataZakon"
	.ReplaceQueryParam "T5","t_zadanie.dDataZamk"
	.ReplaceQueryParam "[","("
	.ReplaceQueryParam "]",")"
	

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
