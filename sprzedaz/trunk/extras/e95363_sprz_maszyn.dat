<?xml version="1.0" encoding="windows-1250" ?>
<!--

RAPTEMPLATE_SPRZEDAZ_MASZYN

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Sprzedaż maszyn

#macro RXE_TEXT_LINK_FORM_VVV(_type_val_,_idobj_,_val_)	\
<text href='<%so.write rapeng_.href_open_form_proxy(_type_val_,_idobj_)%>'><![CDATA[<%so.write cstr(_val_)%>]]></text>

-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'p_nazwa'=p.strNazwa,'p_indeks'=p.strIndeks,'p_idobj'=p.idobj,'p_type'=TYPEID_N5PRODUKT,'p_nr_fabr'=p.strCecha3, " + vbNewLine +_
		"'z_data'=zam.dDataWyst,'k_nazwa'=k.strNazwa,'k_idobj'=k.idobj,'k_type'=TYPEID_N5KLIENT,'vl_idobj'=vl.p_idobj,'vl_type'=TYPEID_N5SPRZEDAZ, " + vbNewLine +_
		"'vl_nrdok'=vl.p_strnrdok,'vl_data_wyst'=vl.p_ddatawyst,'vl_wart_sprz'=vl.c_curwartnetto,'vl_lp'=vl.coll_lp, " + vbNewLine +_
		"'z_idobj'=isnull((select z.idobj from n5zakup z where z.strExtra2 = zam.strNrDok and %3),0) " + vbNewLine +_
		"from vlist_n5sprzedaz_listPozycje vl " + vbNewLine +_
		"inner join n5produkt p on vl.c_pprodukt = p.idobj " + vbNewLine +_
		"inner join n5klient k on vl.p_pklient = k.idobj " + vbNewLine +_
		"inner join n5zamowienie zam on vl.p_pzamowienie = zam.idobj " + vbNewLine +_
		"where isnull((select idobj from n5zakup where strExtra2 = zam.strNrDok),0) <> 0 " + vbNewLine +_
		"and %1 and %2 and %4 and %5 and %6 " + vbNewLine +_
		"order by p_nazwa,p_indeks,k_nazwa,k.strIndeks"
end function
%>

<%
dim nLPSec: nLPSec = clng(0)
dim nLP: nLP = clng(0)
dim curSumaZakupSec: curSumaZakupSec = ccur(0)
dim curSumaSprzSec: curSumaSprzSec = ccur(0)
dim curSumaZakup: curSumaZakup = ccur(0)
dim curSumaSprz: curSumaSprz = ccur(0)

function section_header_1(byref pSection,byref pRec)
  nLPSec = clng(0)
  curSumaZakupSec = ccur(0)
  curSumaSprzSec = ccur(0)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4' hide='true'>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='12' /></tr>
<tr fontsize='4'>
	<td style='27'/>
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(nLPSec,"",0)
	</td>  
	<td style='27'/><td style='27'/><td style='27'/><td style='27'/>
	<td style='27'/><td style='27'/><td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaZakupSec)
	</td>
	<td style='27'/><td style='27'/><td style='27'/><td style='27'/>
	<td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaSprzSec)
	</td>
	<td style='27' /><td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaSprzSec - curSumaZakupSec)
	</td> 
</tr>
<tr border='0' hide='true'><td colspan='12' /></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
  'dokument zakupu
  dim pZakup: set pZakup = trans_.getobj(TYPEID_N5ZAKUP,clng(pRec("z_idobj").value))
  dim pPozZakup: set pPozZakup = pZakup.listPozycje.get(clng(pRec("vl_lp").value))
  dim strNrDok: strNrDok = pZakup.strNrDok
  dim dDataWyst: dDataWyst = pZakup.dDataWyst
  dim curKurs: curKurs = pZakup.curKurs
  dim strDost: strDost = pZakup.pDostawca.strNazwa
  dim curWartNetto: curWartNetto = pPozZakup.curWartNetto
  curSumaZakupSec = curSumaZakupSec + curWartNetto
  curSumaSprzSec = curSumaSprzSec + ccur(pRec("vl_wart_sprz").value)
  curSumaZakup = curSumaZakup + curWartNetto
  curSumaSprz = curSumaSprz + ccur(pRec("vl_wart_sprz").value)
  nLPSec = nLPSec + 1
  nLP = nLP + 1
  
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'><t><%so.write cstr(nLPSec)%></t></td>
  <td/>
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(p_type,p_idobj,p_nazwa)
  </td>  
  <td>
    RXE_TEXT(p_indeks)
  </td>
  <td>
    RXE_TEXT(p_nr_fabr)  
  </td>
  <td>
    RXE_DATE(z_data)
  </td>
  <td>
    RXE_TEXT_LINK_FORM_VVV(TYPEID_N5ZAKUP,clng(pRec("z_idobj").value),strNrDok)
  </td>
  <td>
    <text><![CDATA[<%so.write doc_.afc.display.fulldate(dDataWyst)%>]]></text>
  </td>
  <td align='right'>
    <text><%so.write doc_.afc.display.quantity(curWartNetto,"",2)%></text>
  </td>
  <td/>
  <td align='right'>
    <text><%so.write doc_.afc.display.quantity(curKurs,"",4)%></text>
  </td>
  <td>
    <text><![CDATA[<%so.write cstr(strDost)%>]]></text>
  </td>  
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_nazwa)
  </td>
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(vl_type,vl_idobj,vl_nrdok)
  </td>  
  <td align='right'>
    RXE_QUANTITY_CVV(vl_wart_sprz,"",2)
  </td>  
  <td/>
  <td>
    RXE_DATE(vl_data_wyst)
  </td>  
  <td align='right'>  
    <t><%so.write doc_.afc.display.quantity(ccur(pRec("vl_wart_sprz").value)-curWartNetto,"",2)%></t>
  </td>    
  <td/>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td> 
	<td width='min'><text>Suma LP</text></td> 
	<td>
		<text><![CDATA[Nazwa maszyny]]></text>
	</td> 
	<td>
		<text><![CDATA[Indeks maszyny]]></text>
	</td> 
	<td>
		<text><![CDATA[Numer fabryczny]]></text>
	</td>   
	<td>
		<text><![CDATA[Data zamówienia]]></text>
	</td> 
	<td width='2300'>
		<text><![CDATA[Nr dokumentu zakupu]]></text>
	</td>   
	<td width='2000'>
		<text><![CDATA[Data zakupu]]></text>
	</td>   
	<td width='2000'>
		<text><![CDATA[Wartość zakupu]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Suma wart. zakupu]]></text>
	</td>  
	<td>
		<text><![CDATA[Kurs]]></text>
	</td>   
	<td width='4000'>
		<text><![CDATA[Dostawca]]></text>
	</td>   
	<td width='4000'>
		<text><![CDATA[Nabywca]]></text>
	</td> 
	<td width='2300'>
		<text><![CDATA[Nr dokumentu sprzedaży]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Wartość sprzedaży]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Suma wart. sprzedaży]]></text>
	</td>    
	<td width='2000'>
		<text><![CDATA[Data sprzedaży]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Wartość dodana]]></text>
	</td> 
	<td width='2000'>
		<text><![CDATA[Suma wart. dodanej]]></text>
	</td>   
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27'/>
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(nLP,"",0)
	</td>  
	<td style='27'/><td style='27'/><td style='27'/><td style='27'/>
	<td style='27'/><td style='27'/><td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaZakup)
	</td>
	<td style='27'/><td style='27'/><td style='27'/><td style='27'/>
	<td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaSprz)
	</td>
	<td style='27' /><td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaSprz - curSumaZakup)
	</td>  
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%

	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("p.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("p.strIndeks")	
	pParamArray.add doc_.afc.rap.param.new_date_range("Data zakupu").bindexpr("z.dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data sprzedaży").bindexpr("vl.p_ddatawyst")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("k.strIndeks")

	dim pRapExec : set pRapExec = rapeng_.new_engine()
	with pRapExec
		.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
    .add_group_section 1,getref("section_header_1"),getref("section_footer_1")


if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
		so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

%>
</body>
<footer>
</footer>
</page>
