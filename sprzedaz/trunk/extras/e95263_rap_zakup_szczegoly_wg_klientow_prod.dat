<?xml version="1.0" encoding="windows-1250" ?>
<!-- 05.02.2005 podgrupy produktow --> 
<!-- 18.07.2008 IOW podsumowanie walut -->
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zakup - Szczegóły - wg dostawców - produkty


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_1.strIndeks
#define C_FIELD_SECOND_EXPR		t_1.strNazwa
#else
#define C_FIELD_FIRST_EXPR		t_1.strNazwa
#define C_FIELD_SECOND_EXPR		t_1.strIndeks
#endif

#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_PROD_FIRST_EXPR		t_4.strIndeks
#define C_FIELD_PROD_SECOND_EXPR	t_4.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks produktu
#define C_FIELD_SECOND_HUMANNAME 	Nazwa produktu
#define C_FIELD_FIRST_ALIGN 		right
#define C_FIELD_SECOND_ALIGN 		left
#else
#define C_FIELD_PROD_FIRST_EXPR		t_4.strNazwa
#define C_FIELD_PROD_SECOND_EXPR	t_4.strIndeks
#define C_FIELD_FIRST_HUMANNAME 	Nazwa produktu
#define C_FIELD_SECOND_HUMANNAME 	Indeks produktu
#define C_FIELD_FIRST_ALIGN 		left
#define C_FIELD_SECOND_ALIGN 		right
#endif



-->
#ifdef _IOW
<%
dim tabela(100,2)
dim iTabelaItems : iTabelaItems = clng(0)

dim tabelaSekcja(100,2)
dim iTabelaSekcjaItems : iTabelaSekcjaItems = clng(0)
dim iter : iter = 1
dim iterS : iterS = 1
%>
#endif
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim strWaluta : strWaluta = ""
dim strWalutaJoin : strWalutaJoin = ""
dim strWalutaGroup : strWalutaGroup = ""
#ifdef _IOW
strWaluta = "'c_waluta' = max(t_0.p_pWaluta), 'c_wal_skrot'=max(t_wal.strSkrot), 'c_rej_typ'=max(t_6.eTyp), 'c_kurs'=max(t_0.p_curKurs), "+_
" 'c_suma_wal'=sum(isnull((t_0.p_curSumaWal-isnull(t_orgzakup.p_curSumaWal,0)),0)),   "

strWalutaJoin = " inner join n5jednostka as t_wal on t_0.p_pWaluta = t_wal.IdObj  "
strWalutaGroup = ", t_0.p_pWaluta "
#endif

query = "select 'c_field_first'=max(C_FIELD_FIRST_EXPR),'c_field_second'=max(C_FIELD_SECOND_EXPR),'c_prod_first'=max(C_FIELD_PROD_FIRST_EXPR),'c_prod_second'=max(C_FIELD_PROD_SECOND_EXPR),'c_oznprod'=max(t_4.strCecha1), "+_
" 'c_1'=10131,'c_id'=max(t_4.IdObj),'c_3'=10108, "+_
" 'c_prod_id'=max(t_1.IdObj),'c_6'=max(t_1.strNazwa),'c_8'=max(t_1.IdObj), "+_
" 'c_11'=max(t_1.IdObj),'c_12'=max(t_opak.strNazwa), 'c_prec'=MAX(t_jedn.nDokladnosc),"+_
" 'c_ilosc_ewid'=SUM(t_opak.currKrotnosc * (t_0.c_curIloscOpak - isnull(t_orgzakup.c_curIloscOpak,0)) ) , "+_
" 'c_jedn_ewid'=MAX(t_jedn_ewid.nDokladnosc), 'c_jedn_skrot'=MAX(t_jedn_ewid.strSkrot), "+_
" 'c_ile_opak'=sum(t_0.c_curIloscOpak - isnull(t_orgzakup.c_curIloscOpak,0) ), 'c_opak'=max(t_jedn.strSkrot),"+_
strWaluta +_
" 'c_wart_netto'=sum(t_0.c_curWartNetto- isnull(t_orgzakup.c_curWartNetto,0)), "+_
" 'c_wart_brutto'=sum(t_0.c_curWartNetto- isnull(t_orgzakup.c_curWartNetto,0)) + sum(t_0.c_curVAT- isnull(t_orgzakup.c_curVAT,0)) , "+_
" 'c_wart_vat'=sum(t_0.c_curVAT- isnull(t_orgzakup.c_curVAT,0)) "+_
" from vlist_n5zakup_listpozycje as t_0 "+_
" left outer join vlist_n5zakup_listpozycje t_orgzakup on t_0.p_ppopzakup = t_orgzakup.p_idobj and t_0.coll_lp = t_orgzakup.coll_lp "+_
" inner join n5klient as t_1 on t_0.p_pDostawca = t_1.IdObj  "+_
" inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
" inner join n5produkt as t_4 on t_0.c_pProdukt = t_4.IdObj "+_
" inner join n5opakowanie_produktu as t_opak on t_0.c_pOpak  = t_opak.IdObj "+_
" inner join n5jednostka as t_jedn on t_opak.pJednOpak = t_jedn.IdObj  " + _
" inner join n5jednostka as t_jedn_ewid on t_4.pJednostkaEwid = t_jedn_ewid.IdObj  "+_
" inner join n5rejestrdok as t_6 on t_0.p_pRejestrDok = t_6.IdObj "+_
strWalutaJoin +_
" where t_4.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) "+_
" and  %1 and %2 and %3 and %4 and %5 and %6 and %7 and EXTRA_CUSTOMER_FILTER_AND(9) "+_
" group by t_1.idobj, t_4.IdObj,t_opak.idobj "+_
strWalutaGroup +_
" order by c_field_first, c_prod_first "
end function
%>
<%
dim utilProdHierarchy : set utilProdHierarchy = doc_.getmodule(60246)
dim pProdHierarchy : set pProdHierarchy = utilProdHierarchy.new_prod_hierarchy()
dim pParamArray
dim pGrupaParam

function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data zakupu").bindexpr("t_0.p_dDataZakupu")
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa rejestru").bindexpr("t_6.strNazwa")	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_6.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
#ifdef _MILOMLYN
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP,N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) and eAktywny = N5REJESTRDOK_AKTYWNY order by strNazwa "
#else
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP,N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) order by strNazwa "
#endif
	pParamArray.add pParam2
	
	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa dostawców").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_4.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_4.strIndeks")
	set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam

	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>

#ifdef _IOW
<td style='27' colspan='13'>
#else
<td style='27' colspan='11'>
#endif

	
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>

		RXE_AUTOTEXT_LINK_FORM_CCC(c_3,c_8,c_field_first)
		<t size='3'/>
		RXE_AUTO_TEXT(c_field_second)

	
</td>
</tr>
<%

#ifdef _IOW
	for iterS=0 to iTabelaSekcjaItems - 1	
		tabelaSekcja(iterS,1) = 0.0
	next	
#endif

nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
#ifdef _IOW
<td colspan='11' />
#else
<td colspan='9' />
#endif

</tr>
<tr fontsize='5'>

#ifdef _IOW
<td style='27' colspan='9' />
#else
<td style='27' colspan='8' />
#endif

	
	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(3).result)
	</td>	
#ifdef _IOW
	<td style='27'/>
#endif
</tr>

#ifdef _IOW
<%
iterS=0
for iterS=0 to iTabelaSekcjaItems - 1 
	if tabelaSekcja(iterS,1) <> 0.0 then

%>
<tr fontsize='4'>
	<td style='27' colspan='9'>
		<t >Podsumowanie <%so.write tabelaSekcja(iterS,2)%></t>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>	
	<td style='27' align='right'>
		
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabelaSekcja(iterS,1))
	</td>
</tr>
<%
	end if
next
%>
#endif


#ifdef _IOW
<tr border='0'><td colspan='13' /></tr>
#else
<tr border='0'><td colspan='11' /></tr>
#endif



<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>

#ifdef _IOW
<td style='27' colspan='11'>
#else
<td style='27' colspan='10'>
#endif

	
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_3,c_prod_id,c_nazwa)
	
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>

#ifdef _IOW
<tr hide='true' userprop='propc_section_end="2"'><td colspan='8' /></tr>
#else
<tr hide='true' userprop='propc_section_end="2"'><td colspan='7' /></tr>
#endif


<tr fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>

#ifdef _IOW
<td style='27' colspan='9' />
#else
<td style='27' colspan='8' />
#endif

	

	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(3).result)
	</td>
</tr>

#ifdef _IOW
<tr border='0'><td colspan='10' /></tr>
#else
<tr border='0'><td colspan='9' /></tr>
#endif


<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%

end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td align='C_FIELD_FIRST_ALIGN'>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_id,c_prod_first)
	</td>

#ifdef _IOW

	<td align='C_FIELD_SECOND_ALIGN'>
		RXE_AUTO_TEXT(c_oznprod)
	</td>

#endif

	<td align='C_FIELD_SECOND_ALIGN'>
		RXE_AUTO_TEXT(c_prod_second)
	</td>
	<td>
		RXE_AUTO_TEXT(c_12)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ile_opak,c_opak,c_prec)  
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ilosc_ewid,c_jedn_skrot,c_jedn_ewid) 
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_vat,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_brutto,"",2)
	</td>
#ifdef _IOW
<%if  cstr(pRec("c_wal_skrot")) <> "PLN"  then %>
	<td align='right'>
		RXE_QUANTITY_CCV(c_suma_wal,c_wal_skrot,2)
	</td>
  
<%
			dim iterTabela
			dim iFoundIndex : iFoundIndex = -1
			for iterTabela = 0 to iTabelaItems
				if tabela(iterTabela,0) = clng(pRec("c_waluta")) then
					iFoundIndex = iterTabela
					exit for
				end if
			next
			if iFoundIndex = -1 then
				iFoundIndex = iTabelaItems
				iTabelaItems = iTabelaItems + 1
				tabela(iFoundIndex,0) = ccur(0.0)
			end if
			tabela(iFoundIndex,0) = clng(pRec("c_waluta"))
			tabela(iFoundIndex,1) = tabela(iFoundIndex,1) + ccur(pRec("c_suma_wal"))
			tabela(iFoundIndex,2) = cstr(pRec("c_wal_skrot"))


			'podsumowanie sekcji
			dim iterTabelaS
			dim iFoundIndexS : iFoundIndexS = -1
			for iterTabelaS= 0 to iTabelaSekcjaItems
				if tabelaSekcja(iterTabelaS,0) = clng(pRec("c_waluta")) then
					iFoundIndexS = iterTabelaS
					exit for
				end if
			next
			if iFoundIndexS = -1 then
				iFoundIndexS = iTabelaSekcjaItems
				iTabelaSekcjaItems = iTabelaSekcjaItems + 1
				tabelaSekcja(iFoundIndexS,0) = ccur(0.0)
			end if
			tabelaSekcja(iFoundIndexS,0) = clng(pRec("c_waluta"))
			tabelaSekcja(iFoundIndexS,1) = tabelaSekcja(iFoundIndexS,1) + ccur(pRec("c_suma_wal"))
			tabelaSekcja(iFoundIndexS,2) = cstr(pRec("c_wal_skrot"))

else%>
	<td/>
<%
end if
%>
#endif	
	
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max' >
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text>
	</td>

#ifdef _IOW

	<td width='max'>
		<text><![CDATA[Oznaczenie producenta]]></text>
	</td>

#endif

	<td width='max'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Nazwa opakowania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość opakowań]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość w jedn.ewid.]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu netto]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu VAT]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu brutto]]></text>
	</td>
#ifdef _IOW
	<td width='min'>
		<text><![CDATA[Wartość w walucie]]></text>
	</td>

#endif	
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>

#ifdef _IOW
<td style='27' colspan='9' />
#else
<td style='27' colspan='8' />
#endif

	

	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(3).result)
	</td>

#ifdef _IOW
	<td style='27' />
#endif	
</tr>

#ifdef _IOW 
<%
dim iter : iter=0
for iter=0 to iTabelaItems - 1 
%>
<tr style='21'>
	<td style='27' colspan='12' >
		<t >Podsumowanie <%so.write tabela(iter,2)%></t>
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabela(iter,1))
	</td>
</tr>
<%
next
%>
#endif
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_ilosc_ewid").add_sumator("c_wart_netto").add_sumator("c_wart_vat").add_sumator("c_wart_brutto")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_ilosc_ewid").add_sumator("c_wart_netto").add_sumator("c_wart_vat").add_sumator("c_wart_brutto")

if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pProdHierarchy.fill_on_prodgrupa_param pGrupaParam
	set pPerf = nothing

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pProdHierarchy.manual_done() : set pProdHierarchy = nothing
set utilProdHierarchy = nothing

%>
</body>
<footer>
</footer>
</page>
