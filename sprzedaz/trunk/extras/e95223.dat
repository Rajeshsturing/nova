<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zamówienia wg produktów

RAPTEMPLATE_ZAMOWIENIA_DO_REAL_WG_PRODUKT


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_4.strIndeks
#define C_FIELD_SECOND_EXPR		t_4.strNazwa
#else
#define C_FIELD_FIRST_EXPR		t_4.strNazwa
#define C_FIELD_SECOND_EXPR		t_4.strIndeks
#endif

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<% dim current_jednostka : current_jednostka = "" %>
<% dim current_section_caption : current_section_caption = "" %>

<%
function query()
query = "select 'c_1'=t_3.strNazwa,'c_2'=t_0.c_pzam_ddatareal,'c_3'=t_1.strNazwa, 'c_op' = t_4.strCecha1 , "+_
"'c_field_first'=C_FIELD_FIRST_EXPR,'c_field_second'=C_FIELD_SECOND_EXPR,"+_
"'c_4'=t_0.p_strNrDok,'c_5'=10172,'c_6'=t_0.p_IdObj,'c_7'=t_0.c_pzam_ddatareal,'c_8'=t_0.c_curIloscOpak, "+_
"'c_9'=t_0.c_curIloscOpakPoz,'c_jedn'=t_jedn.strSkrot,'c_prec'=t_jedn.nDokladnosc, "+_
"'c_zreal'=t_0.c_curIloscOpak - t_0.c_curIloscOpakPoz "+_
"from vlist_n5zamowienie_listpozycje as t_0 "+_
"inner join n5klient as t_1 on t_0.p_pKlient = t_1.IdObj "+_
"inner join n5opakowanie_produktu as t_3 on t_0.c_pOpak = t_3.IdObj "+_
"inner join n5produkt as t_4 on t_0.c_pProdukt = t_4.IdObj "+_
"inner join n5jednostka as t_jedn on t_3.pJednOpak = t_jedn.IdObj "+_
"inner join n5GrupaProduktow as t_grupy on t_4.pGrupaProd = t_grupy.idobj " + _
#ifdef _IOW
"left outer join n5kwalifikator as t_kwali on t_0.p_pkwalifikatorex = t_kwali.Idobj  "+_
"where  %1  and  %2  and  %3  and %4 and %5 and %6 and %7 and EXTRA_CUSTOMER_FILTER_AND(8) and %9 and t_0.c_curIloscOpakPoz <> 0 "+_
#else
"where  %1  and  %2  and  %3  and %4 and %5 and %6 and %7 and EXTRA_CUSTOMER_FILTER_AND(8) and t_0.c_curIloscOpakPoz <> 0 "+_
#endif
"and t_0.p_pRejestrDok in (select idobj from n5rejestrdok where etyp=N5REJESTRDOK__ZAM_OBCE) " +_
"order by c_field_first,c_field_second, c_1,c_2"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin realizacji").bindexpr("t_0.c_pzam_ddatareal")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_4.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_4.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy").bindexpr("t_grupy.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa opakowania").bindexpr("t_3.strNazwa")
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)
#ifdef _IOW
	dim pParamKw: set pParamKw= doc_.afc.rap.param.new_choice("Oznaczenie dokumentu").bindexpr("isnull(t_kwali.idobj,0)")
	doc_.afc.rap.param.init_on_query pParamKw, trans_ ,_
		"select strNazwa, idobj, 0 from n5kwalifikator union select '<brak>' , 0 , 1 order by 3 , 1 "
	pParamArray.add pParamKw
#endif

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>

#ifdef _IOW

#else

#endif

	<td style='27' colspan='11'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_field_first)

#ifdef _IOW
	<t size='3'/>
	RXE_AUTO_TEXT(c_op)
#endif

	<t size='3'/>
	RXE_AUTO_TEXT(c_field_second)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>

#ifdef _IOW

#else

#endif

<tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>

<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>

#ifdef _IOW

#else

#endif

	<td style='27' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' 
		href='vs1022="section_hideshow_hli_with_pods" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_1)
	</td>
</tr>

<% 
current_jednostka = pRec("c_jedn")
current_section_caption = pRec("c_1")
%>

<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_2(byref pSection)
%>

<tr fontsize='5'>

#ifdef _IOW

#else

#endif


  <td colspan='3' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
 <td style='27' colspan='4' />
 <td style='27' align='right'>	RXE_MONEY_VAR(pSection.counter(0).result) </td>
 <td style='27' align='right'>	RXE_MONEY_VAR(pSection.counter(2).result) </td>
 <td style='27' align='right' bold='true'>	RXE_MONEY_VAR(pSection.counter(1).result) </td>
 <td style='27' align='right'>	<%so.write "<t><![CDATA[" + CStr(current_jednostka) + "]]></t>"%> </td>
</tr>


#ifdef _IOW

#else

#endif

<tr hide='true' userprop='propc_section_end="2"'><td colspan='10' /></tr>


<tr hide='true' fontsize='4'>
	<td colspan='1' bordercolor='transparent' width='min'><t>&nbsp;</t></td>

#ifdef _IOW

#else

#endif

	<td style='27' colspan='6'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Rozwiń' ignoresysdisable='true' image='PICTURE_SMALL_PLUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' 
		href='vs1022="section_hideshow_hli_podsum" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		<%so.write "<t><![CDATA[" + CStr(current_section_caption) + "]]></t>"%>
	</td>
	<td style='27' align='right'>	RXE_MONEY_VAR(pSection.counter(0).result)	</td>
	<td style='27' align='right'>	RXE_MONEY_VAR(pSection.counter(2).result)	</td>
	<td style='27' align='right' bold='true'>	RXE_MONEY_VAR(pSection.counter(1).result)	</td>	
	<td style='27' align='right'>	<%so.write "<t><![CDATA[" + CStr(current_jednostka) + "]]></t>"%>	</td>
</tr>

<% nSectionPicCounter = nSectionPicCounter + 1 %>


<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>

#ifdef _IOW

#else

#endif


	<td colspan='3' style='36' bordercolor='white' width='min'><t>&nbsp;</t></td>
	<td align='right'>				RXE_LP	</td>
	<td>							RXE_AUTO_TEXT(c_3)	</td>
	<td>							RXE_AUTOTEXT_LINK_FORM_CCC(c_5,c_6,c_4)	</td>
	<td>							RXE_DATE(c_7)	</td>
	<td align='right'>				RXE_QUANTITY_CVC(c_8,"",c_prec)	</td>
	<td align='right'>				RXE_QUANTITY_CVC(c_zreal,"",c_prec)	</td>
	<td align='right' bold='true'>	RXE_QUANTITY_CVC(c_9,"",c_prec)	</td>
	<td align='right'>				RXE_AUTO_TEXT(c_jedn)	</td>

</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' width='min'>
		<t>LP</t>
	</td>
	<td rowspan='2' width='min'><text><![CDATA[Nazwa klienta]]></text>	</td>
	<td rowspan='2' width='min'><text><![CDATA[Numer dokumentu]]></text></td>	
	<td rowspan='2' width='min'><text><![CDATA[Termin realizacji zamówienia]]></text></td>
	<td colspan='3' width='min' align='center'>	<text><![CDATA[Ilość opakowań]]></text>	</td>
	<td rowspan='2' width='min'><text><![CDATA[Jednostka]]></text>	</td>
</tr>

<tr style='21'>
	<td width='min'><text><![CDATA[zamówionych]]></text></td>
	<td width='min'><text><![CDATA[zrealizowanych]]></text>	</td>
	<td width='min'><text><![CDATA[pozostałych]]></text></td>
</tr>

</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>


function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

function section_hideshow_hli_podsum(byref pHLI)
	
	' Picture ID of summary
	Dim pictureid : pictureid = pHLI.prop(100)
	Dim pStartingRow

	' Hide self	
	Set pStartingRow = page_.ctrl(pictureid).Parent.Parent
	pStartingRow.Hide = true

	' Point to section (previous section)
	pictureid = pictureid - 1

	Set pStartingRow = page_.ctrl(pictureid).Parent.Parent

	' Show the section and section head (if actually hidden )
	if pStartingRow.Hide then
		doc_.afc.formsection.section_hideshow page_, pictureid	
		pStartingRow.Hide = false
	end if
	
end function


function section_hideshow_hli_with_pods(byref pHLI)

	
	Dim pictureid : pictureid = pHLI.prop(100)
	Dim pStartingRow

	' hide self
	Set pStartingRow = page_.ctrl(pictureid).Parent.Parent
	pStartingRow.Hide = true
	
	' hide whole section 
	doc_.afc.formsection.section_hideshow page_, pictureid

	' point to picture in summary (next section)
	pictureid = pictureid + 1

	' show summary
	Set pStartingRow = page_.ctrl(pictureid).Parent.Parent
	pStartingRow.Hide = false


end function


]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 4,getref("section_header_1"),getref("section_footer_1")
	.add_group_section (0,getref("section_header_2"),getref("section_footer_2")).add_sumator("c_8").add_sumator("c_9").add_sumator("c_zreal")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
