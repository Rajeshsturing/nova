<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_ROZL_PLATNOSCI_KARTA

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rozliczanie płatności kartą POLCARD

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'r_nazwa'=r.strNazwa,'s_idobj'=s.IdObj,'s_data_wyst'=s.dDataWyst,'s_nr_dok'=s.strNrDok, " + vbNewLine +_
        "	's_kwota'=s.curSumaBrutto,'s_kwota_pobr'=s.curExtra5,'k_idobj'=k.IdObj,'k_nazwa'=k.strNazwa,'k_nip'=k.strNIP " + vbNewLine +_
        "from n5sprzedaz s " + vbNewLine +_
        "	inner join n5klient k on s.pKlient = k.idobj " + vbNewLine +_
        "	inner join n5rejestrdok r on s.pRejestrDok = r.idobj " + vbNewLine +_
        "	inner join n5sposplat sp on s.pSposobPlatnosci = sp.idobj " + vbNewLine +_
        "where s.IdObj not in (select pPopSprzed from n5sprzedaz where pPopSprzed <> 0) and sp.eTyp = N5SPOSPLAT_KARTA " + vbNewLine +_
        "	and %1 and %2 and %3 " + vbNewLine +_
        "order by r.strNazwa,s.dDataWyst,k.strNazwa"
end function
%>
<%
function default_param()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("s.dDataWyst") 
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr (terminal)").bindexpr("s.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON) order by strNazwa"
	pParamArray.add pParam2
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa") 
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
  <td style='27' colspan='8'>	
		  <picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
      RXE_TEXT(r_nazwa)
  </td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td align='right'>
    RXE_LP
  </td>
  <td>
    RXE_DATE(s_data_wyst)
  </td>  
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,k_idobj,k_nazwa)  
  </td>
  <td>
    RXE_TEXT(k_nip)
  </td>
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,s_idobj,s_nr_dok)  
  </td>  
  <td align='right'>
    RXE_QUANTITY_CVV(s_kwota,"",2)
  </td> 
  <td align='right'>
    RXE_QUANTITY_CVV(s_kwota_pobr,"",2)
  </td>   
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
  <td width='min'>
    <text><![CDATA[Data wystawienia]]></text>
  </td> 
  <td width='5000'>
    <text><![CDATA[Nazwa firmy]]></text>
  </td>
  <td width='min'>
    <text><![CDATA[NIP]]></text>
  </td>  
  <td width='min'>
    <text><![CDATA[Numer faktury]]></text>
  </td> 
  <td width='2000'>
    <text><![CDATA[Kwota faktury]]></text>
  </td> 
  <td width='2000'>
    <text><![CDATA[Kwota pobrania]]></text>
  </td>   
</tr>
</thead>
<tbody> 
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<% dim nSectionPicCounter : nSectionPicCounter = 10000000 %>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>   
<p><t size='2'/></p>   
  
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  .add_group_section 0,getref("section_header_1"),getref("section_footer_1")
  
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
end if
end with
%>
</body>
<footer>
</footer>
</page>
