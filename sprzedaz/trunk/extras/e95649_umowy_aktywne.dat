<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_UMOWY_AKTYWNE_NIEAKTYWNE

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Umowy aktywne/nieaktywne


-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

function query()
query = "select 'p_idobj'=p.IdObj,'p_nazwisko'=p.strNazwisko,'p_imie'=p.strImie,'u_typ'=u.eTypUmowy, " +_
        "'u_pocz'=u.dDataOd,'u_kon'=u.dDataDo,'u_idobj'=u.IdObj " +_
        "from n5plumowa u " +_
        "inner join n5pracownik p on u.pPracownik = p.IdObj " +_
#ifdef _KOMPOZYTY
        "inner join n5jedn_org jo on p.pJednostkaOrg = jo.idobj " + vbNewLine +_
        "where %1 and %2 and %3 and %4 and %5 and %6 and %7 order by p.strNazwisko"        
#else  
        "where %1 and %2 and %3 and %4 and %5 and %6 order by p.strNazwisko"
#endif        
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("p.strNazwisko")
  pParamArray.add doc_.afc.rap.param.new_text("Imie").bindexpr("p.strImie")
  dim pTypUmowy : set pTypUmowy = doc_.afc.rap.param.new_choice("Typ umowy").bindexpr("u.eTypUmowy")
  with pTypUmowy
	  .multiple = true
    .names.add "Umowa zlecenia"
    .values.add 1
    .selected.add true
    .names.add "Umowa o pracę"
    .values.add 2
    .selected.add True
    .names.add "Umowa o dzieło"
    .values.add 3
    .selected.add true
  end with
  pParamArray.add pTypUmowy
	pParamArray.add doc_.afc.rap.param.new_date_range("Umowa od").bindexpr("u.dDataOd")
  pParamArray.add doc_.afc.rap.param.new_date_range("Umowa do").bindexpr("u.dDataDo")
  dim pStatus : set pStatus = doc_.afc.rap.param.new_choice("Status umowy").bindexpr("")
  with pStatus
	  .multiple = true
    .names.add "Aktywna"
    .values.add 1
    .selected.add true
    .names.add "Nieaktywna"
    .values.add 2
    .selected.add True
  end with
  pParamArray.add pStatus
  
#ifdef _KOMPOZYTY
	pParamArray.add doc_.afc.rap.param.new_text("Wydział").bindexpr("jo.strNazwa")  
#endif
  
	set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>RXE_LP</td>
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRACOWNIK,p_idobj,p_nazwisko)
  </td>
  <td>
    RXE_TEXT(p_imie)
  </td>
	<td>
    <text href='<%so.write rapeng_.href_open_form_proxy(TYPEID_N5PLUMOWA,pRec("u_idobj"))%>'><![CDATA[<%so.write nazwaUmowy(pRec("u_typ"))%>]]></text>		
	</td>
	<td>
		RXE_DATE(u_pocz)
	</td>
  <td>
    RXE_DATE(u_kon)
  </td>
</tr>
<%
end function

function nazwaUmowy(byval eTyp)
  if eTyp = 1 then
    nazwaUmowy = "Umowa zlecenia"
  end if
  if eTyp = 2 then
    nazwaUmowy = "Umowa o pracę"
  end if
  if eTyp = 3 then
    nazwaUmowy = "Umowa o dzieło"
  end if  
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Nazwisko]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Imię]]></text>
	</td>
	<td width='2100'>
		<text><![CDATA[Typ umowy]]></text>
	</td>
	<td width='1700'>
		<text><![CDATA[Umowa od]]></text>
	</td>
  <td width='1700'>
    <text><![CDATA[Umowa do]]></text>
  </td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

   .ReplaceQueryParam "( = '1')","(u.dDataDo >= "  + trans_.afc.convert.date2SQL(CDate(trans_.var(GVAR_TODAY))) +_
                                 " or u.dDataDo = " + trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate()) + ")"
   .ReplaceQueryParam "( = '2')","(u.dDataDo < " + trans_.afc.convert.date2SQL(CDate(trans_.var(GVAR_TODAY))) +_
                                 " and u.dDataDo <> " + trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate()) + ")"
   .ReplaceQueryParam "( IN ('1','2'))","(1=1)"
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
  
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
