<?xml version="1.0" encoding="windows-1250"?>
<!--

TYPEID_N5SPRZEDAZ
TYPEID_N5TRANSAKCJA
TYPEID_N5PRACOWNIK
TYPEID_N5DOKUMENT

#include "h1000.h"
#include "h1200.h"

-->
<nxapprep>
  <objects>
    <object typeid="TYPEID_N5SPRZEDAZ">
      <fields>
        <embedded>
          <name>curSumaBrutto</name>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5SPRZEDAZ##_curSumaBrutto(byref oASP,byref oEVal,byval strCEA,byref pSprzedaz)
	set display_##TYPEID_N5SPRZEDAZ##_curSumaBrutto = display_value_always_cur(oASP,strCEA,pSprzedaz.curSumaBrutto,pSprzedaz.pWaluta)
end function
]]>
            <using>display_value_always_cur</using>
          </display>
        </embedded>
        <embedded>
          <name>curSumaNetto</name>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5SPRZEDAZ##_curSumaNetto(byref oASP,byref oEVal,byval strCEA,byref pSprzedaz)
	set display_##TYPEID_N5SPRZEDAZ##_curSumaNetto = display_value_always_cur(oASP,strCEA,pSprzedaz.curSumaNetto,pSprzedaz.pWaluta)
end function
]]>
            <using>display_value_always_cur</using>
          </display>
        </embedded>
        <embedded>
          <name>dDataPlat</name>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5SPRZEDAZ##_dDataPlat(byref oASP,byref oEVal,byval strCEA,byref pSprzedaz)
	set display_##TYPEID_N5SPRZEDAZ##_dDataPlat = oASP.newcellex(1,strCEA).e_label_date(pSprzedaz.dDataPlat).e_space(2).e_label_int(pSprzedaz.dDataPlat - now())
end function
]]>
          </display>
        </embedded>
        <embedded>
          <name>@curRoznicaBrutto</name>
          <humanname>Różnica Brutto</humanname>
          <sqltype>SQLcurrency</sqltype>
          <getexpression>
            <![CDATA[
					if oObject.pPopSprzed is nothing then
						result = ccur(0.0)
					else
						result = oObject.curSumaBrutto - oObject.pPopSprzed.curSumaBrutto
					end if
					]]>
          </getexpression>
        </embedded>
      </fields>
    </object>
    <object typeid="TYPEID_N5TRANSAKCJA">
      <fields>
        <embedded>
          <name>@curSaldo</name>
          <humanname>Saldo</humanname>
          <sqltype>SQLcurrency</sqltype>
          <getexpression>
            <![CDATA[
						result = oObject.curWn - oObject.curMa
					]]>
          </getexpression>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5TRANSAKCJA##_curSaldo(byref oASP,byref oEVal,byval strCEA,byref pTrans)
	set display_##TYPEID_N5TRANSAKCJA##_curSaldo = display_value_always_cur(oASP,strCEA,oEVal.val(pTrans,"@curSaldo"),pTrans.pWaluta)
end function
]]>						<using>display_value_always_cur</using>
          </display>
        </embedded>
        <embedded>
          <name>curWn</name>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5TRANSAKCJA##_curWn(byref oASP,byref oEVal,byval strCEA,byref pTrans)
	set display_##TYPEID_N5TRANSAKCJA##_curWn = display_value_always_cur(oASP,strCEA,pTrans.curWn,pTrans.pWaluta)
end function
]]>
            <using>display_value_always_cur</using>
          </display>
        </embedded>
        <embedded>
          <name>curMa</name>
          <display usage="browser">
            <![CDATA[
function display_##TYPEID_N5TRANSAKCJA##_curMa(byref oASP,byref oEVal,byval strCEA,byref pTrans)
	set display_##TYPEID_N5TRANSAKCJA##_curMa = display_value_always_cur(oASP,strCEA,pTrans.curMa,pTrans.pWaluta)
end function
]]>
            <using>display_value_always_cur</using>
          </display>
        </embedded>
      </fields>
      <raports>
        <raport title="@ostatnie_transakcje_klienta@">
          <columns>
            <column link="true">
              <header>Symbol</header>
              <path>
                <embedded>strSymTrans</embedded>
              </path>
            </column>
            <column>
              <header>Termin</header>
              <path>
                <embedded>dDataWym</embedded>
              </path>
            </column>
            <column>
              <header>Winien</header>
              <path>
                <embedded>curWn</embedded>
              </path>
            </column>
            <column>
              <header>Ma</header>
              <path>
                <embedded>curMa</embedded>
              </path>
            </column>
            <column>
              <header>Saldo</header>
              <path>
                <embedded>@curSaldo</embedded>
              </path>
            </column>
            <column>
              <header>Typ</header>
              <path>
                <embedded>eTyp</embedded>
              </path>
            </column>
          </columns>
          <orders>
            <order asc="false">
              <path>
                <embedded>dDataRozp</embedded>
              </path>
            </order>
          </orders>
        </raport>
        <raport title="@browser_##TYPEID_N5TRANSAKCJA##@">
          <columns>
            <column link="true">
              <header>Symbol</header>
              <path>
                <embedded>strSymTrans</embedded>
              </path>
            </column>
            <column>
              <header>Winien</header>
              <path>
                <embedded>curWn</embedded>
              </path>
            </column>
            <column>
              <header>Ma</header>
              <path>
                <embedded>curMa</embedded>
              </path>
            </column>
            <column>
              <header>Saldo</header>
              <path>
                <embedded>@curSaldo</embedded>
              </path>
            </column>
          </columns>
          <orders>
            <order>
              <path>
                <embedded>strSymTrans</embedded>
              </path>
            </order>
          </orders>
        </raport>
      </raports>
      <default_search_field>strSymTrans</default_search_field>
    </object>
    <object typeid="TYPEID_N5PRACOWNIK">
      <fields>
        <embedded>
          <name>strNazwisko</name>
          <display usage="suggestion_text">
            <![CDATA[
	function nx_fill_suggestion(byref pPracownik)
	nx_fill_suggestion = pPracownik.strNazwisko + " " + pPracownik.strImie + " (" + pPracownik.strPESEL + ")"
	end function					
	]]>
          </display>
        </embedded>
      </fields>
      <default_search_field>strNazwisko</default_search_field>
    </object>

    <object typeid="TYPEID_N5DOKUMENT">
      <raports>
        <raport title="@browser_##TYPEID_N5DOKUMENT##@">
          <columns>
            <column>
              <path>
                <embedded>strTematDokum</embedded>
              </path>
            </column>
            <column>
              <path>
                <embedded>strNumDok</embedded>
              </path>
            </column>
            <column>
              <path>
                <embedded>strNumDokObcy</embedded>
              </path>
            </column>
            <column>
              <path>
                <ref>pTypDokumentu</ref>
                <embedded>strNazwa</embedded>
              </path>
            </column>
          </columns>
          <orders>
            <order>
              <path>
                <embedded>strNumDok</embedded>
              </path>
            </order>
          </orders>
        </raport>
        <raport title="@fuzzy_##TYPEID_N5DOKUMENT##@">
          <filters>
            <filter>
              <path>
                <embedded>strTematDokum</embedded>
              </path>
            </filter>
            <filter>
              <path>
                <embedded>strNumDok</embedded>
              </path>
            </filter>
            <filter>
              <path>
                <embedded>strStreszczenie</embedded>
              </path>
            </filter>
          </filters>
        </raport>
      </raports>
    </object>
    <object typeid="TYPEID_N5PLUMOWA">
      <raports>
        <raport title="@browser_##TYPEID_N5PLUMOWA##@">
          <columns>
            <column>
              <path>
                <ref>pPracownik</ref>
                <embedded>strNazwisko</embedded>
              </path>
            </column>
            <column>
              <path>
                <embedded>dDataOd</embedded>
              </path>
            </column>
            <column>
              <path>
                <embedded>dDataDo</embedded>
              </path>
            </column>
          </columns>
          <orders>
            <order>
              <path>
                <ref>pPracownik</ref>
                <embedded>strNazwisko</embedded>
              </path>
            </order>
            <order>
              <path>
                <embedded>dDataOd</embedded>
              </path>
            </order>
          </orders>
        </raport>
      </raports>
      <default_search_field>dDataRej</default_search_field>
    </object>
  </objects>
</nxapprep>