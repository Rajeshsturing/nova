<?xml version="1.0" encoding="windows-1250" ?>

<!-- KOREKTA RACHUNKU -->
<!-- 8.06.2004 poprawka - oryginal/kopia, adresy, zamowienie -->
<!-- 20.06.2004 rabat%-->
<!-- 21.06.2004 adnotacje -->
<!-- 14.09.2004 data wystawienia z bazy -->
<!-- 2.12.2004 adres poprawki -->

#define CTRLID_ORGKOPIA					101

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto %>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>
 

<!-- Dane nabywcy - dokument oryginalny -->
#define DOK_ORG_KLIENT_NAZWA			<% if not root_.pPopSprzed is nothing then so.write util_.Klient_Nazwa(root_.pPopSprzed.pKlient) end if %>
#define DOK_ORG_KLIENT_NIP				<% if not root_.pPopSprzed is nothing then so.write util_.Klient_NIP(root_.pPopSprzed.pKlient) end if  %>
#define DOK_ORG_KLIENT_KOD_MIASTO		<% if root_.pPopSprzed.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pPopSprzed.pKlient) else if root_.pPopSprzed.pKlient.strPoczta<>"" and  root_.pPopSprzed.pKlient.strPoczta<>root_.pPopSprzed.pKlient.pMiejscowosc.strNazwa then so.write root_.pPopSprzed.pKlient.strKod + " " + root_.pPopSprzed.pKlient.strPoczta else if  root_.pPopSprzed.pKlient.strPoczta=root_.pPopSprzed.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pPopSprzed.pKlient) end if end if end if%>
#define DOK_ORG_KLIENT_ULICA_NUMER		<% if not root_.pPopSprzed is nothing then so.write util_.Klient_Ulica(root_.pPopSprzed.pKlient)  end if %>
#define DOK_ORG_KLIENT_MIASTO			<% if not root_.pPopSprzed is nothing then so.write root_.pPopSprzed.pKlient.pMiejscowosc.strNazwa end if %>

#define DOK_ORG_KLIENT_JO_NAZWA			<% if not root_.pPopSprzed is nothing then so.write util_.Klient_Nazwa(root_.pPopSprzed.pKlient_JO) end if %>
#define DOK_ORG_KLIENT_JO_KOD_MIASTO		<% if root_.pPopSprzed.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pPopSprzed.pKlient_JO) else if root_.pPopSprzed.pKlient_JO.strPoczta<>"" and  root_.pPopSprzed.pKlient_JO.strPoczta<>root_.pPopSprzed.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pPopSprzed.pKlient_JO.strKod + " " + root_.pPopSprzed.pKlient_JO.strPoczta else if  root_.pPopSprzed.pKlient_JO.strPoczta=root_.pPopSprzed.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pPopSprzed.pKlient_JO) end if end if end if%>
#define DOK_ORG_KLIENT_JO_ULICA_NUMER	<% if not root_.pPopSprzed is nothing then so.write util_.Klient_Ulica(root_.pPopSprzed.pKlient_JO) end if %>
#define DOK_ORG_KLIENT_JO_MIASTO		<% if not root_.pPopSprzed is nothing then so.write root_.pPopSprzed.pKlient_JO.pMiejscowosc.strNazwa end if%>
 

<!-- Informacje na rachunku -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_SPRZEDAZY			<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(root_.curSumaBrutto) %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaBrutto) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT				<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_ZAMOWIENIE				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_ZAMOWIENIE_NR_OBCY		<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.zam_strNrDokObcy end if  %>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>

#define DOK_ORG_DOKUMENT_NUMER				<% if not root_.pPopSprzed is nothing then so.write root_.pPopSprzed.text end if %>
#define DOK_ORG_DOKUMENT_DATA_SPRZEDAZY		<% if not root_.pPopSprzed is nothing then so.write doc_.afc.display.fulldate(root_.pPopSprzed.dDataWyst) end if  %>
#define DOK_ORG_DOKUMENT_TERMIN_PLATNOSCI	<% if not root_.pPopSprzed is nothing then so.write doc_.afc.display.fulldate(root_.pPopSprzed.dDataPlat) end if  %>
#define DOK_ORG_DOKUMENT_SPOSOB_PLATNOSCI	<% if not root_.pPopSprzed is nothing then so.write util_.Dokument_Sposob_Platnosci(root_.pPopSprzed)  end if %>
#define DOK_ORG_DOKUMENT_DO_ZAPLATY			<% if not root_.pPopSprzed is nothing then so.write MONEY(root_.pPopSprzed.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_DO_ZAPLATY_SLOWNIE	<% if not root_.pPopSprzed is nothing then so.write doc_.afc.display.slownie(root_.pPopSprzed.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_NETTO		<% if not root_.pPopSprzed is nothing then so.write MONEY(root_.pPopSprzed.curSumaNetto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_VAT			<% if not root_.pPopSprzed is nothing then so.write MONEY(root_.pPopSprzed.curSumaVat) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_BRUTTO		<% if not root_.pPopSprzed is nothing then so.write MONEY(root_.pPopSprzed.curSumaBrutto) end if %>


<!-- pozycje rachunku -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNetto) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>



<!-- podsumowanie pozycji -->
#macro DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_VAT(_eVat_)			<% so.write util_.vat_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>


<!-- podsumowanie pozycji - dokument oryginalny-->
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_.pPopSprzed) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_VAT(_eVat_)			<% so.write util_.vat_dla_stawki(_eVat_,root_.pPopSprzed) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_.pPopSprzed) %>
#macro DOK_ORG_DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>


#define KWOTA_ROZNICA_NETTO_OPIS		<% so.write util_.Korekta_Roznica_Netto_Opis(root_) %>
#define KWOTA_ROZNICA_NETTO_WARTOSC		<% so.write util_.Korekta_Roznica_Netto_Wartosc(root_) %>
#define KWOTA_ROZNICA_VAT_OPIS			<% so.write util_.Korekta_Roznica_Vat_Opis(root_) %>
#define KWOTA_ROZNICA_VAT_WARTOSC		<% so.write util_.Korekta_Roznica_Vat_Wartosc(root_) %>

<!--

-->



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"

function fprint 
	fprint = doc_.getmodule(60182).fprint_on_dpc_org_kopia(page_.get_this,CTRLID_ORGKOPIA) 
end function

VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>


						<!-- Nagłówek -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[KOREKTA NR DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[RACHUNKU NR DOK_ORG_DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t name='CTRLID_ORGKOPIA' bold='true'>Oryginał</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

							
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'>BYŁO</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)

<% if not root_.pPopSprzed is nothing then %>

						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<!-- Dane nabywcy - Klient - jednostka organizacyjna-->
						<% if not root_.pPopSprzed.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pPopSprzed.pKlient_JO.strPoczta<>"") and (root_.pPopSprzed.pKlient_JO.pMiejscowosc.strNazwa <> root_.pPopSprzed.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<% else %>
										
						<!-- Dane nabywcy - KLIENT -->
										
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pPopSprzed.pKlient.strPoczta<>"") and (root_.pPopSprzed.pKlient.pMiejscowosc.strNazwa <> root_.pPopSprzed.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<% end if %>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>
						
						ROW_SEPARATOR(3)
						<!-- płatności -->

						<tr>
							<td>
								<t bold='true'>Data sprzedaży:</t>
							</td>
							<td>								
								<t><![CDATA[DOK_ORG_DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>							
							<td  keepline='true'>
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOK_ORG_DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOK_ORG_DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>
						

					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<%
				iter = 1
				'flaga dla kolejnych stawek VAT - czy drukowac je na podsumowaniu
				dim pVATArrayDO:set pVATArrayDO = trans_.afc.new_navoarray()
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td align='right'>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<t>PKWiU</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena netto</text>
							</td>
							<td align='right'>
								<text>Rabat</text>
							</td>
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.pPopSprzed.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min' align='right'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='center'>
								<text><![CDATA[POZ_JM]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
							if not pVATArrayDO.exists(clng(pozycja.eVat)) then
								pVATArrayDO.add(clng(pozycja.eVat))
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							for iter=0 to pVATArrayDO.UpperIndex()
						%>
						<tr>
							<td colspan='8' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><![CDATA[DOK_ORG_DOKUMENT_PODSUMOWANIE_NETTO(pVATArrayDO.value(iter))]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOK_ORG_DOKUMENT_PODSUMOWANIE_STAWKA(pVATArrayDO.value(iter))]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOK_ORG_DOKUMENT_PODSUMOWANIE_VAT(pVATArrayDO.value(iter))]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOK_ORG_DOKUMENT_PODSUMOWANIE_BRUTTO(pVATArrayDO.value(iter))]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		



		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table >
					<tbody>

<!-- Koniec sekcji z dokumentem oryginalnym -->
<% end if %>


						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'>MA BYĆ</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)



						<!-- Dane nabywcy - KLIENT - jednostka organizacyjna -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>			
						
						<% if not root_.pKlient_JO is nothing then %>

						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>			
						<tr>
 							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<% else %>
						<!-- Dane nabywcy - KLIENT -->

						<tr>
 							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<% end if %>
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						ROW_SEPARATOR(3)	
						
						<!-- płatności -->

						<tr>
							<td>
								<t bold='true'>Data sprzedaży:</t>
							</td>
							<td >								
								<t><![CDATA[DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>							
							<td keepline='true' >
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>
						ROW_SEPARATOR(3)							
						
						<!-- dokumenty powiazane - zamowienie -->
						<% if not root_.pZamowienie is nothing then %>				
						<tr>
							<td>
								<t bold='true'>Zamówienie</t>						
							</td>
							<td>
								<t/>
							</td>							
							<td>
							</td>							

						</tr>
						<tr>
							<td>
								<t size='3'/><t bold='true'>Nr. obcy:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE_NR_OBCY]]></t>
							</td>							
							<td>
							</td>							

						</tr>

						<tr>
							<td>
								<t size='3'/><t bold='true'>Nr. dokumentu:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE]]></t>
							</td>							
							<td>
							</td>							

						</tr>

						<% end if %>						


					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				'flaga dla kolejnych stawek VAT - czy drukowac je na podsumowaniu
				dim pVATArray:set pVATArray = trans_.afc.new_navoarray()
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td>
								<text>Indeks</text>
							</td>
							<td align='center'>
								<t>PKWiU</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena netto</text>
							</td>
							<td align='right'>
								<text>Rabat</text>
							</td>
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='center'>
								<text><![CDATA[POZ_JM]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
							if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							for iter=0 to pVATArray.UpperIndex()
						%>
						<tr>
							<td colspan='8' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO(pVATArray.value(iter))]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA(pVATArray.value(iter))]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_VAT(pVATArray.value(iter))]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO(pVATArray.value(iter))]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie: </t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_DO_ZAPLATY_SLOWNIE]]></t>
			</td>
		</tr>

		<tr>
			<td>
				<table>
					<tbody>
						<tr>
							<td width='min'>				
								<t bold='true'><![CDATA[KWOTA_ROZNICA_NETTO_OPIS]]></t>
							</td>
							<td>
								<t size='3'/>				
								<t bold='true'><![CDATA[KWOTA_ROZNICA_NETTO_WARTOSC]]></t>
							</td>
						</tr>
						<tr>
							<td  width='min'>				
								<t bold='true'><![CDATA[KWOTA_ROZNICA_VAT_OPIS]]></t>
							</td>
							<td>				
								<t size='3'/>
								<t bold='true'><![CDATA[KWOTA_ROZNICA_VAT_WARTOSC]]></t>
							</td>
						</tr>
					</tbody>
				</table>				
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'>
							</td>						
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td>
							</td>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia rachunku</t>
							</td>
							<td>
							</td>							
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby uprawnionej do odbioru rachunku</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
