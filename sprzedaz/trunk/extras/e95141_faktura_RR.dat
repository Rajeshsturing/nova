<?xml version="1.0" encoding="windows-1250" ?>


<!-- ZAKUP RR -->
<!-- 12.06.2004 - poprawki adres-->
<!-- 21.06.2004 adnotacje -->
<!-- 5.07.2004 dodanie zamowienia i nr.obcego -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->
<!-- 2.12.2004 adresy poprawki -->

#define CTRLID_ORGKOPIA                                                     101

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
 

<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pDostawca) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pDostawca) %>
#define KLIENT_KOD_MIASTO		<% if root_.pDostawca.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pDostawca) else if root_.pDostawca.strPoczta<>"" and  root_.pDostawca.strPoczta<>root_.pDostawca.pMiejscowosc.strNazwa then so.write root_.pDostawca.strKod + " " + root_.pDostawca.strPoczta else if  root_.pDostawca.strPoczta=root_.pDostawca.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pDostawca) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pDostawca) %>
#define KLIENT_MIASTO					<% so.write root_.pDostawca.pMiejscowosc.strNazwa %>
#define KLIENT_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pDostawca) %>
#define KLIENT_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pDostawca) %>
#define KLIENT_PESEL				<% so.write root_.pDostawca.strPESEL %>
#define KLIENT_NR_DOK				<% so.write root_.pDostawca.strNrDokTozsamosci %>
#define KLIENT_DOK_WYD				<% so.write root_.pDostawca.kli_strDTOrganWyst%>
#define KLIENT_DOK_DATA_WYD			<% so.write root_.pDostawca.kli_dDTDataWyst%>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pDostawca_JO) %>
#define KLIENT_JO_KOD_MIASTO		<% if root_.pDostawca_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pDostawca_JO) else if root_.pDostawca_JO.strPoczta<>"" and  root_.pDostawca_JO.strPoczta<>root_.pDostawca_JO.pMiejscowosc.strNazwa then so.write root_.pDostawca_JO.strKod + " " + root_.pDostawca_JO.strPoczta else if  root_.pDostawca_JO.strPoczta=root_.pDostawca_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pDostawca_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pDostawca_JO) %>
#define KLIENT_JO_RACHUNEK_BANKOWY_BANK	<% so.write util_.Klient_Bank(root_.pDostawca_JO) %>
#define KLIENT_JO_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Klient_Bank_Numer(root_.pDostawca_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pDostawca_JO.pMiejscowosc.strNazwa %>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_ZAKUPU			<% so.write doc_.afc.display.fulldate(root_.dDataZakupu) %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(root_.curSumaBrutto) %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaBrutto) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_VAT_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_POWIAZANY				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_OBCY_NR				<% so.write root_.strNrDokObcy %>

#define DOKUMENT_ODBIORCA_FAKTURY		<% if not root_.pDostawca is nothing then so.write root_.pDostawca.strImie+" "+root_.pDostawca.strNazwisko end if %>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% if pozycja.eVat = 12 then so.write "6%" else so.write util_.vat_to_name(pozycja.eVat) end if %>
#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNettoWal) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>


<!-- podsumowanie pozycji -->
#macro DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_VAT(_eVat_)		<% so.write util_.vat_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% if _eVat_ = 12 then so.write "6%" else so.write util_.vat_to_name(_eVat_) end if %>


<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"

function fprint 
            fprint = doc_.getmodule(60182).fprint_on_dpc_org_kopia(page_.get_this,CTRLID_ORGKOPIA) 
end function

VB_PRINTPREV_DPC 
]]></script>

	
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table>
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>
						</tr>
						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[FAKTURA VAT RR]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t name='CTRLID_ORGKOPIA' bold='true'>Oryginał</t>
							</td>
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

						<!-- Dane dostawcy - KLIENT -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Dostawca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if not root_.pDostawca_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pDostawca_JO.strPoczta<>"") and (root_.pDostawca_JO.pMiejscowosc.strNazwa <> root_.pDostawca_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[KLIENT_JO_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[KLIENT_JO_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

						<% else %>
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pDostawca.strPoczta<>"") and (root_.pDostawca.pMiejscowosc.strNazwa <> root_.pDostawca.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[KLIENT_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[KLIENT_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>PESEL:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_PESEL]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Nr.dowodu os.:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NR_DOK]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Data wydania:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_DOK_DATA_WYD]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Organ wydający:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_DOK_WYD]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<%end if%>
						ROW_SEPARATOR(1)
						<tr>
							<td  keepline='true'>
								<t bold='true'>Data zakupu:</t>								
							</td>
							<td >
								<t><![CDATA[DOKUMENT_DATA_ZAKUPU]]></t>							
							</td>							
							<td  keepline='true'>
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>
						<!-- dokumenty obcy nr-->			
						<tr>
							<td>
								<t bold='true'>Obcy numer dokumentu:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_OBCY_NR]]></t>
							</td>							
							<td>
							</td>							

						</tr>
						ROW_SEPARATOR(3)
						<% if not root_.pZamowienie is nothing then %>				
						
						
						<tr>
							<td>
								<t bold='true'>Zamówienie:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_POWIAZANY]]></t>
							</td>							
							<td>
							</td>							

						</tr>
						<% end if %>
					</tbody>
				</table>
			</td>
		</tr>			


		ROW_SEPARATOR(1)	

		

		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				'flaga dla kolejnych stawek VAT - czy drukowac je na podsumowaniu
				dim pVATArray:set pVATArray = trans_.afc.new_navoarray()
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td>
								<text>Indeks</text>
							</td>
							<td align='center'>
								<t>PKWiU</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena netto</text>
							</td>							
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>							
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
							if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='6' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true' bordercolor='#000000'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							for iter=0 to pVATArray.UpperIndex()
						%>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO(pVATArray.value(iter))]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA(pVATArray.value(iter))]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_VAT(pVATArray.value(iter))]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO(pVATArray.value(iter))]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie:</t>
