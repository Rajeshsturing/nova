			</td>
		</tr>

		ROW_SEPARATOR(1)	

		<tr>
			<td keepline='true'>
				<t fontsize='5' bold='true'>Wartość zryczałtowanego podatku:</t>
				<t size='3'/>
				<t fontsize='5' bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie:</t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_WARTOSC_VAT_SLOWNIE]]></t>
			</td>
		</tr>
		
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>
						ROW_SEPARATOR(3)

						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>
							<td/>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_ODBIORCA_FAKTURY]]></text>
							</td>
						</tr>
						<tr>
							<td align='center'>
								<t>.........................................................................</t>
							</td>
							
							<td/>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>
						</tr>
						<tr>
							<td align='center'>
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia faktury</t>
							</td>
							<td/>
							<td align='center'>
								<t fontsize='2'>Imię i nazwisko, podpis oraz pokwitowanie odbioru</t><t fontsize='2'>oryginału faktury VAT - RR</t>
							</td>																				
						</tr>
						
						ROW_SEPARATOR(3)
						
						ROW_SEPARATOR(3)	
						<tr>
							<td align='left' colspan='3'>
								<text>Oświadczam, że jestem rolnikiem ryczałtowym zwolnionym od podatku od towarów i usług na podstawie art. 43 ust. 1 pkt 3 ustawy z dnia 11 marca 2004r. o podatku od towarów i usług oraz o podatku akcyzowym.</text>	
							</td>
						</tr>

						ROW_SEPARATOR(3)
