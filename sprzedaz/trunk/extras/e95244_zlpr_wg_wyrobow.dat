<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZLECPROD_WG_WYROBOW

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zlecenia produkcyjne do realizacji wg wyrobów 
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=max(t_prod.strNazwa),'c_1'=max(isnull(t_klient.strNazwa,'<brak>')),'c_2'=max(vzp.p_strNrDok), " +_
"'c_4'=vzp.p_IdObj,'c_5'=sum(vzp.c_curIloscOpak),'c_6'=sum(vzp.c_curIloscOpakPoz), " +_
"'c_jedn' = max(t_jedn.strSkrot),'c_prec'=max(t_jedn.nDokladnosc),'c_idprod'=t_prod.IdObj,'c_idklient'=isnull(t_klient.Idobj,0) " +_
#ifdef _FRAM
",'status'=case when max(vzp.p_zlp_estatus) = 0 then 'brak' else " +_
"		  case when max(vzp.p_zlp_estatus) = 1 then 'nowe' else " +_
"		  case when max(vzp.p_zlp_estatus) = 2 then 'w produkcji' else " +_
"		  case when max(vzp.p_zlp_estatus) = 3 then 'zakończone' else " +_
"		  case when max(vzp.p_zlp_estatus) = 4 then 'anulowane' else " +_
"		  case when max(vzp.p_zlp_estatus) = 5 then 'zmodyfikowane'  " +_
"		  end end end end end end " +_
#endif
"from vlist_n5zlecprod_listpozycje as vzp " +_
"inner join n5produkt as t_prod on vzp.c_pProdukt = t_prod.IdObj " +_
"left outer join n5klient as t_klient on vzp.p_pKlient = t_klient.IdObj " +_
"inner join n5opakowanie_produktu as t_opak on vzp.c_pOpak = t_opak.IdObj " +_
"inner join n5jednostka as t_jedn on t_opak.pJednOpak = t_jedn.IdObj " +_
#ifdef _FRAM
"where  %1  and  %2  and  %3  and  %4 and EXTRA_CUSTOMER_FILTER_AND(5) and %6 " +_
#else
"where  %1  and  %2  and  %3  and  %4 and EXTRA_CUSTOMER_FILTER_AND(5) " +_
#endif
"group by t_klient.Idobj,vzp.p_idobj,t_prod.IdObj,t_opak.IdObj " +_
"having sum(vzp.c_curIloscOpakPoz) > 0" +_
"order by c_0,c_1"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_prod.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_prod.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("isnull(t_klient.strNazwa,'<brak>')")
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin realizacji").bindexpr("vzp.p_dDataReal")
	EXTRA_CUSTOMER_FILTER_PARAM(t_klient)
  
#ifdef _FRAM  
  dim pParamStatus:	set pParamStatus = doc_.afc.rap.param.new_choice("Status").bindexpr("vzp.p_zlp_estatus")
	with pParamStatus
		.multiple = true
			.names.add "nowe"
			.values.add clng(N5ZLECPRODS_HORYZONT_NOWE)
			.selected.add True
		.names.add "w produkcji"
		.values.add clng(N5ZLECPRODS_HORYZONT_W_PRODUKCJI)
		.selected.add True
			.names.add "zakończone"
			.values.add clng(N5ZLECPRODS_HORYZONT_ZAKONCZONE)
			.selected.add True
		.names.add "anulowane"
		.values.add clng(N5ZLECPRODS_HORYZONT_ANULOWANE)
		.selected.add True
		  .names.add "zmodyfikowane"
		  .values.add clng(N5ZLECPRODS_HORYZONT_ZMODYFIKOWANE)
		  .selected.add True    
		.names.add "brak"
		.values.add 0
		.selected.add True
	end with
  pParamArray.add pParamStatus 
#endif  

	set default_param = pParamArray
end function
%>
<%
dim g_strJedn
dim g_nPrec
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
#ifdef _FRAM
	<td style='27' colspan='7'>
#else
	<td style='27' colspan='6'>
#endif
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_idprod,c_0)
	<%
	g_strJedn = pRec("c_jedn")
	g_nPrec = clng(pRec("c_prec")-1)
	%>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr fontsize='5'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(0).result,g_strJedn,g_nPrec)
	</td>
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(1).result,g_strJedn,g_nPrec)
	</td>
#ifdef _FRAM
  <td style='27'></td>
#endif
</tr>
<tr border='0'><td colspan='6' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='6' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
#ifdef _FRAM
	<td style='27' colspan='6'>
#else
	<td style='27' colspan='5'>
#end
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	<%if clng(pRec("c_idklient")) <> 0 then %>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,c_idklient,c_1)
	<% else %>
		RXE_AUTO_TEXT(c_1)
	<%end if%>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(0).result,g_strJedn,g_nPrec)
	</td>
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(1).result,g_strJedn,g_nPrec)
	</td>
#ifdef _FRAM
  <td style='27' />
#endif
</tr>
<tr border='0'><td colspan='6' /></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='6' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5ZLECPROD,c_4,c_2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_5,c_jedn,c_prec)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_6,c_jedn,c_prec)
	</td>
#ifdef _FRAM
	<td align='center'>
		RXE_TEXT(status)
	</td>
#endif  
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='5000'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość zamówiona]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość pozostała]]></text>
	</td>
#ifdef _FRAM
	<td width='2000' align='center'>
		<text><![CDATA[Status]]></text>
	</td>
#endif    
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_5").add_sumator("c_6")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_5").add_sumator("c_6")
	.add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("c_5").add_sumator("c_6")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
