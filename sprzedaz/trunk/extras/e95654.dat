<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_OPLATA_PZZIPZ
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE Opłaty na fundusz PZZiPZ
#define NAGLOWEK_SEKCJI <text><% so.write cStr(pRec("strPcn")) + "  " + cStr(pRec("strGrupaProd")) %></text>

#define NAZWA_FUNDUSZU                                      \
<text fontsize = '6'>                                        \
    <%                                                      \
        dim strFund : strFund = pRec("strFund").value       \
                                                            \
        if strFund = "1" then                               \
          so.write "Fundusz Promocji Mleka"                  \
        elseif strFund = "2" then                            \
          so.write "Fundusz Promocji Mięsa Wieprzowego"     \
        elseif strFund = "3" then                           \
          so.write "Fundusz Promocji Mięsa Wołowego"        \
        elseif strFund = "4" then                           \
          so.write "Fundusz Promocji Mięsa Końskiego"       \
        elseif strFund = "5" then                           \
          so.write "Fundusz Promocji Mięsa Owczego"         \
        elseif strFund = "6" then                           \
          so.write "Fundusz Promocji Zierna Zbóż i Przetworów Zbożowych" \
        elseif strFund = "7" then                           \
          so.write "Fundusz Promocji Owoców i Warzyw"       \
        elseif strFund = "8" then                           \
          so.write "Fundusz Promocji Mięsa Drobiowego"      \
        elseif strFund = "9" then                           \
           so.write "Fundusz Promocji Ryb"                  \
        end if                                              \
     %>                                                     \
</text>


-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

dim curOplataSekcja : curOplataSekcja = 0                         'suma opłat w sekcji, ze względu na format opłaty w bazie nie można skorzystać funckji silnika
dim curOplataRaport : curOplataRaport = 0                         'suma opłat w całym raporcie, ze względu na format opłaty w bazie nie można skorzystać funckji silnika

function query()

	query = " select "+_
          " 'strFund' = RIGHT(isnull(max(v_zakup.c_strExtra2), ''), 1), "+_
          " 'strPcn' = isnull(max(t_pcn.pcn_strKod),0), "+_
          " 'dDataWyst' = max(v_zakup.p_dDataWyst), "+_
          " 'strKlient' = isnull(max(t_klient.strNazwa), ''), "+_
          " 'strNrDok' = v_zakup.p_strNrDok,'IdZakup'=max(v_zakup.p_idobj), "+_
          " 'strProdukt' = isnull(max(t_prod.strNazwa), ''), "+_
          " 'strGrupaProd' = isnull(max(t_grupa.strNazwa),''), "+_
          " 'c_curNetto' = sum(v_zakup.c_curWartNetto), "+_
          " 'c_pzz' = max(v_zakup.c_strExtra2),'lp'=max(v_zakup.coll_lp), "+_
          " 'c_ilosc' = max(v_zakup.c_curIloscOpak*1000) "+_
          " from vlist_n5zakup_listpozycje v_zakup "+_
          " left outer join n5klient t_klient on v_zakup.p_pDostawca = t_klient.idobj "+_
          " left outer join n5produkt t_prod on v_zakup.c_pProdukt = t_prod.idObj "+_
          " left outer join n5opakowanie_produktu opak on v_zakup.c_popak = opak.IdObj " +_
          " left outer join n5kodpcn t_pcn on t_prod.prod_pKodCelny = t_pcn.idObj "+_
          " left outer join n5grupaproduktow t_grupa on t_prod.pGrupaProd = t_grupa.idObj "+_
          " where v_zakup.c_strExtra2 <> '' and %1 and %2 and %3 and %4"+_
          " group by RIGHT(v_zakup.c_strExtra2, 1), t_pcn.pcn_strKod, v_zakup.p_strNrDok "+_
          " order by 1,2 "


 
end function
%>
<%

function default_param()

  dim pParamArray
  
	set pParamArray = doc_.afc.new_navoarray()
  
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("v_zakup.p_dDataWyst")
  pParamArray.add doc_.afc.rap.param.new_text("Numer dokumentu").bindexpr("v_zakup.p_strNrDok")
  pParamArray.add doc_.afc.rap.param.new_text("Kod PCN").bindexpr("t_pcn.pcn_strKod")
  pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_grupa.strNazwa")

	set default_param = pParamArray
  
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>

<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
      NAZWA_FUNDUSZU
  </td>

</tr>

<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='10'>
  </td>
  
  
</tr>
<tr border='0'><td colspan='9' /></tr>
<%
end function
%>


<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	  NAGLOWEK_SEKCJI
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='9' /></tr>
<tr bold = 'true' fontsize='4'>
	<td style='27' colspan='5' />
  <td style='27' align='right'>
    <t><%so.write doc_.afc.display.quantity(pSection.counter(1).result,"",0)%></t>
  </td>  
  <td style='27' align='right'>
    <t><%so.write doc_.afc.display.quantity(pSection.counter(0).result,"",2)%></t>
  </td>
  <td style='27' align='right'>
    <t><%
         so.write doc_.afc.display.quantity(curOplataSekcja,"",2)
         curOplataraport = curOplataRaport + curOplataSekcja
         curOplataSekcja = 0
       %>
    </t>
  </td>
  
</tr>
<tr border='0'><td colspan='9' /></tr>
<%
end function
%>


<%
function write_actual_param(byref pActualParam)
	write_actual_param = "0=1" 

	dim iter
	dim bAnyWritten : bAnyWritten = false

	if not pActualParam is nothing then
		for iter = 0 to pActualParam.upperIndex
			if pActualParam.value(iter).get_desc() <> "" then 
				bAnyWritten = true
				so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
			end if
		next
	end if

	if not bAnyWritten then 
		so.write "<t fontsize='4'>brak</t><br/>"
	end if

	so.write "<br/>"
end function
%>

<%
function body_row(byref pSection,byref pRec)

if pRapExec.RecNr mod 2 = 0 then
%>

<tr bordercolor='white'>

<%
else
%>

<tr bordercolor='white' style='37'>

<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(ddatawyst)
	</td>
	<td>
	  RXE_TEXT(strKlient)
	</td>
  <td align='right'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZAKUP,IdZakup,strNrDok)
	</td>
   <td align='right'>
		RXE_QUANTITY_CVV(c_ilosc,"",0)
	</td>	
  <td align='right'>
	  RXE_QUANTITY_CVV(c_curNetto,"",2)
	</td>
  
<%

'------Wyciąganie z bazy należnee opłaty PZZiPZ---------------
  dim strOplata : stroplata = pRec("c_pzz").value
  dim nLP: nLP = cint(pRec("lp").value)
  dim strFund: strFund = pRec("strFund").value
  
  if strOplata <> "" then
    dim curOplata : curOplata = mid(strOplata, 1, instr(strOplata, ";")-1)
  else
    curOplata = 0
  end if

  curOplata = trans_.afc.convert.roundn(ccur(curOplata), 0)
  
  'dodaj opłatę z kolejnych pozycji
  dim pZakup: set pZakup = trans_.getobj(TYPEID_N5ZAKUP,clng(pRec("IdZakup").value))
  dim pPoz, iter: iter = 1
  for each pPoz in pZakup.listPozycje
    if iter <> nLP then
      dim curOpl : curOpl = ccur(0)
      if pPoz.strExtra2 <> "" then
        curOpl = trans_.afc.convert.roundn(ccur(mid(pPoz.strExtra2, 1, instr(pPoz.strExtra2, ";")-1)), 0)
        dim strFun: strFun = right(pPoz.strExtra2, 1)
        if strFund = strFun then
          curOplata = curOplata + curOpl
        end if
      end if
    end if
    iter = iter + 1
  next
  
  curOplataSekcja = curOplataSekcja + curOplata
%>
  <td align='right'>
		<text><% so.write doc_.afc.display.quantity(curOplata,"",2) %></text>
	</td>	
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Dostawca]]></text>
	</td>
	<td width='max'>
		<t><![CDATA[Numer dokumentu]]></t>
	</td>
  <td width='min'>
    <text><![CDATA[Ilość [kg]]]></text>
  </td>
	<td width='min'>
		<t><![CDATA[Wartość Netto]]></t>
	</td>
  <td width='min'>
    <t><![CDATA[Opłata PZZiPZ]]></t>
  </td>
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='10' />
</tr>
<tr bold = 'true' fontsize='6'>
  <td style='27' colspan='5' />
  <td style='27' align='right'>
    <t><%so.write doc_.afc.display.quantity(pSection.counter(1).result,"",0)%></t>
  </td>  
  <td style='27' align='right'>
    <t><%so.write doc_.afc.display.quantity(pSection.counter(0).result,"",2)%></t>
  </td>
  <td style='27' align='right'>
    <t>
      <%
          so.write doc_.afc.display.quantity(curOplataRaport,"",2)
          curOplataRaport = 0
      %>
    </t>
  </td>
  <td style='27'/>
</tr>
<tr border='0'>
  <td colspan='9' />
</tr>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamTypPro
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_curNetto").add_sumator("c_ilosc")
  .add_group_section 0,getref("section_header_1"),getref("section_footer_1")
  .add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("c_curNetto").add_sumator("c_ilosc")
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

  dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())



  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
 end if 
end if
end with
%>
</body>
<footer>
</footer>
</page>
