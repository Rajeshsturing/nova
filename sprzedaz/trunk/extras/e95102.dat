<?xml version="1.0" encoding="windows-1250" ?>

<!-- Przychod wewnetrzny -->
<!-- 8.06.2004 poprawka - adres- poczta -->
<!-- 21.06.2004 adnotacje -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->
#include "1203.h"

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma.strKod else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(root_.curSumaMag)%>
#define	DOKUMENT_WARTOSC_EWID			<% so.write MONEY(curSumaWartEwid)%>
#define DOKUMENT_MAGAZYN				<% if not root_.pMagDocel is nothing then so.write root_.pMagDocel.text end if %>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi%>

#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_CENA_DOSTAWY				<% so.write MONEY(pozycja.curCenaMag) %>
#define POZ_CENA_DOSTAWY_WG_CEN_EWID	<% so.write doc_.afc.display.quantity(curCenaEwid,"",2) %>	
#define POZ_WARTOSC						<% so.write MONEY(pozycja.curWartMag) %>
#define POZ_WARTOSC_WG_CEN_EWID			<% so.write MONEY(ccurWartEwRow) %>
#define POZ_MAGAZYN						<% if not pozycja.pMagDocel is nothing then so.write pozycja.pMagDocel.text end if %>
#define POZ_UWAGI						<% if pozycja.strUwagi <> "" then so.write pozycja.strUwagi end if %>






<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Przychód wewnętrzny nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>

					</tbody>
				</table>
			</td>
		</tr>

		<tr>
			<td>
				<table>
					<tbody>	
						ROW_SEPARATOR(2)
						<tr>
							<td width='min'>
								<t bold='true'>Data wystawienia:&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>						
						</tr>

						<tr>
							<td width='min'>
								<t bold='true'>Magazyn przyjęcia:&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_MAGAZYN]]></t>
							</td>						
						</tr>
						
																																								
					</tbody>
				</table>
			</td>
		</tr>



		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa towaru / usługi</text>
							</td>							
							<td align='right'>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena dostawy</text>
							</td>
							<td align='right'>
								<text>Wartość</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%	dim iter,pozycja
							iter = 1
							
							dim curSumaWartEwid:curSumaWartEwid = ccur(0)

							for each pozycja in root_.listPozycje 
						%>
						<tr>
							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
								<text><![CDATA[POZ_UWAGI]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_JM]]></text>								
							</td>
							<td align='right'>
#ifdef _CTP
<%					dim oProd: set oProd = pozycja.pProdukt
					dim curCenaEwid: curCenaEwid = oProd.listOpakowania.get(1).curCenaNetto4
					%>
								<t><![CDATA[POZ_CENA_DOSTAWY_WG_CEN_EWID]]></t>
#else
								<t><![CDATA[POZ_CENA_DOSTAWY]]></t>
#endif
							</td>
							<td align='right'>
#ifdef _CTP
<%dim ccurWartEwRow : ccurWartEwRow = ccur(curCenaEwid) * ccur(pozycja.curIloscOpak)%>
								<%curSumaWartEwid = curSumaWartEwid + ccurWartEwRow%>

								<t><![CDATA[POZ_WARTOSC_WG_CEN_EWID]]></t>
#else
								<t><![CDATA[POZ_WARTOSC]]></t>
#endif
							</td>
						</tr>
						<%		iter = iter + 1
							next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='3' bordercolor='transparent'>
							</td>
							<td colspan='3'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
#ifdef _CTP
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_EWID]]></t>
#else
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC]]></t>
#endif
							</td>							
						</tr>	
					</tfoot>					
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td width='min' align='center'>	
								<t fontsize='2'>Imię , nazwisko i podpis osoby zatwierdzającej operację</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
