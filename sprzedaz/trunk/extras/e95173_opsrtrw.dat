<?xml version="1.0" encoding="windows-1250" ?>

<!-- 
Operacja na środku trwałym 
-->
#include "h1000"
#include "h1231"
#include "h1240"

#macro DATE(_v_)						nx_.display.fulldate(_v_)
#macro DATE_TIME(_dt_,_tm_)				nx_.display.fulldate(_dt_) + " " + nx_.display.fulltime(_tm_)

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>

#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

#define MIEJSCOWOSC_FIRMA				<% so.write util_.Firma_Miasto%>
#define DOKUMENT_DATA_WYDRUKU			<% so.write doc_.afc.display.fulldate(trans_.var(GVAR_TODAY)) %>

<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.pSRTRW.text + " " + cstr(root_.nNumOpST) %>
#define DOKUMENT_TEMAT					<% so.write "Operacja:" + nazwa_rodzaju_operacji %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_UZYTKOWNIK_MODYFIKUJACY	<% so.write root_.opsrtrw_pUzytModyf.text%>

#define SRODEK_NAZWA					<% so.write root_.pSRTRW.text %>

#define BORDER_MODE						0

<%
function nazwa_rodzaju_operacji()
	nazwa_rodzaju_operacji = root_.getobjdef.field(root_.getobjdef.getfieldindex("eRodzaj")).enumvalue(root_.eRodzaj-1)
end function

function show_wartosc()
	show_wartosc = _ 
		(root_.eRodzaj = N5OPSRTRW_ZAKUP) or _
		(root_.eRodzaj = N5OPSRTRW_PRZYJECIE_OT) or _
		(root_.eRodzaj = N5OPSRTRW_AMORTYZACJA) or _
		(root_.eRodzaj = N5OPSRTRW_PRZESZACOWANIE_PK) or _
		(root_.eRodzaj = N5OPSRTRW_ZMIANA_WARTOSCI_WK) or _
		(false)
end function

function show_umorzenie()
	show_umorzenie = show_wartosc()
end function

function show_amort()
	show_amort = _ 
		(root_.eRodzaj = N5OPSRTRW_AMORTYZACJA) or _
		(false)
end function

function show_stawka()
	show_stawka = _ 
		(root_.eRodzaj = N5OPSRTRW_AMORTYZACJA) or _
		(root_.eRodzaj = N5OPSRTRW_ZMIANA_STAWKI) or _
		(false)
end function
%>

<page style='36' margins='700,700,700,700' border='0' font='Verdana'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"

VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table border='BORDER_MODE'>
	<tbody>
		<tr>
			<!-- naglowek -->
			<td>
				<table>
					<tbody>
						<tr>
							<td>
								<t><![CDATA[FIRMA_NAZWA]]></t>
							</td>
							<td width='max' />
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_FIRMA, DOKUMENT_DATA_WYDRUKU]]></t>
							</td>
						</tr>
						<tr>
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td colspan='2' />
						</tr>
						<tr>
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO ]]></t>
							</td>
							<td colspan='2' />
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		<tr>
			<td border='1' align='center' bold='true' fontsize='6'>
				<text><![CDATA[DOKUMENT_TEMAT]]></text>
			</td>
		</tr>
		<tr>
			<td border='1' align='center' bold='true' fontsize='6'>
				<text><![CDATA[SRODEK_NAZWA]]></text>
			</td>
		</tr>
		
		ROW_SEPARATOR(1)	

		<tr>
			<td border='1'>
				<table border='BORDER_MODE'>
					<tbody>
						<tr>
							<td width='min'><t bold='true'>Data operacji:</t></td>
							<td colspan='4'><t><![CDATA[<%so.write DATE(root_.dDataOper)%>]]></t></td>
						</tr>
						ROW_SEPARATOR(5)
						<tr>
							<td width='min'><t bold='true'><![CDATA[Ujęcie:]]></t></td>
							<td align='right'><t bold='true'><![CDATA[Podatkowe]]></t></td>
							<td><t size='3' /></td>
							<td width='min'></td>
							<td align='right'><t bold='true'><![CDATA[Bilansowe]]></t></td>
						</tr>
						<%if show_wartosc() then %>	
						<tr>
							<td width='min'><text bold='true'>Wartość </text></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curWartoscPod)%>]]></t></td>
							<td><t size='3' /></td>
							<td width='min'></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curWartoscBil)%>]]></t></td>
						</tr>
						<%end if%>
						<%if show_umorzenie() then %>	
						<tr>
							<td width='min'><text bold='true'>Umorzenie</text></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curUmorzPod)%>]]></t></td>
							<td><t size='3' /></td>
							<td width='min'><text bold='true'></text></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curUmorzBil)%>]]></t></td>
						</tr>
						<%end if%>
						<%if show_stawka() then %>	
						<tr>
							<td width='min'><text bold='true'>Stawka</text></td>
							<td align='right'><t><![CDATA[<%so.write doc_.afc.display.quantity(root_.curStawkaPod,"%",2)%>]]></t></td>
							<td><t size='3' /></td>
							<td width='min'><text bold='true'>Stawka</text></td>
							<td align='right'><t><![CDATA[<%so.write doc_.afc.display.quantity(root_.curStawkaBil,"%",2)%>]]></t></td>
						</tr>
						<%end if%>
						<%if show_amort() then %>	
						<tr>
							<td width='min'><text bold='true'>Amortyzacja</text></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curAmortPod)%>]]></t></td>
							<td><t size='3' /></td>
							<td width='min'><text bold='true'></text></td>
							<td align='right'><t><![CDATA[<%so.write MONEY(root_.curAmortBil)%>]]></t></td>
						</tr>
						<tr>
							<td width='min'><text bold='true'>za miesiąc</text></td>
							<td align='right'><t><![CDATA[<%so.write cstr(clng(year(root_.dDataAmort)))  +"/" + cstr(clng(month(root_.dDataAmort))) %>]]></t></td>
						</tr>
						<%end if%>
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		<tr>
			<td border='1'><t bold='true' fontsize='5'><![CDATA[Opis]]></t></td>
		</tr>	
		<tr>
			<td border='1'><text><![CDATA[<%so.write root_.strUwagi%>]]></text></td>
		</tr>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		<tr>
			<td border='1'>
				<table border='BORDER_MODE'>
					<tbody>
						<tr>
							<td>
								<t>Wprowadził:</t>
							</td>	
							<td>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
						</tr>
						<tr>
							<td>
								<t>Modyfikował:</t>
							</td>	
							<td>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_MODYFIKUJACY]]></text>
							</td>							
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
	<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
</footer>
</page>
