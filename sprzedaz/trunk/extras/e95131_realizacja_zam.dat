<?xml version="1.0" encoding="windows-1250" ?>


<!-- Realizacja zamówienia  -->


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto + "   " + util_.Dzisiaj%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>


<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% so.write util_.Klient_Kod_Miasto(root_.pKlient) %>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>

#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_AKTUALNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataAkt) %>
#define DOKUMENT_DATA_PLATNOSCI			<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_DATA_REALIZACJI		<% so.write doc_.afc.display.fulldate(root_.dDataReal) %>

#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_OPIS					<% so.write root_.strUwagi %>


<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% so.write pozycja.pOpak.strNazwa %>
#define POZ_INDEKS						<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_ILOSC						<% so.write QTY(pozycja.curIloscOpak,pozycja.pOpak.pJednOpak) %>
#define POZ_ILOSC_DONE					<% so.write QTY(pozycja.curIloscOpak - pozycja.curIloscOpakPoz,pozycja.pOpak.pJednOpak) %>
#define POZ_ILOSC_TODO					<% so.write QTY(pozycja.curIloscOpakPoz,pozycja.pOpak.pJednOpak) %>





<page style='36' >
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[Realizacja zamówienia]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>						

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Dostawca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

													
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)



						<!-- Dane nabywcy - KLIENT -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Odbiorca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>



					</tbody>
				</table>
			</td>
		</tr>

			ROW_SEPARATOR(1)

		<tr>
			<td>
				<!-- płatności -->
				<table >
					<tbody>
						<tr>
							<td  keepline='true'>
								<t bold='true'>Data wystawienia:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>							
							<td keepline='true'>
								<t bold='true'>Data aktualności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_DATA_AKTUALNOSCI]]></t>
							</td>
						</tr>						
						<tr>
							<td  keepline='true'>
								<t bold='true'>Data płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_DATA_PLATNOSCI]]></t>
							</td>							
							<td keepline='true'>
								<t bold='true'>Data realizacji:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_DATA_REALIZACJI]]></t>
							</td>
						</tr>						
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)	
		

		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja				
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td>
								<text>Opakowanie / odmiana</text>
							</td>
							<td align='center'>
								<t>Indeks</t>
							</td>
							<td align='right'>
								<text>Ilość zamówiona</text>
							</td>
							<td align='right'>
								<text>Ilość zrealizowana</text>
							</td>
							<td align='right'>
								<text>Ilość pozostała do realizacj</text>
							</td>							
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text>
							</td>
							<td>
								<text><![CDATA[POZ_OPAKOWANIE]]></text>								
							</td>
							<td width='min'>
								<text><![CDATA[POZ_INDEKS]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC_DONE]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC_TODO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1							
						next
						%>
					</tbody>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<t bold='true'>Adnotacje</t>
				<t size='3'/>
				<text><![CDATA[DOKUMENT_OPIS]]></text>
			</td>
		</tr>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>														
						</tr>
						<tr>
							<td>	
								<t>.........................................................................</t>
							</td>														
						</tr>
						<tr>
							<td>	
								<t fontsize='2'>Imię i nazwisko osoby wystawiającej</t>
							</td>																				
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
