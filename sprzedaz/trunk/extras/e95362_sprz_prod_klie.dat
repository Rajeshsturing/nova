<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_SPRZEDAZ_PRODUKT_KLIENT

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Zestawienie produkt-klient

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim g_pCustParamDateRange : set g_pCustParamDateRange = doc_.getmodule(43035)

function query()
	query = "select 'p_nazwa'=max(prod.strNazwa),'p_indeks'=max(prod.strIndeks),'k_indeks'=max(k.strIndeks),'p_type'=TYPEID_N5PRODUKT, " + vbNewLine +_
          "'k_nazwa'=max(k.strNazwa),'p_idobj'=prod.idobj,'k_type'=TYPEID_N5KLIENT,'k_idobj'=k.IdObj, " + vbNewLine +_
          "'k_rodzaj_prod'=max(k.kli_strRodzajProd),'s_idobj'=sprz.idobj,'s_type'=TYPEID_N5SPRZEDAZ, " + vbNewLine +_ 
          "'s_nrdok'=max(sprz.strNrDok),'s_datawyst'=max(sprz.dDataWyst), " + vbNewLine +_ 
          "'ilosc'=sum(trs_curIloscOpakSP), " + vbNewLine +_ 
          "'j_skrot'=max(j.strSkrot),'j_doklad'=max(j.nDokladnosc), " + vbNewLine +_ 
          "'cena_sprz'=sum(trs_curCenaSP),'wartosc_sprz'=sum(trs_curWartSP),'wartosc_zak'=-sum(trs_curWartMag), " + vbNewLine +_ 
          "'zysk'=sum(trs_curWartSP) + sum(trs_curWartMag), " + vbNewLine +_ 
          "'os_obsug_nazw'=isnull(max(prac.strNazwisko),''),'os_obsug_imie'=isnull(max(prac.strImie),'') " + vbNewLine +_
          "from #tmp_rentowsp " + vbNewLine +_ 
          "	inner join n5produkt as prod on trs_pProdukt = prod.idobj " + vbNewLine +_ 
          "	inner join n5opakowanie_produktu as opak on trs_pOpak = opak.idobj " + vbNewLine +_ 
          "	inner join n5jednostka j on opak.pJednOpak = j.idobj " + vbNewLine +_ 
          "	inner join n5sprzedaz as sprz on trs_pSprz = sprz.idobj " + vbNewLine +_ 
          "	inner join n5klient as k on sprz.pKlient = k.IdObj " + vbNewLine +_ 
          " inner join n5grupaklient as gk on k.pGrupaKlient = gk.IdObj" + vbNewLine +_          
          "	left join n5pracownik as prac on k.pPracownik = prac.Idobj " + vbNewLine +_
          "	inner join n5rejestrdok as t_3 on sprz.pRejestrDok = t_3.IdObj " + vbNewLine +_ 
          "where sprz.pRozlVAT <> 0 and %2 and %3 and %4 and %5 and %6 and %7 and %8 " + vbNewLine +_ 
          "group by prod.idobj,opak.idobj,k.idobj,sprz.idobj " + vbNewLine +_
          "order by p_nazwa,p_indeks,k_nazwa,k_indeks"
end function
%>
<%
dim nLP

function section_header_1(byref pSection,byref pRec)
  nLP = clng(1)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4' hide='true'>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
<tr fontsize='4'>
	<td style='27' /><td style='27' /><td style='27' /><td style='27' />
	<td style='27' /><td style='27' /><td style='27' /><td style='27' />
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(0).result,"",2)
	</td>  
	<td style='27' />
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(3).result)
	</td>  
</tr>
<tr border='0' hide='true'><td colspan='10' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='white'  />
	<td style='27' colspan='9'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_nazwa)
		<t size='3'/>
		RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_indeks)
	</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
<tr fontsize='3'>
	<td style='27' colspan='5' />
	<td style='27' /><td style='27' /><td style='27' /><td style='27' />
	<td style='27' /><td style='27' />
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(0).result,"",2)
	</td>  
	<td style='27' />  
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(3).result)
	</td>  
</tr>
<tr border='0'><td colspan='10' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)           
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'><t><%so.write cstr(nLP)%></t></td>
  <td>
		RXE_AUTOTEXT_LINK_FORM_CCC(p_type,p_idobj,p_nazwa)  
  </td>
  <td>
		RXE_TEXT(p_indeks)
  </td> 
  <td>
		RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_nazwa)  
  </td>
  <td>
		RXE_AUTOTEXT_LINK_FORM_CCC(k_type,k_idobj,k_indeks)
  </td>    
	<td>
		<text><![CDATA[<%so.write cstr(pRec("os_obsug_imie") + " " + pRec("os_obsug_nazw"))%>]]></text>
	</td>	   
	<td>
		RXE_TEXT(k_rodzaj_prod)
	</td>  
	<td align='right'>
		<t><%so.write doc_.afc.display.quantity(pRec("ilosc"),"",pRec("j_doklad")-1)%></t>
	</td>
	<td/>
	<td>
		RXE_TEXT(j_skrot)
	</td>  
	<td align='right'>
		RXE_QUANTITY_CVV(cena_sprz,"",2)
	</td>
	<td/>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_sprz,"",2)
	</td>
	<td/>
	<td align='right'>
		RXE_QUANTITY_CVV(zysk,"",2)
	</td>
	<td/>
</tr><%
  nLP = nLP + 1
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='4000'>
		<t><![CDATA[Nazwa produktu]]></t>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>  
	<td width='3000'>
		<text><![CDATA[Nazwa klienta]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks klienta]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Osoba obsługująca]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Rodzaj produkcji]]></text>
	</td>  
	<td width='1500'>
		<text><![CDATA[Ilość]]></text>
	</td>
	<td width='1500'>
		<text><![CDATA[Suma ilości]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[J.m.]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Cena sprzedaży]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Suma ceny sprzedaży]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Wartość sprzedaży]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Suma wart. sprzedaży]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Wartość dodana]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Suma wart. dodanej]]></text>
	</td>   
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' /><td style='27' /><td style='27' /><td style='27' />
	<td style='27' /><td style='27' /><td style='27' /><td style='27' />
	<td style='27' align='right'>
		RXE_QUANTITY_VVV(pSection.counter(0).result,"",0)
	</td>  
	<td style='27' />  
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(3).result)
	</td>  
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
  dim strIdRokKsieg: strIdRokKsieg = ""
#ifdef _ALMA_TREND
	strIdRokKsieg = doc_.getmodule(60106).GetIdRokKsieg()
#endif 
  
	dim pM60233 : set pM60233 = doc_.getmodule(60233)
	dim pRentSP : set prentsp = pM60233.new_rent_sp()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	
	dim pParamOkres : set pParamOkres = g_pCustParamDateRange.new_custom("Analizowany okres").bindexpr("psp.p_ddatawyst")
	pParamArray.add pParamOkres

	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("prod.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("prod.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("k.strIndeks")
 
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " + strIdRokKsieg + " " +_	
		"order by strNazwa "
	pParamArray.add pParam2 
  
  pParamArray.add doc_.afc.rap.param.new_text("Osoba obsługująca").bindexpr("prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("gk.strNazwa")
  
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%  
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("ilosc").add_sumator("cena_sprz").add_sumator("wartosc_sprz").add_sumator("zysk")
  .add_group_section (1,getref("section_header_1"),getref("section_footer_1")).add_sumator("ilosc").add_sumator("cena_sprz").add_sumator("wartosc_sprz").add_sumator("zysk")
  .add_group_section (2,getref("section_header_1"),getref("section_footer_1")).add_sumator("ilosc").add_sumator("cena_sprz").add_sumator("wartosc_sprz").add_sumator("zysk")
  
if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
	pRentSP.fill_dok_mag_related
#ifdef _ALMA_TREND  
	pRentSP.fill_dok_mag_ZZ
	pRentSP.fill_dok_mag_not_related
#endif  
	set pPerf = nothing

  .ReplaceQueryParam "prac.strNazwisko is not null", "1=1"

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
		so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
