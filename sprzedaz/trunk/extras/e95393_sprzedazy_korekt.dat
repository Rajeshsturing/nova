<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_SPRZEDAZY_KOREKT

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Raport sprzedaży - korekt

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()

query = "select 'c_data_wyst'=max(t_orgsprz.p_ddatawyst),'c_nr_dok'=max(t_orgsprz.p_strnrdok), " + vbNewLine +_
"'c_dok_idobj'=max(t_orgsprz.p_idobj),'c_indeks'=max(t_prod.strIndeks), " + vbNewLine +_
"'c_cena_sprzed'=max(t_orgsprz.c_curcenanetto),'c_cena_baz'=max(t_orgsprz.c_curcenabaznetto), " + vbNewLine +_
"'c_ilosc_opak'=sum(t_orgsprz.c_curIloscOpak - isnull(t_sprz.c_curIloscOpak,0)),'c_prod_idobj'=t_prod.IdObj, " + vbNewLine +_
"'c_prec'=max(t_jedn_op.nDokladnosc),'c_wart_netto'=sum(t_orgsprz.c_curWartNetto - isnull(t_sprz.c_curWartNetto,0)) " + vbNewLine +_
"from vlist_n5sprzedaz_listpozycje as t_sprz " + vbNewLine +_
"left outer join vlist_n5sprzedaz_listpozycje t_orgsprz on t_sprz.p_ppopsprzed = t_orgsprz.p_idobj and t_sprz.coll_lp = t_orgsprz.coll_lp " + vbNewLine +_
"inner join n5produkt as t_prod on t_sprz.c_pProdukt = t_prod.IdObj " + vbNewLine +_
"inner join n5opakowanie_produktu as t_opak on t_sprz.c_pOpak = t_opak.IdObj " + vbNewLine +_
"inner join n5jednostka as t_jedn_op on t_opak.pJednOpak = t_jedn_op.IdObj " + vbNewLine +_
"inner join n5rejestrdok as t_rej on t_orgsprz.p_prejestrdok = t_rej.IdObj " + vbNewLine +_
"left outer join n5pracownik as t_handl on t_orgsprz.p_sprzed_pHandlowiec = t_handl.idobj " + vbNewLine +_
"where t_sprz.p_pRozlVAT <> 0 and " + vbNewLine +_
"%1 and %2 and %3 and %4 and t_sprz.p_prejestrdok not in (select idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)) " + vbNewLine +_ 
"group by t_prod.IdObj,t_opak.IdObj " + vbNewLine +_
"order by c_data_wyst,c_nr_dok"

end function
%>
<%
function default_param()
	dim pParamArray: set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_sprz.p_dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_text("Numer dokumentu").bindexpr("t_orgsprz.p_strnrdok")
	pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("t_handl.strNazwisko")

	dim pRejDok: set pRejDok= doc_.afc.rap.param.new_choice("Rejestr").bindexpr("t_rej.IdObj")
	doc_.afc.rap.param.init_on_query pRejDok, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_FAKT_EXP, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_FAKTURA_ZALICZKOWA) order by strNazwa "
	pParamArray.add pRejDok
	
	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_data_wyst)
	</td>	
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,c_dok_idobj,c_nr_dok)		
	</td>	
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_prod_idobj,c_indeks)		
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVC(c_ilosc_opak,"",c_prec) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_cena_sprzed,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_cena_baz,"",2)
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>		
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='2600'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość opakowań]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Cena sprzedaży netto]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Cena bazowa netto]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Wartość sprzedaży]]></text>
	</td>	
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	
	if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing

	.ReplaceQueryParam "t_handl.strNazwisko is not null", "1=1"

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

%>
</body>
<footer>
</footer>
</page>
