<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZAKUP_VS_DOKMAG
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Uzgodnienie dokumentów zakupu i PZ/ZD
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query_no_pz()
	query_no_pz = "select 'c_datawyst'=t_zakup.dDataWyst,'c_nrdok'=t_zakup.strNrDok,'c_idobj'=t_zakup.idobj," +_
"'c_klient'=t_dostawca.strNazwa,'c_5'=t_zakup.curSumaNetto " +_
" from n5zakup as t_zakup " +_
" inner join n5rejestrdok as t_rej on t_zakup.pRejestrDok = t_rej.IdObj " +_
" inner join n5klient as t_dostawca on t_zakup.pDostawca = t_dostawca.IdObj " +_
" where  %1  and  %2 and t_zakup.idobj not in (select wrefdokhandl from n5dokmag where wrefdokhandl_wrt=TYPEID_N5ZAKUP)" +_
" and t_zakup.idobj in (select p_idobj from vlist_n5zakup_listPozycje join n5produkt t_prod on c_pprodukt=t_prod.idobj where t_prod.eRodzaj = N5PRODUKT_TOWAR) " +_
" order by c_datawyst,c_nrdok"
end function
%>
<%
function query_no_fak()
	query_no_fak = "select 'c_datawyst'=t_dokmag.dDataWyst,'c_nrdok'=t_dokmag.strNrDok,'c_idobj'=t_dokmag.idobj," +_
"'c_klient'=t_dostawca.strNazwa,'c_5'=-t_dokmag.curSumaEwid " +_
" from n5dokmag as t_dokmag " +_
" inner join n5rejestrdok as t_rej on t_dokmag.pRejestrDok = t_rej.IdObj " +_
" inner join n5klient as t_dostawca on t_dokmag.pKlient = t_dostawca.IdObj " +_
" where  %1 and %3 and t_dokmag.nTypDok in (N5REJESTRDOK__PZ,N5REJESTRDOK__ZD) and (t_dokmag.wrefdokhandl_wrt <> TYPEID_N5ZAKUP)" +_
" order by c_datawyst,c_nrdok"
end function
%>
<%
function query_fak_mismatch()
	query_fak_mismatch = "select 'c_datawyst'=t_zakup.dDataWyst,'c_nrdok'=t_zakup.strNrDok,'c_idobj'=t_zakup.idobj," +_
"'c_klient'=t_dostawca.strNazwa,'c_5'=t_zakup.curSumaNetto " +_
" from n5zakup as t_zakup " +_
" inner join n5rejestrdok as t_rej on t_zakup.pRejestrDok = t_rej.IdObj " +_
" inner join n5klient as t_dostawca on t_zakup.pDostawca = t_dostawca.IdObj " +_
" where  %1  and  %2 and t_zakup.idobj in (select dmm.iddoksp from view_dokmag_sum_magic2 dmm join view_dokzak_sum_magic dsm on dmm.iddoksp = dsm.iddoksp where dmm.magic <> dsm.magic)" +_
" order by c_datawyst,c_nrdok"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("dDataWyst")
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr dok. sprzed.").bindexpr("t_rej.IdObj")

	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_WNT," +_
		"N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP," +_
		"N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR) " + strIdRokKsieg + " order by strNazwa "
	pParamArray.add pParam2

	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Rejestr WZ/ZZ").bindexpr("t_rej.IdObj")

	doc_.afc.rap.param.init_on_query pParam3, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__PZ,N5REJESTRDOK__ZD) " + strIdRokKsieg + " order by strNazwa "
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
<%
function body_row_no_wz(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_datawyst)
	</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5ZAKUP,c_idobj,c_nrdok)
	</td>
	<td>
		RXE_AUTO_TEXT(c_klient)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_5,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header_no_wz(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Klient]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer_no_wz(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%
function body_row_no_fak(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_datawyst)
	</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5DOKMAG,c_idobj,c_nrdok)
	</td>
	<td>
		RXE_AUTO_TEXT(c_klient)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_5,"",2)
	</td>
</tr><%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>

<%
  dim strIdRokKsieg: strIdRokKsieg = ""
#ifdef _ALMA_TREND
	strIdRokKsieg = doc_.getmodule(60106).GetIdRokKsieg()
#endif 
  
dim pRapExec
set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header_no_wz"),getref("body_footer_no_wz"),getref("body_row_no_wz")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query_no_pz()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
%>
<t fontsize='5' bold='true'>Dokumenty zakupu bez PZ/ZD</t><br/>
<%
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header_no_wz"),getref("body_footer_no_wz"),getref("body_row_no_fak")

	.put_final_query rapeng_.query_apply_actual_param(query_no_fak(),rapeng_.get_raport_param())
%>
<br/><t fontsize='3' size='1' /><br/>
<t fontsize='5' bold='true'>PZ/ZD bez dokumentów zakupu</t><br/>
<%
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end with
set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header_no_wz"),getref("body_footer_no_wz"),getref("body_row_no_wz")
	.put_final_query rapeng_.query_apply_actual_param(query_fak_mismatch(),rapeng_.get_raport_param())
%>
<br/><t fontsize='3' size='1' /><br/>
<t fontsize='5' bold='true'>Dokumenty zakupu niezgodne z PZ/ZD</t><br/>
<%
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end with
%>
</body>
<footer>
</footer>
</page>
