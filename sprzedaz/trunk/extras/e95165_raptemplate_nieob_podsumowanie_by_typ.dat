<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Nieobecności - podsumowanie według typów

#macro RXE_PRACOWNIK_TEXT(_imie_,_nazwisko_,_pesel_)	<% so.write "<t><![CD"+"ATA["+ cstr(pRec("_nazwisko_")) + " " + cstr(pRec("_imie_")) + " ("+cstr(pRec("_pesel_"))+")" + "]"+"]></t>" %>
#define RXE_CUSTOM_COL_LD			<t><%so.write cstr(pRec("c_7")) %></t> 

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()

query = "	select " + vbNewLine + _
"	'c_0'=t_0.eTyp, " + vbNewLine + _
"	'c_1'=t_1.strNazwisko, " + vbNewLine + _
"	'c_2'=t_1.strImie, " + vbNewLine + _
"	'c_3'=t_1.strPESEL, " + vbNewLine + _
"	'c_7'= sum ( 1 + convert( int ,  (t_0.dDataDo - t_0.dDataOd ) ) ) " + vbNewLine + _
"	from n5plnieob as t_0 inner join n5pracownik as t_1 on t_0.pPracownik = t_1.IdObj  " + vbNewLine + _
"	where  %1  and  %2  and  %3   " + vbNewLine + _
"	group by t_0.eTyp , t_1.strNazwisko  , t_1.strImie , t_1.strPESEL " + vbNewLine + _
"	order by c_0,c_1,c_2,c_3 " + vbNewLine


'query = "select 'c_0'=t_0.eTyp,'c_1'=t_1.strNazwisko,'c_2'=t_1.strImie,'c_3'=t_1.strPESEL,'c_4'=t_1.strNazwisko,'c_5'=t_1.strImie,'c_6'=t_1.strPESEL,'c_7'=t_0.dDataRej from n5plnieob as t_0 inner join n5pracownik as t_1 on t_0.pPracownik = t_1.IdObj where  %1  and  %2  and  %3  order by c_0,c_1,c_2,c_3"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("t_1.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data rejestracji").bindexpr("t_0.dDataRej")
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ nieobecności").bindexpr("t_0.eTyp")
	pParamFactory2.init_on_enum pParam2, 10202,"eTyp"
	pParamArray.add pParam2

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='6'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>	
	RXE_ENUM_VVC(10202,eTyp,c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='6' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_PRACOWNIK_TEXT(c_2,c_1,c_3)
	</td>
	<td align='right'>
		RXE_CUSTOM_COL_LD
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Nazwisko, imie, (pesel)]]></text>
	</td>
		
	<td width='min'>
		<text><![CDATA[Liczba dni]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
