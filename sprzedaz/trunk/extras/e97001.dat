<html>
<META NAME="GENERATOR" Content="NAVO Enterprise 2002">
<META HTTP-EQUIV="Content-Type" content="text/html; charset=utf-8">
<META NAME=keywords content="NAVO;NAVO Enterprise 2002">
<head>
	<title>NAVO Enterprise 2002 CommFrame</title>
</head>
<SCRIPT LANGUAGE=javascript>
var bSubmitted = 0;
function ne_sufo() 
{ 
	if(!bSubmitted)
	{
		comform.submit();
		bSubmitted = 1;
		document.body.style.backgroundColor = "green";
	}
}
</SCRIPT>
<body onload="return parent.ne_rep();">
<SCRIPT LANGUAGE=javascript>
_menu_goes_here_
</SCRIPT>
<div id=tlbar>
<!-- _toolbar_goes_here_ -->
</div>
<div id=outbar>
<!-- _outlookbar_goes_here_ -->
</div>
<div id=workspace>
<!-- _workspace_goes_here_ -->
</div>
<form name="comform" METHOD="post" action="navoisapi.dll">
<input name="conid" value='_connection_id_'>
</form>
</body>
</html>