<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_MAG_DOKUMENTY_WZ_SPRZEDAZ
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE Dokumenty WZ z cenami sprzedaży
#define PICTURE_LEFT		80930
#define PICTURE_RIGHT		80931


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		pr.strIndeks
#define C_FIELD_SECOND_EXPR		pr.strNazwa
#else
#define C_FIELD_FIRST_EXPR		pr.strIndeks
#define C_FIELD_SECOND_EXPR		pr.strNazwa
#endif

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

function query()
 
	query = "select 'k_strnazwa'=k.strNazwa,'p_strnrdok'=p.p_strnrdok,'p_ddatawyst'=p.p_ddatawyst,'m_idobj'=m.IdObj,'m_strnazwa'=m.strNazwa, " +_
        "'pr_strindeks'=(C_FIELD_FIRST_EXPR),'pr_strnazwa'=(C_FIELD_SECOND_EXPR),'c_ilosc'=p.c_curiloscopak,'o_curcenanetto1'=o.curCenaNetto1, " +_
        "'o_curcenabrutto1'=o.curCenaBrutto1,'wartosc_netto'=p.c_curiloscopak * o.curCenaNetto2,'wartosc_brutto'=p.c_curiloscopak * o.curCenaBrutto2 " +_
        "from vlist_n5dokmag_listPozycje as p " +_
        "inner join n5klient as k on p.p_pklient = k.IdObj " +_
        "inner join n5magazyn as m on p.c_pmagzrod = m.IdObj " +_
        "inner join n5produkt as pr on p.c_pprodukt = pr.IdObj " +_
        "inner join n5opakowanie_produktu as o on p.c_popak = o.IdObj " +_
        "inner join n5uzytkownik as u on p.p_puzytrej = u.IdObj " +_
        "where p_ntypdok = 19 and p_wrefdokhandl = 0 " +_
        "and %1 and %2 and %3 and %4 and %5 and %6 " +_ 
        "order by k_strnazwa, p_strnrdok "
 
end function
%>
<%
'' jest używane poza default_param()
dim RaportOkresParam
dim pParamArray

function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("m.IdObj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")
	pParamArray.add doc_.afc.rap.param.new_text("Klient").bindexpr("k.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("pr.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("pr.strIndeks")

  
	set RaportOkresParam = doc_.afc.rap.param.new_date_range("Analizowany okres").bindexpr("p.p_ddatawyst")
	pParamArray.add RaportOkresParam
  
  pParamArray.add doc_.afc.rap.param.new_text("Osoba wystawiająca").bindexpr("u.strNazwa")

	set default_param = pParamArray
  
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='9'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(k_strnazwa)
</td>
</tr>

<%
nSectionPicCounter=nSectionPicCounter+1
end function

function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(p_strnrdok)
</td>
</tr>

<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='7' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>	
</tr>
<tr border='0'><td colspan='9' /></tr>
<%
end function
%>
<%
function section_footer_2(byref pSection)
%>
#ifdef _CDNOLAWA
<tr border='0'><td colspan='9' /></tr>
#endif
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='7' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>	
</tr>
<tr border='0'><td colspan='9' /></tr>
<%
end function
%>
<%
function write_actual_param(byref pActualParam)
	write_actual_param = "0=1" 

	dim iter
	dim bAnyWritten : bAnyWritten = false

	if not pActualParam is nothing then
			
		dim nDummy1,nDummy2	
		write_actual_param = doc_.getmodule(43025).rap_param_date_range_2_gm_num_oper_where(RaportOkresParam,nDummy1,nDummy2)
			
		for iter = 0 to pActualParam.upperIndex
			if pActualParam.value(iter).get_desc() <> "" then 
				bAnyWritten = true
				so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
			end if
		next
	end if

	if not bAnyWritten then 
		so.write "<t fontsize='4'>brak</t><br/>"
	end if

	so.write "<br/>"
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
#ifdef _CDNOLAWA
<tr bordercolor='black'>
#else
<tr bordercolor='white'>
#endif
<%
else
%>
#ifdef _CDNOLAWA
<tr bordercolor='black' style='37'>
#else
<tr bordercolor='white' style='37'>
#endif
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td align='right'>
		RXE_T(m_strnazwa)
	</td>
	<td>
		RXE_DATE(p_ddatawyst)
	</td>
  <td align='right'>
		RXE_T(pr_strindeks)
	</td>
  <td align='right'>
		RXE_T(pr_strnazwa)
	</td>
    <td align='right'>
		RXE_T(c_ilosc)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_netto,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_brutto,"",2)
	</td>	
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Magazyn]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>
  <td width='max'>
    <text><![CDATA[Nazwa]]></text>
  </td>
	<td width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
  <td width='min'>
    <text><![CDATA[Wartość netto]]></text>
  </td>
  	<td width='min'>
		<text><![CDATA[Wartość brutto]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='9' />
</tr>
<tr fontsize='6'>
  <td style='27' colspan='7' />
  <td style='27' align='right'>
    RXE_MONEY_VAR(pSection.counter(0).result)
  </td>
  <td style='27' align='right'>
    RXE_MONEY_VAR(pSection.counter(1).result)
  </td>
</tr>
<tr border='0'>
  <td colspan='9' />
</tr>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamTypPro
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("wartosc_netto").add_sumator("wartosc_brutto")
  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("wartosc_netto").add_sumator("wartosc_brutto")
  .add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("wartosc_netto").add_sumator("wartosc_brutto")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

  dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())

  '' drobna modyfikacja zapytania - parametr nropmag
  .ReplaceQueryParam "OKRES_NROPMAG_WHERE",nropmag_str
  

  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
 end if 
end if
end with
%>
</body>
<footer>
</footer>
</page>
