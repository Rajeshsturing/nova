<?xml version="1.0" encoding="windows-1250"?>
<!--
TYPEID_N5KLIENT
TYPEID_N5KLIENT_OBIEKT

#include "h1000.h"
#include "h1200.h"
-->
<nxapprep>
	<objects>
		<object typeid="TYPEID_N5KLIENT">
			<fields>
				<alias>
					<name>#ident</name>
					<refers>strIndeks</refers>
				</alias>
				<alias>
					<name>#ident2</name>
					<refers>strNazwa</refers>
				</alias>
				<embedded >
					<name>strNazwa</name>
					<display usage="suggestion_text"><![CDATA[
function nx_fill_suggestion(byref pKlient)
	nx_fill_suggestion = pKlient.strNazwa + " (" + pKlient.strIndeks + ")"
end function					
]]>
					</display>
				</embedded>
				<embedded >
					<name>strIndeks</name>
					<display usage="suggestion_text"><![CDATA[
function nx_fill_suggestion(byref pKlient)
	nx_fill_suggestion = pKlient.strIndeks + " (" + pKlient.strNazwa + ")"
end function					
]]>
					</display>
				</embedded>
				<embedded>
					<name>strNIP</name>
					<display usage="suggestion_text"><![CDATA[
function nx_fill_suggestion(byref pKlient)
	nx_fill_suggestion = pKlient.strNIP + " (" + pKlient.strNazwa + ")"
end function					
]]>
					</display>
				</embedded>
				<embedded>
					<name>@longdesc</name>
					<humanname>Dlugi opis</humanname>
					<sqltype>SQLvc256</sqltype>
					<getexpression><![CDATA[
						result = oObject.strNazwa + " (" + oObject.strIndeks + ")"
					]]></getexpression>
				</embedded>
			</fields>
			<raports>
				<raport title="@fuzzy_##TYPEID_N5KLIENT##@">
					<filters>
						<filter>
							<path>
								<embedded>#ident</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>#ident2</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strNIP</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strTel1</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strUwagi</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<ref>pMiejscowosc</ref>
								<embedded>strNazwa</embedded>
							</path>
						</filter>
					</filters>
				</raport>
				<raport title="@browser_##TYPEID_N5KLIENT##@">
					<columns>
						<column>
							<path>
								<embedded>#ident</embedded>
							</path>
						</column>
						<column>
							<path>
								<embedded>#ident2</embedded>
							</path>
						</column>
						<column>
							<path>
								<embedded>strNIP</embedded>
							</path>
						</column>
						<column>
							<path>
								<ref>pMiejscowosc</ref>
								<embedded>strNazwa</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order>
							<path>
								<embedded>#ident</embedded>
							</path>
						</order>
					</orders>
				</raport>
			</raports>
			<default_search_field>#ident</default_search_field>
		</object>
		<object typeid="TYPEID_N5KLIENT_OBIEKT">
			<raports>
				<raport title="@obiekty_klienta@">
					<columns>
						<column link="true">
							<header>Nazwa</header>
							<path>
								<embedded>klob_strNazwa</embedded>
							</path>
						</column>
						<column>
							<header>Miejscowość</header>
							<path>
								<ref>klob_pMiejscowosc</ref>
								<embedded>strNazwa</embedded>
							</path>
						</column>
						<column>
							<header>Ulica</header>
							<path>
								<embedded>klob_strUlica</embedded>
							</path>
						</column>
						<column>
							<header>Nr domu</header>
							<path>
								<embedded>klob_strNrDomu</embedded>
							</path>
						</column>
						<column>
							<header>Nr lokalu</header>
							<path>
								<embedded>klob_strNrLokalu</embedded>
							</path>
						</column>
					</columns>
				</raport>
			</raports>
		</object>
    <object typeid="TYPEID_N5_KLIENT_JEDN_ORG">
      <raports>
        <raport title="@jednostki_klienta@">
          <columns>
            <column link="true">
              <header>Nazwa</header>
              <path>
                <embedded>strNazwa</embedded>
              </path>
            </column>
            <column>
              <header>Miejscowość</header>
              <path>
                <ref>pMiejscowosc</ref>
                <embedded>strNazwa</embedded>
              </path>
            </column>
            <column>
              <header>Ulica</header>
              <path>
                <embedded>strUlica</embedded>
              </path>
            </column>
            <column>
              <header>Nr domu</header>
              <path>
                <embedded>strNrDomu</embedded>
              </path>
            </column>
            <column>
              <header>Nr lokalu</header>
              <path>
                <embedded>strNrLokalu</embedded>
              </path>
            </column>
          </columns>
        </raport>
      </raports>
    </object>
  </objects>
</nxapprep>