<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_ROZL_WPLAT_PRZEWOZ

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rozliczanie wpłat dla firm przewozowych

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'dm_idobj'=dm.idobj,'dm_data'=dm.dDataWyst,'dm_nrlist'=dm.strExtra1,'dm_nrdok'=dm.strNrDok, " + vbNewLine +_
	      "'s_idobj'=s.idobj,'s_data'=s.dDataWyst,'s_nrdok'=s.strNrDok,'s_suma'=s.curSumaBrutto,'s_kwota_pob'=s.curExtra5, " + vbNewLine +_
	      "'k_idobj'=k.idobj,'k_nazwa'=k.strNazwa,'k_nip'=k.strNIP " + vbNewLine +_ 
	      "from n5dokmag dm " + vbNewLine +_
	      "	inner join n5sprzedaz s on dm.wrefDokHandl = s.idobj and dm.wrefDokHandl_wrt = TYPEID_N5SPRZEDAZ " + vbNewLine +_
	      "	inner join n5transakcja t on s.pTransakcja = t.idobj " + vbNewLine +_
	      "	inner join n5klient k on s.pKlient = k.idobj " + vbNewLine +_
	      "	inner join n5rejestrdok r on dm.pRejestrDok = r.idobj " + vbNewLine +_
	      "where r.eTyp = N5REJESTRDOK__WZ and %1 and %2 and %3 and %4 and %5"
end function
%>
<%
function default_param()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia WZ").bindexpr("dm.dDataWyst")
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia faktury").bindexpr("dm.dDataWyst")
  pParamArray.add doc_.afc.rap.param.new_text("Nr listu").bindexpr("dm.strExtra1")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")
	dim pParamStatus: set pParamStatus = doc_.afc.rap.param.new_choice("Status dokumentu")
	with pParamStatus
		.multiple = true
		.names.add "Nierozliczone"
		.values.add 1
		.selected.add True
		.names.add "Rozliczone"
		.values.add 2
		.selected.add False
	end with
	pParamArray.add pParamStatus  

	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>
    RXE_LP
  </td>
  <td>
    RXE_DATE(dm_data)
  </td>
  <td>
    RXE_AUTO_TEXT(dm_nrlist)
  </td>  
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5DOKMAG,dm_idobj,dm_nrdok)
  </td>  
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,k_idobj,k_nazwa)
  </td>  
  <td>
    RXE_AUTO_TEXT(k_nip)
  </td>  
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,s_idobj,s_nrdok)
  </td>    
  <td align='right'>
    RXE_QUANTITY_CVV(s_suma,"",2)
  </td>    
  <td align='right'>
    RXE_QUANTITY_CVV(s_kwota_pob,"",2)
  </td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
  <td width='1700'>
    <text><![CDATA[Okres (data WZ)]]></text>
  </td>
  <td width='min'>
    <text><![CDATA[Nr listu przewozowego]]></text>
  </td>  
  <td width='min'>
    <text><![CDATA[Nr dokumentu WZ]]></text>
  </td>
  <td width='4000'>
    <text><![CDATA[Nazwa klienta]]></text>
  </td>
  <td width='min'>
    <text><![CDATA[NIP klienta]]></text>
  </td>  
  <td width='min'>
    <text><![CDATA[Nr faktury]]></text>
  </td>
  <td width='2000'>
    <text><![CDATA[Kwota faktury]]></text>
  </td>    
  <td width='2000'>
    <text><![CDATA[Kwota pobrania]]></text>
  </td>  
</tr>
</thead>
<tbody> 
<%
end function
%>

<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<% dim nSectionPicCounter : nSectionPicCounter = 10000000 %>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>  
<p><t size='2'/></p>
  
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
  .ReplaceQueryParam "( = '1')", "(t.eStatus in (1))"
  .ReplaceQueryParam "( = '2')", "(t.eStatus in (2))"
  .ReplaceQueryParam "( IN ('1','2'))", "(t.eStatus in (1,2))"
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
end if
end with
%>
</body>
<footer>
</footer>
</page>
