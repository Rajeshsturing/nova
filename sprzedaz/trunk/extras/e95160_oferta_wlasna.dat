<?xml version="1.0" encoding="windows-1250" ?>


<!-- Oferta wlasna ISOLACJE -->

#define CTRLID_ORGKOPIA					101


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_EMAIL						<% so.write util_.Firma.strEmail %>


<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>


#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_ZAMOWIENIE_NR_OBCY		<% so.write root_.zam_strNrDokObcy %>

#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_AKTUALNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataAkt) %>
#define DOKUMENT_DATA_PLATNOSCI			<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_DATA_REALIZACJI		<% so.write doc_.afc.display.fulldate(root_.dDataReal) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>


#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_UZYTKOWNIK_STANOWISKO	<% 'so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_OPIS					<% so.write root_.strUwagi %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_TRANSPORT				<% %>

#define DOKUMENT_UZYTKOWNIK_EMAIL		<% so.write root_.pUzytRej.strMail %>
#define DOKUMENT_UZYTKOWNIK_TELEFON		<% so.write root_.pUzytRej.strTelefon %>

#define UZYTKOWNIK_RS					<% so.write cstr(rs.fields("strImie").value) + " " + cstr(rs.fields("strNazwisko").value)%>
#define UZYTKOWNIK_STANOWISKO_RS		<% so.write rs.fields("strStanowisko").value%>
#define UZYTKOWNIK_TELEFON_RS			<% so.write rs.fields("strTel1").value%>
#define UZYTKOWNIK_TELEFON_KOM_RS		<% so.write rs.fields("strTel2").value %>
#define UZYTKOWNIK_MAIL_RS				<% so.write rs.fields("strEmail").value%>
#define UZYTKOWNIK_FAX_RS				<% so.write rs.fields("strFax").value%>

#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(root_.curSumaBrutto) %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaBrutto) %>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNetto) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>
#define POZ_CENA_KAT_NETTO				<% so.write MONEY(pozycja.curCenaBazNetto) %>


<!-- podsumowanie pozycji -->
#macro DOKUMENT_PODSUMOWANIE_NETTO(_value_)		<% so.write MONEY(_value_) %>
#macro DOKUMENT_PODSUMOWANIE_VAT(_value_)		<% so.write MONEY(_value_) %>
#macro DOKUMENT_PODSUMOWANIE_BRUTTO(_value_)	<% so.write MONEY(_value_) %>
#macro DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>



<!-- podsumowanie pozycji -->



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>


<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>

<header>
</header>

<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>						
							<td align='left'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						
						<tr>
							<td>
								<t></t>
							</td>
						</tr>
						<tr>
							<td>
								<t></t>
							</td>
						</tr>

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[OFERTA nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>

													
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)



						<!-- Dane nabywcy - KLIENT -->
						<!-- Dane nabywcy - Klient - jednostka organizacyjna-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<% if not root_.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>						

						
						<% else %>
						<% if not root_.pKlient is nothing then %>
						
						<!-- Dane nabywcy - KLIENT -->
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>						

						<% end if %>
						<% end if %>



					</tbody>
				</table>
			</td>
		</tr>

			ROW_SEPARATOR(1)
		        ROW_SEPARATOR(1)	
		        ROW_SEPARATOR(1)	
		        ROW_SEPARATOR(1)	
		        ROW_SEPARATOR(1)
                <tr>
			<td>
				<text bold='true' fontsize='4'>W nawiązaniu do otrzymanego zapytania przedstawiam ofertę cenową wraz z warunkami dostaw na interesujące Państwa materiały:</text>
			</td>
		</tr>

		

		ROW_SEPARATOR(1)
		
		<!-- pozycje -->
		
		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				'flaga dla kolejnych stawek VAT - czy drukowac je na podsumowaniu
				dim pVATArray:set pVATArray = trans_.afc.new_navoarray()
				dim pVATArraySumNetto:set pVATArraySumNetto = trans_.afc.new_navoarray()
				dim pVATArraySumBrutto:set pVATArraySumBrutto = trans_.afc.new_navoarray()
				dim pVATArraySumVat:set pVATArraySumVat = trans_.afc.new_navoarray()
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text><br/>
								
							</td>							
							
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena katalogowa netto</text>
							</td>
							<td align='right'>
								<text>Rabat</text>
							</td>
							<td align='right'>
								<text>Cena netto</text>
							</td>
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
								

							</td>
							
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_KAT_NETTO]]></t>
							</td>							
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
							if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
								pVATArraySumNetto.add(ccur(pozycja.curWartNetto))
								pVATArraySumBrutto.add(ccur(pozycja.curWartBrutto))
								pVATArraySumVat.add(ccur(pozycja.curVat))
							else
								dim indexFound:indexFound = pVATArray.IndexOf(clng(pozycja.eVat))
								pVATArraySumNetto.value(indexFound) = pVATArraySumNetto.value(indexFound) + ccur(pozycja.curWartNetto)
								pVATArraySumBrutto.value(indexFound) = pVATArraySumBrutto.value(indexFound) + ccur(pozycja.curWartBrutto)
								pVATArraySumVat.value(indexFound) = pVATArraySumVat.value(indexFound) + ccur(pozycja.curVat)																
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='6' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							for iter=0 to pVATArray.UpperIndex()
						%>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO(pVATArraySumNetto.value(iter))]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA(pVATArray.value(iter))]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_VAT(pVATArraySumVat.value(iter))]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO(pVATArraySumBrutto.value(iter))]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		
			
		


		ROW_SEPARATOR(1)	

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie</t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_DO_ZAPLATY_SLOWNIE]]></t>
			</td>
		</tr>

		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<t bold='true' fontsize='5'>Adnotacje:</t>
				<t size='3'/>
				<text><![CDATA[DOKUMENT_OPIS]]></text>
			</td>
		</tr>
		<% end if%>
			

		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)

<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='left' width='min'>	
								<t bold='true'>Warunki płatności: </t>
							</td>	
							<td>
								<t><![CDATA[DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>						
						</tr>
						ROW_SEPARATOR(2)
						<tr>
							<td align='left' width='min'>	
								<t bold='true'>Transport: </t>
							</td>	
							<td>
								<t><![CDATA[DOKUMENT_TRANSPORT]]></t>
							</td>						
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
	
		
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<t>Z poważaniem</t><br/>
			</td>
		</tr>
		<%	
		dim rs 					
		set rs = trans_.createadors("select * from n5pracownik as t_prac "+_
		"inner join n5wykonawca as t_wykonawca on t_prac.IdObj = t_wykonawca.wrefObiekt "+_
		"inner join n5uzytkownik as t_uzytkownik on t_wykonawca.IdObj = t_uzytkownik.pWykonawca "+_
		"where t_wykonawca.wrefObiekt_wrt = 10109 "+_
		"and t_uzytkownik.IdObj=" + cstr(root_.pUzytRej.idObj)  )
		
		%>						
		<tr>
			<td>
				<table>
					<tbody>				
					
						<%
						if not rs is nothing then
							if not rs.EOF then
								if not isNull(rs(0)) then
						 %>
						<tr>
							<td align='left'>	
