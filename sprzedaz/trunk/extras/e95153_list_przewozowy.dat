			ROW_SEPARATOR(1)

		

		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				'flaga dla kolejnych stawek VAT - czy drukowac je na podsumowaniu
				dim pVATArray:set pVATArray = trans_.afc.new_navoarray()
				dim sumaWagaNetto
				dim sumaWagaBrutto
				dim sumaOpak
				dim sumaWartoscVat
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>No</t>
							</td>
							<td>
								<text size='30'>Product description</text>
							</td>	
							<td>
								<text>Index</text>
							</td>						
							<td align='right'>
								<text>Customs code</text>
							</td>
							<td align='right'>
								<text>Qty</text>
							</td>
							<td align='right' width='min'>
								<text>Units</text>
							</td>							
							
    						<td align='right'>
								<text>Net weight</text>
							</td>
							<td align='right'>
								<text>Gross weight</text>
							</td>
							<td align='right'>
								<text>Gross value</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% 
						
						dim opZbiorczeKrotnosc : opZbiorczeKrotnosc  = ccur(0)
						dim opZbiorczeIlosc : opZbiorczeIlosc = ccur(0)
						dim rs 
						for each pozycja in root_.listPozycje 
						
						
						
						set rs = trans_.createadors("select 'max' = max(c_curilosc) "+_
							"from vlist_n5produkt_listopakowania "+_
							"where p_idobj=" + cstr(pozycja.pProdukt.idObj)  )
						
						if not rs is nothing then 
							
							opZbiorczeKrotnosc  = rs.fields("max").value
							if ccur(pozycja.pOpak.curIlosc*pozycja.curIloscOpak) > ccur(opZbiorczeKrotnosc) then 
								
								opZbiorczeIlosc = int( ccur(pozycja.pOpak.curIlosc*pozycja.curIloscOpak)/ccur(opZbiorczeKrotnosc))
								if (ccur(pozycja.pOpak.curIlosc*pozycja.curIloscOpak) mod ccur(opZbiorczeKrotnosc))>0 then 
									opZbiorczeIlosc = opZbiorczeIlosc + 1
								end if
								
							else 
								opZbiorczeIlosc = 1
							end if
							
							
						end if
						
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td>
								<text><![CDATA[POZ_IDX]]></text>
							</td>

							<td width='min' align='right'>
								<text><![CDATA[POZ_KOD_CELNY]]></text>								
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_OP]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WAGA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WAGA_BRUTTO]]></t>
							</td>
							<td align='right'>
								<t  bold='true'><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							sumaWagaNetto = sumaWagaNetto + pozycja.pOpak.curWagaNetto * pozycja.curIloscOpak
							sumaWagaBrutto = sumaWagaBrutto + pozycja.pOpak.curWagaBrutto * pozycja.curIloscOpak
							sumaOpak = sumaOpak + opZbiorczeIlosc
							iter = iter + 1
							if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='5' bordercolor='transparent'>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_ILOSC_OP]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_WAGA_NETTO]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_WAGA_BRUTTO]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Payment on due day:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY DOKUMENT_WALUTA]]></t>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>
							<td width='max'></td>							
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td></td>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>authorized signature to sign an invoice</t>
							</td>			
							<td></td>				
							<td align='center'>	
								<t fontsize='2'>authorized signature to receive an invoice</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<t fontsize='1'>Published by EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
