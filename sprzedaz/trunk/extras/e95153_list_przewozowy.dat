							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>						

					<% end if %>					
					
					ROW_SEPARATOR(3)							
					
					<!-- płatności -->
						<tr>
							<td  keepline='true'>
								<t bold='true'>Date:</t>
