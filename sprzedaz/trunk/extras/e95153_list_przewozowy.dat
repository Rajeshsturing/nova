#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto %>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write euronip(util_.Firma_NIP) %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>


<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% so.write util_.Klient_Kod_Miasto(root_.pKlient) %>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) %>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_SPRZEDAZY			<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_PlatnosciMN(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(root_.curSumaBrutto) %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaBrutto) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_POWIAZANY				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_WALUTA					<% so.write root_.pWaluta.strSkrot %>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% if (pozycja.pProdukt.strNazwaMiedzynarodowa<> "") then so.write pozycja.pProdukt.strNazwaMiedzynarodowa else so.write pozycja.pProdukt.strNazwa end if%>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_KOD_CELNY					<% if not pozycja.pProdukt.prod_pKodCelny is nothing then so.write pozycja.pProdukt.prod_pKodCelny.pcn_strKod end if %>

#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1)%>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strNazwaMiedzynarodowa %>
#define POZ_OP							<% so.write opZbiorczeIlosc %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNetto) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>
#define POZ_WAGA_BRUTTO					<% so.write doc_.afc.display.quantity(pozycja.pOpak.curWagaBrutto * pozycja.curIloscOpak,"",pozycja.pOpak.pJednostkaWagi.nDokladnosc - 1) %>
#define POZ_WAGA_NETTO					<% so.write doc_.afc.display.quantity(pozycja.pOpak.curWagaNetto * pozycja.curIloscOpak,"",pozycja.pOpak.pJednostkaWagi.nDokladnosc - 1) %>

#define FIRMA_TELEFON_LABEL				<% so.write util_.Firma_Telefon_Label %>
#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_TELEFON_HIDE				<% so.write util_.Firma_Telefon_Hide %>

#define FIRMA_FAX_LABEL					<% so.write util_.Firma_Fax_Label %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_FAX_HIDE					<% so.write util_.Firma_Fax_Hide %>


#define KLIENT_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient) %>
#define KLIENT_TELEFON					<% so.write util_.Klient_Telefon(root_.pKlient) %>
#define KLIENT_TELEFON_HIDE				<% so.write util_.Klient_Telefon_Hide(root_.pKlient) %>

#define KLIENT_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient) %>
#define KLIENT_TELEFON_KOM				<% so.write util_.Klient_Telefon_Kom(root_.pKlient) %>
#define KLIENT_TELEFON_KOM_HIDE			<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient) %>

#define KLIENT_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient) %>
#define KLIENT_FAX						<% so.write util_.Klient_Fax(root_.pKlient) %>
#define KLIENT_FAX_HIDE					<% so.write util_.Klient_Fax_Hide(root_.pKlient) %>


#define DOKUMENT_WARTOSC_WAGA_NETTO		<% so.write doc_.afc.display.quantity(sumaWagaNetto,"",3)%>
#define DOKUMENT_WARTOSC_WAGA_BRUTTO	<% so.write doc_.afc.display.quantity(sumaWagaBrutto,"",3) %>
#define DOKUMENT_ILOSC_OP				<% so.write sumaOpak %>

<!-- podsumowanie pozycji -->
#macro DOKUMENT_PODSUMOWANIE_NETTO(_eVat_)		<% so.write util_.netto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_VAT(_eVat_)			<% so.write util_.vat_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_BRUTTO(_eVat_)		<% so.write util_.brutto_dla_stawki(_eVat_,root_) %>
#macro DOKUMENT_PODSUMOWANIE_STAWKA(_eVat_)		<% so.write util_.vat_to_name(_eVat_) %>

<%
function euronip(byval nip)
	dim enip : enip = ""
	dim i 
	dim char 

	for i=1 to len(nip)
		char = asc(mid(nip, i, 1))
		if (char >= 48) and (char <= 57) then
			enip = enip + chr(char)
		end if
	next
	euronip = "PL" + enip
end function 
%>

<page style='36' >
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
