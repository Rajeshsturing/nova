<?xml version="1.0" encoding="windows-1250" ?>

<!-- Wypisuje tych klientów oraz te zamówienia, które posiadają chociaż 1 pozycję do realizacji -->

#define AKT_KLIENT	<% so.write aktKlient %>
#define DOKUMENT	<% so.write strDok %>
#define PRODUKT	    <% so.write oDetailObj.pProdukt.text %>
#define SKROT_DOK	<% so.write doc_.afc.display.quantity(oRRID.m_curOrderQty,strSkrot,nDokl) %>
#define SKROT_DOK1	<% so.write doc_.afc.display.quantity(oRRID.m_curPendingQty,strSkrot,nDokl) %>
#define SKROT_DOK2	<% so.write doc_.afc.display.quantity((oStockInfo.get_avail_qty()+oStockInfo.m_curUsedQty),strSkrot,nDokl) %>
#define SKROT_DOK3	<% so.write doc_.afc.display.quantity(oStockInfo.get_reserv_qty(),strSkrot,nDokl) %>
#define SKROT_DOK4	<% so.write doc_.afc.display.quantity(oRRID.m_curAllocQty,strSkrot,nDokl) %>

<!-- Funkcje pomocnicze -->
<%
'sprawdza czy dany klient posiada na zamówieniu pozycję możliwa do zrealizowania
public function sprawdzPozKlient(byval strKlientNazwa, byval iter):sprawdzPozKlient = false
  dim i, j
  for i = iter to root_.m_oItemArray.UpperIndex
     dim oRRI : set oRRI = root_.m_oItemArray.Value(i)
	 dim oOrderObj : set oOrderObj = trans_.getobj(oRRI.m_nTypeId,oRRI.m_idObj)
     if strKlientNazwa = oOrderObj.pKlient.text then
	   for j = 0 to oRRI.m_oDetailArray.UpperIndex
		  dim oRRID : set oRRID = oRRI.m_oDetailArray.Value(j)
		  dim oDetailObj : set oDetailObj = oOrderObj.listPozycje.get(oRRID.m_nLP)
		  dim oStockInfo : set oStockInfo = root_.get_stock_info(oDetailObj.pProdukt.idobj,oDetailObj.pOpak.idobj)
		  dim curStockQty : curStockQty = oStockInfo.get_avail_qty()	
		  if (oRRID.m_curOrderQty <= curStockQty) or (curStockQty > 0) or (oStockInfo.m_curUsedQty > 0) then
		    sprawdzPozKlient = true
		    exit function
		  end if
	   next  
     else
       exit function
     end if
   next
end function  

'sprawdza czy na zamówieniu istnieje pozycja do realizacji
public function sprawdzPozZam(byval strDok, byval iter):sprawdzPozZam = false
  dim i, j
  for i = iter to root_.m_oItemArray.UpperIndex
     dim oRRI : set oRRI = root_.m_oItemArray.Value(i)
	 dim oOrderObj : set oOrderObj = trans_.getobj(oRRI.m_nTypeId,oRRI.m_idObj)
     if strDok = oOrderObj.text then
	   for j = 0 to oRRI.m_oDetailArray.UpperIndex
		  dim oRRID : set oRRID = oRRI.m_oDetailArray.Value(j)
		  dim oDetailObj : set oDetailObj = oOrderObj.listPozycje.get(oRRID.m_nLP)
		  dim oStockInfo : set oStockInfo = root_.get_stock_info(oDetailObj.pProdukt.idobj,oDetailObj.pOpak.idobj)		
		  dim curStockQty : curStockQty = oStockInfo.get_avail_qty()	
		  if (oRRID.m_curOrderQty <= curStockQty) or (curStockQty > 0) or (oStockInfo.m_curUsedQty > 0) then
		    sprawdzPozZam = true
		    exit function
		  end if
	   next  
     else
       exit function
     end if
   next
end function 

%>


<page style='36' margins='500,500,500,500'>
<config>
	<title>Zamówienia do realizacji</title>
</config>
<header>
</header>
<body>
   <table border='1'>
	<thead>
		<tr>
		   <td rowspan='2' width='4000'>
			<text bold='true'>Produkt</text>
	         </td>
		   <td colspan='5'>
			<text bold='true'>Ilość opakowań</text>
		   </td>
		</tr>
		<tr>
		   <td width='2000'>
			<text bold='true'>zamówiona</text>
		   </td>
		   <td width='2000'>
			<text bold='true'>pozostała</text>
		   </td>
		   <td width='2000'>
			<text bold='true'>dostępna</text>
		   </td>
		   <td width='2000'>
			<text bold='true' >zarezerwowana</text>
		   </td>
		   <td width='2000'>
			<text bold='true'>przydzielona</text>
		   </td>
		</tr>
	
	</thead>
	<tbody>
	<%
	dim iter, oRRI, oRRI2, oOrderObj, oOrderObj2, strDok
	dim aktKlient : aktKlient = ""
	dim popKlient : popKlient = "" 
	for iter = 0 to root_.m_oItemArray.UpperIndex
	  'wypisywanie klienta
	  if iter = 0 then
		set oRRI = root_.m_oItemArray.Value(iter)
		set oOrderObj = trans_.getobj(oRRI.m_nTypeId,oRRI.m_idObj)
        aktKlient = oOrderObj.pKlient.text
          if sprawdzPozKlient(aktKlient,iter) then  %>
			<tr>
				<td align='left' colspan='6' backcolor='#E0E0E0'>
					<text bold='true'><![CDATA[AKT_KLIENT]]></text>
				</td>
			</tr>
		  <%
		  end if
	  end if
	  if iter > 0 then
		set oRRI = root_.m_oItemArray.Value(iter)
		set oRRI2 = root_.m_oItemArray.Value(iter - 1)
		set oOrderObj = trans_.getobj(oRRI.m_nTypeId,oRRI.m_idObj)
		set oOrderObj2 = trans_.getobj(oRRI2.m_nTypeId,oRRI2.m_idObj)
        aktKlient = oOrderObj.pKlient.text
        popKlient = oOrderObj2.pKlient.text
          if aktKlient <> popKlient then
			  if sprawdzPozKlient(aktKlient,iter) then  %>
				<tr>
					<td align='left' colspan='6' backcolor='#E0E0E0'>
						<text bold='true'><![CDATA[AKT_KLIENT]]></text>
					</td>
				</tr>
			  <%
			  end if
		  end if	  
	  end if
	  'wypisywanie dokumentu
	  strDok = oOrderObj.text
	  if sprawdzPozZam(strDok,iter) then  %>	
		<tr>
			<td align='left' colspan='6'>
				<text bold='true'><![CDATA[DOKUMENT]]></text>
			</td>
		</tr> 
   	
      <%'pozycje dokumentu
		dim iter2
		for iter2 = 0 to oRRI.m_oDetailArray.UpperIndex
			dim oRRID : set oRRID = oRRI.m_oDetailArray.Value(iter2)
			dim oDetailObj : set oDetailObj = oOrderObj.listPozycje.get(oRRID.m_nLP)
		    dim oStockInfo : set oStockInfo = root_.get_stock_info(oDetailObj.pProdukt.idobj,oDetailObj.pOpak.idobj)		
		    dim curStockQty : curStockQty = oStockInfo.get_avail_qty()	
		  if (oRRID.m_curOrderQty <= curStockQty) or (curStockQty > 0) or (oStockInfo.m_curUsedQty > 0) then %>		
			  <tr>
				<td align='left'>
				   <text><![CDATA[PRODUKT]]></text>
				</td>	
				<%		
				dim strSkrot : strSkrot = oDetailObj.pOpak.pJednOpak.strSkrot
				dim nDokl : nDokl = oDetailObj.pOpak.pJednOpak.nDokladnosc - 1
				%>
				<td align='right'>
					<text><![CDATA[SKROT_DOK]]></text>
				</td>
				<td align='right'>
					<text><![CDATA[SKROT_DOK1]]></text>
				</td>
				<td align='right'>
					<text><![CDATA[SKROT_DOK2]]></text>
				</td>
				<td align='right'>
					<text><![CDATA[SKROT_DOK3]]></text>
				</td> 
				<td align='right'>
				   <text><![CDATA[SKROT_DOK4]]></text>
				</td> 				  
	          </tr> 		 	       
	        <%
		    end if
	    next
	  end if   
	next 
	%>
	</tbody>
   </table>
</body>
<footer>
</footer>
</page>
