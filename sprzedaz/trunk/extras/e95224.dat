<!-- updated: 2024-08-23 --> 

<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Ranking ilości sprzedaży produktu


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_2.strIndeks
#define C_FIELD_SECOND_EXPR		t_2.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks
#define C_FIELD_SECOND_HUMANNAME 	Nazwa
#else
#define C_FIELD_FIRST_EXPR		t_2.strNazwa
#define C_FIELD_SECOND_EXPR		t_2.strIndeks
#define C_FIELD_FIRST_HUMANNAME		Nazwa
#define C_FIELD_SECOND_HUMANNAME	Indeks
#endif


-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<% dim current_jedn_ewid : current_jedn_ewid = 1%>
<% dim current_jedn_skrot : current_jedn_skrot = "BUG"%>

<%
function query()

query = "select 'c_field_second' = max(C_FIELD_SECOND_EXPR),'c_field_first'= max(C_FIELD_FIRST_EXPR),'c_1'=MAX(t_3.strNazwa), 'c_oznprod' = MAX(t_2.strCecha1) , " +_
"'c_ilosc_sum'=SUM(t_sprz.c_curIloscOpak - isnull(t_orgsprz.c_curIloscOpak,0)), " + _
"'c_prod_idobj'=max(t_2.IdObj),'c_opak'=max(t_4.strSkrot), 'c_prec'=MAX(t_4.nDokladnosc), " + _
"'c_ilosc_ewid'=SUM(t_3.currKrotnosc * (t_sprz.c_curIloscOpak - isnull(t_orgsprz.c_curIloscOpak,0))), " + _
"'c_wart_netto'=SUM(t_sprz.c_curWartNetto - isnull(t_orgsprz.c_curWartNetto,0))," +_
"'c_wart_brutto'=SUM(t_sprz.c_curWartNetto - isnull(t_orgsprz.c_curWartNetto,0)) + SUM(t_sprz.c_curVat - isnull(t_orgsprz.c_curVat,0)), " +_
"'c_jedn_ewid'=MAX(t_jedn_ewid.nDokladnosc), " + _
"'c_jedn_skrot'=MAX(t_jedn_ewid.strSkrot) " + _
"from vlist_n5sprzedaz_listpozycje as t_sprz  " + _
" left outer join vlist_n5sprzedaz_listpozycje t_orgsprz on t_sprz.p_ppopsprzed = t_orgsprz.p_idobj and t_sprz.coll_lp = t_orgsprz.coll_lp "+_
"inner join n5klient as t_1 on t_sprz.p_pKlient = t_1.IdObj   "+_
"left join n5pracownik as t_prac on  t_1.pPracownik = t_prac.Idobj "+_
"inner join n5produkt as t_2 on t_sprz.c_pProdukt = t_2.IdObj  " + _
"inner join n5opakowanie_produktu as t_3 on t_sprz.c_pOpak = t_3.IdObj  " + _
"inner join n5jednostka as t_4 on t_3.pJednOpak = t_4.IdObj  " + _
"inner join n5jednostka as t_jedn_ewid on t_2.pJednostkaEwid = t_jedn_ewid.IdObj  " + _
" left outer join n5pracownik as t_handl on t_sprz.p_sprzed_pHandlowiec = t_handl.idobj " +_
"where t_2.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) "+_
"and t_sprz.p_pRozlVAT<>0 and %1 AND %2 AND %3 and %5 and %6 and %7 and %8 " + _
"and t_sprz.p_prejestrdok not in (select idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)) " +_
"group by t_2.strIndeks,t_3.IdObj  " + _
"order by c_ilosc_sum desc, c_field_first,c_field_second"


end function
%>
<%
dim utilProdHierarchy : set utilProdHierarchy = doc_.getmodule(60246)
dim pProdHierarchy : set pProdHierarchy = utilProdHierarchy.new_prod_hierarchy()

dim pParamArray
dim pGrupaParam
 
function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Analizowany okres").bindexpr("t_sprz.p_dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_2.strIndeks")	
	set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam 
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")	
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")	
	pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(t_handl.strNazwisko,'')")
	
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>

<% current_jedn_ewid = pRec("c_jedn_ewid")-1%>
<% current_jedn_skrot = pRec("c_jedn_skrot")%>


<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>

<tr fontsize='5'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='5'/>
	<td style='27' colspan='1' align='right'>
	RXE_QUANTITY_VVV(pSection.counter(0).result, current_jedn_skrot, current_jedn_ewid) 
	</td>

</tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='5' /></tr>

<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<!--	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>-->
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_prod_idobj,c_field_first)		
	</td>
#ifdef _IOW
	<td>
		RXE_AUTO_TEXT(c_oznprod)		
	</td>
#endif
	<td>
		RXE_AUTO_TEXT(c_field_second)		
	</td>

	<td>
		RXE_AUTO_TEXT(c_1)
	</td>
	
	<td colspan='2' align='right'>
		RXE_QUANTITY_CCC(c_ilosc_sum,c_opak,c_prec) 
	</td>
	
	<td colspan='2' align='right'>
		RXE_QUANTITY_CCC(c_ilosc_ewid,c_jedn_skrot,c_jedn_ewid) 
		<t>&nbsp;</t>
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_brutto,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
<!--	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>-->
	<td width='min'><t>LP</t></td>
	<td width='min'>		
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text>
	</td>
#ifdef _IOW
	<td width='min'>
		<text><![CDATA[Oznaczenie producenta]]></text>
	</td>
#endif
	<td width='min'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Nazwa opakowania]]></text>
	</td>

	<td colspan='2' width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
	
	<td colspan='2' width='min'>
		<text><![CDATA[Ilość w jedn. ewid.]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość brutto]]></text>
	</td>
	
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	'.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_ilosc_ewid")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pProdHierarchy.fill_on_prodgrupa_param pGrupaParam
	set pPerf = nothing

	.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=1"

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	'write_actual_param rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pProdHierarchy.manual_done() : set pProdHierarchy = nothing
set utilProdHierarchy = nothing

%>
</body>
<footer>
</footer>
</page>
