<?xml version="1.0" encoding="windows-1250" ?>

<!-- Raport kasowy -->



#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
 

<!-- Informacje na wydruku -->
#define DOKUMENT_NAZWA					<% if root_.raka_pRejestrDok.eTyp = 9 then so.write "kasowy" else if root_.raka_pRejestrDok.eTyp = 10 then so.write "bankowy" end if end if%>
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_WYSTAWIENIA			<% so.write trans_.var(1007) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY		<% so.write root_.raka_pUzytRej.strNazwa%>
#define DOKUMENT_OSOBA_ODBIERAJACA			<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>
#define DOKUMENT_KASA					<% so.write root_.raka_pRejestrDok.strNazwa %>
#define DOKUMENT_OKRES_OD				<% so.write doc_.afc.display.fulldate(root_.raka_dDataOd) %>
#define DOKUMENT_OKRES_DO				<% so.write doc_.afc.display.fulldate(root_.raka_dDataDo) %>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR_RS					<% so.write cstr(rs.fields("nazwa").value) %>
#define POZ_IDX_RS						<% so.write cstr(rs.fields("indeks").value)%>
#define POZ_OPAKOWANIE_RS				<% if cstr(rs.fields("opakowanie").value) <> "Podstawowe" then so.write " (" +  cstr(rs.fields("opakowanie").value) + ")" end if%>
#define POZ_PKWIU_RS					<% so.write cstr(rs.fields("strkodpkwiu").value)%>
#define POZ_ILOSC_RS					<% so.write cstr(rs.fields("ile_opak").value) %>
#define POZ_KROTNOSC_RS					<% so.write cstr(rs.fields("currKrotnosc").value) %>
#define POZ_KARTON_RS					<% so.write cstr(iloscKarton) %>
#define POZ_JM_RS						<% 'so.write rs.fields("strSkrot").value %>
#define POZ_VAT_RS						<% 'so.write util_.vat_to_name(rs.fields("eVat").value) %>
#define POZ_WAGA_NETTO_RS				<% so.write doc_.afc.display.quantity(ccur(rs.fields("waga_netto").value),"",clng(rs.fields("nDokladnosc").value) - 1 )%>
#define POZ_WAGA_BRUTTO_RS				<% so.write doc_.afc.display.quantity(ccur(rs.fields("waga_brutto").value),"",clng(rs.fields("nDokladnosc").value) - 1 )%>


#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>


#define POZ_OPIS					<% so.write pPlatnosc.strOpis%>
#define POZ_PODMIOT					<% so.write pPlatnosc.wrefPodmiot.text%>
#define POZ_DATA					<% so.write doc_.afc.display.fulldate(pPlatnosc.dDataOper)%>
#define POZ_DOK_NR					<% so.write pPlatnosc.strNrDok %>
#define POZ_WYPLATA					<% if pPlatnosc.curKwotaPodm < 0 then  so.write MONEY(pPlatnosc.curKwotaPodm) end if %>
#define POZ_WPLATA					<% if pPlatnosc.curKwotaPodm > 0 then  so.write MONEY(pPlatnosc.curKwotaPodm) end if %>
#define RAZEM_PRZYCHODY					<% so.write MONEY(curPrzychody)%>
#define RAZEM_ROZCHODY					<% so.write MONEY(curRozchody)%>
#define RAZEM_PRZYCHODY_ROZCHODY			<% so.write MONEY(curRazem)%>
#define RAZEM_STAN_PRZED				<% so.write MONEY(curStanPrzed)%>


#define POZ_CENA_NETTO					<% so.write MONEY(pozycja.curCenaNetto) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>

#define FIRMA_TELEFON_LABEL				<% so.write util_.Firma_Telefon_Label %>
#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_TELEFON_HIDE				<% so.write util_.Firma_Telefon_Hide %>

#define FIRMA_FAX_LABEL					<% so.write util_.Firma_Fax_Label %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_FAX_HIDE					<% so.write util_.Firma_Fax_Hide %>



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"


VB_PRINT_DPC 
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
					    <tr >						
							<td align='left' >
								<t bold='true'><![CDATA[FIRMA_NAZWA]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>	
						
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='2' align='center'>
								<t bold='true' fontsize='6'><![CDATA[Raport DOKUMENT_NAZWA nr DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='2' align='center'>
								<t bold='true' ><![CDATA[DOKUMENT_KASA]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='2' align='center'>
								<t bold='true' ><![CDATA[za okres od  DOKUMENT_OKRES_OD do DOKUMENT_OKRES_DO ]]></t>
							</td>
						</tr>
						ROW_SEPARATOR(2)
					
						ROW_SEPARATOR(2)

						


						
					</tbody>
				</table>
			</td>
		</tr>



ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				dim curPrzychody , curRozchody, curRazem, curStanPrzed
    				curPrzychody = ccur(0)
    				curRozchody = ccur(0)
				curRazem = ccur(0)
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
					<%
					dim pCursor: set pCursor = root_.n5rapkas_get_platnosci()
  					dim pPlatnosc
  					
  					for each pPlatnosc in pCursor
						if iter = 1 then
							curStanPrzed = pPlatnosc.n5platnosc_stan(pPlatnosc.pREjestrDok.idobj,pPlatnosc.nNumOper)
							


					%>
						<tr bordercolor='transparent'>
							<td align='right' colspan='3' bordercolor='transparent'>
								<t></t>
							</td>
							
							<td align='right'>
								<t >Stan przed</t>
							</td>
							<td align='right'>
								<t ><![CDATA[RAZEM_STAN_PRZED]]></t>
							</td>
							<td align='right' bordercolor='transparent'>
								<t></t>
							</td>
							
						</tr>
					<%	end if
						iter = iter + 1
					next%>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td align='center'>
								<t>Data</t>
							</td>
							<td align='center'>
								<t>Nr dokumentu</t>
							</td>
							<td align='center'>
								<t>Podmiot</t>
							</td>
							<td align='center'>
								<t>Wpłata</t>
							</td>
							<td align='center'>
								<t>Wypłata</t>
							</td>
							<td align='center'>
								<t>Opis</t>
							</td>
							
						</tr>
					</thead>
					
					
					<tbody>
					<%
					set pCursor = root_.n5rapkas_get_platnosci()
  					
  					iter = 1
  					for each pPlatnosc in pCursor
						if iter = 1 then
							curStanPrzed = pPlatnosc.n5platnosc_stan(pPlatnosc.pREjestrDok.idobj,pPlatnosc.nNumOper)
						end if	


					%>



					
						<tr>
							<td align='right'>
								<t><![CDATA[POZ_LP]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_DATA]]></t>
							</td>
							<td align='left'>
								<t><![CDATA[POZ_DOK_NR]]></t>
							</td>
							<td align='left'>
								<text><![CDATA[POZ_PODMIOT]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WPLATA]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WYPLATA]]></t>
							</td>
							<td align='left'>
								<text><![CDATA[POZ_OPIS]]></text>
							</td>
							
						</tr>
					<% iter = iter + 1
					if pPlatnosc.curKwotaPodm > 0 then
						curPrzychody = curPrzychody + pPlatnosc.curKwotaPodm
					else
						curRozchody = curRozchody + pPlatnosc.curKwotaPodm
					end if

					next 
					

					curRazem = curStanPrzed + curPrzychody + curRozchody%>
					</tbody>
					<tfoot>

						<tr bordercolor='transparent'>
							<td align='right' colspan='3' bordercolor='transparent'>
								<t></t>
							</td>
							
							<td align='right'>
								<t bold='true'>Razem</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[RAZEM_PRZYCHODY]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[RAZEM_ROZCHODY]]></t>
							</td>
							
						</tr>
						<tr bordercolor='transparent'>
							<td align='right' colspan='3' bordercolor='transparent'>
								<t></t>
							</td>
							
							<td align='right'>
								<t bold='true'>Stan po</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[RAZEM_PRZYCHODY_ROZCHODY]]></t>
							</td>
							<td align='right' bordercolor='transparent'>
								<t></t>
							</td>
							
						</tr>
					</tfoot>
				</table>
			</td>
		</tr>	
		
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'></td>						
														
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td></td>
														
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Wprowadził</t>
							</td>				
							<td></td>			
														
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<t>Podpisy</t>
							</td>							
							<td width='max'>									
							</td>							
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td width='max'>									
							</td>							
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							

						</tr>
						<tr>
							<td align='center'>	

							</td>							
							<td width='max'>									
							</td>							

							<td align='center'>	
								<t fontsize='2'>Kontroler</t>
							</td>				
							<td width='max'>									
							</td>							

							<td align='center'>	
								<t fontsize='2'>Księgowy</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		


		<tr valign='bottom'>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
