					<tfoot>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOK_ORG_DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							dim tax_summary: tax_summary = util_.recalc_summary_by_tax_rates(oOrgSprzed)
							for iter = 0 to UBound(tax_summary)
						%>
						<tr>
							<td colspan='8' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA]]></t>								
