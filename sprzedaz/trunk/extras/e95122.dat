<?xml version="1.0" encoding="windows-1250" ?>

<!-- KOREKTA FAKTURY VAT -->
<!-- 8.06.2004 poprawka - oryginal/kopia, adresy, zamowienie -->
<!-- 20.06.2004 rabat %-->
<!-- 21.06.2004 -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->
<!-- 16.11.2004 siedziba firmy klienta -->
#include "h1240"

#define CTRLID_ORGKOPIA					101

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro QTY_(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>

<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>

#define KLIENT_SDB_KOD_MIASTO			<% if root_.pKlient.strPocztaSDB="" then so.write root_.pKlient.strKodSDB+" "+root_.pKlient.pMiejscowoscSDB.strNazwa else if root_.pKlient.strPocztaSDB<>"" and  root_.pKlient.strPocztaSDB<>root_.pKlient.pMiejscowoscSDB.strNazwa then so.write root_.pKlient.strKodSDB + " " + root_.pKlient.strPocztaSDB else if  root_.pKlient.strPocztaSDB=root_.pKlient.pMiejscowoscSDB.strNazwa then so.write root_.pKlient.strKodSDB+" "+root_.pKlient.strPocztaSDB end if end if end if%>
#define KLIENT_SDB_ULICA_NUMER			<% if root_.pKlient.strNrLokaluSDB<>"" then so.write root_.pKlient.strUlicaSDB+" "+root_.pKlient.strNrDomuSDB+"/"+root_.pKlient.strNrLokaluSDB else so.write root_.pKlient.strUlicaSDB+" "+root_.pKlient.strNrDomuSDB end if %>
#define KLIENT_SDB_MIASTO				<% if not root_.pKlient.pMiejscowoscSDB is nothing then so.write root_.pKlient.pMiejscowoscSDB.strNazwa end if%>


<!-- Dane nabywcy - dokument oryginalny -->
#define DOK_ORG_KLIENT_NAZWA			<% if not oOrgSprzed is nothing then so.write util_.Klient_Nazwa(oOrgSprzed.pKlient) end if %>
#define DOK_ORG_KLIENT_NIP				<% if not oOrgSprzed is nothing then so.write util_.Klient_NIP(oOrgSprzed.pKlient) end if  %>
#define DOK_ORG_KLIENT_KOD_MIASTO		<% if oOrgSprzed.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(oOrgSprzed.pKlient) else if oOrgSprzed.pKlient.strPoczta<>"" and  oOrgSprzed.pKlient.strPoczta<>oOrgSprzed.pKlient.pMiejscowosc.strNazwa then so.write oOrgSprzed.pKlient.strKod + " " + oOrgSprzed.pKlient.strPoczta else if  oOrgSprzed.pKlient.strPoczta=oOrgSprzed.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(oOrgSprzed.pKlient) end if end if end if%>
#define DOK_ORG_KLIENT_ULICA_NUMER		<% if not oOrgSprzed is nothing then so.write util_.Klient_Ulica(oOrgSprzed.pKlient)  end if %>
#define DOK_ORG_KLIENT_MIASTO			<% if not oOrgSprzed is nothing then so.write oOrgSprzed.pKlient.pMiejscowosc.strNazwa end if %>

#define DOK_ORG_KLIENT_JO_NAZWA			<% if not oOrgSprzed is nothing then so.write util_.Klient_Nazwa(oOrgSprzed.pKlient_JO) end if %>
#define DOK_ORG_KLIENT_JO_KOD_MIASTO		<% if oOrgSprzed.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(oOrgSprzed.pKlient_JO) else if oOrgSprzed.pKlient_JO.strPoczta<>"" and  oOrgSprzed.pKlient_JO.strPoczta<>oOrgSprzed.pKlient_JO.pMiejscowosc.strNazwa then so.write oOrgSprzed.pKlient_JO.strKod + " " + oOrgSprzed.pKlient_JO.strPoczta else if  oOrgSprzed.pKlient_JO.strPoczta=oOrgSprzed.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(oOrgSprzed.pKlient_JO) end if end if end if%>
#define DOK_ORG_KLIENT_JO_ULICA_NUMER	<% if not oOrgSprzed is nothing then so.write util_.Klient_Ulica(oOrgSprzed.pKlient_JO) end if %>
#define DOK_ORG_KLIENT_JO_MIASTO		<% if not oOrgSprzed is nothing then so.write oOrgSprzed.pKlient_JO.pMiejscowosc.strNazwa end if%>

<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_SPRZEDAZY			<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(abs(ccur(doc_summary.value_brutto_dom))) %>
#define DOKUMENT_DO_ZAPLATY_OPIS		<% if ccur(doc_summary.value_brutto_dom) < 0 then so.write "Do zwrotu: " else so.write "Do zapłaty: "   %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(abs(ccur(doc_summary.value_brutto_dom))) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_ZAMOWIENIE				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_ZAMOWIENIE_NR_OBCY		<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.zam_strNrDokObcy end if  %>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>
#define DOKUMENT_WALUTA					<% so.write root_.pWaluta.strSkrot %>



#define DOK_ORG_DOKUMENT_NUMER				<% if not oOrgSprzed is nothing then so.write oOrgSprzed.text end if %>
#define DOK_ORG_DOKUMENT_DATA_SPRZEDAZY		<% if not oOrgSprzed is nothing then so.write doc_.afc.display.fulldate(oOrgSprzed.dDataWyst) end if  %>
#define DOK_ORG_DOKUMENT_TERMIN_PLATNOSCI	<% if not oOrgSprzed is nothing then so.write doc_.afc.display.fulldate(oOrgSprzed.dDataPlat) end if  %>
#define DOK_ORG_DOKUMENT_SPOSOB_PLATNOSCI	<% if not oOrgSprzed is nothing then so.write util_.Dokument_Sposob_Platnosci(oOrgSprzed)  end if %>
#define DOK_ORG_DOKUMENT_DO_ZAPLATY			<% if not oOrgSprzed is nothing then so.write MONEY(oOrgSprzed.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_DO_ZAPLATY_SLOWNIE	<% if not oOrgSprzed is nothing then so.write doc_.afc.display.slownie(oOrgSprzed.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_NETTO		<% if not oOrgSprzed is nothing then so.write MONEY(oOrgSprzed.curSumaNetto) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_VAT			<% if not oOrgSprzed is nothing then so.write MONEY(oOrgSprzed.curSumaVat) end if %>
#define DOK_ORG_DOKUMENT_WARTOSC_BRUTTO		<% if not oOrgSprzed is nothing then so.write MONEY(oOrgSprzed.curSumaBrutto) end if %>
#define DOK_ORG_DOKUMENT_POWIAZANY				<% if not oOrgSprzed.pZamowienie is nothing then so.write oOrgSprzed.pZamowienie.strNrDok end if  %>
#define DOK_ORG_DOKUMENT_ZAMOWIENIE_NR_OBCY		<% if not oOrgSprzed.pZamowienie is nothing then so.write oOrgSprzed.pZamowienie.zam_strNrDokObcy end if  %>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write doc_.afc.display.quantity(pozycja.curCenaNetto,"",trans_.var(GVAR_PRICE_PREC)) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>



<!-- podsumowanie pozycji -->
#define DOKUMENT_PODSUMOWANIE_NETTO		<% so.write MONEY(ccur(tax_summary(iter).value_netto_dom)) %>
#define DOKUMENT_PODSUMOWANIE_VAT		<% so.write MONEY(ccur(tax_summary(iter).tax_value_dom)) %>
#define DOKUMENT_PODSUMOWANIE_BRUTTO	<% so.write MONEY(ccur(tax_summary(iter).value_brutto_dom)) %>
#define DOKUMENT_PODSUMOWANIE_STAWKA	<% so.write tax_summary(iter).tax_code %>

#define KWOTA_ROZNICA_NETTO_OPIS		<% so.write "Kwota " + kor_opis + " wartości netto" %>
#define KWOTA_ROZNICA_NETTO_WARTOSC		<% so.write MONEY(abs(ccur(doc_summary.value_netto_dom))) %>
#define KWOTA_ROZNICA_VAT_OPIS			<% so.write "Kwota " + kor_opis + " wartości VAT" %>
#define KWOTA_ROZNICA_VAT_WARTOSC		<% so.write MONEY(abs(ccur(doc_summary.tax_value_dom))) %>

<!--

-->



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"

function fprint 
	fprint = doc_.getmodule(60182).fprint_on_dpc_org_kopia(page_.get_this,CTRLID_ORGKOPIA) 
end function

VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<%
dim oOrgSprzed
set oOrgSprzed = root_
do while not (oOrgSprzed.pPopSprzed is nothing)
	set oOrgSprzed = oOrgSprzed.pPopSprzed
	exit do
loop

dim doc_summary: set doc_summary = util_.recalc_doc_summary_with_original(root_, oOrgSprzed)
dim kor_opis: kor_opis = ""
if ccur(doc_summary.value_netto_dom) < ccur(0) then
	kor_opis = "pomniejszenia"
else
	kor_opis = "powiększenia"	
end if

%>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table>
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[KOREKTA NR DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[FAKTURY NR DOK_ORG_DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t name='CTRLID_ORGKOPIA' bold='true'>Oryginał</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

						<!-- KLAUZULA MPP -->
						<% if root_.sprzed_cSplit = "1"  then %>
						<tr>
							<td></td>
							<td colspan='2'>
								<table>
									<tbody>
										<tr>
											<td width='min' border='1'>
												<t bold='true' fontsize='5'>&nbsp;&nbsp;MECHANIZM PODZIELONEJ PŁATNOŚCI&nbsp;&nbsp;</t>
											</td>
											<td></td>
										</tr>
									</tbody>
								</table>
							</td>
						</tr>
						<% end if %>
							
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'>BYŁO</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)


<% if not oOrgSprzed is nothing then %>

						
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<!-- Dane nabywcy - Klient - jednostka organizacyjna-->
						<% if not oOrgSprzed.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (oOrgSprzed.pKlient_JO.strPoczta<>"") and (oOrgSprzed.pKlient_JO.pMiejscowosc.strNazwa <> oOrgSprzed.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<% else %>
										
						<!-- Dane nabywcy - KLIENT -->
						
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (oOrgSprzed.pKlient.strPoczta<>"") and (oOrgSprzed.pKlient.pMiejscowosc.strNazwa <> oOrgSprzed.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOK_ORG_KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						
						<% end if %>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[DOK_ORG_KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>


						ROW_SEPARATOR(3)
						<!-- płatności -->

						<tr>
							<td>
								<t bold='true'>Data sprzedaży:</t>
							</td>
							<td>								
								<t><![CDATA[DOK_ORG_DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>							
							<td  keepline='true'>
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOK_ORG_DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOK_ORG_DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>

					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<%
				iter = 1
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td align='right'>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<t>PKWiU</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='center'>
								<t>J.m.</t>
							</td>							
							<td align='right'>
								<text>Cena netto</text>
							</td>
							<td align='right'>
								<text>Rabat</text>
							</td>
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in oOrgSprzed.listPozycje %>
						<tr>
							<td align='right' width='min'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min' align='right'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='center' width='min'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>							
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
						next
						%>
