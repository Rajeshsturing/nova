							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		



		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table>
					<tbody>

<!-- Koniec sekcji z dokumentem oryginalnym -->
<% end if %>


						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'>MA BYĆ</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)


						
						<!-- Dane nabywcy - KLIENT - jednostka organizacyjna -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>			
						
						<% if not root_.pKlient_JO is nothing then %>

						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>			
						<tr>
 							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<% else %>
						<!-- Dane nabywcy - KLIENT -->

						<tr>
 							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						
						<% end if %>
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>
						
							<!-- KLIENT siedziba -->
						
						<%
						if not root_.pKlient.pMiejscowoscSDB is nothing then 
						if ( (trim(root_.pKlient.strUlica)<>trim(root_.pKlient.strUlicaSDB)) or +_
							 (trim(root_.pKlient.strNrDomu)<>trim(root_.pKlient.strNrDomuSDB)) or +_
							 (trim(root_.pKlient.strNrLokalu)<>trim(root_.pKlient.strNrLokaluSDB)) or +_
							 (trim(root_.pKlient.pMiejscowosc.strNazwa)<>trim(root_.pKlient.pMiejscowoscSDB.strNazwa)) ) then  %>
						ROW_SEPARATOR(3)
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Siedziba:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_SDB_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPocztaSDB<>"") and (root_.pKlient.pMiejscowoscSDB.strNazwa <> root_.pKlient.strPocztaSDB) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_SDB_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_SDB_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<%end if%>
						<%end if%>
						
						ROW_SEPARATOR(3)	
						
						<!-- płatności -->

						<tr>
							<td>
								<t bold='true'>Data sprzedaży:</t>
							</td>
							<td >								
								<t><![CDATA[DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>							
							<td keepline='true' >
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>
													
						
						
						<!-- dokumenty powiazane - zamowienie -->
						<% if not root_.pZamowienie is nothing then %>
						ROW_SEPARATOR(3)				
						<tr>
							<td>
								<t bold='true'>Zamówienie</t>						
							</td>
							<td>
								<t/>
							</td>							
							<td>
