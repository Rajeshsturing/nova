<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Dziennik (skrót)
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=t_1.strNazwa,'c_1'=t_0.eTyp,'c_2'=t_0.nNumDow,'c_3'=t_0.nNumDow,'c_4'=t_0.dDataKsieg,'c_5'=t_0.strNrDok,'c_iddowod'=t_0.IdObj,'c_8'=t_0.strOpis,'c_auto'=t_0.cAuto from n5dowodksieg as t_0 inner join n5rejestrdok as t_1 on t_0.pRejestrDok = t_1.IdObj where  %1  and  %2  and  %3  and  %4  order by c_0,c_1,c_5"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data księgowania").bindexpr("t_0.dDataKsieg")
	
	dim pParamFactory4: set pParamFactory4= doc_.afc.rap.param
	dim pParam4: Set pParam4= pParamFactory4.new_choice("Dziennik").bindexpr("t_1.idobj")
	doc_.afc.rap.param.init_on_query pParam4, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DZIENNIK_NORM,N5REJESTRDOK_DZIENNIK_BO, " +_
		"N5REJESTRDOK_DZIENNIK_BZ,N5REJESTRDOK_DZIENNIK_BZ_OSTAT) and pRokKsieg=" + cstr(trans_.var(8011)) + " order by strNazwa "
	pParamArray.add pParam4

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ zapisu").bindexpr("t_0.eTyp")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5DEKRET,"eTyp"
	pParamArray.add pParam2
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Status").bindexpr("t_0.eStatus")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5DEKRET,"eStatus"
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
<%
dim curSumaRejWn,curSumaRejMa

function section_header_1(byref pSection,byref pRec)
curSumaRejWn = ccur(0.0)
curSumaRejMa = ccur(0.0)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr style='27' userprop='propc_section_end="1"'><td colspan='6' />
	<td align='right'>
		RXE_MONEY_VAR(curSumaRejWn)
	</td>
	<td align='right'>
		RXE_MONEY_VAR(curSumaRejMa)
	</td>
	<td colspan='2'>
		<%
		if (curSumaRejWn <> curSumaRejMa) then
		%>
		<t bold='true' forecolor='red'>&nbsp; Dziennik nie bilansuje się !</t>
		<%
		end if
		%>
	</td>
</tr>
<%
end function
%>
<%
dim curSumaTypWn,curSumaTypMa
function section_header_2(byref pSection,byref pRec)
curSumaTypWn = ccur(0.0)
curSumaTypMa = ccur(0.0)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='9' keepline='true'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		<t>RXF_ENUM_VVC(TYPEID_N5DOWODKSIEG,eTyp,c_1)</t>
	</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr style='27' userprop='propc_section_end="2"'><td colspan='6' />
	<td align='right'>
		RXE_MONEY_VAR(curSumaTypWn)
	</td>
	<td align='right'>
		RXE_MONEY_VAR(curSumaTypMa)
	</td>
	<td colspan='2' >
	</td>
</tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_4)
	</td>
	<td  width='min'>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5DOWODKSIEG,c_iddowod,c_5)
	</td>
	<td colspan='3'>
		
		<%
		dim pDowodKsiegowy : set pDowodKsiegowy = trans_.getobj(TYPEID_N5DOWODKSIEG,clng(pRec("c_iddowod")))
		dim pSumator : set pSumator = pDowodKsiegowy.n5dowodksieg_get_sumator()
		if (pSumator.get_bilwn() <> pSumator.get_bilma()) then
		%>
		<t bold='true' forecolor='red'>&nbsp; Dowód nie bilansuje się !</t>
		<%
		end if
		%>
		
		RXE_AUTO_TEXT(c_8)
	</td>
	<td>
		<t><%
		if cstr(pRec("c_auto")) = "0" then
			so.write "ręczny"
		else
			so.write "automatyczny"
		end if
		%>
		</t>
	</td>
</tr>
<%
	dim idUnit, curSumaWn, curSumaMa, nRef
	dim strUnit
	dim iter : iter = 0
	do while pSumator.get_value(iter,idUnit,curSumaWn,curSumaMa,nRef) 
		if nRef > 0 then
			if idUnit <> 0 then
				strUnit = trans_.getobj(TYPEID_N5JEDNOSTKA,idUnit).strSkrot
			else
				strUnit = "<brak>"
			end if
		curSumaRejWn = curSumaRejWn + curSumaWn
		curSumaRejMa = curSumaRejMa + curSumaMa
		curSumaTypWn = curSumaTypWn + curSumaWn
		curSumaTypMa = curSumaTypMa + curSumaMa
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' colspan='5' width='min'><t>&nbsp;</t></td>
	<td align='right'>
		RXE_MONEY_VAR(curSumaWn)
	</td>
	<td align='right'>
		RXE_MONEY_VAR(curSumaMa)
	</td>
	<td width='min'>
		<t><![CDATA[<% so.write strUnit %>]]></t>
	</td>
	<td></td>
</tr>
<%
			
		end if
		iter = iter + 1
	loop	
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>

	<td width='min'>
		<text><![CDATA[Data księgowania]]></text>
	</td>
	<td width='3000'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='5000' colspan='3'>
		<text><![CDATA[Opis dowodu księgowego]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Sposób utworzenia]]></text>
	</td>
</tr>
<tr style='21'>
	<td  colspan='5' />
	<td width='min'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ma]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Jednostka]]></text>
	</td>
	<td colspan='1' />
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>

<p><br/><br/><br/><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 1,getref("section_header_2"),getref("section_footer_2")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
