<?xml version="1.0" encoding="windows-1250" ?>
<ne2002officeconfig version='1'>
	
	<word>
		<v9>
			<!-- opcje dostępne w Office 2000 i wyżej -->
			<commands>
				<command>
					<caption>Otwórz z EuroKontakt</caption>
					<tag>OPEN_FROM</tag>
					<menupath>Menu Bar;1;3</menupath>
					<call>vn1001=1030 vn1002=60149 vs8003='@appname@' vs1012='@server@' vs8008='@dbname@'</call>
				</command>
				<command>
					<caption>Zapisz do  EuroKontakt</caption>
					<tag>SAVE_INTO</tag>
					<menupath>Menu Bar;1;7</menupath>
					<call>vn1001=1030 vn1002=60149 vs8003='@appname@' vs1012='@server@' vs8008='@dbname@'</call>
				</command>
				<command>
					<caption>Oddaj do  EuroKontakt</caption>
					<tag>CHECK_IN</tag>
					<menupath>Menu Bar;1;8</menupath>
					<call>vn1001=1030 vn1002=60149 vs8003='@appname@' vs1012='@server@' vs8008='@dbname@'</call>
				</command>
			</commands>
		</v9>	
		<v10>
			<!-- opcje dostępne w Office 2000 i wyżej -->
			<commands>
