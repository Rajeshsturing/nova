<?xml version="1.0" encoding="windows-1250" ?>

<!--02.08.2004 -poprawka tytuł-->
<!-- 03.02.2005 data operacji w naglowku -->

#include "h1203_appconfig.h"


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

#define PODMIOT_NAZWA					<% so.write util_.Podmiot_Nazwa(root_.wrefPodmiot) %>
#define PODMIOT_ULICA					<% so.write util_.Podmiot_Ulica(root_.wrefPodmiot) %>
#define PODMIOT_MIASTO_KOD				<% if root_.wrefPodmiot.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.wrefPodmiot) else if root_.wrefPodmiot.strPoczta<>"" and  root_.wrefPodmiot.strPoczta<>root_.wrefPodmiot.pMiejscowosc.strNazwa then so.write root_.wrefPodmiot.strKod + " " + root_.wrefPodmiot.strPoczta else if  root_.wrefPodmiot.strPoczta=root_.wrefPodmiot.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.wrefPodmiot) end if end if end if%>
#define PODMIOT_MIASTO					<% so.write root_.wrefPodmiot.pMiejscowosc.strNazwa %>
#define PODMIOT_OD_DLA					<% if root_.curKwotaPodm > 0 then so.write "Od kogo: " else so.write "Komu: " end if %>

#define DOKUMENT_WPLATA				<% if root_.curKwotaPodm > 0 then so.write "Dowód wpłaty " else so.write "Dowód wypłaty" end if %>
#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_OPERACJI			<% so.write doc_.afc.display.fulldate(root_.dDataOper) %>
#define DOKUMENT_KWOTA					<% so.write MONEY(abs(root_.curKwotaPodm)) %>
#define DOKUMENT_KWOTA_SLOWNIE			<% so.write doc_.afc.display.slownie(abs(root_.curKwotaPodm)) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OPIS					<% so.write root_.strOpis %>

#define POZ_OPIS						<% so.write pozycja.text %>





<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td colspan='2'>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_OPERACJI	]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						
						 <%if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then  %>
						<tr>
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_WPLATA DOKUMENT_NUMER]]> </t>
							</td>
						</tr>						
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[z dnia DOKUMENT_DATA_OPERACJI]]> </t>
							</td>
						</tr>
						#ifdef _FRAM						
						<tr>
							<td align='center' colspan='2'>
								<t bold='true'><![CDATA[Oryginał]]> </t>
							</td>
						</tr>						
						#endif						
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td width='max'>
				<table >
					<tbody>
						<tr>
							<td>
								<t bold='true' size='10'><![CDATA[PODMIOT_OD_DLA]]></t>
							</td>					
							<td width='max'>
								<text size='40'><![CDATA[PODMIOT_NAZWA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<text><![CDATA[PODMIOT_ULICA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<text><![CDATA[PODMIOT_MIASTO_KOD]]></text>
							</td>					
						</tr>						
						<% if (root_.wrefPodmiot.strPoczta<>"") and (root_.wrefPodmiot.pMiejscowosc.strNazwa <> root_.wrefPodmiot.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[PODMIOT_MIASTO]]></text>
							</td>					
						</tr>
						<% end if %>							

						ROW_SEPARATOR(2)

						<%	dim pozycja,iter
							iter = 1
							for each pozycja in root_.listPozycje
						%>
						<tr>
							<td>
							<% if iter = 1 then %>
								<t bold='true' size='10'>Za co:</t>
							<%end if %>
							</td>					
							<td width='max'>
								<text><![CDATA[POZ_OPIS]]></text>
							</td>					
						</tr>																									

						<%		iter = iter + 1
							next
							iter=iter-1
						%>
					</tbody>
				</table>				
			</td>
			<% if root_.curKwotaPodm > 0 then  'KP %>
			<td align='right' width='min'>
				<table border='1'>
					<thead  bold='true' backcolor='#E0E0E0'>					
						<tr backcolor='#E0E0E0'>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr backcolor='#E0E0E0'>
							<td>
								<t>konto</t>
							</td>					
							<td>
								<t>kasa</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t></t>
							</td>					
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
			<% else ' KW %>
			<td align='right' width='min'>
				<table border='1'>
					<thead  bold='true' backcolor='#E0E0E0'>					
						<tr backcolor='#E0E0E0'>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr backcolor='#E0E0E0'>
							<td>
								<t>kasa</t>
							</td>					
							<td>
								<t>konto</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
							<td>
								<t></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
			<% end if %>
			
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td colspan='2'>
				<table >
					<tbody>
						<tr>
							<td colspan='3'>
								<t bold='true'>Słownie:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_KWOTA_SLOWNIE]]></text>
							</td>					
						</tr>
						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3'>
								<t bold='true'>Opis:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_OPIS]]></text>
							</td>					
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)																		
						<tr>
							<td align='center'>
								<t fontsize='3'><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
						</tr>						
						<tr>
							<td align='center'>
								<t fontsize='3' size='20'>Sporządził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Zatwierdził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Kwotę powyższą otrzymałem</t>
							</td>					
						</tr>						
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
					</tbody>
				</table>				
			</td>
		</tr>				
	</tbody>
</table>
<br/>
<% if iter > 12 then %>
<br/><ff/>
<% end if %>

<table >
	<tbody>
		<tr>
			<td colspan='2'>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_OPERACJI	]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_WPLATA DOKUMENT_NUMER]]> </t>
							</td>
						</tr>						
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[z dnia DOKUMENT_DATA_OPERACJI]]> </t>
							</td>
						</tr>
						#ifdef _FRAM						
						<tr>
							<td align='center' colspan='2'>
								<t bold='true'><![CDATA[Kopia]]> </t>
							</td>
						</tr>						
						#endif											
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td width='max'>
				<table >
					<tbody>
						<tr>
							<td>
								<t bold='true' size='10'><![CDATA[PODMIOT_OD_DLA]]></t>
							</td>					
							<td width='max'>
								<text size='40'><![CDATA[PODMIOT_NAZWA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<text><![CDATA[PODMIOT_ULICA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<text><![CDATA[PODMIOT_MIASTO_KOD]]></text>
							</td>					
						</tr>						
						<% if (root_.wrefPodmiot.strPoczta<>"") and (root_.wrefPodmiot.pMiejscowosc.strNazwa <> root_.wrefPodmiot.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[PODMIOT_MIASTO]]></text>
							</td>					
						</tr>
						<% end if %>							

						ROW_SEPARATOR(2)

						<%	
							iter = 1
							for each pozycja in root_.listPozycje
						%>
						<tr>
							<td>
							<% if iter = 1 then %>
								<t bold='true' size='10'>Za co:</t>
							<%end if %>
							</td>					
							<td width='max'>
								<text><![CDATA[POZ_OPIS]]></text>
							</td>					
						</tr>																									

						<%		iter = iter + 1
							next
						%>
					</tbody>
				</table>				
			</td>
			<% if root_.curKwotaPodm > 0 then  'KP %>
			<td align='right' width='min'>
				<table border='1'>
					<thead  bold='true' backcolor='#E0E0E0'>					
						<tr backcolor='#E0E0E0'>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr backcolor='#E0E0E0'>
							<td>
								<t>konto</t>
							</td>					
							<td>
								<t>kasa</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t></t>
							</td>					
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
			<% else ' KW %>
			<td align='right' width='min'>
				<table border='1'>
					<thead  bold='true' backcolor='#E0E0E0'>					
						<tr backcolor='#E0E0E0'>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr backcolor='#E0E0E0'>
							<td>
								<t>kasa</t>
							</td>					
							<td>
								<t>konto</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
							<td>
								<t></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
			<% end if %>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td colspan='2'>
				<table >
					<tbody>
						<tr>
							<td colspan='3'>
								<t bold='true'>Słownie:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_KWOTA_SLOWNIE]]></text>
							</td>					
						</tr>
						ROW_SEPARATOR(3)

						<tr>
							<td colspan='3'>
								<t bold='true'>Opis:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_OPIS]]></text>
							</td>					
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)																		
						<tr>
							<td align='center'>
								<t fontsize='3'><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
						</tr>						
						<tr>
							<td align='center'>
								<t fontsize='3' size='20'>Sporządził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Zatwierdził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Kwotę powyższą otrzymałem</t>
							</td>					
						</tr>						

					</tbody>
				</table>				
			</td>
		</tr>	
	</tbody>
</table>

</body>
<footer>
</footer>
</page>
