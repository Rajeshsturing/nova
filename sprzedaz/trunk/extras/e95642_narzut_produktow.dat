<!-- 16.02.2005 IG filtr na opiekuna klienta -->

<!--
RAPTEMPLATE_ZYSK_NA_PRODUKCIE
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rentowność narzut produkty
#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		max(t_prod.strIndeks)
#define C_FIELD_SECOND_EXPR		max(t_prod.strNazwa)
#define C_FIELD_FIRST_HUMANNAME Indeks
#define C_FIELD_SECOND_HUMANNAME Nazwa
#else
#define C_FIELD_FIRST_EXPR		max(t_prod.strNazwa)
#define C_FIELD_SECOND_EXPR		max(t_prod.strIndeks)
#define C_FIELD_FIRST_HUMANNAME		Nazwa
#define C_FIELD_SECOND_HUMANNAME	Indeks
#endif
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_field_first'=C_FIELD_FIRST_EXPR,'c_field_second'=C_FIELD_SECOND_EXPR, 'c_oznprod'=max(t_prod.strCecha1), " +_
	"'c_idprod'=trs_pProdukt,'c_idopak'=trs_pOpak, " +_
	"'c_ilsp'=sum(trs_curIloscOpakSP),'c_ilmag'=sum(trs_curIloscOpakMag)," +_
	"'sp_wartosc'=sum(trs_curWartSP),'dm_wartosc'=-sum(trs_curWartMag), " +_
	"'c_zysk'=sum(trs_curWartSP) + sum(trs_curWartMag),'c_opak_nazwa'=max(t_opak.strNazwa), " +_
	"'c_jm'=max(t_jedn.strSkrot),'c_prec'=max(t_jedn.nDokladnosc)," +_
	"'c_faktura'=(t_sprz.strNrDok),'c_id_faktury'=t_sprz.idobj, 'c_narzut_opak'=max(t_opak.curNarzutZal)," +_
	"'c_narzut'= case sum(trs_curWartMag) when 0 then 0 else 100.0 * (sum(trs_curWartSP)) / -sum(trs_curWartMag) - 100.0 end " +_
	"from #tmp_rentowsp inner join n5produkt as t_prod on trs_pProdukt = t_prod.idobj " +_
	" inner join n5opakowanie_produktu as t_opak on trs_pOpak = t_opak.idobj " +_
	" inner join n5sprzedaz as t_sprz on trs_pSprz = t_sprz.idobj " +_
	" inner join n5jednostka as t_jedn on t_opak.pJednOpak = t_jedn.idobj " +_
	" inner join n5grupaproduktow as t_grprod on t_prod.pGrupaProd = t_grprod.IdObj "+_
	" inner join n5klient as t_klient on t_sprz.pKlient = t_klient.IdObj "+_
	" inner join n5grupaklient as t_grklient on t_klient.pGrupaKlient = t_grklient.IdObj "+_
	" left join n5pracownik as t_prac on  t_klient.pPracownik = t_prac.Idobj  "+_
	" left outer join n5pracownik as t_handl on t_sprz.sprzed_pHandlowiec = t_handl.idobj " +_
	" left outer join n5klient as t_dost on t_prod.prod_pDostawca = t_dost.idobj " +_
	" where t_sprz.pRozlVat <> 0 "+_
	" and %2 and %3 and  %4 and %5 and %6 and %7 and %8 and %9 and %10 and %11 " +_
	" group by trs_pProdukt,trs_pOpak,t_sprz.strNrDok,t_sprz.idobj " +_
	" having  abs(((case sum(trs_curWartMag) when 0 then 0 else 100.0 * (sum(trs_curWartSP)) / -sum(trs_curWartMag) - 100.0 end))-(max(t_opak.curNarzutZal)))>0.5 " +_
	" order by c_field_first"
end function
%>

<%
function body_row(byref pSection,byref pRec)
dim bUzgod : bUzgod = (ccur(pRec("c_ilsp")) = ccur(pRec("c_ilmag")))
dim bZysk: bZysk = (ccur(pRec("c_zysk")) >= 0.0)

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'
<%
else
%>
<tr bordercolor='white' style='37'
<%
end if

if not bUzgod then
	so.write "italic='true'"
end if
%>
>
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,c_id_faktury,c_faktura)
	</td>
	<td>
		RXE_AUTO_TEXT(c_opak_nazwa)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ilsp,c_jm,c_prec) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(sp_wartosc,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(dm_wartosc,"",2)
	</td>
<!--	<td align='right'
	<%
	if not bZysk then
		so.write "forecolor='red'"
	end if
	%>
	>
		RXE_QUANTITY_CVV(c_zysk,"",2)
	</td> -->
	<td align='right'>
		RXE_QUANTITY_CVV(c_narzut,"%",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_narzut_opak,"%",2)
	</td>
</tr><%
end function
%>

<%
function section_footer_1(byref pSection)
%>
<tr fontsize='5'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' colspan='2' />
</tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<%
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='3'>
	<td style='27' colspan='26'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_idprod,c_field_first)
		</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Faktura]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Opakowanie]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość sprzedaży]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu]]></text>
	</td>
<!--
	<td width='min'>
		<text><![CDATA[Zysk]]></text>
	</td> -->
	<td width='min'>
		<text><![CDATA[Narzut]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Narzut kartoteki]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>


<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>

</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>

</p>
RAPORT_HEADER(3,1)

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pM60233 : set pM60233 = doc_.getmodule(60233)
dim pRentSP : set prentsp = pM60233.new_rent_sp()
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = pRentSP.get_okres_param()
pParamArray.add pParamOkres
pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_prod.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_prod.strIndeks")
pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_grprod.strNazwa")

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA, " +_
		"N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " +_
#ifdef _IOW
		"and strNazwa not like 'Faktury VAT Fundusz Reprezentacyjny' " +_
#endif		
#ifdef _MILOMLYN
		"and eAktywny = N5REJESTRDOK_AKTYWNY " +_
#endif
		"order by strNazwa "
	pParamArray.add pParam2

pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_klient.strIndeks")
pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_grklient.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("t_prac.strNazwisko")
pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(t_handl.strNazwisko,'')")
pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("isnull(t_dost.strNazwa,'')")
pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("isnull(t_dost.strIndeks,'')")
	
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
		.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("sp_wartosc").add_sumator("dm_wartosc")
		
if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
		pRentSP.fill_dok_mag_related
	set pPerf = nothing

	
	.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=1" 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
	
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
