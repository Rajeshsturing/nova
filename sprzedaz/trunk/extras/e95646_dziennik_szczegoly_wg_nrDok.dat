<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Dziennik (szczegóły)
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_rej_nazwa'=t_rejdok.strNazwa,'c_nrdow'=t_dowod.p_nNumDow,'c_3'=t_dowod.p_IdObj,'c_4'=t_dowod.coll_LP," +_
"'c_5'=t_konto.strSymbol,'c_wn'=t_dowod.c_curWn,'c_ma'=t_dowod.c_curMa,'c_8'=t_dowod.c_strOpis " +_
"from vlist_n5dowodksieg_listdekret as t_dowod inner join n5rejestrdok as t_rejdok on t_dowod.p_pRejestrDok = t_rejdok.IdObj " +_
"inner join n5konto as t_konto on t_dowod.c_pKonto = t_konto.IdObj " +_
"inner join n5dowodksieg as dowksieg on dowksieg.idobj=t_dowod.p_IdObj "+_
"where  %1  and  %2  and  %3  and  %4  " +_
"order by c_rej_nazwa,dowksieg.strnrdok"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data księgowania").bindexpr("t_dowod.p_dDataKsieg")

	dim pParamFactory4: set pParamFactory4= doc_.afc.rap.param
	dim pParam4: Set pParam4= pParamFactory4.new_choice("Dziennik").bindexpr("t_rejdok.idobj")
	doc_.afc.rap.param.init_on_query pParam4, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DZIENNIK_NORM,N5REJESTRDOK_DZIENNIK_BO, " +_
		"N5REJESTRDOK_DZIENNIK_BZ,N5REJESTRDOK_DZIENNIK_BZ_OSTAT) and pRokKsieg=" + cstr(trans_.var(8011)) + "  order by strNazwa "
	pParamArray.add pParam4

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ zapisu").bindexpr("t_dowod.p_eTyp")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5DEKRET,"eTyp"
	pParamArray.add pParam2
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Status").bindexpr("t_dowod.p_eStatus")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5DEKRET,"eStatus"
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_rej_nazwa)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr fontsize='5'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' colspan='1' />
</tr>
<tr border='0'><td colspan='7' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<%
end function
%>
<%
dim pDowodKsiegowy : set pDowodKsiegowy = nothing
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' keepline='true'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		<%
		set pDowodKsiegowy = trans_.getobj(TYPEID_N5DOWODKSIEG,clng(pRec("c_3")))
		%>
		<text href='RXF_LINK_FORM_VC(TYPEID_N5DOWODKSIEG,c_3)'><![CDATA[<%so.write pDowodKsiegowy.strNrDok%>]]></text>
		</td>
	<td style='27'>
		<t><%so.write doc_.afc.display.fulldate(pDowodKsiegowy.dDataKsieg)%></t>
	</td>
	<td style='27' colspan='3'>
	</td>
	<td style='27'>
		<%
		dim pSumator : set pSumator = pDowodKsiegowy.n5dowodksieg_get_sumator()
		if (pSumator.get_bilwn() <> pSumator.get_bilma()) then
		%>
		<t bold='true' forecolor='red'>&nbsp; Dowód nie bilansuje się !</t>
		<%
		end if
		%>
	</td>
</tr>
<tr>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='6'>
		<text href='RXF_LINK_FORM_VC(TYPEID_N5DOWODKSIEG,c_3)'><![CDATA[<%so.write pDowodKsiegowy.strOpis%>]]></text>
	</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
	dim pSumator : set pSumator = pDowodKsiegowy.n5dowodksieg_get_sumator()
	dim idUnit, curSumaWn, curSumaMa, nRef
	dim strUnit
	dim iter : iter = 0
	do while pSumator.get_value(iter,idUnit,curSumaWn,curSumaMa,nRef) 
		if nRef > 0 then
			if idUnit <> 0 then
				strUnit = trans_.getobj(TYPEID_N5JEDNOSTKA,idUnit).strSkrot
			else
				strUnit = "<brak>"
			end if
						%>
<tr fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaWn)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaMa)
	</td>
	<td style='27'>
		<t><![CDATA[<% so.write strUnit %>]]></t>
	</td>
</tr>
<%
			
		end if
		iter = iter + 1
	loop
%>
<tr border='0'>
<td colspan='7'>
</td></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='7' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td align='right'>
		RXE_T(c_4)
	</td>
	<td>
		RXE_AUTO_TEXT(c_5)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wn,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_ma,"",2)
	</td>
	<td>
		RXE_AUTO_TEXT(c_8)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Pozycja / Data księgowania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Konto / Nr dok.]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ma]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Opis]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' colspan='1' />
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>

<p><br/><br/><br/><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_wn").add_sumator("c_ma")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_wn").add_sumator("c_ma")
	.add_group_section 1,getref("section_header_2"),getref("section_footer_2")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
