<?xml version="1.0" encoding="windows-1250" ?>
<!-- 01.12.2017 Utworzenie raportu -->
<!--
RAPTEMPLATE_WIEKOWANIE_TOWAROW

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Wiekowanie towarów

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim pRange6: set pRange6 = doc_.afc.rap.param.new_date("")
pRange6.first_value = dateAdd("m",-6,pRaportMomentParam.first_value)
dim pRange12: set pRange12 = doc_.afc.rap.param.new_date("")
pRange12.first_value = dateAdd("m",-12,pRaportMomentParam.first_value)
dim pRange24: set pRange24 = doc_.afc.rap.param.new_date("")
pRange24.first_value = dateAdd("m",-24,pRaportMomentParam.first_value)
dim pRange36: set pRange36 = doc_.afc.rap.param.new_date("")
pRange36.first_value = dateAdd("m",-36,pRaportMomentParam.first_value)

dim nDummy
dim strRange6: strRange6 = Replace(doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRange6,nDummy)," <= ","")
dim strRange12: strRange12 = Replace(doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRange12,nDummy)," <= ","")
dim strRange24: strRange24 = Replace(doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRange24,nDummy)," <= ","")
dim strRange36: strRange36 = Replace(doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRange36,nDummy)," <= ","")

query = "select 'przedzial'= case " + vbNewLine +_  
"  when (min(gm.gmo_idDost) >= " + strRange6 + ") then 'A'  --<6 " + vbNewLine +_ 
"  when (min(gm.gmo_idDost) < " + strRange6 + " and min(gm.gmo_idDost) >= " + strRange12 + ") then 'B' -- 6-12 " + vbNewLine +_
"  when (min(gm.gmo_idDost) < " + strRange12 + " and min(gm.gmo_idDost) >= " + strRange24 + ") then 'C' -- 12-24 " + vbNewLine +_
"  when (min(gm.gmo_idDost) < " + strRange24 + " and min(gm.gmo_idDost) >= " + strRange36 + ")then 'D' --24-36 " + vbNewLine +_
"  when (min(gm.gmo_idDost) < " + strRange36 + ") then 'E' -- >36 " + vbNewLine +_
"end, 'magazyn_nazwa'=m.strNazwa,'produkt_nazwa'=p.strNazwa,'produkt_indeks'=p.strIndeks,'produkt_idobj'=max(p.idObj), " + vbNewLine +_
"'gm_ilosc_opak'=sum(gm.gmo_curIlosc),'gm_ilosc_ewid'=sum(gm.gmo_curIlosc * op.currKrotnosc),'gm_wartosc'=sum(gm.gmo_curWartosc), " + vbNewLine +_
"'j_1_skrot'=max(j_1.strSkrot),'j_1_prec'=max(j_1.nDokladnosc),'p_oznprod'=max(p.strCecha1) " + vbNewLine +_
"from n5gmop as gm " + vbNewLine +_
"inner join n5dokmag as dm on gm.gmo_nNumOp = dm.nNumOper " + vbNewLine +_
"inner join n5magazyn as m on gm.gmo_pMag = m.IdObj " + vbNewLine +_
"inner join n5produkt as p on gm.gmo_pProd = p.IdObj " + vbNewLine +_
"inner join n5opakowanie_produktu as op on gm.gmo_pOpak = op.IdObj " + vbNewLine +_
"inner join n5jednostka as j_1 on op.pJednOpak = j_1.IdObj " + vbNewLine +_
"where dm.nTypDok in (N5REJESTRDOK__PZ,N5REJESTRDOK__WZ,N5REJESTRDOK__ZD,N5REJESTRDOK__ZZ) and %1 and %3 and %4 and NUMOPBORDER and p.eRodzaj=1 " + vbNewLine +_
"and ((case " + vbNewLine +_
"	when gm.gmo_idDost >= " + strRange6 + "  then 'A' " + vbNewLine +_ 
"	when (gm.gmo_idDost < " + strRange6 + "   and gm.gmo_idDost >= " + strRange12 + "  ) then 'B' " + vbNewLine +_ 
"	when (gm.gmo_idDost < " + strRange12 + "   and gm.gmo_idDost >= " + strRange24 + "  ) then 'C' " + vbNewLine +_ 
"	when (gm.gmo_idDost < " + strRange24 + "   and gm.gmo_idDost >= " + strRange36 + "  ) then 'D' " + vbNewLine +_ 
"	when (gm.gmo_idDost < " + strRange36 + ") then 'E' " + vbNewLine +_ 
"	end) RANGEFILTER) " + vbNewLine +_
"group by (case " + vbNewLine +_ 
"		when gm.gmo_idDost >= " + strRange6 + " then 'A' " + vbNewLine +_ 
"		when (gm.gmo_idDost < " + strRange6 + "  and gm.gmo_idDost >= " + strRange12 + " ) then 'B' " + vbNewLine +_ 
"		when (gm.gmo_idDost < " + strRange12 + "  and gm.gmo_idDost >= " + strRange24 + " ) then 'C' " + vbNewLine +_ 
"		when (gm.gmo_idDost < " + strRange24 + "  and gm.gmo_idDost >= " + strRange36 + " ) then 'D' " + vbNewLine +_ 
"		when (gm.gmo_idDost < " + strRange36 + " ) then 'E' " + vbNewLine +_ 
"		end),m.strNazwa,p.strNazwa,p.strIndeks,op.strNazwa " + vbNewLine +_ 
"having (sum(gm.gmo_curIlosc) > 0) " + vbNewLine +_
"order by przedzial,magazyn_nazwa,produkt_nazwa,produkt_indeks"
end function
%>
<%
dim pRaportMomentParam
dim pParamArray
dim pParamRange

function default_param()
	set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("m.idobj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")
	
	set pRaportMomentParam = doc_.afc.rap.param.new_date("Analizowany moment").bindexpr("")
	pParamArray.add pRaportMomentParam
	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("p.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("p.strIndeks")
  
	set pParamRange = doc_.afc.rap.param.new_choice("Przedział czasowy")
	with pParamRange
		.multiple = true
			.names.add "<6 m-cy"
			.values.add 1
			.selected.add True
		  .names.add "6-12 m-cy"
		  .values.add 2
		  .selected.add True
			.names.add "12-24 m-cy"
			.values.add 3
			.selected.add True
		  .names.add "24-36 m-cy"
		  .values.add 4
		  .selected.add True
			.names.add ">36 m-cy"
			.values.add 5
			.selected.add True
	end with
  pParamArray.add pParamRange  
  
	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
	dim iter
	dim bAnyWritten : bAnyWritten = false

	if not pActualParam is nothing then
		
		for iter = 0 to pActualParam.upperIndex
			if pActualParam.value(iter).get_desc() <> "" then 
				bAnyWritten = true
				so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
			end if
		next
	end if

	if not bAnyWritten then 
		so.write "<t fontsize='4'>brak</t><br/>"
	end if
		so.write "<br/>"
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		<text><![CDATA[<% 
    if cstr(pRec("przedzial")) = "A" then 
      so.write "<6 m-cy" 
    else if cstr(pRec("przedzial")) = "B" then 
      so.write "6-12 m-cy"
    else if cstr(pRec("przedzial")) = "C" then 
      so.write "12-24 m-cy"
    else if cstr(pRec("przedzial")) = "D" then 
      so.write "24-36 m-cy"
    else if cstr(pRec("przedzial")) = "E" then 
      so.write ">36 m-cy" 
    end if end if end if end if end if %>]]></text>	
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='6' />
	<td style='27' align='right'>
		<t><%so.write doc_.afc.display.quantity(pSection.counter(0).result,"",2)%></t>
	</td>
</tr>
<tr border='0'><td colspan='7' /></tr>
<%
end function
%>

<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='6'>
		  <picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<% so.write cstr(nSectionPicCounter) %>"'/>
      RXE_AUTO_TEXT(magazyn_nazwa)
  </td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='7'></td></tr>
<tr fontsize='4'>
  <td style='27' colspan='6' />
  <td style='27' align='right'> RXE_MONEY_VAR(pSection.counter(0).result) </td>
</tr>
<tr border='0'><td colspan='7'></td></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,produkt_idobj,produkt_nazwa)
	</td>
	<td>
		RXE_AUTO_TEXT(produkt_indeks)
	</td>  
	<td>
		RXE_AUTO_TEXT(p_oznprod)
	</td>
  <td align='right'>
	  RXE_QUANTITY_CCC(gm_ilosc_opak,j_1_skrot,j_1_prec)
  </td>
	<td align='right'>
		RXE_QUANTITY_CVV(gm_wartosc,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Nazwa produktu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Oznaczenie producenta]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
<td style='27' colspan='6' />	
	<td style='27' align='right'>
		<t><%so.write doc_.afc.display.quantity(pRapExec.body.counter(0).result,"",2)%></t>
	</td>
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
	dim pRapExec : set pRapExec = rapeng_.new_engine()
	with pRapExec
		.add_body_ex(getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("gm_wartosc")
		.add_group_section(0,getref("section_header_1"),getref("section_footer_1")).add_sumator("gm_wartosc")
    .add_group_section(1,getref("section_header_2"),getref("section_footer_2")).add_sumator("gm_wartosc")
	if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),"DUMMY") then
	%>
	<%

		dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		set pPerf = nothing


		write_actual_param rapeng_.get_raport_param()

	  .ReplaceQueryParam "DUMMY",rapeng_.query_apply_actual_param(query(), rapeng_.get_raport_param())
		
    dim nDummy
		.ReplaceQueryParam "NUMOPBORDER", _
			"gm.gmo_nNumOp " + doc_.getmodule(43025).rap_param_date_2_gm_num_oper_where(pRaportMomentParam,nDummy)
   
    dim strRange: strRange = ""
    if pParamRange.selected.value(0) then
      strRange = strRange + "'A',"
    end if
  
    if pParamRange.selected.value(1) then
      strRange = strRange + "'B',"
    end if
  
    if pParamRange.selected.value(2) then
      strRange = strRange + "'C',"
    end if
  
    if pParamRange.selected.value(3) then
      strRange = strRange + "'D',"
    end if
  
    if pParamRange.selected.value(4) then
      strRange = strRange + "'E',"
    end if
  
    strRange = strRange + "'Z'"
    strRange =  "in (" + strRange + ")"
    .ReplaceQueryParam "RANGEFILTER",strRange   

		if not .perform then
		so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
		end if

	%>
	<%
	end if
	end with
%>
</body>
<footer>
</footer>
</page>
