<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_SPRZEDAZ_PRODUKTOW_MIESIACAMI

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Sprzedaż produktów miesiącami

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select tmp.c_field_first,tmp.c_rok, " + vbNewLine +_ 
	" tmp.c_mies,tmp.c_mies_nazwa,tmp.c_field_second, " + vbNewLine +_ 
	" tmp.c_idprod,tmp.c_idopak, tmp.c_ilsp,tmp.c_ilmag, " + vbNewLine +_ 
	" tmp.sp_wartosc,tmp.dm_wartosc,tmp.c_zysk,tmp.c_jm,tmp.c_prec " + vbNewLine +_ 
	" from " + vbNewLine +_
	" (select 'c_field_first'=max(t_prod.strNazwa),'c_rok'=(kartezjan_okres.rok), " + vbNewLine +_ 
	" 'c_mies'= (kartezjan_okres.mies),'c_mies_nazwa'= max(kartezjan_okres.strNazwa), " + vbNewLine +_
	" 'c_field_second'=max(t_prod.strIndeks), " + vbNewLine +_ 
	" 'c_idprod'=trs_pProdukt,'c_idopak'=trs_pOpak, 'c_ilsp'=sum(trs_curIloscOpakSP),'c_ilmag'=sum(trs_curIloscOpakMag), " + vbNewLine +_
	" 'sp_wartosc'=sum(trs_curWartSP),'dm_wartosc'=-sum(trs_curWartMag), 'c_zysk'=sum(trs_curWartSP) + sum(trs_curWartMag), " + vbNewLine +_
  " 'c_jm'=max(t_jedn.strSkrot),'c_prec'=max(t_jedn.nDokladnosc) " + vbNewLine +_ 
	" from #tmp_rentowsp " + vbNewLine +_ 
	" inner join n5produkt as t_prod on trs_pProdukt = t_prod.idobj " + vbNewLine +_ 
  " inner join n5opakowanie_produktu t_opak on trs_pOpak = t_opak.IdObj " + vbNewLine +_ 
	" inner join n5sprzedaz as t_sprz on trs_pSprz = t_sprz.idobj " + vbNewLine +_  
	" right outer join (select 'mies'=n5miesiac.idobj,'strNazwa'=n5miesiac.strNazwa,'rok'=year(n5rokksieg.dDataRozp) " + vbNewLine +_    
	" from n5miesiac, n5rokksieg) kartezjan_okres  on (kartezjan_okres.mies = month(t_sprz.ddataWyst) " + vbNewLine +_  
	" and kartezjan_okres.rok = year(t_sprz.ddataWyst) ) " + vbNewLine +_ 
  " inner join n5jednostka as t_jedn on t_opak.pJednOpak = t_jedn.idobj " + vbNewLine +_  
	" inner join n5grupaproduktow as t_grprod on t_prod.pGrupaProd = t_grprod.IdObj " + vbNewLine +_  
	" inner join n5klient as t_klient on t_sprz.pKlient = t_klient.IdObj " + vbNewLine +_  
	" inner join n5grupaklient as t_grklient on t_klient.pGrupaKlient = t_grklient.IdObj " + vbNewLine +_
	" where t_sprz.pRejestrDok not in (select IdObj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)) and t_sprz.pRozlVat <> 0 and %2 and %3 and  %4 and %5 and %6 and %7 and %8 " + vbNewLine +_
	" group by kartezjan_okres.mies, kartezjan_okres.rok,trs_pProdukt,trs_pOpak " + vbNewLine +_
	" union " + vbNewLine +_ 
	" select 'c_field_first'='','c_rok'=(kartezjan_okres.rok), " + vbNewLine +_
	" 'c_mies'= (kartezjan_okres.mies),'c_mies_nazwa'= max(kartezjan_okres.strNazwa), " + vbNewLine +_
	" 'c_field_second'='', " + vbNewLine +_
	" 'c_idprod'=0,'c_idopak'=0, 'c_ilsp'=0,'c_ilmag'=0, " + vbNewLine +_
	" 'sp_wartosc'=0,'dm_wartosc'=0, 'c_zysk'=0, 'c_jm'='', 'c_prec'=0 " + vbNewLine +_
	" from  (select 'mies'=n5miesiac.idobj,'strNazwa'=n5miesiac.strNazwa,'rok'=year(n5rokksieg.dDataRozp) " + vbNewLine +_ 
	" from n5miesiac, n5rokksieg) kartezjan_okres where " + vbNewLine +_ 
  " (kartezjan_okres.rok > year(%START_DATE%) or (kartezjan_okres.rok = year(%START_DATE%) and kartezjan_okres.mies >= month(%START_DATE%))) and " + vbNewLine +_
  " (kartezjan_okres.rok < year(%END_DATE%) or (kartezjan_okres.rok = year(%END_DATE%) and kartezjan_okres.mies <= month(%END_DATE%)))" +_  
	" group by kartezjan_okres.mies, kartezjan_okres.rok) as tmp " + vbNewLine +_
	" where tmp.c_field_first <> '' " + vbNewLine +_
	" order by tmp.c_field_first, tmp.c_rok asc, tmp.c_mies asc"
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	  RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_idprod,c_field_first)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr fontsize='4'>
	<td style='27' colspan='5' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
  </td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
</tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='5' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_rok)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr fontsize='4'>
	<td style='27' colspan='5' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
  </td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
</tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='5' /></tr>
<%
end function
%>

<%
dim nLP: nLP = clng(1)
function body_row(byref pSection,byref pRec)
dim bZysk: bZysk = (ccur(pRec("c_zysk")) >= 0.0)

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'
<%
else
%>
<tr bordercolor='white' style='37'
<%
end if
%>
>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td align='right'><t><% so.write cstr(nLP) %></t></td>
	<td>
		RXE_AUTO_TEXT(c_mies_nazwa)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ilsp,c_jm,c_prec) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(sp_wartosc,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(dm_wartosc,"",2)
	</td>
	<td align='right'
	<%
	if not bZysk then
		so.write "forecolor='red'"
	end if
	%>
	>
		RXE_QUANTITY_CVV(c_zysk,"",2)
	</td>
</tr><%
nLP = nLP + 1
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Miesiąc]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość sprzedaży]]></text>
  </td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Zysk]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
<td style='27' colspan='5' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
  </td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>

</p>
RAPORT_HEADER(3,1)

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
  dim strIdRokKsieg: strIdRokKsieg = ""
  
dim pM60233 : set pM60233 = doc_.getmodule(60233)
dim pRentSP : set prentsp = pM60233.new_rent_sp()
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("psp.p_ddatawyst")
pParamArray.add pParamOkres
pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_prod.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_prod.strIndeks")
pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_grprod.strNazwa")

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA, " +_
		"N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " + strIdRokKsieg + " " +_	
		"order by strNazwa "
	pParamArray.add pParam2

pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_klient.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_klient.strIndeks")
pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_grklient.strNazwa")
	
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("c_zysk")
  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("c_zysk")
  .add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("c_zysk")  
if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
		pRentSP.fill_dok_mag_related    
	set pPerf = nothing

	.ReplaceQueryParam "%START_DATE%", trans_.afc.convert.date2SQL(pParamOkres.first_value)
	.ReplaceQueryParam "%END_DATE%", trans_.afc.convert.date2SQL(pParamOkres.last_value)  

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
