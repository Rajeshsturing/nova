<?xml version="1.0" encoding="windows-1250"?>
<!--
TYPEID_N5MIEJSCOWOSC
TYPEID_N5KRAJ
TYPEID_N5JEDNOSTKA

#include "h1000.h"
#include "h1200.h"
-->
<nxapprep>
	<objects>
		<object typeid="TYPEID_N5MIEJSCOWOSC">
			<fields>
				<embedded>
					<name>strNazwa</name>
					<display usage="suggestion_text"><![CDATA[
	function nx_fill_suggestion(byref pMiejscowosc)
	nx_fill_suggestion = pMiejscowosc.strNazwa + " (" + pMiejscowosc.pWojewodztwo.strNazwa + ")"
	end function					
	]]>
					</display>
				</embedded>
			</fields>
		</object>		
		<object typeid="TYPEID_N5KRAJ">
			<fields>
				<embedded>
					<name>strSkrot</name>
					<display usage="suggestion_text"><![CDATA[
	function nx_fill_suggestion(byref pKraj)
	nx_fill_suggestion = pKraj.strSkrot + " (" + pKraj.strNazwa + ")"
	end function					
	]]>
					</display>
				</embedded>
			</fields>
			<default_search_field>strSkrot</default_search_field>
		</object>		
		<object typeid="TYPEID_N5JEDNOSTKA">
			<default_search_field>strSkrot</default_search_field>
		</object>		
	</objects>
</nxapprep>