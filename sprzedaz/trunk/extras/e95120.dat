<?xml version="1.0" encoding="windows-1250" ?>

<!-- FAKTURA VAT -->
#include "h1000"
#include "h1240"

#define SHOW_INDEX
#comment SHOW_PKWIU
#comment SHOW_RABAT

#define CTRLID_ORGKOPIA					101

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define ADR_DOST_NAZWA					<% so.write util_.Nazwa_Dost(root_) %>
#define ADR_DOST_ULICA_NUMER			<% so.write util_.Ulica_Dost(root_) %>
#define ADR_DOST_KOD_MIASTO				<% if root_.sprzed_strPoczta_dost="" then so.write util_.Kod_Miasto_Dost(root_) else if root_.sprzed_strPoczta_dost<>"" and  root_.sprzed_strPoczta_dost<>root_.sprzed_pMiejscowosc_dost.strNazwa then so.write root_.sprzed_strKod_dost + " " + root_.sprzed_strPoczta_dost else if  root_.sprzed_strPoczta_dost=root_.sprzed_pMiejscowosc_dost.strNazwa then so.write util_.Kod_Miasto_Dost(root_) end if end if end if%>
#define ADR_DOST_MIASTO					<% so.write root_.sprzed_pMiejscowosc_dost.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>

#define KLIENT_SDB_KOD_MIASTO			<% if root_.pKlient.strPocztaSDB="" then so.write root_.pKlient.strKodSDB+" "+root_.pKlient.pMiejscowoscSDB.strNazwa else if root_.pKlient.strPocztaSDB<>"" and  root_.pKlient.strPocztaSDB<>root_.pKlient.pMiejscowoscSDB.strNazwa then so.write root_.pKlient.strKodSDB + " " + root_.pKlient.strPocztaSDB else if  root_.pKlient.strPocztaSDB=root_.pKlient.pMiejscowoscSDB.strNazwa then so.write root_.pKlient.strKodSDB+" "+root_.pKlient.strPocztaSDB end if end if end if%>
#define KLIENT_SDB_ULICA_NUMER			<% if root_.pKlient.strNrLokaluSDB<>"" then so.write root_.pKlient.strUlicaSDB+" "+root_.pKlient.strNrDomuSDB+"/"+root_.pKlient.strNrLokaluSDB else so.write root_.pKlient.strUlicaSDB+" "+root_.pKlient.strNrDomuSDB end if %>
#define KLIENT_SDB_MIASTO				<% if not root_.pKlient.pMiejscowoscSDB is nothing then so.write root_.pKlient.pMiejscowoscSDB.strNazwa end if%>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_DATA_SPRZEDAZY			<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_TERMIN_PLATNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_SPOSOB_PLATNOSCI		<% so.write util_.Dokument_Sposob_Platnosci(root_) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_DO_ZAPLATY				<% so.write MONEY(root_.curSumaBrutto) %>
#define DOKUMENT_DO_ZAPLATY_SLOWNIE		<% so.write doc_.afc.display.slownie(root_.curSumaBrutto) %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(root_.curSumaVat)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_ZAMOWIENIE				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>
#define DOKUMENT_ZAMOWIENIE_NR_OBCY		<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.zam_strNrDokObcy end if  %>
#define DOKUMENT_UWAGI					<% if root_.strUwagi<>"" then so.write root_.strUwagi end if  %>
#define DOKUMENT_WALUTA					<% so.write root_.pWaluta.strSkrot %>
#define DOKUMENT_ODWROTNE_OBCIAZENIE	<% so.write "Pozycja nr " + GetPoz() + " - odwrotne obciążenie podatek rozlicza nabywca" %>


<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_UWAGI						<% if pozycja.strUwagi <> "" then so.write ":" + pozycja.strUwagi end if  %>
#define POZ_PKWIU						<% so.write pozycja.pProdukt.strKodPKWiU %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_VAT							<% so.write util_.vat_to_name(pozycja.eVat) %>
#define POZ_CENA_NETTO					<% so.write doc_.afc.display.quantity(pozycja.curCenaNetto,"",trans_.var(GVAR_PRICE_PREC)) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_VAT					<% so.write MONEY(pozycja.curVAT) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>

#define FIRMA_TELEFON_LABEL				<% so.write util_.Firma_Telefon_Label %>
#define FIRMA_TELEFON					<% so.write util_.Firma_Telefon %>
#define FIRMA_TELEFON_HIDE				<% so.write util_.Firma_Telefon_Hide %>

#define FIRMA_FAX_LABEL					<% so.write util_.Firma_Fax_Label %>
#define FIRMA_FAX						<% so.write util_.Firma_Fax %>
#define FIRMA_FAX_HIDE					<% so.write util_.Firma_Fax_Hide %>



#define KLIENT_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient) %>
#define KLIENT_TELEFON					<% so.write util_.Klient_Telefon(root_.pKlient) %>
#define KLIENT_TELEFON_HIDE				<% so.write util_.Klient_Telefon_Hide(root_.pKlient) %>

#define KLIENT_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient) %>
#define KLIENT_TELEFON_KOM				<% so.write util_.Klient_Telefon_Kom(root_.pKlient) %>
#define KLIENT_TELEFON_KOM_HIDE			<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient) %>

#define KLIENT_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient) %>
#define KLIENT_FAX						<% so.write util_.Klient_Fax(root_.pKlient) %>
#define KLIENT_FAX_HIDE					<% so.write util_.Klient_Fax_Hide(root_.pKlient) %>

#define KLIENT_JO_TELEFON_LABEL			<% so.write util_.Klient_Telefon_Label(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON				<% so.write util_.Klient_Telefon(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_HIDE			<% so.write util_.Klient_Telefon_Hide(root_.pKlient_JO) %>

#define KLIENT_JO_TELEFON_KOM_LABEL		<% so.write util_.Klient_Telefon_Kom_Label(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_KOM			<% so.write util_.Klient_Telefon_Kom(root_.pKlient_JO) %>
#define KLIENT_JO_TELEFON_KOM_HIDE		<% so.write util_.Klient_Telefon_Kom_Hide(root_.pKlient_JO) %>

#define KLIENT_JO_FAX_LABEL				<% so.write util_.Klient_Fax_Label(root_.pKlient_JO) %>
#define KLIENT_JO_FAX					<% so.write util_.Klient_Fax(root_.pKlient_JO) %>
#define KLIENT_JO_FAX_HIDE				<% so.write util_.Klient_Fax_Hide(root_.pKlient_JO) %>

<!-- podsumowanie pozycji -->
#define DOKUMENT_PODSUMOWANIE_NETTO		<% so.write MONEY(ccur(tax_summary(iter).value_netto_dom)) %>
#define DOKUMENT_PODSUMOWANIE_VAT		<% so.write MONEY(ccur(tax_summary(iter).tax_value_dom)) %>
#define DOKUMENT_PODSUMOWANIE_BRUTTO	<% so.write MONEY(ccur(tax_summary(iter).value_brutto_dom)) %>
#define DOKUMENT_PODSUMOWANIE_STAWKA	<% so.write tax_summary(iter).tax_code %>



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
#include "h1231.h"

<%
function IsStawkaOO(): IsStawkaOO = false
	dim pozycja	
	for each pozycja in root_.listPozycje
		if pozycja.eVAT = STAWKA_VAT_23_OO then
			IsStawkaOO = true
			exit function
		end if
	next
end function

function GetPoz()
	dim iter : iter = 1 
	dim pozycja	
	for each pozycja in root_.listPozycje
		if pozycja.eVAT = STAWKA_VAT_23_OO then
			GetPoz = GetPoz + CStr(iter) + ", "
		end if
		iter = iter + 1
	next
	if Len(GetPoz) > 2 then
		GetPoz = Mid(GetPoz,1,Len(GetPoz)-2)
	end if
end function
%>

function fprint 
	fprint = doc_.getmodule(60182).fprint_on_dpc_org_kopia(page_.get_this,CTRLID_ORGKOPIA) 
end function

VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[FAKTURA VAT]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t name='CTRLID_ORGKOPIA' bold='true'>Oryginał</t>
							</td>
						</tr>

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td colspan='2'>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>	
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
						</tr>
												
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td colspan='2'>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td colspan='2'>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td colspan='2'>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
						</tr>

						<!-- KLAUZULA MPP -->
						<% if root_.sprzed_cSplit = "1"  then %>
						<tr>
							<td></td>
							<td colspan='2'>
								<table>
									<tbody>
										<tr>
											<td width='min' border='1'>
												<t bold='true' fontsize='5'>&nbsp;&nbsp;MECHANIZM PODZIELONEJ PŁATNOŚCI&nbsp;&nbsp;</t>
											</td>
											<td></td>
										</tr>
									</tbody>
								</table>
							</td>
						</tr>
						<% end if %>

						<tr hide='FIRMA_TELEFON_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[FIRMA_TELEFON_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_TELEFON]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='FIRMA_FAX_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[FIRMA_FAX_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_FAX]]></text>
							</td>
							<td>
							</td>							
						</tr>

							
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)

						<!-- Dane nabywcy - Klient - jednostka organizacyjna-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
						</tr>

						<%
						dim bAdresDost: bAdresDost = false
						%>
#ifdef ENABLE_DB14
						<%
						if root_.sprzed_strNazwa_dost <> "" then
							bAdresDost = true
						%>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td colspan='2'>
								<text><![CDATA[ADR_DOST_NAZWA]]></text>
							</td>
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[ADR_DOST_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[ADR_DOST_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.sprzed_strPoczta_dost<>"") and (root_.sprzed_pMiejscowosc_dost.strNazwa <> root_.sprzed_strPoczta_dost) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[ADR_DOST_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<% end if %>				
#endif							
						<% if not bAdresDost then %>

						<% if not root_.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>	
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
						</tr>
												
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
						</tr>						

						<tr hide='KLIENT_JO_TELEFON_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_TELEFON_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_TELEFON]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_JO_TELEFON_KOM_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_TELEFON_KOM_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_TELEFON_KOM]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_JO_FAX_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_JO_FAX_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_FAX]]></text>
							</td>
							<td>
							</td>							
						</tr>
						
						<% else %>
						<% if not root_.pKlient is nothing then %>
						
						<!-- Dane nabywcy - KLIENT -->
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>
						<tr>
							<td width='min'>								
							</td>							
							<td colspan='2'>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
						</tr>
													
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>						

						<tr hide='KLIENT_TELEFON_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_TELEFON_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_TELEFON]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_TELEFON_KOM_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_TELEFON_KOM_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_TELEFON_KOM]]></text>
							</td>
							<td>
							</td>							
						</tr>

						<tr hide='KLIENT_FAX_HIDE'>
							<td width='min'>
								<t size='3'/><t bold='true'><![CDATA[KLIENT_FAX_LABEL:]]></t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_FAX]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% end if %>
						<% end if %>
						<% end if %>
						
						<!-- KLIENT siedziba -->
						
						<%
						if not root_.pKlient.pMiejscowoscSDB is nothing then 
						if ( (trim(root_.pKlient.strUlica)<>trim(root_.pKlient.strUlicaSDB)) or +_
							 (trim(root_.pKlient.strNrDomu)<>trim(root_.pKlient.strNrDomuSDB)) or +_
							 (trim(root_.pKlient.strNrLokalu)<>trim(root_.pKlient.strNrLokaluSDB)) or +_
							 (trim(root_.pKlient.pMiejscowosc.strNazwa)<>trim(root_.pKlient.pMiejscowoscSDB.strNazwa)) ) then  %>
						ROW_SEPARATOR(3)
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Siedziba:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_SDB_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPocztaSDB<>"") and (root_.pKlient.pMiejscowoscSDB.strNazwa <> root_.pKlient.strPocztaSDB) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_SDB_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_SDB_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<%end if%>
						<%end if%>
						
						
						ROW_SEPARATOR(3)

						<!-- płatności -->
						<tr>
							<td keepline='true'>
								<t bold='true'>Data sprzedaży:</t>
							</td>
							<td><t><![CDATA[DOKUMENT_DATA_SPRZEDAZY]]></t></td>							
							<td  keepline='true'>
								<t bold='true'>Sposób płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_SPOSOB_PLATNOSCI]]></t>
							</td>
						</tr>
						<tr>
							<td>								
							</td>
							<td width='max'>								
							</td>														
							<td align='right' keepline='true'>
								<t bold='true'>Termin płatności:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_TERMIN_PLATNOSCI]]></t>
							</td>
						</tr>
						
						
													
						
						<!-- dokumenty powiazane - zamowienie -->
						<% if not root_.pZamowienie is nothing then %>	
						ROW_SEPARATOR(3)			
						<tr>
							<td>
								<t bold='true'>Zamówienie</t>						
							</td>
							<td>
								<t/>
							</td>							
							<td>
							</td>							

						</tr>
						<tr>
							<td>
								<t size='3'/><t bold='true'>Nr. obcy:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE_NR_OBCY]]></t>
							</td>							
							<td>
							</td>							

						</tr>

						<tr>
							<td>
								<t size='3'/><t bold='true'>Nr. dokumentu:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE]]></t>
							</td>							
							<td>
							</td>							

						</tr>

						<% end if %>						

						
					</tbody>
				</table>
			</td>
		</tr>

			


		ROW_SEPARATOR(1)	


		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>
							#ifdef SHOW_INDEX							
							<td align='right'>
								<text>Indeks</text>
							</td>
							#endif
							#ifdef SHOW_PKWIU
							<td align='right'>
								<t>PKWiU</t>
							</td>
							#endif
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena netto</text>
							</td>
							#ifdef SHOW_RABAT
							<td align='right'>
								<text>Rabat</text>
							</td>
							#endif
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t>
								<text><![CDATA[POZ_OPAKOWANIE]]></text>
								<text><![CDATA[POZ_UWAGI]]></text>
								<% if not pozycja.psprzed_pKLOB is nothing then %>
								<br/>
								<text><![CDATA[<%so.write "Dot.:" + pozycja.psprzed_pKLOB.klob_strNazwa%>]]></text>
								<%end if %>
							</td>
							#ifdef SHOW_INDEX
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							#endif
							#ifdef SHOW_PKWIU
							<td width='min' align='right'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							#endif
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							#ifdef SHOW_RABAT
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							#endif
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='3' bordercolor='transparent'>
							</td>
							#ifdef SHOW_INDEX
							<td bordercolor='transparent'/>
							#endif
							#ifdef SHOW_PKWIU
							<td bordercolor='transparent'/>
							#endif
							#ifdef SHOW_RABAT
							<td bordercolor='transparent'/>
							#endif
							
							<td  colspan='2' bordercolor='transparent' align='right'>
								<text bold='true' >Razem</text><t size='2'/>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<%
							dim tax_summary: tax_summary = util_.recalc_summary_by_tax_rates(root_)
							for iter = 0 to UBound(tax_summary)
						%>
						<tr>
							<td colspan='5' bordercolor='transparent'>
							</td>
							#ifdef SHOW_INDEX
							<td bordercolor='transparent'/>
							#endif
							#ifdef SHOW_PKWIU
							<td bordercolor='transparent'/>
							#endif
							#ifdef SHOW_RABAT
							<td bordercolor='transparent'/>
							#endif
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO]]></t>
							</td>					
						</tr>
						<%
							next 							
						%>						
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)
#ifdef ENABLE_DB12
		<% if IsStawkaOO then %>
		ROW_SEPARATOR(1)
		<!-- Odwrotne  obciążenie -->
		<tr>
			<td keepline='true'>
				<t><![CDATA[DOKUMENT_ODWROTNE_OBCIAZENIE]]></t>
			</td>
		</tr>					
		ROW_SEPARATOR(1)	
		<% end if %>							
#endif			

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY DOKUMENT_WALUTA]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie:</t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_DO_ZAPLATY_SLOWNIE]]></t>
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>		
		<% end if%>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'></td>						
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td></td>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia faktury VAT</t>
							</td>				
							<td></td>			
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby uprawnionej do odbioru faktury VAT</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr valign='bottom'>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
