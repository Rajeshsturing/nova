<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZAPISY_NA_KONCIE

#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1203.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zapisy na kontach
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()

#ifdef _CTP
    query = "select 'c_lexsymbol'=dbo.ks_lex_order(t_konto.strSymbol),'c_symbol'=t_konto.strSymbol,'c_idkonto'=t_konto.IdObj,'c_mc'=month(t_dow.c_dDataKsieg)," +_
    "'c_konto_nazwa'=t_konto.strNazwa,'c_dataks'=t_dow.p_dDataRej, " +_
    "'c_nrdziennik'=t_rej.rejdok_strSkrot + '/' + ltrim(str(t_dow.p_nNumDow)),'c_wn'=t_dow.c_curWn,'c_ma'=t_dow.c_curMa," +_
    "'c_opis'=t_dow.c_strOpis,'c_nrdok'=t_dow.p_strNrDok,'c_iddow'=t_dow.p_IdObj," +_
    "'c_trans'=isnull(t_trans.strSymTrans,''),'c_kwalif'=isnull(t_kwalif.strNazwa,'') from n5konto as t_konto " +_
    "inner join vlist_n5dowodksieg_listdekret as t_dow on t_dow.c_pKonto = t_konto.IdObj " +_
    "inner join n5rejestrdok as t_rej on t_dow.p_prejestrdok = t_rej.idobj " +_
    "left outer join n5transakcja as t_trans on t_dow.c_pTransakcja = t_trans.IdObj " +_
    "left outer join n5kwalifikator as t_kwalif on t_dow.c_pKwalifikator = t_kwalif.IdObj " +_
    "where  %1  and  %2  and  %3  and t_dow.c_eTyp=N5_DEKRET_TYP_NORMALNY and year(p_dDataRej) " + " = " +  cstr(year(trans_.var(1007))) +_
    " order by c_lexsymbol,c_symbol,c_dataks,t_dow.p_nNumDow"
#else
    query = "select 'c_lexsymbol'=dbo.ks_lex_order(t_konto.strSymbol),'c_symbol'=t_konto.strSymbol,'c_idkonto'=t_konto.IdObj,'c_mc'=month(t_dow.c_dDataKsieg)," +_
    "'c_konto_nazwa'=t_konto.strNazwa,'c_dataks'=t_dow.c_dDataKsieg, " +_
    "'c_nrdziennik'=t_rej.rejdok_strSkrot + '/' + ltrim(str(t_dow.p_nNumDow)),'c_wn'=t_dow.c_curWn,'c_ma'=t_dow.c_curMa," +_
    "'c_opis'=t_dow.c_strOpis,'c_nrdok'=t_dow.p_strNrDok,'c_iddow'=t_dow.p_IdObj," +_
    "'c_trans'=isnull(t_trans.strSymTrans,''),'c_kwalif'=isnull(t_kwalif.strNazwa,'') from n5konto as t_konto " +_
    "inner join vlist_n5dowodksieg_listdekret as t_dow on t_dow.c_pKonto = t_konto.IdObj " +_
    "inner join n5rejestrdok as t_rej on t_dow.p_prejestrdok = t_rej.idobj " +_
    "left outer join n5transakcja as t_trans on t_dow.c_pTransakcja = t_trans.IdObj " +_
    "left outer join n5kwalifikator as t_kwalif on t_dow.c_pKwalifikator = t_kwalif.IdObj " +_
    "where  %1  and  %2  and  %3  and t_dow.c_eTyp=N5_DEKRET_TYP_NORMALNY and year(c_dDataKsieg) " + " = " +  cstr(year(trans_.var(1007))) +_
    " order by c_lexsymbol,c_symbol,c_dataks,t_dow.p_nNumDow"
#endif
end function
%>
<%

function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Symbol").bindexpr("t_konto.strSymbol COLLATE latin1_general_cs_as")
	

	pParamArray.add doc_.afc.rap.param.new_date_range("Data księgowania").bindexpr("t_dow.c_dDataKsieg")

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
'	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ zapisu").bindexpr("t_dow.c_eTyp")
'	pParamFactory2.init_on_enum pParam2, TYPEID_N5DEKRET,"eTyp"
'	pParamArray.add pParam2
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Status").bindexpr("t_dow.c_eStatus")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5DEKRET,"eStatus"
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
<%
dim curObrWnRun : curObrWnRun = ccur(0.0)
dim curObrMaRun : curObrMaRun = ccur(0.0)
dim curBOWn : curBOWn = ccur(0.0)
dim curBOMa : curBOMa = ccur(0.0)

function section_header_1(byref pSection,byref pRec)
%>
<table border='1' width='max'>
<tbody>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='STYLE_GROUP_HEADER' colspan='11'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KONTO,c_idkonto,c_symbol)
		<t size='1' />		
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KONTO,c_idkonto,c_konto_nazwa)
		<t>&nbsp;(<%so.write trans_.getobj(TYPEID_N5KONTO,pRec("c_idkonto")).pJednostka.strSkrot %>)</t>
	</td>
</tr>
<%
	dim oRecordset
	dim query : query = "select isnull(sum(curWn),0), isnull(sum(curMa),0) from n5dekret_sums where pKonto=" + cstr(pRec("c_idkonto")) + " and eTyp=N5_DEKRET_TYP_BO "
		'trans_.message 0,0,"first_value=" + cstr(year(rapeng_.get_raport_param().Value(1).first_value))
		if year(rapeng_.get_raport_param().Value(1).first_value)<>1899 then 
			if year(rapeng_.get_raport_param().Value(1).last_value)<>1899 then 
			query = query + " and year(dDataKsieg) >=" +  cstr(year(rapeng_.get_raport_param().Value(1).first_value)) + " and year(dDataKsieg) <="+  cstr(year(rapeng_.get_raport_param().Value(1).last_value)) 
			else
			query = query + " and year(dDataKsieg) = " +  cstr(year(rapeng_.get_raport_param().Value(1).first_value))
			end if
		else
			query = query + " and year(dDataKsieg) = " +  cstr(year(trans_.var(1007)))			
		end if
	'set oRecordset=trans_.createadors( _
	'	"select isnull(sum(curWn),0), isnull(sum(curMa),0) from n5dekret_sums where pKonto=" +_
	'	 cstr(pRec("c_idkonto")) + " and eTyp=N5_DEKRET_TYP_BO and year(dDataKsieg) >= " +  cstr(year(rapeng_.get_raport_param().Value(1).first_value)) )

	set oRecordset=trans_.createadors(query)
	curBOWn = ccur(oRecordset(0).value)
	curBOMa = ccur(oRecordset(1).value)
%>
<tr style='STYLE_GROUP_HEADER'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
  #ifndef _FRAM
	<td width='min'>
		<text><![CDATA[Numer w dzienniku]]></text>
	</td>
  #endif
	 #ifdef _CTP 
	    <td width='min'>
		    <text><![CDATA[Data rejestracji]]></text>
	    </td>
	 #else 
		<td width='min'>
		    <text><![CDATA[Data księgowania]]></text>
	    </td>
	#endif 
	<td width='min'>
		<text><![CDATA[Kwota Winien]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota Ma]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Opis]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Transakcja]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwalifikator]]></text>
	</td>
</tr>
<tr fontsize='4' bordercolor='transparent' >
  #ifndef _FRAM
  <td bordercolor='transparent' colspan='4' />
  #else
  <td bordercolor='transparent' colspan='3' />
  #endif
  <td style='STYLE_GROUP_HEADER'>
		<t>Bilans otwarcia</t>
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curBOWn)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curBOMa)
	</td>
	<td colspan='4' />
</tr>

<%
	'set oRecordset=trans_.createadors( _
	'	"select isnull(sum(curWn),0), isnull(sum(curMa),0) from n5dekret_sums where pKonto=" +_
	'	 cstr(pRec("c_idkonto")) + " and eTyp=N5_DEKRET_TYP_NORMALNY and dDataKsieg < " + trans_.afc.convert.date2SQL(rapeng_.get_raport_param().Value(1).first_value) +_
	'	 " and year(dDataKsieg) = " +  cstr(year(rapeng_.get_raport_param().Value(1).first_value)))
	query = "select isnull(sum(curWn),0), isnull(sum(curMa),0) from n5dekret_sums where pKonto=" +_
		 cstr(pRec("c_idkonto")) + " and eTyp=N5_DEKRET_TYP_NORMALNY and dDataKsieg < " + trans_.afc.convert.date2SQL(rapeng_.get_raport_param().Value(1).first_value)
		
		
		if rapeng_.get_raport_param().Value(1).mode = 5 then 
			rapeng_.get_raport_param().Value(1).first_value = trans_.afc.globals.nulldate()
			query = query + " and year(dDataKsieg) = " +  cstr(year(rapeng_.get_raport_param().Value(1).first_value))
		else
		if year(rapeng_.get_raport_param().Value(1).first_value)<>1899 then
      query = query + " and year(dDataKsieg) = " +  cstr(year(rapeng_.get_raport_param().Value(1).first_value))
      end if
      end if
      set oRecordset=trans_.createadors(query)



      curObrWnRun = ccur(oRecordset(0).value)
      curObrMaRun = ccur(oRecordset(1).value)
      dim curStrWn : curStrWn = curObrWnRun + curBOWn
      dim curStrMa : curStrMa = curObrMaRun + curBOMa
      dim curSaldoWn : curSaldoWn = ccur(0.0)
      dim curSaldoMa : curSaldoMa = ccur(0.0)

      if abs(curStrWn) > abs(curStrMa) then
        curSaldoWn = curStrWn - curStrMa
      else
        curSaldoMa =  curStrMa - curStrWn
      end if
%>
<tr fontsize='4' bordercolor='transparent' >
  #ifndef _FRAM
  <td bordercolor='transparent' colspan='4' />
  #else
  <td bordercolor='transparent' colspan='3' />
  #endif
  <td style='STYLE_GROUP_HEADER'>
		<t>Obroty do okresu</t>
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curObrWnRun)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curObrMaRun)
	</td>
	<td colspan='4' />
</tr>
<tr fontsize='4' bordercolor='transparent' >
  #ifndef _FRAM
  <td bordercolor='transparent' colspan='4' />
  #else
  <td bordercolor='transparent' colspan='3' />
  #endif
  <td style='STYLE_GROUP_HEADER'>
		<t>Saldo do okresu</t>
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curSaldoWn)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curSaldoMa)
	</td>
	<td colspan='4' />
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='11' /></tr>
</tbody>
<tfoot>
</tfoot>
</table>
<t>&nbsp;</t><br/>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='STYLE_GROUP_HEADER' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	<t><%so.write Monthname(pRec("c_mc"))%></t>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
  curObrWnRun = curObrWnRun + pSection.counter(0).result
  curObrMaRun = curObrMaRun + pSection.counter(1).result

  dim curStrWn : curStrWn = curObrWnRun + curBOWn
  dim curStrMa : curStrMa = curObrMaRun + curBOMa
  dim curSaldoWn : curSaldoWn = ccur(0.0)
  dim curSaldoMa : curSaldoMa = ccur(0.0)

  if abs(curStrWn) > abs(curStrMa) then
    curSaldoWn = curStrWn - curStrMa
  else
    curSaldoMa =  curStrMa - curStrWn
  end if
%>
<tr bordercolor='transparent' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  #ifndef _FRAM
	  <td bordercolor='transparent' colspan='3' />
  #else
    <td bordercolor='transparent' colspan='2' />
  #endif
  <td style='STYLE_GROUP_HEADER' ><t>Obroty miesiąca</t></td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td colspan='4' />
</tr>
<tr bordercolor='transparent' fontsize='4'>
	<td width='min'><t>&nbsp;</t></td>
  #ifndef _FRAM
  <td bordercolor='transparent' colspan='3' />
  #else
  <td bordercolor='transparent' colspan='2' />
  #endif
  <td style='STYLE_GROUP_HEADER' ><t>Obroty narastająco</t></td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curObrWnRun)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curObrMaRun)
	</td>
	<td colspan='4' />
</tr>
<tr bordercolor='transparent' fontsize='4'>
	<td width='min'><t>&nbsp;</t></td>
  #ifndef _FRAM
  <td bordercolor='transparent' colspan='3' />
  #else
  <td bordercolor='transparent' colspan='2' />
  #endif
  <td style='STYLE_GROUP_HEADER' ><t>Saldo</t></td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curSaldoWn)
	</td>
	<td style='STYLE_GROUP_HEADER' align='right'>
		RXE_MONEY_VAR(curSaldoMa)
	</td>
	<td colspan='4' />
</tr>
<tr border='0'><td colspan='11' /></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='11' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
  #ifndef _FRAM
	<td align='right'>
		RXE_T(c_nrdziennik)
	</td>
  #endif
	<td>
		RXE_DATE(c_dataks)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wn,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_ma,"",2)
	</td>
	<td>
		RXE_TEXT(c_opis)
	</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5DOWODKSIEG,c_iddow,c_nrdok)
	</td>
	<td>
		RXE_TEXT(c_trans)
	</td>
	<td>
		RXE_TEXT(c_kwalif)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>

<%
end function
%>
<%
function body_footer(byref pSection)
%>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function


]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>

<p><br/><br/><br/><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 1,getref("section_header_1"),getref("section_footer_1")
	.add_group_section (3,getref("section_header_2"),getref("section_footer_2")).add_sumator("c_wn").add_sumator("c_ma")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
