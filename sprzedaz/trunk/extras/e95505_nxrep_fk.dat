<?xml version="1.0" encoding="windows-1250"?>
<!--
TYPEID_N5KONTO
TYPEID_N5DOWODKSIEG
TYPEID_N5ROZLVAT
TYPEID_N5ROZLCIT

#include "h1000.h"
#include "h1200.h"
-->
<nxapprep>
	<objects>
		<object typeid="TYPEID_N5KONTO">
			<fields>
				<embedded>
					<name>strSymbol</name>
					<display usage="suggestion_text"><![CDATA[
	function nx_fill_suggestion(byref pKonto)
	nx_fill_suggestion = pKonto.strSymbol + " (" + pKonto.strNazwa + ") [" + pKonto.pJednostka.strSkrot + "]"
	end function					
	]]>
					</display>
				</embedded>
			</fields>
			<raports>
				<raport title="@browser_##TYPEID_N5KONTO##@">
					<columns>
						<column>
							<header>Symbol</header>
							<path>
								<embedded>strSymbol</embedded>
							</path>
						</column>
						<column>
							<header>Nazwa</header>
							<path>
								<embedded>strNazwa</embedded>
							</path>
						</column>
						<column>
							<header>Opis</header>
							<path>
								<embedded>strOpis</embedded>
							</path>
						</column>
						<column>
							<header>Rodzaj</header>
							<path>
								<embedded>eAnalit</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order>
							<path>
								<embedded>strSymbol</embedded>
							</path>
						</order>
					</orders>
				</raport>
				<raport title="@fuzzy_##TYPEID_N5KONTO##@">
					<filters>
						<filter>
							<path>
								<embedded>strSymbol</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strNazwa</embedded>
							</path>
						</filter>
					</filters>
				</raport>
			</raports>
			<default_search_field>strSymbol</default_search_field>
		</object>
		<object typeid="TYPEID_N5DOWODKSIEG">
			<raports>
				<raport title="@browser_##TYPEID_N5DOWODKSIEG##@">
					<columns>
						<column>
							<path>
								<embedded>strNrDok</embedded>
							</path>
						</column>
						<column>
							<header>Opis</header>
							<path>
								<embedded>strOpis</embedded>
							</path>
						</column>
						<column>
							<path>
								<embedded>dDataKsieg</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order>
							<path>
								<embedded>strNrDok</embedded>
							</path>
						</order>
					</orders>
				</raport>
				<raport title="@fuzzy_##TYPEID_N5DOWODKSIEG##@">
					<filters>
						<filter>
							<path>
								<embedded>strNrDok</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>dDataKsieg</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<list>listDekret</list>
								<ref>pKonto</ref>
								<embedded>strSymbol</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<list>listDekret</list>
								<embedded>curWn</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<list>listDekret</list>
								<embedded>curMa</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<list>listDekret</list>
								<embedded>strOpis</embedded>
							</path>
						</filter>
					</filters>
				</raport>
			</raports>
			<default_search_field>strSymbol</default_search_field>
		</object>
		<object typeid="TYPEID_N5ROZLVAT">
			<raports>
				<raport title="@browser_##TYPEID_N5ROZLVAT##@">
					<columns>
						<column>
							<header>Data początkowa</header>
							<path>
								<embedded>vat7_dDataOd</embedded>
							</path>
						</column>
						<column>
							<header>Data końcowa</header>
							<path>
								<embedded>vat7_dDataDo</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order asc="false">
							<path>
								<embedded>vat7_dDataOd</embedded>
							</path>
						</order>
					</orders>
				</raport>
			</raports>
		</object>
		<object typeid="TYPEID_N5ROZLCIT">
			<raports>
				<raport title="@browser_##TYPEID_N5ROZLCIT##@">
					<columns>
						<column>
							<header>Data początkowa</header>
							<path>
								<embedded>dDataOd</embedded>
							</path>
						</column>
						<column>
							<header>Data końcowa</header>
							<path>
								<embedded>dDataDo</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order asc="false">
							<path>
								<embedded>dDataOd</embedded>
							</path>
						</order>
					</orders>
				</raport>
			</raports>
		</object>
</objects>
</nxapprep>