<?xml version="1.0" encoding="windows-1250"?>
<!--

TYPEID_N5ZADANIE

#include "h1000.h"
#include "h1200.h"
#include "h1231.h"

-->
<nxapprep>
	<objects>
		<object typeid="TYPEID_N5ZADANIE">
			<fields>
				<embedded>
					<name>nStatus</name>
					<sqltype>SQLlong</sqltype>
					<display usage="browser"><![CDATA[
function display_##TYPEID_N5ZADANIE##_##nStatus##(byref oASP,byref oEVal,byval strCEA,byref oZadanie)
	dim strStatusName
	select case oZadanie.nStatus
	case N5ZADANIE_UTWORZONE
		strStatusName = "utworzone"
	case N5ZADANIE_NIEGOTOWE
		strStatusName = "niegotowe"
	case N5ZADANIE_ZLECONE
		strStatusName = "zlecone"
	case N5ZADANIE_ODEBRANE
		strStatusName = "odebrane"
	case N5ZADANIE_WYKONYWANE
		strStatusName = "wykonywane"
	case N5ZADANIE_WSTRZYMANE
		strStatusName = "wstrzymane"
	case N5ZADANIE_ZAKONCZONE
		strStatusName = "zakończone"
	case N5ZADANIE_ZAMKNIETE
		strStatusName = "zamknięte"
	case else
		strStatusName = "inny status"
	end select
	set display_##TYPEID_N5ZADANIE##_##nStatus = oASP.newcellex(1,strCEA).e_label(strStatusName)
end function
]]>
					</display>
				</embedded>
				<embedded >
					<name>@dDataCzasZlec</name>
					<humanname>Data i czas zlecenia</humanname>
					<sqltype>SQLvc20</sqltype>
					<getexpression><![CDATA[
						result = nx_.display.fulldate(oObject.dDataZlec) + " " + nx_.display.fulltime(oObject.tCzasZlec)
					]]></getexpression>
					<display usage="browser"><![CDATA[
function display_##TYPEID_N5ZADANIE##_##dDataCzasZlec##(byref oASP,byref oEVal,byval strCEA,byref oZadanie)
	set display_##TYPEID_N5ZADANIE##_##dDataCzasZlec = display_date_and_time(oASP,strCEA,oZadanie.dDataZlec,oZadanie.tCzasZlec)
end function
]]>
						<using>display_date_and_time</using>
					</display>
				</embedded>
			</fields>
			<raports>
				<raport title="@zadania_do_wykonania@">
					<columns>
						<column>
							<header>Zlecono</header>
							<path>
								<embedded>@dDataCzasZlec</embedded>
							</path>
						</column>
						<column>
							<header>Typ</header>
							<path>
								<ref>pTypDzialania</ref>
								<embedded>strNazwa</embedded>
							</path>
						</column>
						<column link="true">
							<header>Temat</header>
							<path>
								<embedded>strTemat</embedded>
							</path>
						</column>
						<column link="true">
							<header>Zlecający</header>
							<path>
								<ref>pZlecajacy</ref>
								<embedded>strIndeks</embedded>
							</path>
						</column>
						<column link="true">
							<header>Klient</header>
							<path>
								<ref>pKlient</ref>
								<embedded>@longdesc</embedded>
							</path>
						</column>
						<column>
							<header>Status</header>
							<path>
								<embedded>nStatus</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order asc="false">
							<path>
								<embedded>dDataZlec</embedded>
							</path>
						</order>
					</orders>
				</raport>
				<raport title="@browser_##TYPEID_N5ZADANIE##@">
					<columns>
						<column>
							<path>
								<embedded>strTemat</embedded>
							</path>
						</column>
						<column>
							<path>
								<embedded>dDataZlec</embedded>
							</path>
						</column>
						<column>
							<path>
								<ref>pWykonawca</ref>
								<embedded>strIndeks</embedded>
							</path>
						</column>
					</columns>
					<orders>
						<order>
							<path>
								<embedded>dDataZlec</embedded>
							</path>
						</order>
						<order>
							<path>
								<embedded>strTemat</embedded>
							</path>
						</order>
					</orders>
				</raport>
				<raport title="@fuzzy_##TYPEID_N5ZADANIE##@">
					<filters>
						<filter>
							<path>
								<embedded>strTemat</embedded>
							</path>
						</filter>
						<filter>
							<path>
								<embedded>strOpis</embedded>
							</path>
						</filter>
					</filters>
				</raport>
			</raports>
			<default_search_field>strTemat</default_search_field>
		</object>
	</objects>
</nxapprep>