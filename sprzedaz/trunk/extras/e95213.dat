	<td style='27'  />
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curGlobNetto)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curGlobVAT)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curGlobBrutto)
	</td>
</tr>
</tfoot>
<tprevfoot>
<!-- rezerwuj 2 wiersze na dynamiczną stopkę -->
