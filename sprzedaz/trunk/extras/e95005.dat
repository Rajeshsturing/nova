<BODY CLASS="body">

<SCRIPT language=JavaScript event=onload for=window>
      start();      
	var x=12;
</SCRIPT>

<SCRIPT ID=clientEventHandlersVBS LANGUAGE=vbscript>
Sub button1_onclick

	dim str,fileName,command,error,srvName,dbName
	dim appName
	
	str = document.all("neipckg").innerHTML
	'dim doc
	dim application
	on error resume next
	set application = createobject("navo2002.client")
	select case Err.Number
		case 0:
			on error resume next
			fileName = application.document.system.createtempfilename("x","xml")
			dbName = application.document.system.registry(3,"SOFTWARE\NAVO\NAVO2002\Applications\" + appName,"DefaultDB")
			srvName = application.document.system.registry(3,"SOFTWARE\NAVO\NAVO2002\Applications\" + appName,"DefaultServer")

			dim DBAndSrv:DBAndSrv = ""

			if dbName <> "" then
				DBAndSrv = DBAndSrv + " vs8008='" + dbName+ "'"
			end if

			if srvName <> "" then
				DBAndSrv = DBAndSrv + " vs1012='" + srvName+ "'"
			end if


			select case err.Number
				case 0:
					dim pSXML
					on error resume next
					set pSXML = application.document.createstreamobj()
					select case err.number'todo - rozpoznawanie bledow
						case 0:
							pSXML.write "<?xml version=""1.0"" encoding=""windows-1250""?>"
							pSXML.write str
							pSXML.save fileName
							on error resume next
							application.document.postcommand("vn1001=1030 vn1002=70004 vs3034='" + fileName + "' vs8003='" + appName + "'" + DBAndSrv)
							select case err.number
								case 0:
									set application = nothing
								case else									
									msgbox "Aplikacja jest zainstalowana niepoprawnie - Opis bledu: " + err.description
									err.clear
									exit sub
							end select
						case else
							msgbox "Aplikacja jest zainstalowana niepoprawnie  - Opis bledu: " + err.description
							err.clear
							exit sub
					end select
				case else					
					msgbox "Aplikacja jest zainstalowana niepoprawnie - Opis bledu: " + err.description
					err.clear
					exit sub
			end select			
		case else
			msgbox "Na Twoim komputerze nie ma zainstalowanego programu ""NAVO Kontakt 2002"" ... A to taka fajowa aplikacja :-) NAPRAWDĘ!!!  - Opis bledu: " + err.description
			err.clear
			exit sub
	end select

End Sub
</SCRIPT>

<SCRIPT language=JavaScript>
      function start()
        {				
			var bInTable=false;
			var strInnerPrac="";
			var strInnerFirma="";
			var bCanGenerate=true;

			if (!bCanGenerate) return;
			
			
			var strWoj, strMiejsc, strWaluta, strFirmData
			var strBank1,strBank2,strBank3,id1,id2,id3,bIsB1,bIsB2,bIsB3
			bIsB1=false;//ktore banki sa wypelnione
			bIsB2=false;
			bIsB3=false;
			strBank1=""
			strBank2=""
			strBank3=""
			var rootElem = neipckg.documentElement;
			var childNode = rootElem.firstChild;
			var count1 = childNode.childNodes.length;			
			for (cl=0; cl<count1; cl++)
			{
				currNode = childNode.childNodes.item(cl)
				currNodeChild = currNode.childNodes.item(0)

				var strObjectName = currNodeChild.text;

				if (strObjectName=="-4")
				{
					currNodeChild = currNode.selectSingleNode("finf_real_typeid")
					strObjectName = currNodeChild.text
				}

				if (strObjectName=="10100")
				{
					strWoj = currNode.selectSingleNode("fstrnazwa").text;
				}
				
				if (strObjectName=="10111")
				{
					strMiejsc = currNode.selectSingleNode("fstrnazwa").text;
				}

				if (strObjectName=="10102")
				{
					strWaluta = currNode.selectSingleNode("fstrnazwa").text;
				}
				
				if (strObjectName=="10104")	
				{	if (strBank1=="")
					{	
						strBank1 = currNode.selectSingleNode("fstrnazwa").text;
						id1 = currNode.selectSingleNode("idobj").text;
						bIsB1=true;
					}
					else if (strBank2=="")
					{	
						strBank2 = currNode.selectSingleNode("fstrnazwa").text;
						id2 = currNode.selectSingleNode("idobj").text;
						bIsB2=true;
					}
					else
					{	
						strBank3 = currNode.selectSingleNode("fstrnazwa").text;
						id3 = currNode.selectSingleNode("idobj").text;
						bIsB3=true;
					}	
				}
				
				//przetwarzamy obiekt firmy
				if (strObjectName=="10108")				
				{
					var strAdr = ""
					if (currNode.selectSingleNode("fstrulica").text !="")
					{	strAdr = "ul." + currNode.selectSingleNode("fstrulica").text + " " +currNode.selectSingleNode("fstrnrdomu").text;
					};
					if (currNode.selectSingleNode("fstrnrlokalu").text!= "")
					{	strAdr = strAdr + "/" + currNode.selectSingleNode("fstrnrlokalu").text + ", " + currNode.selectSingleNode("fstrkod").text + " " + strMiejsc;
					}
					else
					{	strAdr = strAdr + ", " + currNode.selectSingleNode("fstrkod").text + " " + strMiejsc
					};
					
					var strTel="";
					if (currNode.selectSingleNode("fstrtel1").text!="") 
						{	strTel = currNode.selectSingleNode("fstrtel1").text}
					if (currNode.selectSingleNode("fstrtel2").text!="") 
						{	strTel = strTel + ", " + currNode.selectSingleNode("fstrtel2").text}
					if (currNode.selectSingleNode("fstrtel3").text!="") 
						{	strTel = strTel + ", " + currNode.selectSingleNode("fstrtel3").text}
						
					//banki
					var strB1=""
					if (currNode.selectSingleNode("fpbank1").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank1").text)
						{	case id1:
							{	strB1 +=strBank1
								if (currNode.selectSingleNode("fstrrachunek1").text != "")
								{	strB1 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek1").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie1").text != "")
								{	strB1 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie1").text
								}
								break;
							}							
							case id2:
							{	strB1 +=strBank2
								if (currNode.selectSingleNode("fstrrachunek1").text != "")
								{	strB1 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek1").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie1").text != "")
								{	strB1 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie1").text
								}
								break;
							}
							case id3:
							{	strB1 +=strBank3
								if (currNode.selectSingleNode("fstrrachunek1").text != "")
								{	strB1 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek1").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie1").text != "")
								{	strB1 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie1").text
								}
								break;
							}
						}
					}

					var strB2=""
					if (currNode.selectSingleNode("fpbank2").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank2").text)
						{	case id1:
							{	strB2 +=strBank1
								if (currNode.selectSingleNode("fstrrachunek2").text != "")
								{	strB2 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek2").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie2").text != "")
								{	strB2 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie2").text
								}
								break;
							}
							case id2:
							{	strB2 +=strBank2
								if (currNode.selectSingleNode("fstrrachunek2").text != "")
								{	strB2 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek2").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie2").text != "")
								{	strB2 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie2").text
								}
								break;
							}
							case id3:
							{	strB2 +=strBank3
								if (currNode.selectSingleNode("fstrrachunek2").text != "")
								{	strB2 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek2").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie2").text != "")
								{	strB2 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie2").text
								}
								break;
							}
						}
					}
					var strB3=""
					if (currNode.selectSingleNode("fpbank3").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank3").text)
						{	case id1:
							{	strB3 +=strBank1
								if (currNode.selectSingleNode("fstrrachunek3").text != "")
								{	strB3 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek3").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie3").text != "")
								{	strB3 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie3").text
								}
								break;
							}
							case id2:
							{	strB3 +=strBank2
								if (currNode.selectSingleNode("fstrrachunek2").text != "")
								{	strB3 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek2").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie2").text != "")
								{	strB3 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie2").text
								}
								break;
							}
							case id3:
							{	strB3 +=strBank3
								if (currNode.selectSingleNode("fstrrachunek3").text != "")
								{	strB3 += ", nr.rach.: " + currNode.selectSingleNode("fstrrachunek3").text
								}
								if (currNode.selectSingleNode("fstrprzeznaczenie3").text != "")
								{	strB3 += ", przeznaczenie: " + currNode.selectSingleNode("fstrprzeznaczenie3").text
								}
								break;
							}
						}
					}
				
					strInnerFirma += "<TABLE WIDTH=50% BORDER=0 CELLPADDING=0 CELLSPACING=0 ALIGN=CENTER BGCOLOR=#003060>"+
					"<TR><TD><TABLE WIDTH=100% BORDER=0 CELLPADDING=8 CELLSPACING=1 ALIGN=CENTER>" +
					"<TR CLASS=naglowek_kolor><TD CLASS=naglowek>"+currNode.selectSingleNode("fstrnazwa").text+"</TD></TR>" + 					
					"<TR CLASS=pole_kolor><TD CLASS=pole>"
					if (strAdr!="")
					{	strInnerFirma +="<SPAN CLASS=naglowekpola>Adres: </SPAN>"+ strAdr +"<BR></TD></TR><TR CLASS=pole_kolor><TD CLASS=pole>"
					}
					if (strTel!="")
					{	strInnerFirma +="<SPAN CLASS=naglowekpola>Telefony: </SPAN>"+ strTel +"<BR>"
					}
					if (currNode.selectSingleNode("fstrfax").text!="")
					{	
						strInnerFirma +="<SPAN CLASS=naglowekpola>Fax: </SPAN>"+ currNode.selectSingleNode("fstrfax").text +"<BR>"
					}
					if (currNode.selectSingleNode("fstremail").text!="")
					{	strInnerFirma += "<SPAN CLASS=naglowekpola>Adres e-mail: </SPAN><A HREF=mailto:"+currNode.selectSingleNode("fstremail").text+">"+currNode.selectSingleNode("fstremail").text+"</A><BR>"
					}
					if (currNode.selectSingleNode("fstrwww").text!="")
					{	strInnerFirma += "<SPAN CLASS=naglowekpola>Strona WWW: </SPAN><A HREF=&quot;"+currNode.selectSingleNode("fstrwww").text+">"+currNode.selectSingleNode("fstrwww").text+"</A><BR>"
					}
					strInnerFirma += "</TD></TR>" +
					"<TR CLASS=pole_kolor><TD CLASS=pole><SPAN CLASS=naglowekpola>NIP: </SPAN>"+currNode.selectSingleNode("fstrnip").text+"</TD></TR>"
					if ((strB1 + strB2 + strB3) != "" )
					{	strInnerFirma += "<TR CLASS=pole_kolor><TD CLASS=pole><SPAN CLASS=naglowekpola>Konta bankowe</SPAN><BR>"
						if (strB1 !="")
						{	strInnerFirma += "<SPAN CLASS=naglowekpola> - </SPAN>"+strB1+"<BR><BR>"
						}
						if (strB2 !="")
						{	strInnerFirma += "<SPAN CLASS=naglowekpola> - </SPAN>"+strB2+"<BR><BR>"
						}
						if (strB3 !="")
						{	strInnerFirma += "<SPAN CLASS=naglowekpola> - </SPAN>"+strB3+"<BR><BR>"
						}
						strInnerFirma += "</TD></TR>"
					}
					
					
				}
					
				if (strObjectName=="10112")
				{	
	
					if (!bInTable)
					{
						strInnerPrac += "<TABLE WIDTH=50% BORDER=0 CELLPADDING=0 CELLSPACING=0 ALIGN=CENTER BGCOLOR=#003060><TR><TD>" +
						"<TABLE WIDTH=100% BORDER=0 CELLPADDING=8 CELLSPACING=1 ALIGN=CENTER>" +
						"<TR CLASS=naglowek_kolor><TD CLASS=nazwafirmy>Pracownicy</TD></TR>"
						bInTable=true;
					}
					
			
					
					
					
					var strImieNazwisko = currNode.selectSingleNode("fstrnazwisko").text + " " + currNode.selectSingleNode("fstrimie").text
					strImieNazwisko = "<SPAN CLASS=naglowekpola>"+strImieNazwisko
					if (currNode.selectSingleNode("fstrstanowisko").text!="")
					{	strImieNazwisko += "</SPAN>, " + currNode.selectSingleNode("fstrstanowisko").text + "</TD></TR>"
					}
					else
					strImieNazwisko += "</SPAN></TD></TR>"
				
			
					strInnerPrac +=	 "<TR CLASS=pole_kolor_prac><TD CLASS=pole>" + strImieNazwisko 

					strInnerPrac +="<TR CLASS=pole_kolor><TD CLASS=pole>" 
//					if (currNode.selectSingleNode("fstrfax").text != "" )
//					{	strInnerPrac +="<SPAN CLASS=naglowekpola>Numer faksu: </SPAN>"+currNode.selectSingleNode("fstrfax").text+"<BR>" 
//					}
					if (currNode.selectSingleNode("fstrtel1").text != "" )
					{	strInnerPrac +="<SPAN CLASS=naglowekpola>Telefon służbowy: </SPAN>"+currNode.selectSingleNode("fstrtel1").text+"<BR>" 
					}
					if (currNode.selectSingleNode("fstrtel2").text != "" )
					{	strInnerPrac +="<SPAN CLASS=naglowekpola>Telefon służbowy komórkowy: </SPAN>" + currNode.selectSingleNode("fstrtel2").text + "<BR>"
					}
					if (currNode.selectSingleNode("fstremail").text != "" )
					{	strInnerPrac +="<SPAN CLASS=naglowekpola>Adres e-mail: </SPAN><A HREF=mailto:" + currNode.selectSingleNode("fstremail").text + ">" + currNode.selectSingleNode("fstremail").text + "</A><BR>" 
					}
//					if (currNode.selectSingleNode("fstrwww").text != "" )
//					{	
//						strInnerPrac +="<SPAN CLASS=naglowekpola>Strona WWW: </SPAN><A HREF=&quot;"+currNode.selectSingleNode("fstrwww").text+">"+currNode.selectSingleNode("fstrwww").text+"</A><BR>"
//					}
					strInnerPrac +="</TD></TR>"
									

				}	
				
			}

			strFirma.innerHTML = strInnerFirma;
			strPracownicy.innerHTML=strInnerPrac;
			
		}


</SCRIPT>




<XML id="neipckg" version="1.0" encoding="windows-1250">
%%XMLFROMNE%%
</XML>



<BODY CLASS="body">

<H1 ALIGN="CENTER"><I>WIZYTÓWKA FIRMY</I></H1>
</p>

<p id="strFirma">
</p>


<p id="strPracownicy">
</p>

