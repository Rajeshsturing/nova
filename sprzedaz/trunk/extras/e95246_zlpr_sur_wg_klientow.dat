<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZLECPROD_SUROWCE_WG_KLIENTOW

#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zapotrzebowanie na surowce wg zleceń
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=max(t_surow.strNazwa),'c_1'=max(t_opak_sur.strNazwa),'c_2'=max(isnull(t_klient.strNazwa,'<brak>')), " +_
"'c_3'=max(vzp.p_dDataReal),'c_4'=max(vzp.p_strNrDok),'c_ilosc_sur_zp' = sum(vzp.c_curIloscOpakPoz / vrw.c_curIloscOpak * vrs.c_curIloscOpak), " +_
"'c_dokladnosc'=t_jedn.nDokladnosc-1, 'c_surow_inx'=max(t_surow.strIndeks),"+_
"'c_5'=max(t_jedn.strSkrot),'c_6'=t_jedn.nDokladnosc,'c_idklient'=isnull(t_klient.Idobj,0),'c_idzlec'=vzp.p_idobj, " +_
"'c_idsur'=vrs.c_pProdukt from vlist_n5zlecprod_listpozycje as vzp " +_
"inner join vlist_n5recepta_listWyrob as vrw on vzp.c_pProdukt = vrw.c_pprodukt and vzp.c_pRecepta = vrw.p_idObj " +_
"inner join vlist_n5recepta_listSurowce as vrs on vrs.p_idobj = vrw.p_idobj " +_
"inner join n5produkt as t_wyrob on vrw.c_pprodukt = t_wyrob.IdObj " +_
"inner join n5produkt as t_surow on vrs.c_pprodukt = t_surow.IdObj " +_
"inner join n5opakowanie_produktu as t_opak_sur on vrs.c_pOpak = t_opak_sur.IdObj " +_
"inner join n5jednostka as t_jedn on t_opak_sur.pJednOpak = t_jedn.IdObj " +_
"left outer join n5klient as t_klient on vzp.p_pKlient = t_klient.IdObj " +_
"where  %1  and  %2  and  %3  and  %4 and %5 and %6 and vzp.c_curIloscOpakPoz <> 0 " +_
"group by t_klient.Idobj,vzp.p_idobj,vrs.c_pProdukt,vrs.c_pOpak,t_jedn.nDokladnosc " +_
"order by c_2,c_3,c_4,c_surow_inx,c_1"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin realizacji").bindexpr("vzp.p_dDataReal")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("isnull(t_klient.strNazwa,'<brak>')")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa wyrobu").bindexpr("t_wyrob.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks wyrobu").bindexpr("t_wyrob.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa surowca").bindexpr("t_surow.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks surowca").bindexpr("t_surow.strIndeks")

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	<%if clng(pRec("c_idklient")) <> 0 then %>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,c_idklient,c_2)
	<% else %>
		RXE_AUTO_TEXT(c_2)
	<%end if%>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<%
end function
%>
<%
function section_header_3(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="3" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='6'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZLECPROD,c_idzlec,c_4)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_3(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="3"'><td colspan='7' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
dim curIloscPotrz : curIloscPotrz = trans_.afc.convert.roundn(ccur(pRec("c_ilosc_sur_zp")),ccur(pRec("c_dokladnosc")))

%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_idsur,c_surow_inx)
	</td>
	<td>
		RXE_AUTO_TEXT(c_0)
	</td>
  <td>
		RXE_AUTO_TEXT(c_1)
	</td>
	<td align='right'>
	<%dim iZaokragl
	iZaokragl = pRec("c_6").value
	if iZaokragl>4 then
		iZaokragl = 4    'dlatego poniewaz przy definiowaniu zaokraglenia dla jednostki ustawia 1,2,3,i 5 (nie 4)
	end if
	%>
		RXE_QUANTITY_VVV(curIloscPotrz,pRec("c_5"),iZaokragl)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Indeks surowca]]></text>
  </td>
  <td width='max'>
		<text><![CDATA[Nazwa surowca]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Nazwa opakowania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 2,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 4,getref("section_header_3"),getref("section_footer_3")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
