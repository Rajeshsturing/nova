<?xml version="1.0" encoding="windows-1250" ?>

<!-- Kompensata -->
<!-- dla rozliczen w PLN i walutach-->

#include "h1203_appconfig.h"

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>

#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>
#define DATA_OPERACJI					<% so.write doc_.afc.display.fulldate(root_.dDataOper) %>
#define DATA_WYDR					<% so.write doc_.afc.display.fulldate(now()) %>

<!-- Dane firmy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica%>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

<!-- Dane podmiotu-->
#define PODMIOT_NAZWA					<% so.write util_.Podmiot_Nazwa(root_.wrefPodmiot) %>
#define PODMIOT_ULICA_NUMER				<% so.write util_.Podmiot_Ulica(root_.wrefPodmiot)%>						
#define PODMIOT_KOD_MIASTO				<% if root_.wrefPodmiot.strPoczta="" then so.write util_.Podmiot_Miasto(root_.wrefPodmiot) else if root_.wrefPodmiot.strPoczta<>"" and  root_.wrefPodmiot.strPoczta<>root_.wrefPodmiot.pMiejscowosc.strNazwa then so.write root_.wrefPodmiot.strKod + " " + root_.wrefPodmiot.strPoczta else if  root_.wrefPodmiot.strPoczta=root_.wrefPodmiot.pMiejscowosc.strNazwa then so.write util_.Podmiot_Miasto(root_.wrefPodmiot) end if end if end if%>	
#define PODMIOT_MIASTO					<% so.write root_.wrefPodmiot.pMiejscowosc.strNazwa %>
#define DOKUMENT_WALUTA					<% so.write root_.pWalutaPodm.strSkrot %>

#define TRANSAKCJA_SYMBOL				<% so.write pozycja.pTransakcja.strSymTrans  %>
#define TRANSAKCJA_SALDO				<% so.write MONEY((pozycja.curPozKwotaTrans))  %>
#define TRANSAKCJA_SALDO2				<% so.write MONEY((-pozycja.curPozKwotaTrans))  %>
#define NALEZNOSCI_SUMA					<% so.write MONEY((sumaN))  %>
#define ZOBOWIAZANIA_SUMA				<% so.write MONEY((sumaZ))  %>
#define DOKUMENT_UWAGI					<% so.write root_.strOpis%>

#define DOKUMENT_NUMER					<% so.write root_.text %>

<page style='36' margins='700,700,700,700'>

<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>

<header>
</header>

<body>
<table >
	<tbody>

		<tr>
			<td>
				<table>
					<tbody>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_NAZWA]]></t>
							</td>
							<td align='right'>
								<t fontsize='4'><![CDATA[MIEJSCOWOSC_DATA DATA_WYDR]]></t>
							</td>
						</tr>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td/>
						</tr>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td/>
						</tr>

						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td>
								<t fontsize='4'><![CDATA[FIRMA_MIASTO]]></t>
							</td>
							<td/>
						</tr>
						<%end if%>
						ROW_SEPARATOR(2)

						
						<tr>
							<td width='max'></td>
							<td>
								<t fontsize='4' size='40' bold='true'><![CDATA[PODMIOT_NAZWA]]></t>
							</td>
							
						</tr>
						
						<tr>
							<td/>
							<td>
								<t fontsize='4' size='40' bold='true'><![CDATA[PODMIOT_ULICA_NUMER]]></t>
							</td>
							
						</tr>
						<tr>
							<td/>
							<td>
								<t fontsize='4' size='40' bold='true'><![CDATA[PODMIOT_KOD_MIASTO]]></t>
							</td>
							
						</tr>

						<% if (root_.wrefPodmiot.strPoczta<>"") and (root_.wrefPodmiot.pMiejscowosc.strNazwa <> root_.wrefPodmiot.strPoczta) then %>
						<tr>
							<td/>
							<td>
								<t fontsize='4' size='40' bold='true'><![CDATA[PODMIOT_MIASTO]]></t>
							</td>
							
						</tr>
						<%end if%>
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)

						<tr>
							<td colspan='2' align='center'>
								<t fontsize='8' bold='true'>Kompensata nr DOKUMENT_NUMER</t>
							</td>
						</tr>

						ROW_SEPARATOR(2)

						<tr>
							<td colspan='2'>
								<text fontsize='4' >W oparciu o art. 498 i art 502 Kodeksu cywilnego uprzejmie informujemy, że dokonaliśmy kompensaty na dzień DATA_OPERACJI:</text>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td colspan='2' align='center'>
								<t>naszych zobowiązań wobec Państwa, wynikających z faktur:</t>
							</td>
						</tr>
					</thead>
					<tbody>
						<%
							dim pozycja
							dim sumaZ,sumaN
							sumaZ = ccur(0)
							sumaN = ccur(0)
							for each pozycja in root_.listPozycje
								if pozycja.pTransakcja.eTyp = 1 then
									sumaZ = sumaZ - pozycja.curPozKwotaTrans
						%>
						<tr>
							<td>
								<t>TRANSAKCJA_SYMBOL</t>
							</td>
							<td align='right'>
								<t>TRANSAKCJA_SALDO2 DOKUMENT_WALUTA</t>
							</td>
						</tr>
						<%		
								end if
							next
						%>
					</tbody>
					<tfoot bold='true'>
						<tr>
							<td backcolor='#E0E0E0' align='center'>
								<t>na sumę:</t>
							</td>
							<td align='right'>
								<t>ZOBOWIAZANIA_SUMA DOKUMENT_WALUTA</t>
							</td>
						</tr>
					</tfoot>
				</table>
			</td>
		</tr>




		ROW_SEPARATOR(1)


		ROW_SEPARATOR(1)



		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td colspan='2' align='center'>
								<t width='min'>z naszymi należnościami wynikającymi z faktur:</t>
							</td>
						</tr>
					</thead>
					<tbody>
						<%
							for each pozycja in root_.listPozycje
								if pozycja.pTransakcja.eTyp = 2 then
									sumaN = sumaN + pozycja.curPozKwotaTrans
						%>
						<tr>
							<td>
								<t>TRANSAKCJA_SYMBOL</t>
							</td>
							<td align='right'>
								<t>TRANSAKCJA_SALDO DOKUMENT_WALUTA</t>
							</td>
						</tr>
						<%		
								end if
							next
						%>
					</tbody>
					<tfoot bold='true'>
						<tr>
							<td backcolor='#E0E0E0' align='center'>
								<t width='min'>na sumę:</t>
							</td>
							<td align='right'>
								<t>NALEZNOSCI_SUMA DOKUMENT_WALUTA</t>
							</td>
						</tr>
					</tfoot>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table>
					<tbody>
						<%
							'należności + zobowiazania(ujemne)
							dim saldo_typTrans1, saldo_typTrans2
							dim query
							
							query =  doc_.afc.convert.Formatter("select isnull(sum(curWn - curMa),0) as suma from n5transakcja where wrefPodmiot = %2 and wrefPodmiot_wrt = %1 and eTyp = %3 and pWaluta =  %4") _
			.add(cstr(root_.wrefPodmiot.type)).add(cstr(root_.wrefPodmiot.idobj)).add(cstr(1)).add(cstr(root_.pWalutaPodm.idObj)).done() 
							
							dim rs:set rs = trans_.createadors(query)
							saldo_typTrans1 = ccur(rs.fields("suma").value)
							
							query =  doc_.afc.convert.Formatter("select isnull(sum(curWn - curMa),0) as suma from n5transakcja where wrefPodmiot = %2 and wrefPodmiot_wrt = %1 and eTyp = %3 and pWaluta =  %4") _
			.add(cstr(root_.wrefPodmiot.type)).add(cstr(root_.wrefPodmiot.idobj)).add(cstr(2)).add(cstr(root_.pWalutaPodm.idObj)).done() 
								
							set rs = trans_.createadors(query)
							saldo_typTrans2 = ccur(rs.fields("suma").value)
	
							
							dim saldo:saldo = saldo_typTrans2 + saldo_typTrans1
							
							
							'dim saldo:saldo = util_.suma_transkacje(root_.wrefPodmiot,2) + util_.suma_transkacje(root_.wrefPodmiot,1)
#ifndef _KOMPOZYTY
							if saldo > 0 then
						%>
							<tr>
								<td colspan='2' keepline='true'>
									<!-- tu musi być IF -->
									<t fontsize='4'>Po kompensacie w/w faktur pozostaje do zapłaty na nasze dobro kwota:</t>
									<t size='1'/>
									<t fontsize='4'><%  so.write doc_.afc.display.money(saldo,"")  %> DOKUMENT_WALUTA</t>
								</td>
							</tr>
						<%
							else
						%>
							<tr>
								<td colspan='2' keepline='true'>
									<!-- tu musi być IF -->
									<t fontsize='4'>Po kompensacie w/w faktur pozostaje do zapłaty na Państwa dobro kwota:</t>
									<t size='1'/>
									<t fontsize='4'><%  so.write doc_.afc.display.money(abs(saldo),"")  %> DOKUMENT_WALUTA</t>
								</td>
							</tr>
						<%
							end if
						%>					
						
						
						
						<%if root_.pWalutaPodm.strSkrot = "PLN" then %>
						<tr>
							<td colspan='2' keepline='true'>
								<t>Słownie:</t>
								<t size='1'/>
								<t><%  so.write doc_.afc.display.slownie(ccur(abs(saldo)))  %></t>
							</td>
						</tr>
						<%
						end if
#endif
						%>
						
						
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)						
						<tr>
							<td colspan='2'>
								<text fontsize='4'><![CDATA[Dokonujemy ww kompensaty, prosimy o zgodne z nami księgowanie i potwierdzenie w ciągu 7 dni. Brak odpowiedzi będziemy traktować jako akceptację.]]></text>
									
							</td>
						</tr>
						
						
						<% if root_.strOpis <> "" then %>
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)						
						<tr>
							<td colspan='2'>
								<t bold='true'>Adnotacje:</t><br/>
								<text><![CDATA[DOKUMENT_UWAGI]]></text>
									
							</td>
						</tr>
						<% end if%>
						
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						ROW_SEPARATOR(2)
						<tr>
							<td colspan='2'>
								<table>
									<tbody>
										<tr>
											<td align='center'>
												<t>.........................................................................</t>
											</td>
											<td width='max'>
											</td>
										</tr>
										<tr>
											<td align='center'>
												<t fontsize='2'>Imię i nazwisko osoby składającej oświadczenie</t>
											</td>
											<td width='max'>
											</td>
										</tr>

									</tbody>
								</table>								
							</td>
						</tr>
						
						
					</tbody>
				</table>
			</td>
		</tr>
	</tbody>
</table>
</body>

<footer>
</footer>

</page>
