<?xml version="1.0" encoding="windows-1250" ?>

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane dostawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataRej) %>
#define DOKUMENT_NUMER					<% so.write cstr(root_.nNumNal) %>
#define DOKUMENT_DATAOD_DO	\
	<% so.write doc_.afc.display.fulldate(root_.dDataOd) + " - " +  doc_.afc.display.fulldate(root_.dDataDo) %>

#define DOKUMENT_LISTA_PLAC				<% so.write root_.pListaPlac.strNrDok %>
#define DOKUMENT_PRACOWNIK_IMIE_NAZWISKO	\
		<% so.write root_.pPracownik.text %>
#define DOKUMENT_PRACOWNIK_PESEL		<% so.write root_.pPracownik.strPESEL %>
#defien DISPLAY_LEVEL	1
<page style='36' margins='700,700,700,700'  border='0'>
<config>
	<title>Naliczenie wynagrodzeń</title>

<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>

</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>
						</tr>


						<!-- Nagłówek  -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[Naliczenie wynagrodzeń]]></t>
							</td>
						</tr>
						<!--
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>
						-->
						<tr>
							<td>
								<table width='max'>
									<tbody>
										<tr bold='true'>
											<td>
												<t> Pracownik: </t>
											</td>
											<td>
												<t> DOKUMENT_PRACOWNIK_IMIE_NAZWISKO </t>
											</td>
										</tr>
										<tr bold='true'>
											<td>
												<t> PESEL: </t>
											</td>
											<td>
												<t> DOKUMENT_PRACOWNIK_PESEL </t>
											</td>
										</tr>
										ROW_SEPARATOR(2)
										<tr>
											<td>
												<t> Naliczenie za okres: </t>
											</td>
											<td>
												<t> DOKUMENT_DATAOD_DO </t>
											</td>
										</tr>
										<tr>
											<td>
												<t> Lista płac: </t>
											</td>
											<td>
												<t> DOKUMENT_LISTA_PLAC </t>
											</td>
										</tr>
									</tbody>
								</table>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		<!-- ujete dokumenty -->
		<tr align='center'>
			<td><t fontsize='6'>Ujęte dokumenty</t></td>
		</tr>
		<tr>
			<td>
				<table border='1'>
					<tbody>
						<%
						dim pSkladnik
						'watchdog field
						dim pWD:set pWD = nothing
						dim iter : iter = 1

						for each pSkladnik in root_.listSkladnik
							if not pWD is pSkladnik.wrefDokument then
						%>						
						<tr>
							<td><t><%so.write cstr(iter) + ". " + util_.DokPlac_Nazwa_krotka(pSkladnik.wrefDokument)%></t>
							</td>							
						</tr>
						<%
							set pWD = pSkladnik.wrefDokument
							iter = iter + 1
							end if
						next
						%>
					</tbody>
				</table>
			</td>
		</tr>
		<!-- szczegóły naliczenia -->
		<tr align='center'>
			<td><t fontsize='6'>Szczegóły naliczenia</t></td>
		</tr>
		<tr>
			<td>
				<table border='1'>
					<tbody>
						<%
						dim pModule : set pModule = doc_.getmodule(60192)
						dim pRootNalStorage : set pRootNalStorage = pModule.load_naliczenie(root_)
						iter = 1
						do while true
							dim pDisplayItem : set pDisplayItem = pRootNalStorage.get_display_item(iter)
							
							if pDisplayItem is nothing then
								exit do
							end if
							if pDisplayItem.get_level() >= DISPLAY_LEVEL then
							select case pDisplayItem.get_type()
							case 1
							%>
							<tr fontsize='3'>
								<td colspan='2'>
									<t><%so.write pDisplayItem.get_text()%></t>
								</td>							
							</tr>
							<%
							case 4
							%>
							<tr fontsize='4'>
								<td colspan='2'>
									<t  bold='true'><%so.write pDisplayItem.get_text()%></t>
								</td>							
							</tr>
							<%
							case 2
							%>
							<tr fontsize='3'>
								<td>
									<t><%so.write pDisplayItem.get_text()%></t>
								</td>							
								<td align='right'>
									<t><%so.write trans_.afc.display.quantity(pDisplayItem.get_curvalue(),	_
					pDisplayItem.get_unit(),pDisplayItem.get_precision()) %></t>
								</td>							
							</tr>
							<%
							case 3
							%>
							<tr fontsize='3'>
								<td>
									<t><%so.write pDisplayItem.get_text()%></t>
								</td>							
								<td align='right'>
									<t><%so.write trans_.afc.display.quantity(pDisplayItem.get_computed_value().curvalue,	_
					pDisplayItem.get_unit(),pDisplayItem.get_precision()) %></t>
								</td>							
							</tr>
							<%
							end select
							end if
							iter = iter + 1
						loop

						%>						
						<%
						%>
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<table>
					<tbody>
						<tr>
							<td><t>Podpis pracownika</t></td>
							<td><t size='20'></t></td>
							<td><t>Sporządził</t></td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
