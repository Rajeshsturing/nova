<?xml version="1.0" encoding="windows-1250" ?>


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto + "   " + util_.Dzisiaj%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>


#define PODMIOT_NAZWA					<% so.write util_.Podmiot_Nazwa(root_.wrefPodmiot) %>
#define PODMIOT_ULICA					<% so.write util_.Podmiot_Ulica(root_.wrefPodmiot) %>
#define PODMIOT_MIASTO					<% so.write util_.Podmiot_Miasto(root_.wrefPodmiot) %>



#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_OPERACJI			<% so.write doc_.afc.display.fulldate(root_.dDataOper) %>
#define DOKUMENT_KWOTA					<% so.write MONEY(root_.curKwotaPodm) %>
#define DOKUMENT_KWOTA_SLOWNIE			<% so.write doc_.afc.display.slownie(abs(root_.curKwotaPodm)) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>

#define POZ_OPIS						<% so.write pozycja.text %>





<page style='36' border='0'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td colspan='2'>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[Dowód wypłaty DOKUMENT_NUMER]]> </t>
							</td>
						</tr>						
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[z dnia DOKUMENT_DATA_OPERACJI]]> </t>
							</td>
						</tr>						
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td width='max'>
				<table >
					<tbody>
						<tr>
							<td>
								<t bold='true' size='10'>Komu:</t>
							</td>					
							<td width='max'>
								<text size='40'><![CDATA[PODMIOT_NAZWA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<t><![CDATA[PODMIOT_ULICA]]></t>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<t><![CDATA[PODMIOT_MIASTO]]></t>
							</td>					
						</tr>						

						ROW_SEPARATOR(2)

						<%	dim pozycja,iter
							iter = 1
							for each pozycja in root_.listPozycje
						%>
						<tr>
							<td>
							<% if iter = 1 then %>
								<t bold='true' size='10'>Za co:</t>
							<%end if %>
							</td>					
							<td width='max'>
								<t><![CDATA[POZ_OPIS]]></t>
							</td>					
						</tr>																									

						<%		iter = iter + 1
							next
						%>
					</tbody>
				</table>				
			</td>
			<td align='right' width='min'>
				<table border='1'>
					<thead backcolor='#E0E0E0' bold='true'>					
						<tr>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr>
							<td>
								<t>kasa</t>
							</td>					
							<td>
								<t>konto</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
							<td>
								<t></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td colspan='2'>
				<table >
					<tbody>
						<tr>
							<td colspan='3'>
								<t bold='true'>Słownie:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_KWOTA_SLOWNIE]]></text>
							</td>					
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)																		
						<tr>
							<td align='center'>
								<t fontsize='3'><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
						</tr>						
						<tr>
							<td align='center'>
								<t fontsize='3' size='20'>Sporządził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Zatwierdził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Kwotę powyższą otrzymałem</t>
							</td>					
						</tr>						

					</tbody>
				</table>				
			</td>
		</tr>				
	</tbody>
</table>

<br/>
<br/>



<table>
	<tbody>
		<tr>
			<td colspan='2'>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[Dowód wypłaty DOKUMENT_NUMER]]> </t>
							</td>
						</tr>						
						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[z dnia DOKUMENT_DATA_OPERACJI]]> </t>
							</td>
						</tr>						
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td width='max'>
				<table >
					<tbody>
						<tr>
							<td>
								<t bold='true' size='10'>Komu:</t>
							</td>					
							<td width='max'>
								<text size='40'><![CDATA[PODMIOT_NAZWA]]></text>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<t><![CDATA[PODMIOT_ULICA]]></t>
							</td>					
						</tr>						
						<tr>
							<td>
							</td>					
							<td width='max'>
								<t><![CDATA[PODMIOT_MIASTO]]></t>
							</td>					
						</tr>						

						ROW_SEPARATOR(2)

						<%	
							iter = 1
							for each pozycja in root_.listPozycje
						%>
						<tr>
							<td>
							<% if iter = 1 then %>
								<t bold='true' size='10'>Za co:</t>
							<%end if %>
							</td>					
							<td width='max'>
								<t><![CDATA[POZ_OPIS]]></t>
							</td>					
						</tr>																									

						<%		iter = iter + 1
							next
						%>
					</tbody>
				</table>				
			</td>
			<td align='right' width='min'>
				<table border='1'>
					<thead backcolor='#E0E0E0' bold='true'>					
						<tr>
							<td>
								<t>Ma</t>
							</td>					
							<td>
								<t>Winien</t>
							</td>					
						</tr>						
						<tr>
							<td>
								<t>kasa</t>
							</td>					
							<td>
								<t>konto</t>
							</td>					
						</tr>						
					</thead>
					<tbody>
						<tr bold='true'>
							<td>
								<t><![CDATA[DOKUMENT_KWOTA]]></t>
							</td>					
							<td>
								<t></t>
							</td>					
						</tr>						
					</tbody>
				</table>				
			</td>
		</tr>
		ROW_SEPARATOR(2)
		<tr>
			<td colspan='2'>
				<table >
					<tbody>
						<tr>
							<td colspan='3'>
								<t bold='true'>Słownie:</t>
								<t size='3'></t>
								<text><![CDATA[DOKUMENT_KWOTA_SLOWNIE]]></text>
							</td>					
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)																		
						<tr>
							<td align='center'>
								<t fontsize='3'><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>...............................................................</t>
							</td>					
						</tr>						
						<tr>
							<td align='center'>
								<t fontsize='3' size='20'>Sporządził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Zatwierdził</t>
							</td>					
							<td align='center'>
								<t fontsize='3'>Kwotę powyższą otrzymałem</t>
							</td>					
						</tr>						

					</tbody>
				</table>				
			</td>
		</tr>				
	</tbody>
</table>



</body>
<footer>
