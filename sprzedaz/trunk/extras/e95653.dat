<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Lista dokumentów powiązanych - WZ
#define WZ_ZLEC_PROD #wz_zlec_prod


#define COL_ID_WZ 7
-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>

<script>
<![CDATA[
<%
function query()
  
  dim temp_query

  temp_query = " create table WZ_ZLEC_PROD "+_
               " ( "+_
               " idZamow integer not null, "+_
               " idProd integer not null, "+_
               " idOpak integer not null, "+_
               " idWz integer not null, "+_
               " curIloscWZ decimal(14,4), "+_
               " ) "
           
  trans_.execsql temp_query
  
  temp_query = " insert into WZ_ZLEC_PROD select "+_
               " v_zamow.p_idobj, v_zamow.c_pProdukt, v_zamow.c_pOpak, 0, 0"+_
               " from vlist_n5zamowienie_listpozycje v_zamow "+_
               " join n5produkt t_prod on v_zamow.c_pProdukt=t_prod.idObj "+_
               " where c_curiloscopakpoz<>0 "+_
               " group by p_idobj,c_pProdukt,c_pOpak "
    
  trans_.execsql temp_query


  temp_query = " insert into WZ_ZLEC_PROD "+_
               " select v_dokmag.p_wrefdokhandl,v_dokmag.c_pProdukt, v_dokmag.c_pOpak, v_dokmag.p_idObj, max(v_dokmag.c_curiloscopak) "+_
               " from vlist_n5dokmag_listpozycje v_dokmag "+_
               " join n5produkt t_prod on v_dokmag.c_pProdukt = t_prod.idObj "+_
               " where p_wrefdokhandl in (select idZamow from WZ_ZLEC_PROD) and p_wrefdokhandl_wrt=10172 and p_nTypDok = 19 "+_
               " group by p_idObj,p_wrefdokhandl,c_pProdukt,c_pOpak "


  trans_.execsql temp_query


   temp_query = " insert into WZ_ZLEC_PROD select "+_
                " n5sprzedaz.pZamowienie,v_dokmag.c_pProdukt, v_dokmag.c_pOpak, v_dokmag.p_idObj, sum(v_dokmag.c_curiloscopak) "+_
                " from vlist_n5dokmag_listpozycje v_dokmag join n5sprzedaz on v_dokmag.p_wrefdokhandl = n5sprzedaz.idobj and v_dokmag.p_wrefdokhandl_wrt=10129 "+_
                " inner join n5produkt t_prod on v_dokmag.c_pProdukt = t_prod.idObj "+_
                " where n5sprzedaz.pZamowienie in (select distinct p_idObj from vlist_n5zamowienie_listpozycje where c_curiloscopakpoz<>0) and v_dokmag.p_nTypDok = 19 "+_
                " group by v_dokmag.p_idObj,n5sprzedaz.pZamowienie,v_dokmag.c_pProdukt,v_dokmag.c_pOpak "

    trans_.execsql temp_query


           
    query =  " select "+_
             " 'c_nrDok'=max(t_dokmag.strNrDok), "+_
             " 'c_idWz'=max(t_tmp.idWz), "+_
             " max(t_tmp.idOpak), "+_
             " max(t_tmp.idProd), "+_
             " 'c_curIloscWZ'=sum(t_tmp.curIloscWZ), "+_
             " 'c_ddataWyst'=max(t_dokmag.ddatawyst) "+_
             " from WZ_ZLEC_PROD as t_tmp "+_
             " join n5dokmag t_dokmag on t_tmp.idWz=t_dokmag.idobj "+_
             " where %1 and %2 "+_
             " group by t_dokmag.strNrDok"+_
             " order by 1,2"
             
 
   
             

end function
  
%>

<%

dim pGrupaParam

function default_param()

  
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.afc.rap.param.new_text("Zamowienie").bindexpr("t_tmp.idZamow")
  pParamArray.add doc_.afc.rap.param.new_text("Produkt").bindexpr("t_tmp.idProd")

  set default_param = pParamArray
  
end function
%>

<%
function write_actual_param(byref pActualParam)
  dim iter
  dim bAnyWritten : bAnyWritten = false
  if not pActualParam is nothing then
  for iter = 0 to pActualParam.upperIndex
  if pActualParam.value(iter).get_desc() <> "" then 
  bAnyWritten = true
	  so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
  end if
  next
  end if
  if not bAnyWritten then 
	  so.write "<t fontsize='4'>brak</t><br/>"
  end if
	  so.write "<br/>"
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='4'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
  </td> 
  <td style='27' align='right'>
  </td>
  

</tr>

<%
  nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_1(byref pSection)
%>

#ifdef _IOW
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
#else
<tr hide='true' userprop='propc_section_end="1"'><td colspan='6' /></tr>
#endif

<tr fontsize='4'>
  <td style='27' colspan='7'><text>&nbsp;</text></td>
</tr>


<%
end function
%>

<%
function body_row(byref pSection,byref pRec)

  if pRapExec.RecNr mod 2 = 0 then
%>

<tr bordercolor='white'>

<%
  else
%>

<tr bordercolor='white' style='37'>

<%
  end if
%>

<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5DOKMAG, c_idWz, c_NrDok)
	</td>
  <td align='right'>
    RXE_DATE(c_ddataWyst)
	</td>
  <td align='right'>
    RXE_QUANTITY_CVV(c_curIloscWz,"",2)
	</td>

 
</tr>

<%
end function
%>

<%
function body_header(byref pSection,byref pRec)
'so.write "<p backcolor='yellow'><text><![CD"+"ATA["+pRapExec.get_final_query() + "]"+"]></text></p><br/>" 

%>

<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>

<td width='max'>
  <text><![CDATA[Numer dokumentu]]></text>
</td>
  <td width='min'>
    <text><![CDATA[Data wystawienia dokumentu]]></text>
  </td>
<td width='min'>
  <text><![CDATA[Ilość wydana (WZ)]]></text>
</td>

</tr>
</thead>
<tbody>
  
<%
end function
%>

<%
function body_footer(byref pSection)
%>

</tbody>
<tfoot>
<tr style='21'>
  <td style='27' align='right' colspan='4'>
    <t>
      &nbsp;
    </t>
  </td>
  <td style='27' align='right' >
    <t>
      &nbsp;
    </t>
  </td>
</tr>
</tfoot>
</table>
  
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
  RAPORT_HEADER(3,0)
</p>
  <p>
  <t size='2'/>
  </p>

  <p>
    <text fontsize='7'><![CDATA[RAPORT_TITLE]]></text>
  </p><br/><br/>
  
<%
dim pParamTypPro
%>
   
  <t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
  
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

 '' dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())

 
  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
  end if
  end if
  end with
  
   trans_.execsql " drop table WZ_ZLEC_PROD"
%>


</body>
<footer>
</footer>
</page>
