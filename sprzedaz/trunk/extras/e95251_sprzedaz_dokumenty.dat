<!-- 17.08.2004 v.1 --> 
<!-- 16.02.2005 IG filtr na opiekuna klienta -->
<!-- 18.07.2008 IOW podsumowanie walut -->
<!--

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Sprzedaż - podsumowanie wg dokumentów


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_1.strIndeks
#define C_FIELD_SECOND_EXPR		t_1.strNazwa
#else
#define C_FIELD_FIRST_EXPR		t_1.strNazwa
#define C_FIELD_SECOND_EXPR		t_1.strIndeks
#endif 

-->
#ifdef _IOW
<%
dim tabela(100,4)
dim iTabelaItems : iTabelaItems = clng(0)

dim iter : iter = 1

%>
#endif


<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim strWaluta : strWaluta = ""
dim strWalutaJoin : strWalutaJoin = ""
#ifdef _IOW
strWaluta = "'c_waluta' = t_sprzed.pWaluta, 'c_wal_skrot'=t_wal.strSkrot, 'c_rej_typ'=t_3.eTyp, 'c_kurs'=t_sprzed.curKurs, "+_
" 'c_suma_wal'=isnull(t_sprzed.curSumaWal,0),   "+_
" 'c_suma_wal_brutto'=isnull(t_sprzed.curSumaWalBrutto,0),  "+_
" 'c_suma_wal_vat'=isnull(t_sprzed.curSumaWalBrutto,0) - isnull(t_sprzed.curSumaWal,0), "

strWalutaJoin = " inner join n5jednostka as t_wal on t_sprzed.pWaluta = t_wal.IdObj  "
#endif

query = "select 'c_field_first'=C_FIELD_FIRST_EXPR,'c_field_second'=C_FIELD_SECOND_EXPR, "+_
" 'c_1'=10108,'c_idobj'=t_1.IdObj,'c_3'=t_sprzed.strNrDok,'c_4'=t_1.strNazwa, "+_
" 'c_5'=10108,'c_6'=t_1.IdObj,'c_10'=t_sprzed.strNrDok,'c_11'=10129, "+_
" 'c_12'=t_sprzed.IdObj,'c_13'=isnull(t_sprzed.curSumaNetto-isnull(t_orgsprz.curSumaNetto,0),0), "+_
" 'c_14'=isnull(t_sprzed.curSumaBrutto-isnull(t_orgsprz.curSumaBrutto,0),0), "+_
" 'c_15'=isnull(t_sprzed.curSumaVAT-isnull(t_orgsprz.curSumaVAT,0),0),  "+_
strWaluta +_
"'c_data_sprzed'=t_sprzed.dDataSprzed,"+_
"'c_extra1'=t_sprzed.strExtra1"+_
" from n5sprzedaz as t_sprzed "+_
" left outer join n5sprzedaz t_orgsprz on t_sprzed.ppopsprzed = t_orgsprz.idobj "+_
" inner join n5klient as t_1 on t_sprzed.pKlient = t_1.IdObj "+_
" left join n5pracownik as t_prac on  t_1.pPracownik = t_prac.Idobj  "+_
" inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
" inner join n5rejestrdok as t_3 on t_sprzed.pRejestrDok = t_3.IdObj "+_
strWalutaJoin +_
" left outer join n5pracownik as t_handl on t_sprzed.sprzed_pHandlowiec = t_handl.idobj " 
#ifdef _IOW
query=query+" left outer join n5kwalifikator as t_kwali on  t_sprzed.pkwalifikatorex = t_kwali.Idobj  "+_
" where t_sprzed.pRozlVAT<>0 and %1  and  %2 and %3 and  %4  and  %5  and  %6 and %7 and EXTRA_CUSTOMER_FILTER_AND(9) and %8 "
#else
query=query+" where t_sprzed.pRozlVAT<>0 and %1  and  %2 and %3 and  %4  and  %5  and  %6 and EXTRA_CUSTOMER_FILTER_AND(7) and %8 "
#endif
#ifdef _PRINTY_LAND
query = query + " and %9 "
#endif
#ifdef _RAND
query = query + " and %9 "
#endif
query=query+" order by c_data_sprzed,c_10, c_3"

'" left outer join n5pracownik as t_handl on t_sprzed.sprzed_pHandlowiec = t_handl.idobj " +_
'" where t_sprzed.pRozlVAT<>0 and %1  and  %2  and  %3  and  %4  and  %5 and %6 and EXTRA_CUSTOMER_FILTER_AND(7) and %8 "+_
'" order by c_data_sprzed,c_10, c_3"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_sprzed.dDataWyst")
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa rejestru").bindexpr("t_3.strNazwa")
	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_3.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " + strIdRokKsieg + " " +_
#ifdef _IOW
		"and strNazwa not like 'Faktury VAT Fundusz Reprezentacyjny' " +_
#endif	
#ifdef _MILOMLYN
		"and eAktywny = N5REJESTRDOK_AKTYWNY " +_
#endif	
		"order by strNazwa "
	pParamArray.add pParam2
#ifdef _IOW
	dim pParam3: Set pParam3= pParamFactory2.new_choice("Oznaczenie dokumentu").bindexpr("isnull(t_kwali.idobj,0)")
	doc_.afc.rap.param.init_on_query pParam3, trans_ ,_
		"select strNazwa , idobj , 0 from n5kwalifikator union select '<brak>' , 0 , 1 order by 3 , 1 "
	pParamArray.add pParam3
#endif
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(t_handl.strNazwisko,'')")
#ifdef _PRINTY_LAND
	pParamArray.add doc_.afc.rap.param.new_text("Status").bindexpr("isnull(t_sprzed.strExtra1,'')")
#endif
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)
#ifdef _RAND
	pParamArray.add doc_.afc.rap.param.new_date_range("Data sprzedaży").bindexpr("t_sprzed.dDataSprzed")
#endif	
	
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_field_first)
	<t size='3'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_field_second)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<tr fontsize='4'>
	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>

</tr>
<tr border='0'><td colspan='7' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)

dim curWalNetto : curWalNetto = ccur(0.0) 
dim curWalVat : curWalVat = ccur(0.0)  
dim curWalBrutto : curWalBrutto = ccur(0.0)  

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	
<td align='right'>RXE_LP</td>
	<td align='right'>
		RXE_DATE(c_data_sprzed)<t size='1'/> 
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_11,c_12,c_10)
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_4)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_13,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_15,"",2)
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(c_14,"",2)
	</td>
#ifdef _PRINTY_LAND	
	<td align='right'>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_11,c_12,c_extra1)
	</td>
#endif
#ifdef _IOW
<%if  cstr(pRec("c_wal_skrot")) <> "PLN" and ccur(pRec("c_suma_wal_brutto"))<>ccur(0.0) then
	if pRec("c_rej_typ")=2 or pRec("c_rej_typ")=4 or pRec("c_rej_typ")=6 or pRec("c_rej_typ")=36 or pRec("c_rej_typ")=51 or pRec("c_rej_typ")=60 then
		curWalNetto = ccur(pRec("c_13")) / ccur(pRec("c_kurs"))
		curWalVat = ccur(pRec("c_15")) / ccur(pRec("c_kurs"))
		curWalBrutto = ccur(pRec("c_suma_wal_brutto"))
	%>
		<td align='right'>
			RXE_QUANTITY_VVV(curWalNetto,cstr(pRec("c_wal_skrot")),2)
		</td>
		<td align='right'>
			RXE_QUANTITY_VVV(curWalVat,cstr(pRec("c_wal_skrot")),2)
		</td>	
		<td align='right'>
			RXE_QUANTITY_CCV(c_suma_wal_brutto,c_wal_skrot,2)
		</td>
		<%
		
	else
	%>
		
		<td align='right'>
			RXE_QUANTITY_CCV(c_suma_wal,c_wal_skrot,2)
		</td>
		<td align='right'>
			RXE_QUANTITY_CCV(c_suma_wal_vat,c_wal_skrot,2)
		</td>	
		<td align='right'>
			RXE_QUANTITY_CCV(c_suma_wal_brutto,c_wal_skrot,2)
		</td>
	<%
		curWalNetto = ccur(pRec("c_suma_wal"))
		curWalVat = ccur(pRec("c_suma_wal_vat"))
		curWalBrutto = ccur(pRec("c_suma_wal_brutto"))
	
	end if%>
<%else%>
	<td align='right'>
		<t></t>
	</td>
	<td align='right'>
		<t></t>
	</td>	
	<td align='right'>
		<t></t>
	</td>
<%end if%>

<%
		if  cstr(pRec("c_wal_skrot")) <> "PLN" then
		
			dim iterTabela
			dim iFoundIndex : iFoundIndex = -1
			for iterTabela = 0 to iTabelaItems
				if tabela(iterTabela,0) = clng(pRec("c_waluta")) then
					iFoundIndex = iterTabela
					exit for
				end if
			next
			if iFoundIndex = -1 then
				iFoundIndex = iTabelaItems
				iTabelaItems = iTabelaItems + 1
				tabela(iFoundIndex,0) = ccur(0.0)
			end if
			tabela(iFoundIndex,0) = clng(pRec("c_waluta"))
			tabela(iFoundIndex,1) = tabela(iFoundIndex,1) + curWalNetto
			tabela(iFoundIndex,2) = tabela(iFoundIndex,2) + curWalVat
			tabela(iFoundIndex,3) = tabela(iFoundIndex,3) + curWalBrutto
			tabela(iFoundIndex,4) = cstr(pRec("c_wal_skrot"))
		end if
%>


#endif	

</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<t><![CDATA[Data operacji]]></t>
	</td>
	<td width='max'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Klient]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość VAT]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Wartość brutto]]></text>
	</td>
#ifdef _IOW
	<td width='min'>
		<text><![CDATA[Wartość netto w walucie]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość VAT w walucie]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość brutto w walucie]]></text>
	</td>
#endif
#ifdef _PRINTY_LAND
	<td width='min'>
		<text><![CDATA[Status]]></text>
	</td>
#endif		
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
#ifdef _IOW	
	<td style='27' colspan='3' />
#endif
#ifdef _PRINTY_LAND
	<td style='27' />
#endif	
</tr>

#ifdef _IOW 
<%
dim iter : iter=0
for iter=0 to iTabelaItems - 1 
%>
<tr style='21'>
	<td style='27' colspan='3' >
		<t >Podsumowanie <%so.write tabela(iter,4)%></t>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>	
	<td style='27' align='right'>
		
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabela(iter,1))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabela(iter,2))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabela(iter,3))
	</td>
</tr>
<%
next
%>
#endif
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='6' bold='true'>Kryteria selekcji:</t><br/>
<%
  dim strIdRokKsieg: strIdRokKsieg = ""
#ifdef _ALMA_TREND
	strIdRokKsieg = doc_.getmodule(60106).GetIdRokKsieg()
#endif

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
.add_body_ex(getref("body_header"), getref("body_footer"), getref("body_row")).add_sumator("c_13").add_sumator("c_14").add_sumator("c_15")

#ifdef NXM_EXPERIMENTAL_SET_1
If .prepare4nxm("RAPORT_TITLE", default_param(), rapeng_.get_raport_param(), "e95251_sprzedaz_dokumenty") Then
#else
If .prepare("RAPORT_TITLE", default_param(), rapeng_.get_raport_param(), query()) Then
#endif

%>
<%
	.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=1"
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

%>
</body>
<footer>
</footer>
</page>
