<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZLECPROD_SUROWCE_SUMA
#include "h1000.h"
#include "h1200_typeid.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Rezerwacje wybranego produktu

#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		k.strIndeks
#define C_FIELD_SECOND_EXPR		k.strNazwa
#define C_FIELD_FIRST_HUMANNAME Indeks klienta
#define C_FIELD_SECOND_HUMANNAME Nazwa klienta
#else
#define C_FIELD_FIRST_EXPR		k.strNazwa
#define C_FIELD_SECOND_EXPR		k.strIndeks
#define C_FIELD_FIRST_HUMANNAME		Nazwa klienta
#define C_FIELD_SECOND_HUMANNAME	Indeks klienta
#endif
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim strWhere: strWhere = ""

#ifdef _ABAKUS
  dim pHARPage: set pHARPage = doc_.getmodule(60106)
  if pHARPage.FindRightFree(1) then  '1 = UAR_OGRANICZONY_DOSTEP_DANE_KLIENTA
    if trans_.isvar(113) then
      if trans_.var(113) = N5REJESTRDOK_OFERTY_WLASNE or trans_.var(113) = N5REJESTRDOK__ZAM_OBCE then
        strWhere = _
          "and k.IdObj in " + _
          "(select IdObj from n5klient where pPracownik in " + _
          "(select n5pracownik.idobj from n5uzytkownik " + _
          "inner join n5wykonawca on n5uzytkownik.pWykonawca = n5wykonawca.idobj " + _
          "inner join n5pracownik on n5wykonawca.wrefObiekt = n5pracownik.idobj and n5wykonawca.wrefObiekt_wrt = TYPEID_N5PRACOWNIK " + _
          "where n5uzytkownik.idobj = " + CStr(CLng(trans_.var(GVAR_USER))) + ")) "
      end if
    end if
  end if
#endif

query = " select 'c_ilosc_zam'=v.c_curiloscopak " +_
" -isnull((select max(vl.c_curiloscopak) from vlist_n5dokmag_listPozycje vl "+_
" where vl.p_ntypdok=46 and vl.p_pdokmag=v.p_idobj group by p_idobj),0) " +_
", 'strNrdok'=v.p_strnrdok, 'strNazKlienta'=C_FIELD_FIRST_EXPR,  " +_
" 'strIndeksKlienta'=C_FIELD_SECOND_EXPR, 'strNazProd'=p.strnazwa, 'strIndProd'=p.strIndeks, " +_
" 'd_wystRezerw'=v.p_ddatawyst,'d_rezerw'=v.p_ddatarezerw, 'liknDok'=10162, 'idobjmag'=v.p_idobj " +_
" from  vlist_n5dokmag_listPozycje v " +_
" inner join n5magazyn m on v.c_pMagZrod=m.idobj " +_
" inner join n5klient k on v.p_pKlient=k.idobj " +_
" inner join n5produkt p on v.c_pprodukt=p.idobj " +_
" where %1 and v.p_ntypdok=45 " + strWhere +_
" order by c_ilosc_zam desc "
end function

%>

<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("p.strIndeks")

	set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
dim bShow



bShow = true
if bShow then
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTO_TEXT(strNazKlienta)
	</td>
	<td>
		RXE_AUTO_TEXT(strIndeksKlienta)
	</td>
	<td>
		RXE_AUTO_TEXT(strNazProd)
	</td>
	<td>
		RXE_AUTO_TEXT(strIndProd)
	</td>
	<td>
	RXE_AUTOTEXT_LINK_FORM_CCC(liknDok,idobjmag,strNrdok)
	</td>
	<td align='right'>
		RXE_AUTO_TEXT(c_ilosc_zam)
	</td>
	<td>
		RXE_DATE(d_wystRezerw)
	</td>
	<td>
		RXE_DATE(d_rezerw)
	</td>
</tr><%
end if
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Nazwa produktu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość zarezerwowana]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data rezerwacji]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>

<tfoot>
<tr style='21' colspan='3'>
	<td style='27'/>
	<td style='27'/>
	<td style='27'/>
	<td style='27'/>
	<td style='27'/>
	<td style='27'/>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27'/>
	<td style='27' colspan='3' />
</tr>
</tfoot>

</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_ilosc_zam")


if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
