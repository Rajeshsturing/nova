		<t><![CDATA[<% if arrValues(iIter,1)<> 0 then so.write trans_.getobj(TYPEID_N5JEDNOSTKA,arrValues(iIter,1)).strSkrot %>]]></t>
  </td>
	<td style='27' colspan='2' />
</tr>
<%
end if
next
