<%
'================================================================================================================== 

dim g_dtStart
function body_row(byref pSection, byref pRec)
  dim iIter
  set pDowodKsiegowy = trans_.getobj(TYPEID_N5DOWODKSIEG,clng(pRec("c_idDowod")))
  dim bBefore : bBefore = pDowodKsiegowy.dDataKsieg < g_dtStart
  dim bAfter : bAfter = pDowodKsiegowy.dDataKsieg > pParamArray.value(0).last_value
  
  reset_value_column COL_DOW_WN
  reset_value_column COL_DOW_MA

  if (not bBefore and not bAfter) then
    if not g_bWasSomethingInRej then
      %>
      <tr>
  <td bordercolor='transparent' width='min'>
    <t>&nbsp;</t>
  </td>
  <td style='27'/>
  <td style='27' colspan='1'>
    <text>Przed okresem:</text>
  </td>
  <td style='27' align='right'>
    RXE_MONEY_VAR(arrValues(1,COL_RUNNING_WN))
  </td>
  <td style='27' align='right'>
    RXE_MONEY_VAR(arrValues(1,COL_RUNNING_MA))
  </td>
  <td style='27'>
    <t><![CDATA[<% if arrValues(1,1)<> 0 then so.write trans_.getobj(TYPEID_N5JEDNOSTKA,arrValues(1,1)).strSkrot %>]]></t>
  </td>
  <td style='27' colspan='2'>
    <%
    if arrValues(1,COL_RUNNING_WN) <> arrValues(1,COL_RUNNING_MA) then
      %>
      <t bold='true' forecolor='red'>&nbsp; Dziennik nie bilansuje się !</t>
    <% 
      end if
    %>
  </td>
</tr> 
<%
  iIter = iIter + 1
  do while arrValues(iIter,COL_RUNNING_WN) <> 0 or arrValues(iIter,COL_RUNNING_MA) <> 0
%>
<tr>
    <td bordercolor='transparent' width='min'>
      <t>&nbsp;</t>
    </td>
    <td style='27' colspan='2' />
      <td style='27' align='right'>
        RXE_MONEY_VAR(arrValues(iIter, COL_RUNNING_WN))
      </td>
      <td style='27' align='right'>
        RXE_MONEY_VAR(arrValues(iIter, COL_RUNNING_MA))
      </td>
      <td style='27'>
        <t><![CDATA[<% if arrValues(iIter,1)<> 0 then so.write trans_.getobj(TYPEID_N5JEDNOSTKA,arrValues(iIter,1)).strSkrot %>]]></t>
      </td>
      <td style='27' colspan='2' />
    </tr>      
<%
    iIter = iIter + 1
  loop
   iIter = 1
%>  
      <%
      g_bWasSomethingInRej = true
    end if
    dowod_section_header 
  end if
  dim oDekret
  dim iLP
  iLP =clng(1)
  for each oDekret in pDowodKsiegowy.listDekret
        
  if (not bBefore and not bAfter) then
  %>
  <tr bordercolor='transparent'
  >
  <td bordercolor='transparent' width='min'>
    <t>&nbsp;</t>
  </td>
  <td align='right' width='min'>
    <t><%so.write cstr(iLP)%></t></td>
  <td>
    <t><%so.write oDekret.pKonto.strSymbol%></t>
  </td>
  <td align='right'>
    RXE_MONEY_VAR(oDekret.curWn)
  </td>
  <td align='right'>
    RXE_MONEY_VAR(oDekret.curMa)
  </td>
  <td>
    <text><![CDATA[<%so.write oDekret.pKonto.pJednostka.strSkrot%>]]></text>
  </td>
  <td>
    <text><![CDATA[<%so.write oDekret.strOpis%>]]></text>
  </td>
  <td>
    <text><![CDATA[<%if not oDekret.pTransakcja is nothing then so.write oDekret.pTransakcja.strSymTrans%>]]></text>
  </td>
</tr>
<%
  end if

  iLP = iLP + 1

    update_column oDekret.pKonto.pJednostka.IdObj, COL_RUNNING_WN, oDekret.curWn
    update_column oDekret.pKonto.pJednostka.IdObj, COL_RUNNING_MA, oDekret.curMa
  
  if (not bBefore and not bAfter) then
      update_column oDekret.pKonto.pJednostka.IdObj, COL_DOW_WN, oDekret.curWn
      update_column oDekret.pKonto.pJednostka.IdObj, COL_DOW_MA, oDekret.curMa
      update_column oDekret.pKonto.pJednostka.IdObj, COL_SUMA_WN, oDekret.curWn
      update_column oDekret.pKonto.pJednostka.IdObj, COL_SUMA_MA, oDekret.curMa
  end if

  next
  if (not bBefore and not bAfter) then
    dowod_section_footer
  end if
exit function
%>

  <tr userprop='
	vc1=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(0))%>
	vc2=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(1))%>
	vc3=<%so.write doc_.afc.convert.cur2sql(ArrCurGlobSum(0))%>
	vc4=<%so.write doc_.afc.convert.cur2sql(ArrCurGlobSum(1))%>
	%>'  
	<% if pRapExec.RecNr mod 2 = 0 then %>
    bordercolor='white'
	<% else %>
    bordercolor='white' style='37'
  <% end if %>
  >
  
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td align='right'>
		RXE_T(c_4)
	</td>
	<td>
		RXE_AUTO_TEXT(c_5)
	</td>
	<td align='right'>
		RXE_MONEY_VAR(ArrCurBodyVal(0))
	</td>
	<td align='right'>
		RXE_MONEY_VAR(ArrCurBodyVal(1))
	</td>
	<td>
		RXE_AUTO_TEXT(c_8)
	</td>
</tr><%
end function
