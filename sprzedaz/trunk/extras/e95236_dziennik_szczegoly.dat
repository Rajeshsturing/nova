	<td style='27' colspan='2' />
  <td style='27' colspan='2'>
    <text>Narastająco dziennik:</text>
  </td>
	<td style='27' colspan='3' />
</tr>
<%
for iIter = 1 to UNIT_COUNT
  if arrValues(iIter, 1) <> 0 then
%>
<tr>
	<td style='27' colspan='3' />
  <td style='27' align='right'>
    RXE_MONEY_VAR(arrValues(iIter, COL_RUNNING_WN))
  </td>
	<td style='27' align='right'>
