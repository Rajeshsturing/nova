</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>

<p><br/><br/><br/><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
init_array

dim strSubQuery: strSubQuery ="%3 and %4"

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("rejestr_section_header"),getref("rejestr_section_footer")
	
	set pParamArray = default_param()
	rapeng_.merge_params pParamArray, rapeng_.get_raport_param()
	pRapExec.title = "RAPORT_TITLE"  
  
  if rapeng_.show_raport_param_dialog(pParamArray,"RAPORT_TITLE") <> 0 then
    'ograniczenie do biezacego roku ksiegowego
    pParamArray.value(0).get_where_part trans_

    if pParamArray.value(0).first_value = trans_.afc.globals.nulldate() then
    pParamArray.value(0).first_value = getCurrentRKS().dDataRozp
    end if
    if pParamArray.value(0).last_value = trans_.afc.globals.nulldate() then
    pParamArray.value(0).last_value = getCurrentRKS().dDataZakon
    end if

    g_dtStart = pParamArray.value(0).first_value
    pParamArray.value(0).mode = 7
    pParamArray.value(0).first_value = getCurrentRKS().dDataRozp

    .put_final_query query(pParamArray)
    rapeng_.set_raport_param pParamArray
    strSubQuery = rapeng_.query_apply_actual_param(strSubQuery, pParamArray)
    %>
    <%

 ' trans_.message 0,0, cstr(pParamArray.value(0).first_value) + "/"+cstr(pParamArray.value(0).last_value)

  pParamArray.value(0).first_value = g_dtStart
  rapeng_.write_actual_param so, rapeng_.get_raport_param()
  
  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	    end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
