<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Dziennik (szczegóły)

#define CTRLID_MAINTABLE				101

#define UNIT_COUNT      10

#define COL_DOW_WN      3
#define COL_DOW_MA      4
#define COL_RUNNING_WN   5
#define COL_RUNNING_MA   6
#define COL_SUMA_WN     7
#define COL_SUMA_MA     8

#define COUNTERS_COUNT	2

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

VB_PRINT_PORTRAIT_COMMON
VB_PRINTPREV_PORTRAIT_COMMON

function c##CTRLID_MAINTABLE##_on_table_split(byref pClonedTable,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	if yAreaY <> yCount then
	dim oTB : set oTB = doc_.afc.new_tb(page_).attach(pClonedTable).section_foot
		oTB.removeall
		dim curArr(COUNTERS_COUNT)
		dim iter
		
		for iter = 1 to COUNTERS_COUNT
			curArr(iter) = ccur(0.0)
		next
    
		dim pRow 
		dim curSumaWartoscNaStronie : curSumaWartoscNaStronie = ccur(0.0)
		dim i:i = 1
		for each pRow in pClonedTable.body
		if not pRow.userprop is nothing then
			for iter = 1 to COUNTERS_COUNT
				if pRow.userprop.exists(iter) then
					curArr(iter) = curArr(iter) + ccur(pRow.userprop(iter)) 
				end if
			next
			i = i + 1
		end if
		next
    
    exit function

		'podsumowanie na stronie
		with oTB.newrow.row
			.border = 0
			.bold = true
		end with
		oTB.newcell
		oTB.cell.colspan = 2
		oTB.newcell.addtext "Na stronie"
		oTB.cell.colspan = 2
		
  
		dim pLastRowUserProp : set pLastRowUserProp = pClonedTable.body.row(pClonedTable.body.count).userprop
		dim licznik: licznik = pClonedTable.body.count
		do while licznik > 0
			if not pLastRowUserProp is nothing then
				if not pLastRowUserProp.exists(100) then
					exit do
				end if  
			end if
			licznik = licznik - 1    
			set pLastRowUserProp = pClonedTable.body.row(licznik).userprop
		loop    
		
		for iter = 1 to COUNTERS_COUNT
			oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
		next
		oTB.newcell.addtext("")
    
		'posumowanie narastajaco
		with oTB.newrow.row
			.border = 0
			.bold = true
		end with
		oTB.newcell
		oTB.cell.colspan = 2
		oTB.newcell.addtext "Całość Narastająco"
		oTB.cell.colspan = 2
	
		for iter = 1 to COUNTERS_COUNT
			oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + 2)))).cell.align=ALIGN_RIGHT
		next
    oTB.newcell.addtext("")
	end if
end function

function on_page_split(byref pClonedPage,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	pClonedPage.footer.removeall
	dim strText
	if yCount > 1 then
		strText = page_.topelement.title + " - strona " + cstr(yAreaY) + " z " + cstr(yCount) 
	end if
	pClonedPage.footer.addnew(0,-1).text = strText
end function

<%
'pobiera IdObj roku księgowego
function getCurrentRKSId()
	if trans_.isvar(GVAR_ROKKSIEG) then
		getCurrentRKSId = trans_.var(GVAR_ROKKSIEG)
	else
		getCurrentRKSId = 0
	end if
end function

'pobiera aktualny rok księgowy
function getCurrentRKS()
	set getCurrentRKS = nothing
	dim id:id = getCurrentRKSId
	if id > 0 then
		set getCurrentRKS = trans_.getobj(TYPEID_N5ROKKSIEG,id)
	end if
end function

dim arrValues(UNIT_COUNT, 10)

sub init_array
  dim iIter
  for iIter = 1 to UNIT_COUNT
    arrValues(iIter, 1) = clng(0)
  next
end sub

sub reset_value_column(iColumn)
  dim iIter
  for iIter = 1 to UNIT_COUNT
    arrValues(iIter, iColumn) = ccur(0.0)
  next
end sub

sub update_column(iUnit, iColumn, curValue)
  dim iIter
  for iIter = 1 to UNIT_COUNT
    if arrValues(iIter, 1) = iUnit then
      arrValues(iIter, iColumn) = arrValues(iIter, iColumn) + ccur(curValue)
      exit sub
    end if
    if arrValues(iIter, 1) = 0 then
      arrValues(iIter, 1) = iUnit
      arrValues(iIter, iColumn) = ccur(curValue)
      exit sub
    end if
  next  
end sub

dim pParamArray

function query(pParamArray)
query = "select 'c_rej_nazwa'=t_rejdok.strNazwa,'c_nrdow'=t_dowod.nNumDow,'c_idDowod'=t_dowod.IdObj " +_
"from n5dowodksieg as t_dowod inner join n5rejestrdok as t_rejdok on t_dowod.pRejestrDok = t_rejdok.IdObj " +_
"where  %1  and  %2  and  %3  and  %4  " +_
"order by c_rej_nazwa,c_nrdow"
query = rapeng_.query_apply_actual_param(query, pParamArray)
end function
%>
<%
'================================================================================================================== 

function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data księgowania").bindexpr("t_dowod.dDataKsieg")

	dim pParamFactory4: set pParamFactory4= doc_.afc.rap.param
	dim pParam4: Set pParam4= pParamFactory4.new_choice("Dziennik").bindexpr("t_rejdok.idobj")
	doc_.afc.rap.param.init_on_query pParam4, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DZIENNIK_NORM,N5REJESTRDOK_DZIENNIK_BO, " +_
		"N5REJESTRDOK_DZIENNIK_BZ,N5REJESTRDOK_DZIENNIK_BZ_OSTAT) and pRokKsieg=" + cstr(trans_.var(8011)) + "  order by strNazwa "
	pParamArray.add pParam4

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ zapisu").bindexpr("t_dowod.eTyp")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5DEKRET,"eTyp"
	pParamArray.add pParam2
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Status").bindexpr("t_dowod.eStatus")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5DEKRET,"eStatus"
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
