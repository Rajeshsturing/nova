<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE #*vs1
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim g_pUtilModule : set g_pUtilModule = doc_.getmodule(60158)

function query()
  dim strSubQuery : strSubQuery = ""
  dim strOrderBy : strOrderBy = ""

if trans_.isvar(3) then
  strSubQuery = "select 'c_datarozp'=t_zadanie.dDataTerminRozp,'c_czasrozp'=t_zadanie.tCzasTerminRozp, " +_
                "'c_0'=t_1.strIndeks,'c_status'=t_zadanie.nStatus,'c_2'=t_zadanie.dDataZlec,'c_3'=t_zadanie.tCzasZlec, "
  strOrderBy = "and %3 order by c_datarozp,c_czasrozp,c_0"              
else
#ifdef APPCONFIG_PROTOKOLY
  strSubQuery = "select 'c_0'=t_1.strIndeks,'c_status'=t_zadanie.nStatus,'c_2'=t_zadanie.dDataZlec,'c_3'=t_zadanie.tCzasZlec," +_
                "'c_datarozp'=t_zadanie.dDataTerminRozp,'c_czasrozp'=t_zadanie.tCzasTerminRozp, "
  strOrderBy = "and %3 order by c_0,c_datarozp,c_czasrozp" 
#else
  strSubQuery = "select 'c_0'=t_1.strIndeks,'c_status'=t_zadanie.nStatus,'c_2'=t_zadanie.dDataZlec,'c_3'=t_zadanie.tCzasZlec,"
  strOrderBy = "order by c_0,c_2,c_3"
#endif  
end if

query = strSubQuery +_
"'c_4'=t_zadanie.eTypterminZak,'c_5'=t_zadanie.strTemat,'c_6'=10119,'c_zadanie_idobj'=t_zadanie.IdObj,'c_8'=t_2.strIndeks," +_
"'c_klient_nazwa'=isnull(t_3.strNazwa,''),'c_klient_idobj'=isnull(t_3.IdObj,0),'c_nazwa_td'=t_td.strNazwa " +_
"from n5zadanie as t_zadanie inner join n5wykonawca as t_1 on t_zadanie.pWykonawca = t_1.IdObj " +_
"inner join n5wykonawca as t_2 on t_zadanie.pZlecajacy = t_2.IdObj " +_
"inner join n5typdzialania as t_td on t_zadanie.pTypDzialania = t_td.IdObj " +_
"left outer join n5klient as t_3 on t_zadanie.pKlient = t_3.IdObj " +_
"where  %1 and %2 and nStatus between N5ZADANIE_ZLECONE and N5ZADANIE_ZAKONCZONE " +_
strOrderBy

end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Indeks wykonawcy").bindexpr("t_1.strIndeks")

	dim pExtraParam : set pExtraParam = doc_.afc.rap.param.new_filter("Extra")
	pExtraParam.set_where_part "(1=1)"
	pParamArray.add pExtraParam
  
#ifdef APPCONFIG_PROTOKOLY
  pParamArray.add doc_.afc.rap.param.new_date_range("Data realizacji").bindexpr("t_zadanie.dDataTerminRozp")
#endif

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
#ifdef APPCONFIG_PROTOKOLY
	<td style='27' colspan='10'>
#else
	<td style='27' colspan='9'>
#endif  
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
<% if trans_.isvar(3) then %>
		RXE_DATE(c_datarozp)
		<t size='1' />
		RXE_TIME(c_czasrozp)
<% else %>
  RXE_AUTO_TEXT(c_0)
<% end if %>  
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
<% if trans_.isvar(3) then %>
	<td keepline='true'>
		RXE_AUTO_TEXT(c_0)
	</td>   
<% end if %>
	<td keepline='true'>
		<picture width='SIZE_FOR_12PX' height='SIZE_FOR_12PX' image='<%so.write g_pUtilModule.get_status_pic(pRec("c_status"))%>' />
		<t><% so.write g_pUtilModule.get_status_name(pRec("c_status"))%></t>
	</td>
	<td keepline='true'>
		RXE_DATE(c_2)
		<t size='1' />
		RXE_TIME(c_3)
	</td>
#ifdef APPCONFIG_PROTOKOLY
<% if not trans_.isvar(3) then %>
	<td keepline='true'>
		RXE_DATE(c_datarozp)
		<t size='1' />
		RXE_TIME(c_czasrozp)
	</td>
<% end if %>  
#endif
	<td>
		<text><% so.write trans_.getobj(TYPEID_N5ZADANIE,clng(pRec("c_zadanie_idobj"))).n5zadanie_get_termin_zakon_desc() %></text>
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_6,c_zadanie_idobj,c_5)
	</td>
	<td>
		RXE_AUTO_TEXT(c_nazwa_td)
	</td>
	<td>
		RXE_AUTO_TEXT(c_8)
	</td>
	<td>
		<%
		if clng(pRec("c_klient_idobj")) <> 0 then 
		%>
			RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,c_klient_idobj,c_klient_nazwa)
		<%
		end if
		%>
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
<% if trans_.isvar(3) then %>
	<td width='min'>
		<text><![CDATA[Wykonawca]]></text>
	</td>   
<% end if %>
	<td width='min'>
		<text><![CDATA[Status zadania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data zlecenia]]></text>
	</td>
#ifdef APPCONFIG_PROTOKOLY
<% if not trans_.isvar(3) then %>
	<td width='min'>
		<text><![CDATA[Data realizacji]]></text>
	</td>
<% end if %>  
#endif
	<td width='min'>
		<text><![CDATA[Termin rozpoczęcia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Temat]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Typ zadania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Zlecający]]></text>
	</td>
	<td width='5000'>
		<text><![CDATA[Klient]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
