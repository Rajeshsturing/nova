<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_PLATNOSCI_SZCZEGOLY
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Lista płatności - szczegóły
#define FULL_SPAN	9
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim strWalPodm : strWalPodm = ""

#ifdef _UNIPLAST
'zmienia znak kwoty na dodatni
function changeZnak(byval curWart)
	if curWart < ccur(0) then
		curWart = curWart * (-1)
	end if
	changeZnak = curWart
end function
#endif
%>
<%
function query()
query = "select 'c_nazwa_rej'=t_rej.strNazwa,'c_numop'=t_plat.p_nNumOper,'c_nrdok'=t_plat.p_strNrDok,'c_dataop'=t_plat.p_dDataOper, " +_
"'c_kwotapodm'=t_plat.c_curPozKwotaPodm,'c_kwotastan'=t_plat.c_curPozKwotaTrans,'c_kwotaewid'=t_plat.c_curPozKwotaEwid, " +_
"'c_nazwa'= CASE t_plat.p_wrefPodmiot_wrt WHEN TYPEID_N5KLIENT THEN t_klient.strNazwa WHEN TYPEID_N5PRACOWNIK THEN t_prac.strNazwisko  " +_
"WHEN TYPEID_N5INSTYTUCJA THEN t_inst.strNazwa WHEN TYPEID_N5BANK THEN t_bank.strNazwa " +_
"WHEN TYPEID_N5FIRMA THEN t_firma.strSkrot ELSE '' END , " +_
"'c_podmiot_type'= t_plat.p_wrefPodmiot_wrt, " +_
"'c_podmiot_idobj'= t_plat.p_wrefPodmiot,'c_opis'=t_plat.p_strOpis, " +_
"'c_plat_idobj'=t_plat.p_IdObj,'c_symbtran'=t_trans.strSymTrans,'c_trans_idobj'=t_trans.idobj, " +_ 
"'c_walrej'=t_walrej.strSkrot,'c_prec'=3,'c_walpodm'=t_walpodm.strSkrot,'c_waltrans'=t_waltrans.strSkrot " +_
"from vlist_n5platnosc_listpozycje as t_plat  " +_
"left outer join n5klient as t_klient on t_plat.p_wrefPodmiot = t_klient.IdObj AND t_plat.p_wrefPodmiot_wrt = TYPEID_N5KLIENT  " +_
"left outer join n5pracownik as t_prac on t_plat.p_wrefPodmiot = t_prac.IdObj AND t_plat.p_wrefPodmiot_wrt = TYPEID_N5PRACOWNIK  " +_
"left outer join n5instytucja as t_inst on t_plat.p_wrefPodmiot = t_inst.IdObj AND t_plat.p_wrefPodmiot_wrt = TYPEID_N5INSTYTUCJA  " +_
"left outer join n5bank as t_bank on t_plat.p_wrefPodmiot = t_bank.IdObj AND t_plat.p_wrefPodmiot_wrt = TYPEID_N5BANK  " +_
"left outer join n5firma as t_firma on t_plat.p_wrefPodmiot = t_firma.IdObj AND t_plat.p_wrefPodmiot_wrt = TYPEID_N5FIRMA " +_
"inner join n5rejestrdok as t_rej on t_plat.p_pRejestrDok = t_rej.IdObj  " +_
"inner join n5transakcja as t_trans on t_plat.c_pTransakcja = t_trans.IdObj  " +_
"inner join n5jednostka as t_walrej on t_rej.wrefParam1 = t_walrej.IdObj  " +_
"inner join n5jednostka as t_walpodm on t_plat.p_pWalutaPodm = t_walpodm.IdObj  " +_
"inner join n5jednostka as t_waltrans on t_trans.pWaluta = t_waltrans.IdObj  " +_
"where  %1  and  (%2  or  %3  or  %4  or  %5 or (t_firma.strNazwa is not null) or EXTRA_CUSTOMER_FILTER_AND(8)) and  %6 and %7 "+_
"order by c_nazwa_rej,c_numop"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data operacji").bindexpr("t_plat.p_dDataOper")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_klient.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko pracownika").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa instytucji").bindexpr("t_inst.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa banku").bindexpr("t_bank.strNazwa")
	
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Rejestr").bindexpr("t_rej.idobj")
	doc_.afc.rap.param.init_on_query pParam3, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_KASOWY,N5REJESTRDOK_BANKOWY) order by strNazwa "
	pParamArray.add pParam3

	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Status").bindexpr("t_plat.p_eStatus")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5PLATNOSC, "eStatus"
	pParamArray.add pParam2
	EXTRA_CUSTOMER_FILTER_PARAM(t_klient)

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
if pActualParam.value(iter).get_desc() <> "" then 
bAnyWritten = true
	so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='4'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%>

<%
function actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then    
for iter = 1 to 4 'parametry dot. pracownika, firmy, instyt, itp
if pActualParam.value(iter).get_desc() <> "" then 
	bAnyWritten = true
end if
next
end if
if pActualParam.upperIndex >= 7 then
 if pActualParam.value(7).get_desc() <> "" then 'kod pocztowy
	bAnyWritten = true
 end if
end if

if not bAnyWritten then 
	actual_param = 0
else 
	actual_param = 1
end if

end function
%>
<%
function actual_param_date(byref pActualParam)
dim iter
if not pActualParam is nothing then
if pActualParam.value(0).get_desc() <> "" then 
	actual_param_date = 1
else 
	actual_param_date = 0
end if
end if
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='FULL_SPAN'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_nazwa_rej)
	<t size='2' />
	RXE_T(c_walrej)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<!--
<tr fontsize='5'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
	</td>
	<td style='27' colspan='4' />
</tr>
<tr border='0'><td colspan='FULL_SPAN' /></tr>
-->
<tr hide='true' userprop='propc_section_end="1"'><td colspan='FULL_SPAN' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
strWalPodm = cstr(pRec("c_walpodm"))
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PLATNOSC,c_plat_idobj,c_nrdok)
	<t size='2' />
	RXE_AUTOTEXT_LINK_FORM_CCC(c_podmiot_type,c_podmiot_idobj,c_nazwa)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
#ifdef _UNIPLAST
		<t><%so.write doc_.afc.display.money(changeZnak(pSection.counter(0).result),strWalPodm)%></t>
#else
		<t><%so.write doc_.afc.display.money(pSection.counter(0).result,strWalPodm)%></t>
#endif    
	</td>
	<td style='27' colspan='3' />
</tr>
<tr border='0'><td colspan='FULL_SPAN' /></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='FULL_SPAN' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>

<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_dataop)
	</td>
#ifdef _UNIPLAST
	<td align='right'>
		RXE_QUANTITY_VCC(changeZnak(ccur(pRec("c_kwotapodm").value)),c_walpodm,c_prec)
	</td>
	<td align='right'>
		RXE_QUANTITY_VCC(changeZnak(ccur(pRec("c_kwotastan").value)),c_waltrans,c_prec)
	</td>
	<td align='right'>
		RXE_QUANTITY_VVV(changeZnak(ccur(pRec("c_kwotaewid").value)),"",2)
	</td>  
#else
	<td align='right'>
		RXE_QUANTITY_CCC(c_kwotapodm,c_walpodm,c_prec)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_kwotastan,c_waltrans,c_prec)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_kwotaewid,"",2)
	</td>
#endif  
	<td>
		RXE_AUTO_TEXT(c_opis)
	</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5TRANSAKCJA,c_trans_idobj,c_symbtran)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
'so.write "<p backcolor='yellow'><text><![CD"+"ATA["+pRapExec.get_final_query() + "]"+"]></text></p><br/>" 
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data operacji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota od/dla podmiotu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota uznania / obciążenia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota zarach.]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Opis]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Symbol transakcji]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<!--
<tr style='21'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
	</td>
	<td style='27' colspan='4' />
</tr>
-->
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("c_kwotapodm")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	if actual_param(rapeng_.get_raport_param()) <> 0 then 
		.ReplaceQueryParam "t_klient.strNazwa is not null", "1=0"
		.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=0"
		.ReplaceQueryParam "t_inst.strNazwa is not null", "1=0"
		.ReplaceQueryParam "t_bank.strNazwa is not null", "1=0"
		.ReplaceQueryParam "t_firma.strNazwa is not null", "1=0"
		if APPCONFIG_EXTRA_CUSTOMER_FILTER = 1 then
			.ReplaceQueryParam "isnull(t_klient.strKod,'') is not null", "2=0"
		end if
		if APPCONFIG_EXTRA_CUSTOMER_FILTER = 0 then 
			.ReplaceQueryParam "or (1=1))", "or (1=0))"
		end if	

	end if

	write_actual_param rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>