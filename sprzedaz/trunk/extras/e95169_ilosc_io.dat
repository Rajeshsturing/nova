<?xml version="1.0" encoding="windows-1250" ?>

<!-- Wydanie zewnetrzne v2 - tylko ilosc + indeksy obce-->
<!-- 8.06.2004 - poprawka adresy-->
<!-- 21.06.2004 adnotacje -->
<!-- 19.05.2005 indeksy obce -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


#define DOSTAWCA_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define DOSTAWCA_NIP					<% so.write util_.Klient_NIP(root_.pKlient) %>
#define DOSTAWCA_KOD_MIASTO1				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta end if end if%>
#define DOSTAWCA_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define DOSTAWCA_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define DOSTAWCA_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define JEDNOSTKA_ORG_NAZWA				<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define JEDNOSTKA_ORG_KOD_MIASTO		<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define JEDNOSTKA_ORG_ULICA_NUMER		<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define DOSTAWCA_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>

#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_ZAKUPU			<% if not root_.wrefDokHandl is nothing then so.write doc_.afc.display.fulldate(root_.wrefDokHandl.dDataZakupu) end if  %>
#define DOKUMENT_KWOTA					<% so.write MONEY(root_.curKwota) %>
#define DOKUMENT_KWOTA_SLOWNIE			<% so.write doc_.afc.display.slownie(root_.curKwota) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_MAGAZYN				<% if not root_.pMagZrod is nothing then so.write root_.pMagZrod.text end if%>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi%>

#define DOKUMENT_OBCY_NR				<% if not root_.wrefDokHandl is nothing then so.write "Do: " + root_.wrefDokHandl.strNrDok end if  %>

#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_ILOSC						<% if pozycja.pOpak.pJednOpak.strSkrot="100" then so.write  doc_.afc.display.quantity(pozycja.curIloscOpak*100,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) else so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) end if%>
#define POZ_JM							<% if pozycja.pOpak.pJednOpak.strSkrot="100" then so.write "szt."else so.write pozycja.pOpak.pJednOpak.strSkrot end if %>

#define POZ_TOWAR_RS					<% so.write cstr(rs.fields("klpr_strNazwa").value) %>
#define POZ_IDX_RS						<% so.write cstr(rs.fields("klpr_strIndeks").value)%>





<page style='36' margins='500,500,500,500'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>	
</config>
<header>

</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table>
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>								
						
						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Wydanie zewnętrzne (WZ) nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>

						<tr>
							<td align='center' colspan='2'>
								<t><![CDATA[DOKUMENT_OBCY_NR]]></t>
							</td>
						</tr>

					</tbody>
				</table>
			</td>
		</tr>
		<tr>
			<td>
				<table>
					<tbody>																		
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td valign='bottom'>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>						
						</tr>

						ROW_SEPARATOR(2)	
						
						<% if not root_.pKlient_JO is nothing then %>
						<!-- jednostka organizacyjna klienta-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>

						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[JEDNOSTKA_ORG_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_ULICA_NUMER]]></t>
							</td>							
						</tr>
						
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<!-- /jednostka organizacyjna klienta-->
						<% else %>
						<% if not root_.pKlient is nothing then %>
						
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<% else %>				
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								Brak danych
							</td>						
						</tr>
						<% end if %>
						<% end if %>

						
						ROW_SEPARATOR(2)
						<tr>
							<td width='min'>
								<t bold='true'>Data wystawienia:</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>						
						</tr>

						<tr>
							<td width='min'>
								<t bold='true'>Magazyn</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_MAGAZYN]]></t>
							</td>						
						</tr>


						ROW_SEPARATOR(2)
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa towaru / usługi</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>																	
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
						</tr>
					</thead>
						
					<tbody>
						<%	
						dim rs

						if doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
							dim iter,pozycja
							iter = 1
							for each pozycja in root_.listPozycje 

								set rs = trans_.createadors("select * from n5produkt t_prod "+_
								"right join n5klient_produkt t_klpr on t_prod.idObj = t_klpr.klpr_Pprodukt "+_
								" join n5jednostka on t_prod.pJednostkaEwid = n5jednostka.idobj "+_
								" where t_prod.idobj="+ cstr(pozycja.pprodukt.idobj) +_
								" and t_klpr.klpr_pklient= "+cstr(root_.pklient.idobj))


								if not rs is nothing then 
								if not rs.eof then 
								if not isNull(rs(0)) then



						%>
						<tr>
							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX_RS]]></text>
							</td>	
							<%
								'end if 'if not rs is nothing then 
								end if
								
								else 
								%>
						<tr>
							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>	
							
							<%
								end if
								end if%> 
											
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_JM]]></text>
							</td>					
						</tr>
						<%		iter = iter + 1
							next
						else
						%>
						<tr border='1' fontsize='5' forecolor='red' bold='true'><td><t>Uwaga! Niepoprawny stan magazynu</t></td></tr>
						
						<% end if %>
						
					</tbody>
				</table>
			</td>
		</tr>
		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)

		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<t><![CDATA[DOKUMENT_UWAGI]]></t>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>							
							<td colspan='2'>	
								
							</td>							
							
						</tr>
						<tr>
							<td align='center'>	
								<t>................................................................</t>
							</td>							
							<td align='center'>	
								<t>...........................................................</t>
							</td>		
							<td align='center'>	
								<t>...........................................................</t>
							</td>		
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby wystawiającej dokument</t>
							</td>							
							<td align='center'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby wydającej towar</t>
							</td>							
							<td align='center'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby odbierającej towar</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
