<?xml version="1.0" encoding="windows-1250" ?>
<!--

RAPTEMPLATE_PLACE_NIEOB_WSZYSTKIE

#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Wszystkie nieobecności

#macro RXE_PRACOWNIK_TEXT(_nazwisko_,_imie_,_pesel_)	<% so.write "<t><![CD"+"ATA["+ cstr(pRec("_nazwisko_")) + " " + cstr(pRec("_imie_")) + " ("+cstr(pRec("_pesel_"))+")" + "]"+"]></t>" %>
#macro RXE_AUTO_TEXT_RODZAJ(_val_col_)                <% so.write "<t><![CDA"+"TA["+ strRodzaj(cstr(pRec("_val_col_"))) + "]"+"]></t>" %>

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

function strRodzaj(byval strNr) : strRodzaj = ""
  if strNr = "1" then
    strRodzaj = "Choroba"
  else
    strRodzaj = "Nieobecność"
  end if
end function

function query()
query = "select 'p_nazwisko'=p.strNazwisko, 'p_imie'=p.strImie, 'p_pesel'=p.strPesel, " + vbNewLine +_ 
        "'p_idobj'=max(p.idobj),'n_dni'= sum(1 + datediff(day,n.dDataOd,n.dDataDo)),'n_rodzaj'=1 " + vbNewLine +_
        "from n5plchoroba as n " + vbNewLine +_ 
        "inner join n5pracownik as p on n.pPracownik = p.IdObj " + vbNewLine +_  
        "where %1 and %2 and %3 and [CHOROBA%5] " + vbNewLine +_  
        "group by p.strNazwisko, p.strImie, p.strPesel " + vbNewLine +_
        "union all " + vbNewLine +_
        "select 'p_nazwisko'=p.strNazwisko, 'p_imie'=p.strImie, 'p_pesel'=p.strPesel, " + vbNewLine +_ 
        "'p_idobj'=max(p.idobj),'n_dni'= sum(1 + datediff(day,n.dDataOd,n.dDataDo)),'n_rodzaj'=2 " + vbNewLine +_ 
        "from n5plnieob as n " + vbNewLine +_ 
        "inner join n5pracownik as p on n.pPracownik = p.IdObj " + vbNewLine +_ 
        "where %1 and %2 and %3 and %4 and [NIEOB%5] " + vbNewLine +_
        "group by p.strNazwisko , p.strImie , p.strPesel " + vbNewLine +_ 
        "order by p_nazwisko,p_imie,p.strPesel"

end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("p.strNazwisko")
  pParamArray.add doc_.afc.rap.param.new_text("Imię").bindexpr("p.strImie")
	pParamArray.add doc_.afc.rap.param.new_date_range("Analizowany okres").bindexpr("n.dDataRej")
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Typ nieobecności").bindexpr("n.eTyp")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5PLNIEOB,"eTyp"
	pParamArray.add pParam2
  'rodzaj => choroba/nieobecność
  dim pParamRodzaj : set pParamRodzaj = doc_.afc.rap.param.new_choice("Rodzaj")
  with pParamRodzaj
	  .multiple = true
    .names.add "Choroba"
    .values.add 1
    .selected.add true
    .names.add "Nieobecność"
    .values.add 2
    .selected.add true    
  end with  
  pParamArray.add pParamRodzaj  

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='4'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	    RXE_PRACOWNIK_TEXT(p_nazwisko,p_imie,p_pesel)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr style='21' userprop='propc_section_end="1"'>
    <td style='27' align='right' colspan='3'><text>Razem:</text> </td>
    <td style='27' align='right'>
      RXE_QUANTITY_VVV(pSection.counter(0).result,"",0)
    </td>
</tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTO_TEXT_RODZAJ(n_rodzaj) 
	</td> 
	<td align='right'>
		RXE_QUANTITY_CVV(n_dni,"",0)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='6000'>
		<text><![CDATA[Rodzaj]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Liczba dni kalendarzowych]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  .add_group_section(2,getref("section_header_1"),getref("section_footer_1")).add_sumator("n_dni")  
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
  .ReplaceQueryParam "[CHOROBA( = '1')]","(1=1)"
  .ReplaceQueryParam "[NIEOB( = '1')]","(1<>1)"
  .ReplaceQueryParam "[CHOROBA( = '2')]","(1<>1)"
  .ReplaceQueryParam "[NIEOB( = '2')]","(1=1)"
  .ReplaceQueryParam "[CHOROBA( IN ('1','2'))]","(1=1)"
  .ReplaceQueryParam "[NIEOB( IN ('1','2'))]","(1=1)"
  
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
