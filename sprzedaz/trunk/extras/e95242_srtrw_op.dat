<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Operacje na środkach trwałych

#define N5OPSRTRW_AMORTYZACJA			3
#define N5OPSRTRW_KOREKTA_AMORT			13
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=t_1.strNazwa + '(' + t_1.strNumEwid + ')','c_1'=t_0.nNumOpST,'c_2'=t_0.nNumOpST,'c_3'=t_0.eRodzaj, " +_
"'c_4'=TYPEID_N5OPSRTRW,'c_5'=t_0.IdObj,'c_6'=t_0.dDataOper,'c_7'=t_0.curWartoscPod,'c_8'=t_0.curWartoscBil, " +_
"'c_9'=t_0.curUmorzPod,'c_10'=t_0.curUmorzBil,'c_11'=t_0.curAmortPod,'c_12'=t_0.curAmortBil, " +_
"'c_13'=t_0.dDataAmort,'c_14'=t_0.strUwagi from n5opsrtrw as t_0 inner " +_
" join n5srtrw as t_1 on t_0.pSRTRW = t_1.IdObj inner " +_
" join n5grupasrtrw as t_2 on t_1.pGrupa = t_2.IdObj " +_
" where  %1  and  %2  and  %3  and  %4  order by c_0,c_1"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data operacji").bindexpr("t_0.dDataOper")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa środka trwałego").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy").bindexpr("t_2.strNazwa")
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rodzaj operacji").bindexpr("t_0.eRodzaj")
	pParamFactory2.init_on_enum pParam2, TYPEID_N5OPSRTRW,"eRodzaj"
	pParamArray.add pParam2

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='13'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr fontsize='4'>
	<td style='27' colspan='9' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' colspan='2' />
</tr>
<tr border='0'><td colspan='13' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='13' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td align='right'>
		RXE_T(c_2)
	</td>
	<td>
		<t href='RXF_LINK_FORM_VC(TYPEID_N5OPSRTRW,c_5)'><![CDATA[RXF_ENUM_VVC(TYPEID_N5OPSRTRW,eRodzaj,c_3)]]></t>
	</td>
	<td>
		RXE_DATE(c_6)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_7,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_8,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_9,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_10,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_11,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_12,"",2)
	</td>
	<td align='right'>
	<%
		dim dDateAm : dDateAm = cdate(pRec("c_13"))
		dim eRodzaj : eRodzaj = clng(pRec("c_3"))
		if eRodzaj = N5OPSRTRW_AMORTYZACJA or eRodzaj = N5OPSRTRW_KOREKTA_AMORT then
			so.write "<t>" + cstr(year(dDateAm)) + "/" + cstr(month(dDateAm)) + "</t>"
		end if
	%>
	</td>
	<td>
		RXE_AUTO_TEXT(c_14)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' width='min'><t>LP</t></td>
	<td rowspan='2' width='min'>
		<text><![CDATA[Numer operacji]]></text>
	</td>
	<td rowspan='2' width='min'>
		<text><![CDATA[Rodzaj operacji]]></text>
	</td>
	<td rowspan='2' width='min'>
		<text><![CDATA[Data operacji]]></text>
	</td>
	<td width='min' colspan='2'>
		<text><![CDATA[Wartość]]></text>
	</td>
	<td width='min'  colspan='2'>
		<text><![CDATA[Umorzenie]]></text>
	</td>
	<td width='min'  colspan='2'>
		<text><![CDATA[Amortyzacja]]></text>
	</td>
	<td rowspan='2' width='min'>
		<text><![CDATA[Miesiąc amortyzowany]]></text>
	</td>
	<td rowspan='2' width='max'>
		<text><![CDATA[Uwagi]]></text>
	</td>
</tr>
<tr style='21'>
	<td width='min'>
		<text><![CDATA[podatkowa]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[bilansowa]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[podatkowe]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[bilansowe]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[podatkowa]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[bilansowa]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='9' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' colspan='2' />
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_11").add_sumator("c_12")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_11").add_sumator("c_12")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
