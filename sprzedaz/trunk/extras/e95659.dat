<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

RAPTEMPLATE_ZAKUP_ROZLICZENIA_RR_NIEZAPLCONE

#define RAPORT_TITLE Niezapłacone RR

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()
  query = "select 'z_idobj'=z.idobj,'z_nrdok'=z.strNrDok,'z_data_wyst'=z.dDataWyst,'z_data_plat'=z.dDataPlat, " + vbNewLine +_
          "   'z_wart_netto'=z.curSumaNetto - isnull(kz.curSumaNetto,0),'z_wart_vat'=z.curSumaVat - isnull(kz.curSumaVat,0), " + vbNewLine +_
          "   'z_wart_brutto'=z.curSumaBrutto - isnull(kz.curSumaBrutto,0),'sp_plat'=sp.strNazwa " + vbNewLine +_ 
          "from n5zakup z " + vbNewLine +_ 
          "   left outer join n5zakup kz on z.pPopZakup = kz.idobj " + vbNewLine +_ 
          "   inner join n5transakcja tr on z.pTransakcja = tr.idObj " + vbNewLine +_
          "   inner join n5klient kl on z.pDostawca = kl.idObj " + vbNewLine +_
          "   inner join n5sposplat sp on z.pSposobPlatnosci = sp.idobj " + vbNewLine +_
          "   inner join n5rejestrdok r on z.pRejestrDok = r.idobj " + vbNewLine +_
          "where (tr.idobj not in (select c_ptransakcja from vlist_n5platnosc_listPozycje vl " + vbNewLine +_ 
          "                        inner join n5rejestrdok rd on vl.p_prejestrdok = rd.idobj and rd.eTyp = N5REJESTRDOK_BANKOWY) " + vbNewLine +_
          "       or tr.idobj in (select c_ptransakcja from vlist_n5platnosc_listPozycje vl " + vbNewLine +_ 
          "                       inner join n5rejestrdok rd on vl.p_prejestrdok = rd.idobj and rd.eTyp = N5REJESTRDOK_BANKOWY " + vbNewLine +_
          "                       where vl.p_plat_prapkas = 0)) " + vbNewLine +_
          "and r.eTyp in (N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR) and %1 and %2 " + vbNewLine +_ 
          "and %3 and %4"
end function
%>

<%
function default_param()
  dim pParamArray :	set pParamArray = doc_.afc.new_navoarray()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("z.dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin zapłaty").bindexpr("z.dDataPlat")  
  pParamArray.add doc_.afc.rap.param.new_text("Numer dokumentu").bindexpr("z.strNrDok")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("kl.strNazwa")
	set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZAKUP,z_idobj,z_nrdok) 
	</td>
	<td>
		RXE_DATE(z_data_wyst)
	</td>
  <td>
		RXE_DATE(z_data_plat)
	</td>
	 <td>
		RXE_TEXT(sp_plat)
	</td>
  <td align='right'>
		RXE_QUANTITY_CVV(z_wart_netto,"",2)
	</td>
  <td align='right'>
		RXE_QUANTITY_CVV(z_wart_vat,"",2)
	</td>
  <td align='right'>
		RXE_QUANTITY_CVV(z_wart_brutto,"",2)
	</td>
 </tr>
<%
end function
%>

<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
  <td width='min'><t>LP</t></td>
	<td width='4000'>
		<t><![CDATA[Numer dokumentu]]></t>
	</td>
	<td width='2000'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Termin zapłaty]]></text>
	</td>
  <td width='2500'>
    <text><![CDATA[Sposób płatności]]></text>
  </td>
  <td width='2000'>
    <text><![CDATA[Wartość netto]]></text>
  </td>
  <td width='2000'>
    <text><![CDATA[Wartość VAT]]></text>
  </td>
  <td width='2000'>
    <text><![CDATA[Wartość brutto]]></text>
  </td>
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
<tr style='21' bold='true'>
  <td style='27' colspan='5' align='right'>
    <text>Razem:</text>
    <tex>&nbsp;</tex>
  </td>
  <td style='27' align='right'>
    <t>
      <%so.write doc_.afc.display.quantity(pSection.counter(0).result,"",2)%>
    </t>
  </td>
  <td style='27' align='right'>
    <t>
      <%so.write doc_.afc.display.quantity(pSection.counter(1).result,"",2)%>
    </t>
  </td>
  <td style='27' align='right'>
    <t>
      <%so.write doc_.afc.display.quantity(pSection.counter(2).result,"",2)%>
    </t>
  </td>
</tr>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
    .add_body_ex(getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("z_wart_netto").add_sumator("z_wart_vat").add_sumator("z_wart_brutto")
    if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

      dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
      set pPerf = nothing

      rapeng_.write_actual_param so,rapeng_.get_raport_param()

      if not .perform then
        so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
      end if
    end if
  end with
  %>
</body>
<footer>
</footer>
</page>
