							</td>
							#ifdef SHOW_CUSTOMS_CODE
							<td width='min' >
								<t>Kod celny</t>																
							</td>
							#endif

							<td align='right'>
								<t>Ilość</t>
							</td>
							<td align='right'>
								<t>J.m.</t>
							</td>							
							<td align='right'>
								<t>Cena netto</t>
							</td>
							<td align='right'>
								<t>Rabat</t>
							</td>
							<td align='right'>
								<t>Wartość brutto</t>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td >
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min' >
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							#ifdef SHOW_CUSTOMS_CODE
							<td width='min' >
								<text><![CDATA[POZ_KOD_CELNY]]></text>																
							</td>
							#endif

							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
							if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
							end if
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							#ifdef SHOW_CUSTOMS_CODE
							<td width='min' align='right' bordercolor='transparent'/>
							#endif
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
										
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY DOKUMENT_WALUTA]]></t>
			</td>
		</tr>
		<!--
		<tr>
			<td>
				<t bold='true'>Słownie:</t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_DO_ZAPLATY_SLOWNIE]]></t>
			</td>
		</tr>
		-->
		
		
		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>		<% end if%>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'></td>						
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td></td>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia faktury VAT</t>
							</td>				
							<td></td>			
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby uprawnionej do odbioru faktury VAT</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
