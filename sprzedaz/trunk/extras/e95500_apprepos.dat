<?xml version="1.0" encoding="windows-1250"?>
<!--
	biblioteka z funkcjami display
-->
<nxapprep>
	<functions>
		<function name="display_price_always_cur">
			<![CDATA[
function display_price_always_cur(byref oASP,byval strCEA,byval curValue,byref pCurr)
	set display_price_always_cur = oASP.newcellex(1,"align='right' " + strCEA).e_label_currency(curValue,pCurr.strSkrot,trans_.var(8502)) 
end function
			]]>
		</function>
		<function name="display_price_no_cur">
			<![CDATA[
function display_price_no_cur(byref oASP,byval strCEA,byval curValue)
	set display_price_no_cur = oASP.newcellex(1,"align='right' " + strCEA).e_label_currency(curValue,"",trans_.var(8502)) 
end function
			]]>
		</function>
		<function name="display_price_smart_cur">
			<![CDATA[
function display_price_smart_cur(byref oASP,byval strCEA,byval curValue,byref pCurr)
	if pCurr is getCurrentFirma().pWaluta then
		set display_price_smart_cur = display_price_no_cur(oASP,strCEA,curValue)
	else
		set display_price_smart_cur = display_price_always_cur(oASP,strCEA,curValue,pCurr)
	end if
end function
			]]>
			<using>display_price_always_cur</using>
			<using>display_price_no_cur</using>
		</function>
		<function name="display_value_always_cur">
			<![CDATA[
function display_value_always_cur(byref oASP,byval strCEA,byval curValue,byref pCurr)
	set display_value_always_cur = oASP.newcellex(1,"align='right' " + strCEA).e_label_money(curValue,pCurr.strSkrot) 
end function
			]]>
		</function>
		<function name="display_quantity_no_unit">
			<![CDATA[
function display_quantity_no_unit(byref oASP,byval strCEA,byval curValue,byref pUnit)
	set display_quantity_no_unit = oASP.newcellex(1,"align='right' " + strCEA).e_label_currency(curValue,"",pUnit.nDokladnosc-1) 
end function
			]]>
		</function>
		<function name="display_quantity_with_unit">
			<![CDATA[
function display_quantity_with_unit(byref oASP,byval strCEA,byval curValue,byref pUnit)
	set display_quantity_with_unit = oASP.newcellex(1,"align='right' " + strCEA).e_label_currency(curValue,pUnit.strSkrot,pUnit.nDokladnosc-1) 
end function
			]]>
		</function>
		<function name="display_date_and_time">
			<![CDATA[
function display_date_and_time(byref oASP,byval strCEA,byval dDate,byval iTime)
	set display_date_and_time = oASP.newcellex(1,"keepline='true' " + strCEA).e_label_date(dDate).e_space(1).e_label_time(iTime)
end function
			]]>
		</function>
	</functions>
</nxapprep>
