<?xml version="1.0" encoding="windows-1250" ?>
<!--Wydruk blankietu polecenia przelewu do faktury -->
<!--

#include "h1250_raport_macros.h"
#include "h1206_pit_form_macros.h"


#define X_PICTURE_WIDTH			14900
#define Y_PICTURE_HEIGHT		10500
#define FONT_WYSOKOSC			7
#define PICTURE_2_OFFSET		10800
#define Y_FIELD_OFFSET			860



#define X_POLE_NAZWA_ODBIORCY	800
#define Y_POLE_NAZWA_ODBIORCY	400
#define X_POLE_NAZWA_ODBIORCY_2	X_POLE_NAZWA_ODBIORCY
#define Y_POLE_NAZWA_ODBIORCY_2	Y_POLE_NAZWA_ODBIORCY + PICTURE_2_OFFSET






#define X_POLE_ADRES_ODBIORCY	X_POLE_NAZWA_ODBIORCY
#define Y_POLE_ADRES_ODBIORCY	Y_POLE_NAZWA_ODBIORCY + Y_FIELD_OFFSET
#define X_POLE_ADRES_ODBIORCY_2	X_POLE_ADRES_ODBIORCY
#define Y_POLE_ADRES_ODBIORCY_2	Y_POLE_ADRES_ODBIORCY + PICTURE_2_OFFSET



#define X_POLE_RACHI_ODBIORCY	X_POLE_ADRES_ODBIORCY
#define Y_POLE_RACHI_ODBIORCY	Y_POLE_ADRES_ODBIORCY + Y_FIELD_OFFSET

#define X_POLE_RACHII_ODBIORCY	X_POLE_RACHI_ODBIORCY + 1000
#define Y_POLE_RACHII_ODBIORCY	Y_POLE_RACHI_ODBIORCY



#define X_POLE_RACHI_ODBIORCY_2		X_POLE_RACHI_ODBIORCY
#define Y_POLE_RACHI_ODBIORCY_2		Y_POLE_RACHI_ODBIORCY + PICTURE_2_OFFSET

#define X_POLE_RACHII_ODBIORCY_2	X_POLE_RACHII_ODBIORCY
#define Y_POLE_RACHII_ODBIORCY_2	Y_POLE_RACHII_ODBIORCY +  PICTURE_2_OFFSET


#define X_POLE_KWOTA		9000
#define Y_POLE_KWOTA		Y_POLE_RACHII_ODBIORCY + Y_FIELD_OFFSET

#define X_POLE_KWOTA_2		X_POLE_KWOTA
#define Y_POLE_KWOTA_2		Y_POLE_KWOTA + PICTURE_2_OFFSET


#define X_POLE_SLOWNIE		X_POLE_ADRES_ODBIORCY
#define Y_POLE_SLOWNIE		Y_POLE_KWOTA + Y_FIELD_OFFSET


#define X_POLE_ZLEC			X_POLE_ADRES_ODBIORCY
#define Y_POLE_ZLEC			Y_POLE_SLOWNIE + Y_FIELD_OFFSET

#define X_POLE_ZLEC_2		X_POLE_ZLEC	
#define Y_POLE_ZLEC_2		Y_POLE_ZLEC + PICTURE_2_OFFSET


#define X_POLE_ZLEC_ADR			X_POLE_ZLEC
#define Y_POLE_ZLEC_ADR			Y_POLE_ZLEC + Y_FIELD_OFFSET


#define X_POLE_ZLEC_ADR_2			X_POLE_ZLEC_ADR
#define Y_POLE_ZLEC_ADR_2			Y_POLE_ZLEC_ADR	+ PICTURE_2_OFFSET


#define X_POLE_ZA_CO			X_POLE_ZLEC_ADR
#define Y_POLE_ZA_CO			Y_POLE_ZLEC_ADR + Y_FIELD_OFFSET

#define X_POLE_ZA_CO2			X_POLE_ZA_CO
#define Y_POLE_ZA_CO2			Y_POLE_ZA_CO + Y_FIELD_OFFSET



#define X_POLE_ZA_CO_2			X_POLE_ZLEC_ADR
#define Y_POLE_ZA_CO_2			Y_POLE_ZA_CO + PICTURE_2_OFFSET

#define X_POLE_ZA_CO2_2			X_POLE_ZA_CO2
#define Y_POLE_ZA_CO2_2			Y_POLE_ZA_CO2 + PICTURE_2_OFFSET

	

-->
<page backcolor='white' width='21000' height='29700'>
<config>
	<title>
Polecenie przelewu
#ifdef _DEBUG
[THIS_FILE]
#endif
</title>
<script><![CDATA[

<%

'funkcje pomocne przy ukladaniu napisów - do deklaracji
#include "50514" 

#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 

%>



]]></script>
</config>
<header>
</header>
<body>
<p width='X_PICTURE_WIDTH'>

<picture position='0,0' print='true'  scalingmode='1' image='80964' width='X_PICTURE_WIDTH' height='Y_PICTURE_HEIGHT' />
<picture position='0,PICTURE_2_OFFSET' print='true'  scalingmode='1' image='80964' width='X_PICTURE_WIDTH' height='Y_PICTURE_HEIGHT' />


<%
dim tekst_o:tekst_o = util_.Firma_Nazwa + ", " + util_.Firma_Kod_Miasto + ", " + util_.Firma_Ulica
dim font_o:font_o = 5
dim dlugosc_o:dlugosc_o = 62
dim linia1_o:linia1_o = mid(tekst_o,1,dlugosc_o)
dim linia2_o:linia2_o = ""
if len(tekst_o) > dlugosc_o then
	linia2_o = mid(tekst_o,dlugosc_o + 1,len(tekst_o) - dlugosc_o)
end if

dim bank_numer : bank_numer = util_.Firma_Bank_Numer
dim rachunek: rachunek = ""
dim rachunek_LK : rachunek_LK = ""


if len(bank_numer) > 2 then
	rachunek_LK = mid(bank_numer,1,2)
else
	rachunek_LK = bank_numer
end if


if len(bank_numer) > 2 then
	rachunek = mid(bank_numer,3,len(bank_numer)-2)
else
	rachunek = ""
end if




%>

<%
dim tekst:tekst = util_.Klient_Nazwa(root_.pKlient) '+ ", " + util_.Podmiot_Adres(root_.wrefPodmiot)
dim font:font = 5
dim dlugosc:dlugosc = 62
dim linia1:linia1 = mid(tekst,1,dlugosc)
dim linia2:linia2 = ""
if len(tekst) > dlugosc then
	linia2 = mid(tekst,dlugosc + 1,len(tekst) - dlugosc)
end if
%>

WTPFXY(_NAZWA_ODBIORCY,linia1_o,font_o)
WTPFXY(_NAZWA_ODBIORCY_2,linia1_o,font_o)

WTPFXY(_ADRES_ODBIORCY,linia2_o,font_o)
WTPFXY(_ADRES_ODBIORCY_2,linia2_o,font_o)


WTPFXY(_RACHI_ODBIORCY,rachunek_LK,FONT_WYSOKOSC)
WTPFXY(_RACHII_ODBIORCY,rachunek,FONT_WYSOKOSC)

WTPFXY(_RACHI_ODBIORCY_2,rachunek_LK,FONT_WYSOKOSC)
WTPFXY(_RACHII_ODBIORCY_2,rachunek,FONT_WYSOKOSC)

WTPFXY(_KWOTA,doc_.afc.display.money(abs(root_.curSumaBrutto),""),FONT_WYSOKOSC)
WTPFXY(_KWOTA_2,doc_.afc.display.money(abs(root_.curSumaBrutto),""),FONT_WYSOKOSC)

WTPFXY(_ZLEC,linia1,font)
WTPFXY(_ZLEC_2,linia1,font)

WTPFXY(_ZLEC_ADR,linia2,font)
WTPFXY(_ZLEC_ADR_2,linia2,font)

WTPFXY(_ZA_CO,mid(root_.strNrDok,1,55),6)
WTPFXY(_ZA_CO2,mid(root_.strNrDok,56,110),6)

WTPFXY(_ZA_CO_2,mid(root_.strNrDok,1,55),6)
WTPFXY(_ZA_CO2_2,mid(root_.strNrDok,56,110),6)

</p>
</body>
<footer>
</footer>
</page>
