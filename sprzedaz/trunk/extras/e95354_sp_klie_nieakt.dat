<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_SPRZEDAZ_KLIENCI_NIEAKTYWNI
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Klienci nieaktywni - którzy nie zakupili danego produktu

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'k_idobj'=min(k.idobj),'k_strnazwa'=k.strNazwa,'k_strskrot'=min(k.strSkrot),'k_strindeks'=min(k.strIndeks) " +_
        "from n5sprzedaz as s " +_
        "inner join n5klient as k on s.pKlient = k.idobj " +_
        "inner join n5grupaklient as gk on k.pGrupaKlient = gk.idobj " +_
        "where s.pKlient in " +_
        "(select pKlient from n5sprzedaz " +_ 
        "where %2 " +_
        "group by pKlient " +_
        "having %6 and %7) " +_ 
        "and s.pKlient not in " +_
	      "(select 'k_idobj'=k.idobj " +_
	      "from vlist_n5sprzedaz_listPozycje as t_sprz " +_
	      "join n5klient as k on t_sprz.p_pklient = k.idobj " +_
	      "join n5produkt as pr on t_sprz.c_pprodukt = pr.idobj " +_
	      "join n5grupaproduktow as gp on pr.pGrupaProd = gp.idobj " +_
	      "where %1 and %4 and %5 " +_
        "group by k.idobj) " +_
        "and eAktywny = 1 and %3 " +_
        "group by k.strNazwa " +_
        "order by k.strNazwa"
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>
    RXE_LP
  </td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5KLIENT,k_idobj,k_strnazwa)
	</td>
	<td>
		RXE_AUTO_TEXT(k_strskrot)
	</td>
	<td>
		RXE_AUTO_TEXT(k_strindeks)
	</td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Nazwa klienta]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Skrót klienta]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Indeks klienta]]></text>
	</td>
</tr>
</thead>
<tbody> 
<%
end function
%>

<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<% dim nSectionPicCounter : nSectionPicCounter = 10000000 %>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = doc_.afc.rap.param.new_date_range("Analizowany okres").bindexpr("t_sprz.p_ddatawyst")
pParamArray.add pParamOkres
dim pParamOkres2 : set pParamOkres2 = doc_.afc.rap.param.new_date_range("Okres aktywności").bindexpr("dDataWyst")
pParamArray.add pParamOkres2
pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy klientów").bindexpr("gk.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("pr.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy produktów").bindexpr("gp.strNazwa")
pParamArray.add doc_.afc.rap.param.new_int("Liczba dokumentów").bindexpr("count(pKlient)")
pParamArray.add doc_.afc.rap.param.new_currency("Kwota obrotu").bindexpr("sum(curSumaNetto)")
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
end if
end with
%>
</body>
<footer>
</footer>
</page>
