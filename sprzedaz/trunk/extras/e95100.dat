<?xml version="1.0" encoding="windows-1250" ?>

<!-- Przychod zewnetrzny PZ -->
<!-- 8.06.2004 - poprawka danych jednostki.org. -->
<!-- 21.06.2004 adnotacje -->
<!-- 14.09.2004 data wystawienia z bazy, poprawka ilosci-->
<!-- 19.11.2004 poprawka dla PZ z zamowienia -->
#include "h1240"
#include "h1203"

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


#define DOSTAWCA_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define DOSTAWCA_NIP					<% so.write util_.Klient_NIP(root_.pKlient) %>
#define DOSTAWCA_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta end if end if%>
#define DOSTAWCA_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define DOSTAWCA_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>


#define JEDNOSTKA_ORG_NAZWA				<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define JEDNOSTKA_ORG_KOD_MIASTO		<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta end if end if%>
#define JEDNOSTKA_ORG_ULICA_NUMER		<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define DOSTAWCA_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>


#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_ZAKUPU			<% if not root_.wrefDokHandl is nothing then so.write doc_.afc.display.fulldate(root_.wrefDokHandl.dDataZakupu) end if  %>
#define DOKUMENT_KWOTA					<% so.write MONEY(root_.curKwota) %>
#define DOKUMENT_KWOTA_SLOWNIE			<% so.write doc_.afc.display.slownie(root_.curKwota) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_MAGAZYN				<% if not root_.pMagDocel is nothing then so.write root_.pMagDocel.text end if%>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(root_.curSumaMag) %>

#define DOKUMENT_OBCY_NR				<% if not root_.wrefDokHandl is nothing then so.write root_.wrefDokHandl.strNrDokObcy end if  %>
#define DOKUMENT_POWIAZANY_NR			<% if not root_.wrefDokHandl is nothing then so.write root_.wrefDokHandl.strNrDok end if  %>
#define DOKUMENT_OBCY_WARTOSC_NETTO		<% if not root_.wrefDokHandl is nothing then so.write MONEY(root_.wrefDokHandl.curSumaNetto) end if  %>
#define DOKUMENT_OBCY_WARTOSC_VAT		<% if not root_.wrefDokHandl is nothing then so.write MONEY(root_.wrefDokHandl.curSumaVat) end if  %>
#define DOKUMENT_OBCY_WARTOSC_BRUTTO	<% if not root_.wrefDokHandl is nothing then so.write MONEY(root_.wrefDokHandl.curSumaBrutto) end if  %>

#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>							
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_CENA_DOSTAWY				<% so.write doc_.afc.display.quantity(pozycja.curCenaMag,"",trans_.var(GVAR_PRICE_PREC)) %>
#define POZ_CENA_DOSTAWY_WG_CEN_EWID	<% so.write doc_.afc.display.quantity(curCenaEwid,"",trans_.var(GVAR_PRICE_PREC)) %>

#define POZ_WARTOSC						<% so.write MONEY(pozycja.curWartMag) %>
#define POZ_WARTOSC_WG_CEN_EWID			<% so.write MONEY(ccurWartEwRow) %>
#define POZ_MAGAZYN						<% if not pozycja.pMagDocel is nothing then so.write pozycja.pMagDocel.text end if %>






<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table>
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							

						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Przychód zewnętrzny (PZ) nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		<tr>
			<td>
				<table>
					<tbody>																		
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>						
						</tr>

						ROW_SEPARATOR(2)	
						
						<% if not root_.pKlient_JO is nothing then %>
						<!-- jednostka organizacyjna klienta-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>

						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[JEDNOSTKA_ORG_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<!-- /jednostka organizacyjna klienta-->
						<% else %>
						<% if not root_.pKlient is nothing then %>
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<% else %>
						
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Sprzedawca:</t>
							</td>							
							<td>
								Brak danych
							</td>						
						</tr>
						<% end if %>
						<% end if %>
						
						<%	
						dim rs 					
						
						set rs = trans_.createadors("select 'wrefDokHandl'=wrefDokHandl_wrt "+_
							"from n5dokmag "+_
							"where idobj=" + cstr(root_.idObj)  )
						
						
						%>
						
						
						
						
						<% if not root_.wrefDokHandl is nothing then  %>
						ROW_SEPARATOR(2)
						<tr>
							<td width='min'>
							
								<t bold='true'>Nr. dok. powiazanego:</t>
							
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_POWIAZANY_NR]]></t>
							</td>						
						</tr>
						<% end if %>
						
						
						<% if rs.fields("wrefDokHandl").value=10176  then  %>
						<tr>
							<td width='min'>
							
								<t bold='true'>Nr. dok. obcego:</t>
							
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_OBCY_NR]]></t>
							</td>						
						</tr>
						<% end if %>


						

						<tr>
							<td width='min'>
							
								<t bold='true'>Data wystawienia:</t>
							
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>						
						</tr>
						<% if rs.fields("wrefDokHandl").value=10176 then  %>
						<tr>
							<td width='min'>
							
								<t bold='true'>Data zakupu:</t>
							
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_ZAKUPU]]></t>
							</td>						
						</tr>
						<% end if %>

						<tr>
							<td width='min'>
								<t bold='true'>Magazyn:</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_MAGAZYN]]></t>
							</td>						
						</tr>

																																								
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<% if rs.fields("wrefDokHandl").value=10176 then  %>
		<tr>
			<td>
				<table >
					<tbody>

												
						<tr>										
							<td align='left' colspan='3'>
								<t bold='true'>Wartości z dokumentu obcego:</t>
							</td>									
						</tr>						
						<tr>										
							<td align='left' keepline='true'>
								<t size='3'/>
								<t bold='true'>Wartość netto:</t>
								<t size='3'/>
								<t><![CDATA[DOKUMENT_OBCY_WARTOSC_NETTO]]></t>								
								<t size='3'/>
							</td>									
							<td align='left' keepline='true'>
								<t bold='true'>Wartość VAT:</t>
								<t size='3'/>
								<t><![CDATA[DOKUMENT_OBCY_WARTOSC_VAT]]></t>
								<t size='3'/>
							</td>					
							<td align='left' keepline='true'>
								<t bold='true'>Wartość brutto:</t>
								<t size='3'/>
								<t><![CDATA[DOKUMENT_OBCY_WARTOSC_BRUTTO]]></t>																
							</td>									
						</tr>						
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		<% end if %>
		

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa towaru / usługi</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>							
						
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena dostawy</text>
							</td>
							<td align='right'>
								<text>Wartość</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%	dim iter,pozycja
							iter = 1
							dim curSumaWartEwid:curSumaWartEwid = ccur(0)
							for each pozycja in root_.listPozycje 
						%>
						<tr>

							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>

							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>			
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
#ifdef _CTP
					<%
					dim oProd: set oProd = pozycja.pProdukt
					dim curCenaEwid: curCenaEwid = oProd.listOpakowania.get(1).curCenaNetto4
					
					%>
								<t><![CDATA[POZ_CENA_DOSTAWY_WG_CEN_EWID]]></t>
#else
								<t><![CDATA[POZ_CENA_DOSTAWY]]></t>
#endif
							</td>
							<td align='right'>
#ifdef _CTP
					<%dim ccurWartEwRow: ccurWartEwRow = ccur(oProd.listOpakowania.get(1).curCenaNetto4) * ccur(pozycja.curIloscOpak)
					curSumaWartEwid = curSumaWartEwid + ccurWartEwRow%>
								<t><![CDATA[POZ_WARTOSC_WG_CEN_EWID]]></t>
#else
								<t><![CDATA[POZ_WARTOSC]]></t>
#endif
							</td>
						</tr>
						<%		iter = iter + 1
							next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='3' bordercolor='transparent'>
							</td>
							<td colspan='3'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
							
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC]]></t>
							</td>							
						</tr>	
					</tfoot>					
				</table>
			</td>
		</tr>
	
		
		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<text bold='true'>Adnotacje:</text>
			</td>
		</tr>
		<tr>
			<td>
				<t><![CDATA[DOKUMENT_UWAGI]]></t>
			</td>
		</tr>
		<% end if%>

			
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
						
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>			
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							

						</tr>
						<tr>
							<td width='min' align='center'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby zatwierdzającej operację</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
