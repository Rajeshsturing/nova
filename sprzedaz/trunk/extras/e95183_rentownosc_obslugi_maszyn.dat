<?xml version="1.0" encoding="windows-1250" ?>

<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rentowność obsługi maszyn

#macro RXE_DATE_HREF(_val_col_,_href_)				<text href='_href_'><![CDATA[RXF_DATE(_val_col_)]]></text>
#macro RXE_TEXT_HREF_PREC(_val_col_,_prec_val_,_href_)				<text href='_href_'><![CDATA[RXF_QUANTITY_CVV(_val_col_,"",_prec_val_)]]></text>
#macro RXE_MONEY_VAR_UNIT(_var_,_unit_val_)						<t><%so.write doc_.afc.display.money(_var_,_unit_val_)%></t>
#define OB_LP											<% so.write cstr(nObLP) %>

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

VB_PRINT_LANDSCAPE_COMMON
VB_PRINTPREV_LANDSCAPE_COMMON

function FuncTestowa(byval pHLI)
  doc_.postcommand "varCmd=CMD_OPEN_STATIC_PAGE varDestPage=60140 appvar_raport_type=95183 vs111='" + cstr(pHLI(200)) + "' vs112='" + cstr(pHLI(201)) + "' vs113='" + cstr(pHLI(202)) + "' vs114='" + cstr(pHLI(203)) +"'" 
end function

function PokazObiekt(pHLI)
  if clng(pHLI.prop(200)) > clng(0) then
    doc_.postcommand "varCmd=CMD_OPEN_STATIC_PAGE varDestPage=60180 varNewThread=1 varTypeId=TYPEID_N5ZAMOWIENIE varObject=" + pHLI.prop(200) + " varFormUsage=0"
  end if
end function

function fback()
  dim strSQL
	strSQL =  "drop table #wyniki" + vbCrLf
	trans_.execsql strSQL
	strSQL =  "drop table #amortyzacja" + vbCrLf
	trans_.execsql strSQL	
  fback=std_fback()
end function

<%
dim nObLP : nObLP = clng(1)
dim nObjCount : nObjCount = clng(0)
dim nCustCount : nCustCount = clng(0)

function query()
query = "select 'strNazwaKl' = strNazwaKl,'indeksObiektuKlienta' = strIndeksObKl,'idKl' = min(idKl),dataCiagla, " + vbNewLine +_
        "'strIndeksKl' = max(strIndeksKl),'idobiektuKlienta' = MAX(idObKl),'nazwaObiektuKlienta' = max(strNazwaObKl), " + vbNewLine +_														 
        "'naz_ind_Obiektu' = strIndeksObKl + '(' + max(strNazwaObKl) + ')','KosztMaterialow' = isnull(sum(kosztMaterialow),0), " + vbNewLine +_             
        "'data'=max(data),'KosztUslug' = isnull(sum(kosztUslug),0),'KosztRazem' = isnull(sum(kosztDziałuHandl),0) + isnull(sum(kosztMaterialow),0) + isnull(sum(kosztUslug),0) + isnull(max(a.curMa),0) + " +_
        "isnull(max(kosztLeasingu),0),'KosztDziałuHandl' = isnull(sum(kosztDziałuHandl),0), 'amortyzacja'= isnull(max(a.curMa),0), " + vbNewLine +_
        "'przychod' = isnull(sum(wartosc),0), " + vbNewLine +_
        "'zysk' = isnull(sum(wartosc),0) - (isnull(sum(kosztDziałuHandl),0) + isnull(sum(kosztMaterialow),0) + isnull(sum(kosztUslug),0) + isnull(max(a.curMa),0) + isnull(max(kosztLeasingu),0)), " + vbNewLine +_   
        "'procent'=case when isnull(sum(wartosc),0) = 0 then 0 else " + vbNewLine +_
        "(isnull(sum(wartosc),0) - (isnull(sum(kosztDziałuHandl),0) + isnull(sum(kosztMaterialow),0) + isnull(sum(kosztUslug),0) + isnull(max(a.curMa),0) + isnull(max(kosztLeasingu),0)))/isnull(sum(wartosc),1) * 100 end, " + vbNewLine +_
        "'amor_koszt_lizingu'=isnull(max(a.curMa),0) + isnull(max(kosztLeasingu),0),'idProt'=max(idProt) " + vbNewLine +_
        "from #wyniki " + vbNewLine +_
        "left join #amortyzacja a on kontoObiektuKl = a.symKonta and a.dataCiag = dataCiagla " + vbNewLine +_
        "where %1 and %2 and %TYPUMOWY% and %4 and %5 " + vbNewLine +_
        "group by strNazwaKl,strIndeksObKl,dataCiagla " + vbNewLine +_
        "order by strNazwaKl,strIndeksObKl,dataCiagla "
end function
%>

<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.afc.rap.param.new_text("Urządzenie nazwa").bindexpr("strNazwaObKl")
	pParamArray.add doc_.afc.rap.param.new_text("Urządzenie indeks").bindexpr("strIndeksObKl")

	set pParamTypPro = doc_.afc.rap.param.new_choice("Typ umowy")
	with pParamTypPro
		.multiple = true
			.names.add "Umowy najmu"
			.values.add 1
			.selected.add True
		.names.add "Umowy serwisowe"
		.values.add 2
		.selected.add True
			.names.add "Umowy gwarancyjne"
			.values.add 2
			.selected.add True
		.names.add "Obsługa posprzedażna"
		.values.add 2
		.selected.add True
			.names.add "Umowy bez określonego typu"
			.values.add 2
			.selected.add True
	end with
  pParamArray.add pParamTypPro
  
	dim pParamFactoryWZ: set pParamFactoryWZ = doc_.afc.rap.param
	dim pParamRejWZ: Set pParamRejWZ = pParamFactoryWZ.new_choice("Rejestr WZ").bindexpr("idRejestrWZ")
	doc_.afc.rap.param.init_on_query pParamRejWZ, trans_ ,"select strNazwa,idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__WZ) order by strNazwa"
	pParamArray.add pParamRejWZ  
  
	dim pParamFactorySprzed: set pParamFactorySprzed = doc_.afc.rap.param
	dim pParamRejSprzed: Set pParamRejSprzed = pParamFactorySprzed.new_choice("Rejestr sprzedaży").bindexpr("idRejestrSprz")
	doc_.afc.rap.param.init_on_query pParamRejSprzed, trans_ , _
  "select strNazwa,idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) order by strNazwa"
	pParamArray.add pParamRejSprzed    

	set default_param = pParamArray
end function
%>

<%
function section_header_cust(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='12'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
		RXE_T_LINK_FORM_VCC(TYPEID_N5KLIENT,idKl,strNazwaKl)<t><%so.write " ("+pRec("strIndeksKl").value+")"%></t>
		<t size='2' />
	</td>
</tr>
<%
nCustCount = nCustCount + 1
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_cust(byref pSection)
%>
  <tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
  <tr style='21'>
    <td align='right' colspan='4'><t>Klient razem:</t> </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(0).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(1).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(2).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR(pSection.counter(3).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(4).result,"PLN")    
    </td>    
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(5).result,"PLN")     
    </td>  
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(6).result,"PLN")
    </td> 
 	  <td align='right' border='1'>
      <% if pSection.counter(5).result <> ccur(0) then %>
        RXE_QUANTITY_VVV(trans_.afc.convert.round2(pSection.counter(6).result/pSection.counter(5).result*100),"%",2)
      <% else %>
        RXE_QUANTITY_VVV(0,"%",2)      
      <% end if %>
    </td>    
  </tr>
  <tr border='0'><td colspan='10' /></tr>
<%
   nObLP = 1
end function
%>

<%
function section_header_ob(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' />
	<td style='27' align='right'>
		<t>OB_LP</t>
	</td>
	<td style='27' colspan='10'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
       RXE_T_LINK_FORM_VCC(TYPEID_N5KLIENT_OBIEKT,idobiektuKlienta,naz_ind_Obiektu)
		<t size='2' />
	</td>
</tr>
<%
nObjCount = nObjCount + 1
nObLP = nObLP + 1
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_ob(byref pSection)
%>
<tr border='0'><td colspan='10' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='10' /></tr>
  <tr style='21' bold='false'>
    <td style='27' />
    <td align='right' colspan='3'><t>Urządzenie razem:</t></td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(0).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(1).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(2).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR(pSection.counter(3).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(4).result,"PLN")    
    </td>    
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(5).result,"PLN")     
    </td>  
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(6).result,"PLN")
    </td> 
 	  <td align='right' border='1'>
      <% if pSection.counter(5).result <> ccur(0) then %>
        RXE_QUANTITY_VVV(trans_.afc.convert.round2(pSection.counter(6).result/pSection.counter(5).result*100),"%",2)
      <% else %>
        RXE_QUANTITY_VVV(0,"%",2)      
      <% end if %>
    </td>
  </tr>

  <tr border='0'><td colspan='10' /></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right' colspan='3'></td>
  <td>
    RXE_DATE_HREF(data,varFunctionHLI="PokazObiekt" <%so.write " vs200=""" + CStr(pRec("idProt").value) + """" %>)
  </td>
  <td align='right'>
    RXE_TEXT_HREF_PREC(kosztMaterialow,2,varFunctionHLI="FuncTestowa" <%so.write " vs200=""" +cStr(pRec("strindekskl").value) + """" %>  <%so.write " vs201=""" + cstr(pRec("data").value) + """" %> <%so.write " vs202=1" %><%so.write " vs203=""" +cStr(pRec("indeksObiektuKlienta").value) + """" %>)
  </td>
  <td align='right'>
    RXE_TEXT_HREF_PREC(kosztUslug,2,varFunctionHLI="FuncTestowa" <%so.write " vs200=""" +cStr(pRec("strindekskl").value) + """" %>  <%so.write " vs201=""" + cstr(pRec("data").value) + """" %> <%so.write " vs202=2" %><%so.write " vs203=""" +cStr(pRec("indeksObiektuKlienta").value) + """" %>)
  </td>
  <td align='right'>
    RXE_TEXT_HREF_PREC(amor_koszt_lizingu,2,varFunctionHLI="FuncTestowa" <%so.write " vs200=""" +cStr(pRec("strindekskl").value) + """" %>  <%so.write " vs201=""" + cstr(pRec("data").value) + """" %> <%so.write " vs202=3" %><%so.write " vs203=""" +cStr(pRec("indeksObiektuKlienta").value) + """" %>)
  </td>
	<td align='right'>
    RXE_QUANTITY_CVV(KosztDziałuHandl,"",2)
  </td>
  <td align='right'>
    RXE_QUANTITY_CVV(KosztRazem,"PLN",2)  
  </td>
	<td align='right'>
    RXE_QUANTITY_CVV(przychod,"PLN",2)  
  </td>
  <% if ccur(pRec("zysk").value) < ccur(0) then %>
    <td forecolor='red' align='right'>
      RXE_QUANTITY_CVV(zysk,"PLN",2)      
    </td>
  <% else %>
    <td align='right'>
      RXE_QUANTITY_CVV(zysk,"PLN",2)      
    </td>
  <% end if %>
	<% if ccur(pRec("procent").value) <= ccur(0)  then %>
	  <td forecolor='red' align='right'>
      RXE_QUANTITY_CVV(procent,"%",2)      
    </td>
	<% else %>
		<td align='right'>
      RXE_QUANTITY_CVV(procent,"%",2)    
    </td>
	<% end if %>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='max' width='1800'>
		<text><![CDATA[Klient]]></text>
	</td>
	<td width='max' width='500'>
		<text><![CDATA[LP]]></text>
	</td>  
	<td width='max' width='500'>
		<text><![CDATA[Urzą- dzenie]]></text>
	</td>
	<td width='max' width='1300'>
		<text><![CDATA[Rok, miesiąc]]></text>
	</td>
	<td width='max' width='2000'>
		<text><![CDATA[Koszty materiałów]]></text>
	</td>
	<td width='max' width='2000'>
		<text><![CDATA[Koszty usług]]></text>
	</td>
	<td width='max' width='2000'>
		<text><![CDATA[Koszty amortyzacji]]></text>
	</td>
	<td width='max' width='2000'>
		<text><![CDATA[Koszty działu handlowego]]></text>
	</td>
  <td width='max' width='2000'>
    <text><![CDATA[Suma kosztów]]></text>
  </td>  
  <td width='max' width='2000'>
		<text><![CDATA[Przychód]]></text>
	</td>
  <td width='max' width='2000'>
    <text><![CDATA[Zysk]]></text>
  </td>  
	<td width='max' width='2000'>
		<text><![CDATA[Zysk %]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
    <tr style='21' fontsize='4'>
    <td align='right' colspan='4'><t>Razem:</t> </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(0).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(1).result)
    </td>
    <td align='right'>
      RXE_MONEY_VAR(pSection.counter(2).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR(pSection.counter(3).result)
    </td>
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(4).result,"PLN")    
    </td>    
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(5).result,"PLN")     
    </td>  
 	  <td align='right' border='1'>
      RXE_MONEY_VAR_UNIT(pSection.counter(6).result,"PLN")
    </td> 
 	  <td align='right' border='1'>
      <% if pSection.counter(5).result <> ccur(0) then %>
        RXE_QUANTITY_VVV(trans_.afc.convert.round2(pSection.counter(6).result/pSection.counter(5).result*100),"%",2)
      <% else %>
        RXE_QUANTITY_VVV(0,"%",2)      
      <% end if %>
    </td>
  </tr>
  <tr style='21' fontsize='4'>
    <td align='right' colspan='4'>
      <t>Liczba kontrahentów:</t>
    </td>
    <td align='right'>
      RXE_QUANTITY_VVV(nCustCount,"",0)
    </td>    
    <td colspan='11'/>
  </tr>
  <tr style='21' fontsize='4'>
    <td align='right' colspan='4'>
      <t>Liczba urządzeń:</t>
    </td>
    <td align='right'>
      RXE_QUANTITY_VVV(nObjCount,"",0)
    </td>
    <td colspan='11'/>
  </tr>
</tfoot>
</table>
<%
end function
%>
<%
dim nSectionPicCounter : nSectionPicCounter = 10000000
dim nSectionCurrCounter : nSectionCurrCounter = 0
%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>

<p>
<t size='2'/>
</p>
<%

dim pParamTypPro

	dim pM60312 : set pM60312 = doc_.getmodule(60312)
	dim pRentSP : set pRentSP = pM60312.new_rent()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
  dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("KosztMaterialow").add_sumator("KosztUslug").add_sumator("amor_koszt_lizingu").add_sumator("KosztDziałuHandl").add_sumator("KosztRazem").add_sumator("przychod").add_sumator("zysk")
  .add_group_section(0,getref("section_header_cust"),getref("section_footer_cust")).add_sumator("KosztMaterialow").add_sumator("KosztUslug").add_sumator("amor_koszt_lizingu").add_sumator("KosztDziałuHandl").add_sumator("KosztRazem").add_sumator("przychod").add_sumator("zysk")
  .add_group_section(1,getref("section_header_ob"),getref("section_footer_ob")).add_sumator("KosztMaterialow").add_sumator("KosztUslug").add_sumator("amor_koszt_lizingu").add_sumator("KosztDziałuHandl").add_sumator("KosztRazem").add_sumator("przychod").add_sumator("zysk")

  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
  %>
  <%

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
 
  dim strTyp1: strTyp1 = " (zasadaObslugi='1')" 'umowa najmu'
  dim strTyp2: strTyp2 = " (zasadaObslugi='2')" 'umowa serwisowa'
  dim strTyp3: strTyp3 = " (zasadaObslugi='3')" 'umowa gwarancyjna'
  dim strTyp4: strTyp4 = " (zasadaObslugi='4')" 'obsluga posprzedazna'
  dim strTyp5: strTyp5 = " (zasadaObslugi='')"  'zaden z powyzszych'
  dim strTyp : strTyp = "("
  if pParamTypPro.selected.value(0) then
    strTyp =  strTyp + strTyp1 + " or "
  end if
  
  if pParamTypPro.selected.value(1) then
    strTyp =  strTyp + strTyp2 + " or " 
  end if
  
  if pParamTypPro.selected.value(2) then
    strTyp =  strTyp + strTyp3 + " or "
  end if
  
  if pParamTypPro.selected.value(3) then
    strTyp =  strTyp + strTyp4 + " or " 
  end if
  
  if pParamTypPro.selected.value(4) then
    strTyp =  strTyp + strTyp5 + " or " 
  end if
  
  strTyp = strTyp + " and (1=1))"
  strTyp = replace(strTyp,"or  and","and")
  .ReplaceQueryParam "%TYPUMOWY%",strTyp
  
  .ReplaceQueryParam "idRejestrWZ IN (","idRejestrWZ IN ('0',"
  .ReplaceQueryParam "idRejestrSprz IN (","idRejestrSprz IN ('0',"
  .ReplaceQueryParam "idRejestrWZ =","idRejestrWZ = '0' or idRejestrWZ ="
  .ReplaceQueryParam "idRejestrSprz =","idRejestrSprz = '0' or idRejestrSprz ="  
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
set pRentSP = nothing
set pM60312 = nothing
%>
</body>
<footer>
</footer>
</page>
