<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_PROWIZJA_METROX

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Prowizja

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
	query = "select 'p_idobj'=prod.idobj,'p_type'=10131,'p_nazwa'=max(prod.strNazwa), " + vbNewLine +_
          "'j_skrot'=max(j.strSkrot),'j_doklad'=max(j.nDokladnosc),'ilosc'=sum(trs_curIloscOpakSP), " + vbNewLine +_
          "'wartosc_sprz'=sum(trs_curWartSP),'wartosc_oplat'=sum(trs_curWartSP) * max(CAST(case when k.strCecha3='' then '0.0' else replace(k.strCecha3,',','.') end  as decimal(12,2))/100),'wartosc_zak'=-sum(trs_curWartMag), " + vbNewLine +_
          "'pozost_koszt'=sum(trs_curIloscOpakSP)*max(cast(case when opak.strKodOpak='' then '0.0' else replace(opak.strKodOpak,',','.') end as decimal(12,2))), " + vbNewLine +_
          "'zysk'=sum(trs_curWartSP) + sum(trs_curWartMag) - sum(trs_curWartSP) * max(CAST(case when k.strCecha3='' then '0.0' else replace(k.strCecha3,',','.') end  as decimal(12,2))/100) - sum(trs_curIloscOpakSP)*max(cast(case when opak.strKodOpak='' then '0.0' else replace(opak.strKodOpak,',','.') end  as decimal(12,2))), " + vbNewLine +_
          "'prowizja'=(sum(trs_curWartSP) + sum(trs_curWartMag) - sum(trs_curWartSP) * max(CAST(case when k.strCecha3='' then '0.0' else replace(k.strCecha3,',','.') end  as decimal(12,2))/100) - sum(trs_curIloscOpakSP)*max(cast(case when opak.strKodOpak='' then '0.0' else replace(opak.strKodOpak,',','.') end  as decimal(12,2)))) * [PROWIZJA] " + vbNewLine +_
          "from #tmp_rentowsp " + vbNewLine +_ 
	        "  inner join n5produkt as prod on trs_pProdukt = prod.idobj " + vbNewLine +_ 
	        "  inner join n5opakowanie_produktu as opak on trs_pOpak = opak.idobj " + vbNewLine +_ 
	        "  inner join n5jednostka j on opak.pJednOpak = j.idobj " + vbNewLine +_ 
	        "  inner join n5sprzedaz as sprz on trs_pSprz = sprz.idobj " + vbNewLine +_ 
	        "  inner join n5klient as k on sprz.pKlient = k.IdObj " + vbNewLine +_ 
	        "  inner join n5grupaklient as grk on k.pGrupaKlient = grk.IdObj " + vbNewLine +_
	        "  left join n5pracownik as prac on sprz.sprzed_pHandlowiec = prac.IdObj " + vbNewLine +_
          "where sprz.pRozlVAT <> 0 and sprz.pRejestrDok not in (select IdObj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA,N5REJESTRDOK_KOR_DOSTAWA)) and prod.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy) " + vbNewLine +_
          " and %1 and %2 and %3 and %4 and %6 and %7 " + vbNewLine +_ 
          "group by prod.idobj,opak.idobj,k.idobj " + vbNewLine +_
          "order by p_nazwa"
end function
%>
<%
function body_row(byref pSection,byref pRec)           
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
  <td>
		RXE_AUTOTEXT_LINK_FORM_CCC(p_type,p_idobj,p_nazwa)  
  </td>
	<td align='right'>
		<t><%so.write doc_.afc.display.quantity(pRec("ilosc"),"",pRec("j_doklad")-1)%></t>
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_sprz,"",2)
	</td> 
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_oplat,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(wartosc_zak,"",2)
	</td> 
	<td align='right'>
		RXE_QUANTITY_CVV(pozost_koszt,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(zysk,"",2)
	</td>  
	<td align='right'>
		RXE_QUANTITY_CVV(prowizja,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='4000'>
		<t><![CDATA[Nazwa produktu]]></t>
	</td>
	<td width='1500'>
		<text><![CDATA[Ilość]]></text>
	</td> 
	<td width='2000'>
		<text><![CDATA[Wartość sprzedaży]]></text>
	</td>  
	<td width='1500'>
		<text><![CDATA[Wart. opłat u klienta]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Wartość zakupu]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Pozostałe koszty]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Zysk]]></text>
	</td>  
 	<td width='2000'>
		<text><![CDATA[Prowizja]]></text>
	</td>  
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='2' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>  
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(3).result)
	</td> 
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(4).result)
	</td> 
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(5).result)
	</td> 
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(6).result)
	</td>   
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
  dim utilProdHierarchy : set utilProdHierarchy = doc_.getmodule(60246)
  dim pProdHierarchy : set pProdHierarchy = utilProdHierarchy.new_prod_hierarchy()
  
	dim pM60233 : set pM60233 = doc_.getmodule(60233)
	dim pRentSP : set prentsp = pM60233.new_rent_sp()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	
	dim pParamOkres : set pParamOkres = pRentSP.get_okres_param()
	pParamArray.add pParamOkres
  
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("grk.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("prod.strNazwa")
	dim pGrupaParam: set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
  pParamArray.add pGrupaParam
	pParamArray.add doc_.afc.rap.param.new_text("Nr dok. sprzedaży").bindexpr("sprz.strNrDok")  
  pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("prac.strNazwisko")
  pParamArray.add doc_.afc.rap.param.new_currency("Prowizja %").bindexpr("")
	
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%  

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("ilosc").add_sumator("wartosc_sprz").add_sumator("wartosc_oplat").add_sumator("wartosc_zak").add_sumator("pozost_koszt").add_sumator("zysk").add_sumator("prowizja")
  
if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  pProdHierarchy.fill_on_prodgrupa_param pGrupaParam
	pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
	pRentSP.fill_dok_mag_related
	set pPerf = nothing
  
  'procent prowizji
  dim curProwizja: curProwizja = ccur(pParamArray.value(7).first_value)
  if curProwizja < ccur(0.0) or curProwizja > ccur(100.00) then
     so.write "<br/><p style='21'><t>Wartość prowizji musi być w przedziale 0-100</t></p>"
    else
    curProwizja = curProwizja/100

    .ReplaceQueryParam "prac.strNazwisko is not null", "1=1"
    .ReplaceQueryParam "[PROWIZJA]", Replace(CStr(curProwizja),",",".")
    .ReplaceQueryParam "psp.p_ddatawyst", "sprz.dDataWyst"

    rapeng_.write_actual_param so,rapeng_.get_raport_param()
    if not .perform then
    so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	  end if    
  end if

%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
pProdHierarchy.manual_done() : set pProdHierarchy = nothing
set utilProdHierarchy = nothing
%>
</body>
<footer>
</footer>
</page>
