<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1200"
#include "h1231"

-->
<!-- PARAGON zbiorczy Terranova -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.JO_Miasto %>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>

<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write "KASA/SPRZEDAŻ" %>
#define KLIENT_NIP						<% so.write "" %>
#define KLIENT_KOD_MIASTO				<% so.write "" %>
#define KLIENT_ULICA_NUMER				<% so.write "" %>
#define KLIENT_MIASTO					<% so.write "" %>

#define KLIENT_JO_NAZWA					<% so.write "" %>
#define KLIENT_JO_KOD_MIASTO			<% so.write "" %>
#define KLIENT_JO_ULICA_NUMER			<% so.write "" %>
#define KLIENT_JO_MIASTO				<% so.write "" %>



<!-- Informacje rachunku -->
#define DOKUMENT_NUMER					<% so.write g_strNrDok %>
#define DOKUMENT_DATA_SPRZEDAZY			<% so.write doc_.afc.display.fulldate(rapeng_.get_raport_param().value(0).first_value) %>
#define DOKUMENT_WARTOSC_VAT			<% so.write MONEY(curSumaVATPAR)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(curSumaBruttoPAR)%>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(curSumaNettoPAR)%>

<!-- pozycje paragonu -->
#define POZ_JM							<% so.write "szt." %>
#define POZ_VAT							<% so.write "22" %>



<page style='36' margins='700,700,700,700'>
<config>
<%

dim pM60294 : set pM60294 = doc_.getmodule(60294)



dim curSumaNetto_TN : curSumaNetto_TN = ccur(0.0)
dim curSumaNetto_RN : curSumaNetto_RN = ccur(0.0)
dim curSumaNetto_IN : curSumaNetto_IN = ccur(0.0)

dim curSumaBrutto_TN : curSumaBrutto_TN = ccur(0.0)
dim curSumaBrutto_RN : curSumaBrutto_RN = ccur(0.0)
dim curSumaBrutto_IN : curSumaBrutto_IN = ccur(0.0)

dim ilosc_TN : ilosc_TN = ccur(0.0)
dim ilosc_RN : ilosc_RN = ccur(0.0)
dim ilosc_IN : ilosc_IN = ccur(0.0)

dim strSQL
dim strTypLicznika
dim bKorekta
bKorekta = (rapeng_.get_raport_param().value(1).first_value = 1)

'Rinascimento = grupa BC
dim idGrProdTN : idGrProdTN = trans_.findobjid(TYPEID_N5GRUPAPRODUKTOW,"strNazwa='TERRANOVA'")
dim idGrProdRN : idGrProdRN = trans_.findobjid(TYPEID_N5GRUPAPRODUKTOW,"strNazwa='RINASCIMENTO'")
dim idGrProdKosmetyki : idGrProdKosmetyki = trans_.findobjid(TYPEID_N5GRUPAPRODUKTOW,"strNazwa='KOSMETYKI'")

strSQL = "select 'c_ilosc' = isnull(sum(isnull(t_0.c_curIloscOpak,0) - isnull(t_orgsprz.c_curIloscOpak,0)),0), " +_
	"'c_brutto' = isnull(sum(isnull(t_0.c_curiloscopak * t_0.c_curcenabrutto,0) - isnull(t_orgsprz.c_curiloscopak * t_orgsprz.c_curcenabrutto,0)),0), " +_
	"'c_netto'  = isnull(sum(isnull(t_0.c_curiloscopak * t_0.c_curcenanetto,0) - isnull(t_orgsprz.c_curiloscopak * t_orgsprz.c_curcenanetto,0)),0)" +_
	" from vlist_n5sprzedaz_listPozycje t_0 " +_
	" left outer join vlist_n5sprzedaz_listpozycje t_orgsprz on t_0.p_ppopsprzed = t_orgsprz.p_idobj and t_0.coll_lp = t_orgsprz.coll_lp "+_
	" join n5produkt t_prod on t_0.c_pprodukt = t_prod.idobj " +_
	" where t_0.p_ddatawyst = " + trans_.afc.convert.date2SQL(rapeng_.get_raport_param().value(0).first_value) +_
	" and t_0.p_prejestrdok in (select idobj from n5rejestrdok where eTyp ="


if bKorekta then
	strSQL = strSQL + "N5REJESTRDOK_KOR_PARAGON)"
	strTypLicznika = "KPR"
else
	strSQL = strSQL + "N5REJESTRDOK_PARAGON)"
	strTypLicznika = "PAR"
end if


dim oRS
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdTN))

curSumaNetto_TN = ccur(oRS("c_netto"))
curSumaBrutto_TN = ccur(oRS("c_brutto"))
ilosc_TN = ccur(oRS("c_ilosc"))

set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdRN))
curSumaNetto_RN = ccur(oRS("c_netto"))
curSumaBrutto_RN = ccur(oRS("c_brutto"))
ilosc_RN = ccur(oRS("c_ilosc"))

set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdKosmetyki))
curSumaNetto_IN = ccur(oRS("c_netto"))
curSumaBrutto_IN = ccur(oRS("c_brutto"))
ilosc_IN = ccur(oRS("c_ilosc"))
'-----------------------------------------
dim strWhereGot : strWhereGot = "t_0.p_pSposobPlatnosci in (select idobj from n5sposplat where eTyp = 1)"
dim strWhereKarta : strWhereKarta = "t_0.p_pSposobPlatnosci in (select idobj from n5sposplat where eTyp = 2)"
dim curSumaBruttoGot
dim curSumaVATGot
set oRS = trans_.createadors(strSQL + " and " + strWhereGot)
curSumaBruttoGot = ccur(oRS("c_brutto"))
curSumaVATGot = curSumaBruttoGot - ccur(oRS("c_netto"))

dim curSumaBruttoKarta
dim curSumaVATKarta
set oRS = trans_.createadors(strSQL + " and " + strWhereKarta)
curSumaBruttoKarta = ccur(oRS("c_brutto"))
curSumaVATKarta = curSumaBruttoKarta - ccur(oRS("c_netto"))

dim curSumaNetto_TN_Got
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdTN) + " and " + strWhereGot)
curSumaNetto_TN_Got = ccur(oRS("c_netto"))

dim curSumaNetto_RN_Got
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdRN) + " and " + strWhereGot)
curSumaNetto_RN_Got = ccur(oRS("c_netto"))

dim curSumaNetto_IN_Got
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdKosmetyki) + " and " + strWhereGot)
curSumaNetto_IN_Got = ccur(oRS("c_netto"))

dim curSumaNetto_TN_Karta
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdTN) + " and " + strWhereKarta)
curSumaNetto_TN_Karta = ccur(oRS("c_netto"))

dim curSumaNetto_RN_Karta
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdRN) + " and " + strWhereKarta)
curSumaNetto_RN_Karta = ccur(oRS("c_netto"))

dim curSumaNetto_IN_Karta
set oRS = trans_.createadors(strSQL + " and t_prod.pGrupaProd = " + cstr(idGrProdKosmetyki) + " and " + strWhereKarta)
curSumaNetto_IN_Karta = ccur(oRS("c_netto"))

dim curSumaVAT_TN : curSumaVAT_TN = curSumaBrutto_TN - curSumaNetto_TN
dim curSumaVAT_RN : curSumaVAT_RN = curSumaBrutto_RN - curSumaNetto_RN
dim curSumaVAT_IN : curSumaVAT_IN = curSumaBrutto_IN - curSumaNetto_IN

dim curSumaBruttoPAR : curSumaBruttoPAR = curSumaBrutto_TN + curSumaBrutto_RN + curSumaBrutto_IN

dim curSumaNettoPAR : curSumaNettoPAR = curSumaNetto_TN + curSumaNetto_RN + curSumaNetto_IN

dim curSumaVATPAR : curSumaVATPAR = curSumaVAT_TN + curSumaVAT_RN + curSumaVAT_IN

dim g_strNrDok
dim pM60293 : set pM60293 = doc_.getmodule(60293)
dim oGaGLC : set oGaGLC = pM60293.new_GandGLocalConfig()
dim strKodSklepuTN : strKodSklepuTN = oGaGLC.m_strTNShopId

dim g_iNrDok : g_iNrDok = pM60294.gg_get_dok_nr_for_day(strTypLicznika,rapeng_.get_raport_param().value(0).first_value)
g_strNrDok = "06-" + strTypLicznika + "/" + cstr(g_iNrDok) + "/" + strKodSklepuTN


function write_dekret(strKonto,curWn,curMa,strOpis)
	if curWn <> 0.0 or curMa <> 0.0 then
	so.write "<tr><td><t>" + strKonto + "</t></td><td align='right'><t>"
	if curWn <> 0.0 then
		so.write MONEY(curWn)
	end if
	so.write "</t></td><td align='right'><t>"
	if curMa <> 0.0 then
		so.write MONEY(curMa)
	end if
	so.write "</t></td><td><t>" + strOpis + "</t></td></tr>"
	end if
end function
%>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 

]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>					
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>

						<!-- Dane sprzedawcy - FIRMA -->
						<tr>						
							<td align='left'>
								<text bold='true'><![CDATA[Sprzedawca:]]></text>
							</td>					
						</tr>
						<tr>						
							<td align='left'>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>					
						</tr>
						<tr>						
							<td align='left'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t><t>,</t><t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<tr>
							<td align='left'>
								<t><![CDATA[NIP: FIRMA_NIP]]></t>
							</td>
						</tr>						
						<tr>
							<td align='left'>
								<t><![CDATA[<%so.write util_.JO_Nazwa %>]]></t>
							</td>					
						</tr>
						<tr>
							<td align='left'>
								<t><![CDATA[<%so.write util_.JO_Adres %>]]></t>
							</td>					
						</tr>

						ROW_SEPARATOR(1)	

						<tr>
							<td align='center'>
								<t bold='true' fontsize='7'>PARAGON <%if bKorekta then so.write " - KOREKTA" end if %></t>
							</td>
						</tr>
						<tr>
							<td align='center'>
								<t bold='true' fontsize='5'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>	
						<tr>
							<td align='center'>
								<t bold='true' fontsize='5'><![CDATA[KLIENT_NAZWA]]></t>
							</td>
						</tr>						


						<tr>
							<td align='center'>
								<t bold='true' fontsize='5'><![CDATA[Data: DOKUMENT_DATA_SPRZEDAZY]]></t>
							</td>
						</tr>
						<%
						dim strInfo
						strInfo = util_.input_box("Numer dobowego raportu fiskalnego","Podaj numer dobowego raportu fiskalnego (Z-ki)",vbOKCancel)
						%>
						<tr>
							<td align='center'>
								<t bold='true' fontsize='5'>
									<![CDATA[Numer dobowego raportu fiskalnego: <%so.write strInfo%>]]>
								</t>
							</td>
						</tr>
						
						ROW_SEPARATOR(1)
											
					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)

		<tr>
			<td>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td align='right'>
								<text>Ilość</text>
							</td>							
							<td align='center'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='center'>
								<text>St. VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td align='right'> 
								<t>1</t>
							</td>
							<td>
								<text><![CDATA[Towary Terranova]]></text><t>&nbsp;</t><text><![CDATA[]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write doc_.afc.display.quantity(ilosc_TN,"",0) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_JM]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaNetto_TN) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaVAT_TN) %>]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaBrutto_TN) %>]]></t>
							</td>
						</tr>
						<tr>
							<td align='right'> 
								<t>2</t>
							</td>
							<td>
								<text><![CDATA[Towary Rinascimento]]></text><t>&nbsp;</t><text><![CDATA[]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write doc_.afc.display.quantity(ilosc_RN,"",0) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_JM]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaNetto_RN) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaVAT_RN) %>]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaBrutto_RN) %>]]></t>
							</td>
						</tr>
						<tr>
							<td align='right'> 
								<t>3</t>
							</td>
							<td>
								<text><![CDATA[Towary kosmetyki]]></text><t>&nbsp;</t><text><![CDATA[]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write doc_.afc.display.quantity(ilosc_IN,"",0) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_JM]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaNetto_IN) %>]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaVAT_IN) %>]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[<% so.write MONEY(curSumaBrutto_IN) %>]]></t>
							</td>
						</tr>

					</tbody>
					<tfoot>
						<tr>
							<td colspan='3' bordercolor='transparent'>
							</td>
							<td align='right'>
								<text bold='true' >Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>								
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>						
						<tr>
							<td colspan='4' bordercolor='transparent'>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>					
							<td align='center'>
								<t><![CDATA[22]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>
							</td>					
						</tr>
					</tfoot>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)	
		<tr>
			<td>	
				<t>.........................................................................</t>
			</td>							
		</tr>
		<tr>
			<td>	
				<t fontsize='2'>Imię i nazwisko osoby wystawiającej dokument</t>
			</td>				
		</tr>
		ROW_SEPARATOR(1)	
		<tr>
			<td>
				<table border='1' width='min'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td><t size='10'>Konto</t></td>
							<td><t size='10'>Wn</t></td>
							<td><t size='10'>Ma</t></td>
							<td><t size='10'>Opis</t></td>
						</tr>
					</thead>
					<tbody>
						<%write_dekret "103-" + strKodSklepuTN,curSumaBruttoGot,0,"Utarg "+ g_strNrDok %>
						<%write_dekret "733-" + strKodSklepuTN,0,curSumaNetto_TN_Got,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "729-" + strKodSklepuTN,0,curSumaNetto_RN_Got,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "212-2-" + strKodSklepuTN,0,curSumaNetto_IN_Got,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "222",0,curSumaVATGot,"Sprzedaż sklep "+ g_strNrDok%>

						<%write_dekret "209-2-" + strKodSklepuTN,curSumaBruttoKarta,0,"Utarg "+ g_strNrDok%>
						<%write_dekret "733-" + strKodSklepuTN,0,curSumaNetto_TN_Karta,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "729-" + strKodSklepuTN,0,curSumaNetto_RN_Karta,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "212-2-" + strKodSklepuTN,0,curSumaNetto_IN_Karta,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "222",0,curSumaVATKarta,"Sprzedaż sklep "+ g_strNrDok%>

						<%write_dekret "099-1",ilosc_TN,0,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "799-1-" + strKodSklepuTN,0,ilosc_TN,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "099-2",ilosc_RN,0,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "799-2-" + strKodSklepuTN,0,ilosc_RN,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "099-3",ilosc_IN,0,"Sprzedaż sklep "+ g_strNrDok%>
						<%write_dekret "391-1-" + strKodSklepuTN,0,ilosc_IN,"Sprzedaż sklep "+ g_strNrDok%>
					</tbody>
				</table>
			</td>
		</tr>		
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)

		<tr>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
