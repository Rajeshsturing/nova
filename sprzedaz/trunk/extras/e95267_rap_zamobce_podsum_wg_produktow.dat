<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Zamówienia obce - podsumowanie wg produktów 


#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_PROD_FIRST_EXPR		t_4.strIndeks
#define C_FIELD_PROD_SECOND_EXPR	t_4.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks produktu
#define C_FIELD_SECOND_HUMANNAME 	Nazwa produktu
#define C_FIELD_FIRST_ALIGN 		right
#define C_FIELD_SECOND_ALIGN 		left
#else
#define C_FIELD_PROD_FIRST_EXPR		t_4.strNazwa
#define C_FIELD_PROD_SECOND_EXPR	t_4.strIndeks
#define C_FIELD_FIRST_HUMANNAME 	Nazwa produktu
#define C_FIELD_SECOND_HUMANNAME 	Indeks produktu
#define C_FIELD_FIRST_ALIGN 		left
#define C_FIELD_SECOND_ALIGN 		right
#endif



-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()


query = "select 'c_oznprod'= max(t_4.strCecha1) , 'c_prod_first'=max(C_FIELD_PROD_FIRST_EXPR),'c_prod_second'=max(C_FIELD_PROD_SECOND_EXPR), "+_
" 'c_1'=10131,'c_id'=max(t_4.IdObj),'c_3'=10108, "+_
" 'c_prod_id'=max(t_1.IdObj),'c_6'=max(t_1.strNazwa),'c_8'=max(t_1.IdObj), "+_
" 'c_11'=max(t_1.IdObj),'c_12'=max(t_opak.strNazwa), 'c_prec'=MAX(t_jedn.nDokladnosc),"+_
" 'c_ilosc_ewid'=SUM(t_opak.currKrotnosc * (t_zam.c_curIloscOpak) ) , "+_
" 'c_jedn_ewid'=MAX(t_jedn_ewid.nDokladnosc), 'c_jedn_skrot'=MAX(t_jedn_ewid.strSkrot), "+_
" 'c_ile_opak'=sum(t_zam.c_curIloscOpak), 'c_opak'=max(t_jedn.strSkrot),"+_
" 'c_wart_netto'=sum(t_zam.c_curWartNetto), "+_
" 'c_wart_brutto'=sum(t_zam.c_curWartNetto) + sum(t_zam.c_curVAT) , "+_
" 'c_wart_vat'=sum(t_zam.c_curVAT), "+_
" 'c_ile_zreal'=sum(t_zam.c_pzam_curiloscopakzreal), 'c_ile_poz'=sum(t_zam.c_curiloscopakpoz), "+_
" 'c_wart_netto_zreal'=sum(t_zam.c_curcenanettowal * t_zam.c_pzam_curiloscopakzreal), "+_
" 'c_wart_netto_niezreal'=sum(t_zam.c_curcenanettowal * t_zam.c_curiloscopakpoz)  "+_ 
" from vlist_n5zamowienie_listpozycje as t_zam "+_
" inner join n5klient as t_1 on t_zam.p_pKlient = t_1.IdObj  "+_
" inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
" inner join n5produkt as t_4 on t_zam.c_pProdukt = t_4.IdObj "+_
" inner join n5grupaproduktow as t_5 on t_4.pGrupaProd = t_5.IdObj "+_
" inner join n5opakowanie_produktu as t_opak on t_zam.c_pOpak  = t_opak.IdObj "+_
" inner join n5jednostka as t_jedn on t_opak.pJednOpak = t_jedn.IdObj  " + _
" inner join n5jednostka as t_jedn_ewid on t_4.pJednostkaEwid = t_jedn_ewid.IdObj  "+_
" inner join n5rejestrdok as t_6 on t_zam.p_pRejestrDok = t_6.IdObj "+_
" where  %1  and  %2  and  %3  and  %4  and  %5  and  %6  and  %7  and  %8 and EXTRA_CUSTOMER_FILTER_AND(9)  "+_
" group by t_4.IdObj,t_opak.idobj "+_
" order by c_prod_first "
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_zam.p_dDataWyst")	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_6.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__ZAM_OBCE) order by strNazwa "
	pParamArray.add pParam2

	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_4.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_4.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_5.strNazwa")
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>



<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%

end if
%>
<td align='right'>RXE_LP</td>
	<td align='C_FIELD_FIRST_ALIGN'>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_id,c_prod_first)
	</td>

#ifdef _IOW

	<td align='C_FIELD_SECOND_ALIGN'>
		RXE_AUTO_TEXT(c_oznprod)
	</td>

#endif


	<td align='C_FIELD_SECOND_ALIGN'>
		RXE_AUTO_TEXT(c_prod_second)
	</td>
	<td>
		RXE_AUTO_TEXT(c_12)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ile_opak,c_opak,c_prec)  
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ilosc_ewid,c_jedn_skrot,c_jedn_ewid) 
	</td>	
	<td align='right'>
		RXE_QUANTITY_CCC(c_ile_zreal,c_opak,c_prec) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ile_poz,c_opak,c_prec) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto_zreal,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wart_netto_niezreal,"",2)
	</td>
	
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>

	<td width='min'><t>LP</t></td>
	<td width='max' >
		<t><![CDATA[C_FIELD_FIRST_HUMANNAME]]></t>
	</td>


#ifdef _IOW

	<td width='max'>
		<t><![CDATA[Oznaczenie producenta]]></t>
	</td>

#endif


	<td width='max'>
		<t><![CDATA[C_FIELD_SECOND_HUMANNAME]]></t>
	</td>
	<td width='max'>
		<text><![CDATA[Nazwa opakowania]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość opakowań zamówiona]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość w jedn.ewid.]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość zrealizowana]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość pozostała do realizacji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto zamówienia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto zrealizowana]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto niezrealizowana]]></text>
	</td>
	
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>

#ifdef _IOW
<td style='27' colspan='9' />
#else
<td style='27' colspan='8' />
#endif

	

	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(3).result)
	</td>

</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_ilosc_ewid").add_sumator("c_wart_netto").add_sumator("c_wart_netto_zreal").add_sumator("c_wart_netto_niezreal")

if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
