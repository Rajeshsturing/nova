<?xml version="1.0" encoding="windows-1250" ?>

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Biała lista

#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define KLIENT_NAZWA	<% so.write strNazwa %>
#define KLIENT_NIP		<% so.write strNIP %>
#define RACHUNEK1		<% so.write strRachunek1 %>
#define RACHUNEK2		<% so.write strRachunek2 %>
#define RACHUNEK3		<% so.write strRachunek3 %>
#define STATUS			<% so.write strStatus %>
#define IDENT			<% so.write strKod %>

<page style='36' margins='700,700,700,700'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
dim g_pModule60106: set g_pModule60106 = doc_.getmodule(60106)

function drawRow(byref oRS)
	dim strNazwa: strNazwa = oRS("strNazwa").value
	dim strNIP: strNIP = oRS("strNIP").value
	dim strSkrot: strSkrot = oRS("strSkrot").value
	if InStr(strNIP, "PL") = 1 then
		exit function
	end if

	dim strRachunek1: strRachunek1 = trim(oRS("strRachunek1").value)
	dim strRachunek2: strRachunek2 = trim(oRS("strRachunek2").value)
	dim strRachunek3: strRachunek3 = trim(oRS("strRachunek3").value)

	if strRachunek1 = "" and strRachunek2 = "" and strRachunek3 = "" then
		%>
			<tr>
				<td>
					<text><![CDATA[KLIENT_NAZWA]]></text>
				</td>
				<td>
					<text><![CDATA[KLIENT_NIP]]></text>
				</td>
				<td>
					<text><![CDATA[brak rachunku bankowego w kartotece]]></text>
				</td>
				<td></td>
				<td></td>
			</tr>
		<%		
	else

		dim strAnswer1: strAnswer1 = g_pModule60106.RachStatusKas(strNIP, strRachunek1, strSkrot)
		dim strAnswer2: strAnswer2 = g_pModule60106.RachStatusKas(strNIP, strRachunek2, strSkrot)
		dim strAnswer3: strAnswer3 = g_pModule60106.RachStatusKas(strNIP, strRachunek3, strSkrot)
		dim strAnswer: strAnswer = strAnswer1 + "|" + strAnswer2 + "|" + strAnswer3
		dim strStatusKAS: strStatusKAS = g_pModule60106.SetKasStatus(strAnswer,trans_.var(GVAR_TODAY))
		dim strStatus, strKod

		if strAnswer1 <> "" then
			strStatus = g_pModule60106.GetKasStatus(strStatusKAS, 1)
			strKod = g_pModule60106.GetKod(strAnswer1)
		%>
			<tr>
				<td>
					<text><![CDATA[KLIENT_NAZWA]]></text>
				</td>
				<td>
					<text><![CDATA[KLIENT_NIP]]></text>
				</td>
				<td>
					<text><![CDATA[RACHUNEK1]]></text>
				</td>
				<td align='center'>
					<text><![CDATA[STATUS]]></text>
				</td>
				<td>
					<text><![CDATA[IDENT]]></text>
				</td>
			</tr>
		<%
			strNazwa = ""
			strNIP = ""
		end if

		if strAnswer2 <> "" then
			strStatus = g_pModule60106.GetKasStatus(strStatusKAS, 2)
			strKod = g_pModule60106.GetKod(strAnswer2)
		%>
			<tr>
				<td>
					<text><![CDATA[KLIENT_NAZWA]]></text>
				</td>
				<td>
					<text><![CDATA[KLIENT_NIP]]></text>
				</td>
				<td>
					<text><![CDATA[RACHUNEK2]]></text>
				</td>
				<td align='center'>
					<text><![CDATA[STATUS]]></text>
				</td>
				<td>
					<text><![CDATA[IDENT]]></text>
				</td>
			</tr>
		<%
			strNazwa = ""
			strNIP = ""
		end if

		if strAnswer3 <> "" then
			strStatus = g_pModule60106.GetKasStatus(strStatusKAS, 3)
			strKod = g_pModule60106.GetKod(strAnswer3)
		%>
			<tr>
				<td>
					<text><![CDATA[KLIENT_NAZWA]]></text>
				</td>
				<td>
					<text><![CDATA[KLIENT_NIP]]></text>
				</td>
				<td>
					<text><![CDATA[RACHUNEK3]]></text>
				</td>
				<td align='center'>
					<text><![CDATA[STATUS]]></text>
				</td>
				<td>
					<text><![CDATA[IDENT]]></text>
				</td>
			</tr>
		<%
			strNazwa = ""
			strNIP = ""
		end if
	end if
end function
%>

]]>
</script>
</config>
<header>
</header>
<body>
	<table>
		<tbody>
			<tr>
				<td ><text bold='true' ><![CDATA[H_FIRMA_NAZWA]]></text></td>
				<td align='right'><t size='3'/><t><![CDATA[<% so.write util_.Firma_Miasto + " " + doc_.afc.display.fulldate(trans_.var(GVAR_TODAY)) %>]]></t></td>
			</tr>
			<tr>
				<td><t bold='true'><![CDATA[H_FIRMA_ULICA_NUMER]]></t></td>
				<td/>
			</tr>
			<% if util_.Firma.strPoczta="" or util_.Firma.pMiejscowosc.strNazwa=util_.Firma.strPoczta then %>
			<tr>
				<td><t bold='true'><![CDATA[H_FIRMA_KOD_MIASTO]]></t></td>
				<td/>
			</tr>
			<% else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then
				if util_.Firma.strUlica <> "" then %>
			<tr>
				<td><t bold='true'><![CDATA[H_FIRMA_MIASTO]]></t></td>
				<td/>
			</tr>
				<%end if%> 
			<tr>
				<td><t bold='true'><![CDATA[H_FIRMA_KOD_POCZTA]]></t></td>
				<td/>
			</tr>
			<%	end if 
			end if
			%>
				
			ROW_SEPARATOR(1)
			
			<tr>
				<td>
					<%
					dim strSQL: strSQL = "select k.strNazwa,strNIP,strRachunek1,strRachunek2,strRachunek3,kr.strSkrot from n5klient k " +_
										 "inner join n5kraj kr on k.pKraj = kr.IdObj where k.IdObj in (" +_
										rapeng_.get_raport_param().value(0).first_value + ") order by k.strNazwa"
					dim oRS: set oRS = trans_.createadors(strSQL)
					%>
					<table border='1' >
						<thead bold='true'>
							<tr backcolor='#E0E0E0'>
								<td>
									<text size='30'>Kontrahent (nazwa)</text>
								</td>
								<td width='min'>
									<text>NIP</text>
								</td>
								<td width='5200'>
									<text>Nr rachunku bankowego</text>
								</td>
								<td width='2200'>
									<text>Widnieje w ewidencji KAS</text>
								</td>
								<td width='min'>
									<text>Identyfikator zapytania</text>
								</td>
							</tr>
						</thead>
						<tbody>
							<% do while not oRS.eof 
								drawRow oRS
								oRS.movenext	
							loop 
							%>
						</tbody>
						<tfoot>									
						</tfoot>
					</table>
				</td>
			</tr>

			ROW_SEPARATOR(1)

			<tr>
				<td>
					<t fontsize='2'>Powyższe zestawienie dotyczy tylko tych kontrahentów, dla których wartość transakcji jest równa lub większa 15 tys. zł</t>
				</td>
			</tr>
		</tbody>
	</table>
</body>
<footer>
</footer>
</page>