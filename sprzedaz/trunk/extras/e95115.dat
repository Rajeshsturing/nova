<?xml version="1.0" encoding="windows-1250" ?>

<!-- Polecenie księgowania -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto + "   " + util_.Dzisiaj%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% so.write util_.Firma_Kod_Miasto %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>

#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_KSIEGOWANIA		<% so.write doc_.afc.display.fulldate(root_.dDataKsieg) %>
#define DOKUMENT_DATA_REJESTRACJI		<% so.write doc_.afc.display.fulldate(root_.dDataRej) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_TRESC						<% so.write root_.strOpis %>


#define POZ_LP					<% so.write cstr(iter) %>
#define POZ_KONTO				<% if not pozycja.pKonto is nothing then so.write pozycja.pKonto.strSymbol end if%>
#define POZ_WN					<% so.write MONEY(pozycja.curWn) %>
#define POZ_MA					<% so.write MONEY(pozycja.curMa) %>
#define POZ_TRESC				<% so.write pozycja.strOpis %>
#define POZ_TRANSAKCJA			<% if not pozycja.pTransakcja is nothing then so.write pozycja.pTransakcja.text end if%>
#define POZ_DATA				<% so.write doc_.afc.display.fulldate(pozycja.dDataKsieg) %>
#define POZ_KWALIFIKATOR		<% if not pozycja.pKwalifikator is nothing then so.write pozycja.pKwalifikator.strNazwa end if%>





<page style='36'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>

						<tr>
							<td align='center' colspan='2'>
								<t bold='true' fontsize='6'><![CDATA[Dowód księgowy nr DOKUMENT_NUMER]]> </t>
							</td>
						</tr>												

					</tbody>
				</table>
			</td>
		</tr>

		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>						
						<tr>
							<td align='left'>
								<t>Data księgowania</t>
								<t size='3'></t>
								<t><![CDATA[DOKUMENT_DATA_KSIEGOWANIA]]></t>
							</td>
							<td align='left'>
								<t>Data rejestracji</t>
								<t size='3'></t>
								<t><![CDATA[DOKUMENT_DATA_REJESTRACJI]]></t>
							</td>
						</tr>
					</tbody>
				</table>
			</td>
		</tr>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>	
						<tr>
							<td width='min'>
								<t>Treść dokumentu:</t>
							</td>
							<td align = 'left'>
								<text><![CDATA[DOKUMENT_TRESC]]></text>
							</td>
						</tr>

					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min'>
								<t>LP</t>
							</td>
							<td>
								<text>Konto</text>
							</td>							
							<td align='right'>
								<t>Kwota Wn</t>
							</td>
							<td align='right'>
								<t>Kwota Ma</t>
							</td>
							<td align='center'>
								<text>Treść dekretu</text>
							</td>
							<td align='center'>
								<text>Symbol transakcji</text>
							</td>
							<td align='center'>
								<text>Data real.</text>
							</td>
							<td align='center'>
								<text>Kwalifikator</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%	dim iter,pozycja
							iter = 1
							for each pozycja in root_.listDekret 
						%>
						<tr>
							<td width='min'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_KONTO]]></text>
							</td>

							<td align='right'>
								<t><![CDATA[POZ_WN]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[POZ_MA]]></t>								
							</td>

							<td align='center'>
								<t><![CDATA[POZ_TRESC]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_TRANSAKCJA]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_DATA]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_KWALIFIKATOR]]></t>
							</td>
						</tr>
						<%		iter = iter + 1
							next
						%>
					</tbody>
					<tfoot>
						<%
							dim pSumator : set pSumator = root_.n5dowodksieg_get_sumator()
							dim idUnit, curSumaWn, curSumaMa, nRef
							dim strUnit
							iter = 0
							do while pSumator.get_value(iter,idUnit,curSumaWn,curSumaMa,nRef) 
								if nRef > 0 then
									if idUnit <> 0 then
										strUnit = trans_.getobj(10102,idUnit).strSkrot
									else
										strUnit = "<brak>"
									end if
						%>
							<tr bold='true'>
								<td>
								</td>
								<td backcolor='#E0E0E0'>
									<t><![CDATA[Suma ( <% so.write strUnit %> )]]></t>
								</td>
								<td width='right' backcolor='#E0E0E0'>
									<t><![CDATA[<% so.write MONEY(curSumaWn) %>]]></t>
								</td>
								<td  width='right' backcolor='#E0E0E0'>
									<t><![CDATA[<% so.write MONEY(curSumaMa) %>]]></t>
								</td>

							</tr>

						<%
									
								end if
								iter = iter + 1
							loop

						%>
						
					</tfoot>					
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>							
						</tr>
						<tr>
							<td>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td>	
								<t fontsize='2'>Imię i nazwisko i podpis osoby wprowadzającej dokument</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
