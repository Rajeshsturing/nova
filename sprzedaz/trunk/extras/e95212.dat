<!--
RAPTEMPLATE_VAT_SPRZEDAZ_STAWKAMI

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Rejestr sprzedaży VAT
#define CTRLID_MAINTABLE				102
#define CTRLID_HEADER_ROW       103
#define GODZINA_WYDRUKU                 <% so.write cstr(FormatDateTime(Now(),3)) %>

#macro RXE_AUTO_TEXT_LEN(_val_col_,_len_)								<% if len(cstr(pRec("_val_col_"))) > _len_ then so.write "<text><![CD"+"ATA["+ cstr(pRec("_val_col_")) + "]"+"]></text>" else so.write "<t><![CDA"+"TA["+ cstr(pRec("_val_col_")) + "]"+"]></t>" %>
#macro RXE_FORCE_LEN(_val_col_,_len_)	<%so.write "<text><![CD"+"ATA["+ left(cstr(pRec("_val_col_")),_len_) + "]"+"]></text><text><![CD"+"ATA["+mid(cstr(pRec("_val_col_")),_len_) + "]"+"]></text>"%>

#ifdef ENABLE_DB12
#define COUNTERS_COUNT	19
#else
#define COUNTERS_COUNT	18
#endif

#define BIG_COLSPAN		13

#ifdef APPCONFIG_HIDE_NP_VAT
#define SHOW_VATNP		0
#else
#define SHOW_VATNP		1
#endif

#define ENUM_VAT22    1
#define ENUM_VAT23    2
#define ENUM_VAT7     3
#define ENUM_VAT8     4
#define ENUM_VAT3     5
#define ENUM_VAT5     6
#ifdef ENABLE_DB12
#define ENUM_VAT23oo  7
#endif

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
VB_PRINTPREV_LANDSCAPE_COMMON
VB_PRINT_LANDSCAPE_COMMON


function c##CTRLID_MAINTABLE##_on_table_split(byref pClonedTable,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	if yAreaY <> yCount then

		dim oRow, strColValue
		if not page_.ctrl(CTRLID_HEADER_ROW).userprop is nothing then
			if page_.ctrl(CTRLID_HEADER_ROW).userprop.exists(0) then
				strColValue = page_.ctrl(CTRLID_HEADER_ROW).userprop.prop(0)
				if Len(strColValue) > 1 then
					strColValue = Mid(strColValue,2)
				end if
			end if
		end if    
    
		dim oTB : set oTB = doc_.afc.new_tb(page_).attach(pClonedTable).section_foot
		oTB.removeall
		dim curArr(COUNTERS_COUNT)
		dim iter		
		for iter = 1 to COUNTERS_COUNT
			curArr(iter) = ccur(0.0)
		next
		
		dim pRow
		dim curSumaWartoscNaStronie : curSumaWartoscNaStronie = ccur(0.0)
		dim i:i = 1
		for each pRow in pClonedTable.body
		  if not pRow.userprop is nothing then
			  for iter = 1 to COUNTERS_COUNT
				  if pRow.userprop.exists(iter) then
					  curArr(iter) = curArr(iter) + ccur(pRow.userprop(iter)) 
				  end if
			  next
			  i = i + 1
		  end if
		next
		
		'podsumowanie na stronie  ---------------------------------------------------------------------- 	
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
		oTB.newcell
		oTB.newcell.cell.colspan=2
		oTB.addtext "Na stronie"
		dim pLastRowUserProp : set pLastRowUserProp = pClonedTable.body.row(pClonedTable.body.count).userprop
		
		for iter = 1 to 4
			oTB.newcell.addtext("")
		next
    
		'wartość netto, vat, brutto
		for iter = 1 to 3
			oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
		next
    
		'vat 23
		if Mid(strColValue,ENUM_VAT23,1) = "1" then
			for iter = 13 to 14
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if
		'vat 8
		if Mid(strColValue,ENUM_VAT8,1) = "1" then
			for iter = 15 to 16
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if  
		'vat 5
		if Mid(strColValue,ENUM_VAT5,1) = "1" then
			for iter = 17 to 18
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if          
#ifdef ENABLE_DB12
		'vat 23oo
		if Mid(strColValue,ENUM_VAT23oo,1) = "1" then
			for iter = 18 to 19
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if
#endif    

		'vat 22
		if Mid(strColValue,ENUM_VAT22,1) = "1" then
			for iter = 4 to 5
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if
		'vat 7
		if Mid(strColValue,ENUM_VAT7,1) = "1" then
			for iter = 6 to 7
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if  
		'vat 3
		if Mid(strColValue,ENUM_VAT3,1) = "1" then
			for iter = 8 to 9
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			next      
		end if 

		'vat 0, zw
		for iter = 10 to 11
			oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
		next
if SHOW_VATNP = 1 then
			oTB.newcell.addtext(MONEY(curArr(12))).cell.align=ALIGN_RIGHT
end if
    '-------------------------------------------------------------------------------------------------

		'posumowanie narastajaco  ------------------------------------------------------------------------
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
		oTB.newcell
		oTB.newcell.cell.colspan=2
		oTB.addtext "Narastająco"		
		
		for iter = 1 to 4
			oTB.newcell.addtext("")
		next
    
		'wartość netto, vat, brutto
		for iter = 1 to 3
			oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
		next
     
		'vat 23
		if Mid(strColValue,ENUM_VAT23,1) = "1" then
			for iter = 13 to 14
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if
		'vat 8
		if Mid(strColValue,ENUM_VAT8,1) = "1" then
			for iter = 15 to 16
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if  
		'vat 5
		if Mid(strColValue,ENUM_VAT5,1) = "1" then
			for iter = 17 to 18
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if    
#ifdef ENABLE_DB12
		'vat 23oo
		if Mid(strColValue,ENUM_VAT23oo,1) = "1" then
			for iter = 18 to 19
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if
#endif    
    
		'vat 22
		if Mid(strColValue,ENUM_VAT22,1) = "1" then
			for iter = 4 to 5
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if
		'vat 7
		if Mid(strColValue,ENUM_VAT7,1) = "1" then
			for iter = 6 to 7
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if  
		'vat 3
		if Mid(strColValue,ENUM_VAT3,1) = "1" then
			for iter = 8 to 9
				oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			next      
		end if
    
		'vat 0, zw
		for iter = 10 to 11
			oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
		next    

    if SHOW_VATNP = 1 then
    	oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(12 + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
    end if
	end if
end function

function on_page_split(byref pClonedPage,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	pClonedPage.footer.removeall
	dim strText
	if yCount > 1 then
#ifdef _CDNOLAWA  
		strText = page_.topelement.title + " -  strona " + cstr(yAreaY)
#else
    strText = page_.topelement.title + " -  strona " + cstr(yAreaY) + " z " + cstr(yCount)
#endif
	end if
	pClonedPage.footer.addnew(0,-1).text = strText
end function
<%
dim ArrCurGlobSum(COUNTERS_COUNT)
dim ArrCurSecSum(COUNTERS_COUNT)
dim ArrCurBodyVal(COUNTERS_COUNT)
dim g_arrCurRunningSum(COUNTERS_COUNT)
dim curWartNaStronie(COUNTERS_COUNT)

sub reset_global_sums()
	dim iter
	for iter = 0 to ubound(ArrCurGlobSum)
		ArrCurGlobSum(iter) = ccur(0.0)
	next
end sub

sub reset_section_sums()
	dim iter
	for iter = 0 to ubound(ArrCurSecSum)
		ArrCurSecSum(iter) = ccur(0.0)
	next
end sub

sub update_sum(nIter,curVal)
	ArrCurGlobSum(nIter) = ArrCurGlobSum(nIter) + curVal
	ArrCurSecSum(nIter)  = ArrCurSecSum(nIter) + curVal
end sub


dim pMod: set pMod = doc_.getmodule(60129)

'ustawia filtr dla kolumn na True w zależności od trybu VAT
function setMode(nVat): setMode = False
  if pMod.isNewRokKsieg() then
    'checkbox z nowymi stawkami na True
    select case nVat
#ifdef ENABLE_DB12
      case 23,8,5,24
#else
      case 23,8,5
#endif  
        setMode = True
    end select
  else
    'checkbox ze starymi stawkami na True
    select case nVat
      case 22,7,3
        setMode = True
    end select    
  end if
end function

'zwraca liczbę zaznaczonych checkbox w filtrze Kolumny
function getColNr(): getColNr = clng(0)
  dim iter
  for iter = 0 to pParamArray.value(3).selected.upperIndex
    if pParamArray.value(3).selected.value(iter) then
      getColNr = getColNr + 2
    end if
  next
end function

'zwraca true gdy w filtrze wybrano kolumny o danej stawce VAT
function isChecked(enumVat): isChecked = false
  isChecked = pParamArray.value(3).selected.value(enumVat - 1)  
end function

'zamienia wartości wybranych kolumn na string
function col2Str(): col2Str = "9"
  dim iter
  for iter = 0 to pParamArray.value(3).selected.upperIndex
    if pParamArray.value(3).selected.value(iter) then
      col2Str = col2Str + Cstr(1)
    else
      col2Str = col2Str + Cstr(0)
    end if
  next
end function
%>
<%
function query()
query = _
#ifdef ENABLE_DB12
"select 'c_nazwa_rej'=t_1.strNazwa,'c_datawyst'=t_sprz.dDataWyst,'c_2'=t_sprz.strNrDok,'c_3'=t_sprz.dDataWyst, " +_
"'c_4'=t_sprz.dDataSprzed,'c_5'=t_sprz.strNrDok,'c_7'=t_sprz.IdObj,'c_typeid'=TYPEID_N5SPRZEDAZ,'c_8'=t_klient.strNazwa, " +_
"'c_10'=t_klient.IdObj,'c_11'=t_klient.strNIP,'c_popdok'=t_sprz.pPopSprzed," +_
"'c_netto'=t_sprz.curSumaNetto,'c_vat'=t_sprz.curSumaVAT,'c_brutto'=t_sprz.curSumaBrutto," +_
"'c_n_23oo'=t_sprz.curNetto23oo,'c_v_23oo'=t_sprz.curVat23oo," +_
"'c_n_23'=t_sprz.curNetto23,'c_v_23'=t_sprz.curVat23," +_
"'c_n_08'=t_sprz.curNetto8,'c_v_08'=t_sprz.curVat8," +_
"'c_n_05'=t_sprz.curNetto5,'c_v_05'=t_sprz.curVat5," +_
"'c_n_22'=t_sprz.curNetto22,'c_v_22'=t_sprz.curVat22," +_
"'c_n_07'=t_sprz.curNetto7,'c_v_07'=t_sprz.curVat7," +_
"'c_n_03'=t_sprz.curNetto3,'c_v_03'=t_sprz.curVat3," +_
"'c_n_zw'=t_sprz.curNettoZw,'c_n_0'=t_sprz.curNetto0," +_
"'c_n_np'=t_sprz.curNettoNp, " +_
"'c_rej_typ'=t_1.etyp, 'c_ob_idobj'=t_sprz.idobj  "+_
"from n5sprzedaz as t_sprz " +_
"inner join n5rejestrdok as t_1 on t_sprz.pRejestrDok = t_1.IdObj " +_
"inner join n5klient as t_klient on t_sprz.pKlient = t_klient.IdObj " +_
"where t_sprz.pRozlVAT<>0 and  %1  and  %2  and %3 " + vbNewLine +_
"and (Year(t_sprz.dDataWyst) <= 2013  -- dokumenty przed zmiana momentu podatkowego " + vbNewLine +_
doc_.getmodule(60238).Korekty(5) + ")" +_
"union " +_
#endif
"select 'c_nazwa_rej'=t_1.strNazwa,'c_datawyst'=t_sprz.dDataWyst,'c_2'=t_sprz.strNrDok,'c_3'=t_sprz.dDataWyst, " +_
"'c_4'=t_sprz.dDataSprzed,'c_5'=t_sprz.strNrDok,'c_7'=t_sprz.IdObj,'c_typeid'=TYPEID_N5SPRZEDAZ,'c_8'=t_klient.strNazwa, " +_
"'c_10'=t_klient.IdObj,'c_11'=t_klient.strNIP,'c_popdok'=t_sprz.pPopSprzed," +_
"'c_netto'=t_sprz.curSumaNetto,'c_vat'=t_sprz.curSumaVAT,'c_brutto'=t_sprz.curSumaBrutto," +_
#ifdef ENABLE_DB12
"'c_n_23oo'=t_sprz.curNetto23oo,'c_v_23oo'=t_sprz.curVat23oo," +_
#endif
"'c_n_23'=t_sprz.curNetto23,'c_v_23'=t_sprz.curVat23," +_
"'c_n_08'=t_sprz.curNetto8,'c_v_08'=t_sprz.curVat8," +_
"'c_n_05'=t_sprz.curNetto5,'c_v_05'=t_sprz.curVat5," +_
"'c_n_22'=t_sprz.curNetto22,'c_v_22'=t_sprz.curVat22," +_
"'c_n_07'=t_sprz.curNetto7,'c_v_07'=t_sprz.curVat7," +_
"'c_n_03'=t_sprz.curNetto3,'c_v_03'=t_sprz.curVat3," +_
"'c_n_zw'=t_sprz.curNettoZw,'c_n_0'=t_sprz.curNetto0," +_
"'c_n_np'=t_sprz.curNettoNp, " +_
"'c_rej_typ'=t_1.etyp, 'c_ob_idobj'=t_sprz.idobj  "+_
"from n5sprzedaz as t_sprz " +_
"inner join n5rejestrdok as t_1 on t_sprz.pRejestrDok = t_1.IdObj " +_
"inner join n5klient as t_klient on t_sprz.pKlient = t_klient.IdObj " +_
"where t_sprz.pRozlVAT<>0 and  %1  and  %2  and %3 " + vbNewLine +_
#ifdef ENABLE_DB12
"and Year(t_sprz.dDataWyst) >= 2014 -- dokumenty po zmianie momentu podatkowego " + vbNewLine +_
"and (((t_sprz.IdObj not in (select sprzed_pDostawa from n5sprzedaz)) -- gdy faktura i dostawa pokazuj tylko fakturę " + vbNewLine +_ 
"and (t_sprz.IdObj not in (select pPopSprzed from n5sprzedaz where IdObj in (select sprzed_pDostawa from n5sprzedaz))) -- korekta dostawy + faktura do korekty dostawy  -> pokazuj tylko fakurę " + vbNewLine +_
"and (t_sprz.IdObj not in (select IdObj from n5sprzedaz where sprzed_pDostawa = 0 and pPopSprzed = 0 and IdObj not in (select pPopSprzed from n5sprzedaz) and t_sprz.pRejestrDok in (select IdObj from n5rejestrdok where eTyp not in (N5REJESTRDOK_DOSTAWA,N5REJESTRDOK_KOR_DOSTAWA)))) -- faktura bez korekty i dostawy -> nie wchodzi " + vbNewLine +_
"and (t_sprz.IdObj not in (select IdObj from n5sprzedaz where pPopSprzed > 0 and (sprzed_pDostawa = 0 and pPopSprzed in (select IdObj from n5sprzedaz where sprzed_pDostawa = 0 and year(dDataWyst) >= 2014)) and t_sprz.pRejestrDok in (select IdObj from n5rejestrdok where eTyp not in (N5REJESTRDOK_DOSTAWA,N5REJESTRDOK_KOR_DOSTAWA)))) -- korekta bez dostawy nie wchodzi gdy oryginał nie ma dostawy " + vbNewLine +_
"and (t_sprz.IdObj not in (select IdObj from n5sprzedaz where sprzed_pDostawa = 0 and IdObj in (select pPopSprzed from n5sprzedaz where sprzed_pDostawa = 0) and t_sprz.pRejestrDok in (select IdObj from n5rejestrdok where eTyp not in (N5REJESTRDOK_DOSTAWA,N5REJESTRDOK_KOR_DOSTAWA)))) -- faktura bez dostawy nie wchodzi gdy korekta też nie ma dostawy " + vbNewLine +_
") or (t_sprz.pRejestrDok in (select IdObj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_WDT,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP))) "+_
"  or (" + doc_.getmodule(60238).Korekty2014(5) + ")) "+_
#endif
"union all select 'c_nazwa_rej'=t_1.strNazwa,'c_datawyst'=t_zak.dDataWyst,'c_2'=t_zak.strNrDok,'c_3'=t_zak.dDataWyst, " +_
"'t_zak'=t_zak.dDataZakupu,'c_5'=t_zak.strNrDok,'c_7'=t_zak.IdObj,'c_typeid'=TYPEID_N5ZAKUP,'c_8'=t_klient.strNazwa, " +_
"'c_10'=t_klient.IdObj,'c_11'=t_klient.strNIP,'c_popdok'=t_zak.pPopZAkup," +_
"'c_netto'=t_zak.curSumaNetto,'c_vat'=t_zak.curSumaVAT,'c_brutto'=t_zak.curSumaBrutto," +_
#ifdef ENABLE_DB12
"'c_n_23oo'=t_zak.curNetto23oo,'c_v_23oo'=t_zak.curVat23oo," +_
#endif
"'c_n_23'=t_zak.curNetto23,'c_v_23'=t_zak.curVat23," +_
"'c_n_08'=t_zak.curNetto8,'c_v_08'=t_zak.curVat8," +_
"'c_n_05'=t_zak.curNetto5,'c_v_05'=t_zak.curVat5," +_
"'c_n_22'=t_zak.curNetto22,'c_v_22'=t_zak.curVat22," +_
"'c_n_07'=t_zak.curNetto7,'c_v_07'=t_zak.curVat7," +_
"'c_n_03'=t_zak.curNetto3,'c_v_03'=t_zak.curVat3," +_
"'c_n_zw'=t_zak.curNettoZw,'c_n_0'=t_zak.curNetto0," +_
"'c_n_np'=t_zak.curNettoNp, " +_
"'c_rej_typ'=t_1.etyp, 'c_ob_idobj'=t_zak.idobj  "+_
"from n5zakup as t_zak " +_
"inner join n5rejestrdok as t_1 on t_zak.pRejestrDok = t_1.IdObj " +_
"inner join n5klient as t_klient on t_zak.pDostawca = t_klient.IdObj " +_
"where %1  and  %2 and [%3 " +_
#ifdef ENABLE_DB12
"and t_1.eTyp not in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP) " + vbNewLine +_
"union all --import spoza UE " + vbNewLine +_
"select 'c_nazwa_rej'=t_1.strNazwa,'c_datawyst'=t_zak.dDataWyst,'c_2'=t_zak.strNrDok,'c_3'=t_zak.dDataWyst, 't_zak'=t_zak.dDataZakupu, " + vbNewLine +_
"'c_5'=t_zak.strNrDok,'c_7'=t_zak.IdObj,'c_typeid'=10176,'c_8'=t_klient.strNazwa, 'c_10'=t_klient.IdObj,'c_11'=t_klient.strNIP, " + vbNewLine +_
"'c_popdok'=t_zak.pPopZAkup,'c_netto'=t_zak.curSumaNetto,'c_vat'=t_zak.curSumaVAT,'c_brutto'=t_zak.curSumaBrutto,'c_n_23oo'=t_zak.curNetto23oo, " + vbNewLine +_
"'c_v_23oo'=t_zak.curVat23oo,'c_n_23'=t_zak.curNetto23,'c_v_23'=t_zak.curVat23,'c_n_08'=t_zak.curNetto8,'c_v_08'=t_zak.curVat8, " + vbNewLine +_
"'c_n_05'=t_zak.curNetto5,'c_v_05'=t_zak.curVat5,'c_n_22'=t_zak.curNetto22,'c_v_22'=t_zak.curVat22,'c_n_07'=t_zak.curNetto7,'c_v_07'=t_zak.curVat7, " + vbNewLine +_
"'c_n_03'=t_zak.curNetto3,'c_v_03'=t_zak.curVat3,'c_n_zw'=t_zak.curNettoZw,'c_n_0'=t_zak.curNetto0,'c_n_np'=t_zak.curNettoNp, 'c_rej_typ'=t_1.etyp, " + vbNewLine +_ 
"'c_ob_idobj'=t_zak.idobj " + vbNewLine +_  
"from n5zakup as t_zak " + vbNewLine +_
"inner join n5rejestrdok as t_1 on t_zak.pRejestrDok = t_1.IdObj " + vbNewLine +_
"inner join n5klient as t_klient on t_zak.pDostawca = t_klient.IdObj " + vbNewLine +_
"where %1 and %2 and [%3 " + vbNewLine +_
"and t_1.eTyp in (N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP) " + vbNewLine +_
"and (t_zak.IdObj not in (select p_idobj from vlist_n5zakup_listPozycje)  --faktury importowe bez pozycji " + vbNewLine +_
"or t_zak.IdObj in (select zak_poz.p_idobj from vlist_n5zakup_listPozycje zak_poz inner join n5produkt p on zak_poz.c_pprodukt = p.IdObj where p.eRodzaj = N5PRODUKT_USLUGA group by zak_poz.p_idobj " + vbNewLine +_
"except " + vbNewLine +_
"select zak_poz.p_idobj from vlist_n5zakup_listPozycje zak_poz inner join n5produkt p on zak_poz.c_pprodukt = p.IdObj where p.eRodzaj = N5PRODUKT_TOWAR group by zak_poz.p_idobj)) " + vbNewLine +_
"union all select 'c_nazwa_rej'=t_1.strNazwa,'c_datawyst'=t_zak.dDataWyst,'c_2'=t_zak.strNrDok,'c_3'=t_zak.dDataWyst, " +_
"'t_zak'=t_zak.dDataZakupu,'c_5'=t_zak.strNrDok,'c_7'=t_zak.IdObj,'c_typeid'=TYPEID_N5ZAKUP,'c_8'=t_klient.strNazwa, " +_
"'c_10'=t_klient.IdObj,'c_11'=t_klient.strNIP,'c_popdok'=t_zak.pPopZAkup," +_
"'c_netto'=t_zak.curNetto23oo,'c_vat'=t_zak.curVat23oo,'c_brutto'=t_zak.curNetto23oo + t_zak.curVat23oo," +_
"'c_n_23oo'=t_zak.curNetto23oo,'c_v_23oo'=t_zak.curVat23oo," +_
"'c_n_23'=0,'c_v_23'=0," +_
"'c_n_08'=0,'c_v_08'=0," +_
"'c_n_05'=0,'c_v_05'=0," +_
"'c_n_22'=0,'c_v_22'=0," +_
"'c_n_07'=0,'c_v_07'=0," +_
"'c_n_03'=0,'c_v_03'=0," +_
"'c_n_zw'=0,'c_n_0'=0," +_
"'c_n_np'=0, " +_
"'c_rej_typ'=t_1.etyp, 'c_ob_idobj'=t_zak.idobj  "+_
"from n5zakup as t_zak " +_
"inner join n5rejestrdok as t_1 on t_zak.pRejestrDok = t_1.IdObj " +_
"inner join n5klient as t_klient on t_zak.pDostawca = t_klient.IdObj " +_
"where %1  and  %2 and [%3 " +_
"and t_zak.curNetto23oo > 0 and t_1.eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_KOR_FAKT_ZAK) " +_
#endif
"order by c_nazwa_rej,c_datawyst,c_2"
end function
%>
<%
private function getCurrentRKSId()
	if trans_.isvar(GVAR_ROKKSIEG) then
		getCurrentRKSId = trans_.var(GVAR_ROKKSIEG)
	else
		getCurrentRKSId = 0
	end if
end function

function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("dDataWyst")
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_1.idobj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where (pRokKsieg=0 or pRokKsieg=" + cstr(getCurrentRKSId()) +_
		") and eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP, " +_
#ifdef ENABLE_DB12
		"N5REJESTRDOK_DOSTAWA,N5REJESTRDOK_KOR_DOSTAWA,N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_KOR_FAKT_ZAK, " +_
#endif
#ifdef _MILOMLYN
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) and eAktywny = N5REJESTRDOK_AKTYWNY order by strNazwa "
#else
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) order by strNazwa "
#endif
	pParamArray.add pParam2

	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Okres VAT").bindexpr("pRozlVAT")
	doc_.afc.rap.param.init_on_query pParam3, trans_ , _
		"select 'bez odliczeń',0 union select ltrim(str(year(vat7_ddataod))) + '/' + substring(ltrim(str(100+month(vat7_ddataod))),2,2),idobj " +_
		"from n5rozlvat where datediff(month,vat7_ddataod," + trans_.afc.convert.date2SQL(trans_.var(GVAR_TODAY)) + ") < 12 order by 1 desc"
	pParamArray.add pParam3
  
	dim pParamCol : set pParamCol = doc_.afc.rap.param.new_choice("Kolumny")
	with pParamCol
		.multiple = true
		.names.add "Stawka 22%"
		.values.add ENUM_VAT22
		.selected.add setMode(22)
		.names.add "Stawka 23%"
		.values.add ENUM_VAT23
		.selected.add setMode(23)
		.names.add "Stawka 7%"
		.values.add ENUM_VAT7
		.selected.add setMode(7)  
		.names.add "Stawka 8%"
		.values.add ENUM_VAT8
		.selected.add setMode(8)
		.names.add "Stawka 3%"
		.values.add ENUM_VAT3
		.selected.add setMode(3)
		.names.add "Stawka 5%"
		.values.add ENUM_VAT5
		.selected.add setMode(5)  
#ifdef ENABLE_DB12
		.names.add "Stawka o.o."
		.values.add ENUM_VAT23oo
		.selected.add setMode(24)
#endif    
	end with
	pParamArray.add pParamCol

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
if pActualParam.value(iter).get_desc() <> "" then 
bAnyWritten = true
	so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='4'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%>
