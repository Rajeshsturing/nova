<%
function body_row(byref pSection,byref pRec)

  'fill up array
		ArrCurBodyVal(0) = trans_.afc.convert.round2(ccur(pRec("c_netto")))
		ArrCurBodyVal(1) = trans_.afc.convert.round2(ccur(pRec("c_vat")))
		ArrCurBodyVal(2) = trans_.afc.convert.round2(ccur(pRec("c_brutto")))
		ArrCurBodyVal(3) = trans_.afc.convert.round2(ccur(pRec("c_n_22")))
		ArrCurBodyVal(4) = trans_.afc.convert.round2(ccur(pRec("c_v_22")))
		ArrCurBodyVal(5) = trans_.afc.convert.round2(ccur(pRec("c_n_07")))
		ArrCurBodyVal(6) = trans_.afc.convert.round2(ccur(pRec("c_v_07")))
		ArrCurBodyVal(7) = trans_.afc.convert.round2(ccur(pRec("c_n_03")))
		ArrCurBodyVal(8) = trans_.afc.convert.round2(ccur(pRec("c_v_03")))
		ArrCurBodyVal(9) = trans_.afc.convert.round2(ccur(pRec("c_n_zw")))
		ArrCurBodyVal(10) = trans_.afc.convert.round2(ccur(pRec("c_n_0")))
		ArrCurBodyVal(11) = trans_.afc.convert.round2(ccur(pRec("c_n_np")))
		ArrCurBodyVal(12) = trans_.afc.convert.round2(ccur(pRec("c_n_23")))
		ArrCurBodyVal(13) = trans_.afc.convert.round2(ccur(pRec("c_v_23")))
		ArrCurBodyVal(14) = trans_.afc.convert.round2(ccur(pRec("c_n_08")))
		ArrCurBodyVal(15) = trans_.afc.convert.round2(ccur(pRec("c_v_08")))
		ArrCurBodyVal(16) = trans_.afc.convert.round2(ccur(pRec("c_n_05")))
		ArrCurBodyVal(17) = trans_.afc.convert.round2(ccur(pRec("c_v_05")))   
#ifdef ENABLE_DB12
		ArrCurBodyVal(18) = trans_.afc.convert.round2(ccur(pRec("c_n_23oo")))
		ArrCurBodyVal(19) = trans_.afc.convert.round2(ccur(pRec("c_v_23oo")))
#endif    

  curWartNaStronie(0) = ccur(pRec("c_netto"))
	curWartNaStronie(1) = ccur(pRec("c_vat"))
	curWartNaStronie(2) = ccur(pRec("c_brutto"))	
	
  'jesli korekta - odejmij oryginał
  dim iPopDok : iPopDok = clng(pRec("c_popdok"))
  if iPopDok <> 0 then
    dim oPopDok : set oPopDok = trans_.getobj(clng(pRec("c_typeid")),iPopDok)

    ArrCurBodyVal(0) = ArrCurBodyVal(0) - oPopDok.curSumaNetto
    ArrCurBodyVal(1) = ArrCurBodyVal(1) - oPopDok.curSumaVAT
    ArrCurBodyVal(2) = ArrCurBodyVal(2) - oPopDok.curSumaBrutto
    ArrCurBodyVal(3) = ArrCurBodyVal(3) - oPopDok.curNetto22
    ArrCurBodyVal(4) = ArrCurBodyVal(4) - oPopDok.curVat22
    ArrCurBodyVal(5) = ArrCurBodyVal(5) - oPopDok.curNetto7
    ArrCurBodyVal(6) = ArrCurBodyVal(6) - oPopDok.curVat7
    ArrCurBodyVal(7) = ArrCurBodyVal(7) - oPopDok.curNetto3
    ArrCurBodyVal(8) = ArrCurBodyVal(8) - oPopDok.curVat3
    ArrCurBodyVal(9) = ArrCurBodyVal(9) - oPopDok.curNettoZw
    ArrCurBodyVal(10) = ArrCurBodyVal(10) - oPopDok.curNetto0
    ArrCurBodyVal(11) = ArrCurBodyVal(11) - oPopDok.curNettoNp
    ArrCurBodyVal(12) = ArrCurBodyVal(12) - oPopDok.curNetto23
    ArrCurBodyVal(13) = ArrCurBodyVal(13) - oPopDok.curVat23
    ArrCurBodyVal(14) = ArrCurBodyVal(14) - oPopDok.curNetto8
    ArrCurBodyVal(15) = ArrCurBodyVal(15) - oPopDok.curVat8
    ArrCurBodyVal(16) = ArrCurBodyVal(16) - oPopDok.curNetto5
    ArrCurBodyVal(17) = ArrCurBodyVal(17) - oPopDok.curVat5    
#ifdef ENABLE_DB12
    ArrCurBodyVal(18) = ArrCurBodyVal(18) - oPopDok.curNetto23oo
    ArrCurBodyVal(19) = ArrCurBodyVal(19) - oPopDok.curVat23oo
#endif    
  
    set oPopDok = nothing
  end if

	dim iter
	for iter = 0 to COUNTERS_COUNT - 1
		g_arrCurRunningSum(iter) = g_arrCurRunningSum(iter) + ArrCurBodyVal(iter)
	next
			
	for iter = 0 to ubound(ArrCurBodyVal)
		update_sum iter,trans_.afc.convert.round2(ArrCurBodyVal(iter))
	next
  
	%>
	
	<tr fontsize='2' userprop='
	vc1=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(0))%>
	vc2=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(1))%>
	vc3=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(2))%>
	vc4=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(3))%>
	vc5=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(4))%>
	vc6=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(5))%>
	vc7=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(6))%>
	vc8=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(7))%>
	vc9=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(8))%>
	vc10=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(9))%>
	vc11=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(10))%>
	vc12=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(11))%>
	vc13=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(12))%>
	vc14=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(13))%>
	vc15=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(14))%>
	vc16=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(15))%>
	vc17=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(16))%>
	vc18=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(17))%>  
#ifdef ENABLE_DB12
	vc19=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(18))%>
	vc20=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(19))%>
#endif  
	vc21=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(0))%>
	vc22=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(1))%>
	vc23=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(2))%>
	vc24=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(3))%>
	vc25=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(4))%>
	vc26=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(5))%>
	vc27=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(6))%>
	vc28=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(7))%>
	vc29=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(8))%>
	vc30=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(9))%>
	vc31=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(10))%>
	vc32=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(11))%>
	vc33=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(12))%>
	vc34=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(13))%>
	vc35=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(14))%>
	vc36=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(15))%>
	vc37=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(16))%>
	vc38=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(17))%>
#ifdef ENABLE_DB12
	vc39=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(18))%>
	vc40=<%so.write doc_.afc.convert.cur2sql(g_arrCurRunningSum(19))%>
#endif
	
	%>'  
	<%
	if pRapExec.RecNr mod 2 = 0 then
	%>
	 style='37' 
	<%
	end if
	%>
	bordercolor='black'>
	
		<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
		<td>
			RXE_DATE(c_3)
		</td>
		<td>
			RXE_DATE(c_4)
		</td>
		<td>
#ifdef _DENIS	
			RXE_TEXT_LINK_FORM_CCC_EX(c_typeid,c_7,c_5,"varFormUsage=USAGE_SP_EDIT_VAT")
#else
			RXE_TEXT_LINK_FORM_CCC(c_typeid,c_7,c_5)
#endif			
		</td>
		<td width='3000'>
			RXE_TEXT_HREF(c_8,RXF_LINK_FORM_VC(TYPEID_N5KLIENT,c_10))
		</td>
		<td>
			RXE_TEXT(c_11)
		</td>
		<td align='right'  >
			RXE_MONEY_VAR(ArrCurBodyVal(0))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(1))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(2))
		</td>    
<% if isChecked(ENUM_VAT23) then %>     
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(12))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(13))
		</td>
<% end if %>
<% if isChecked(ENUM_VAT8) then %>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(14))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(15))
		</td>
<% end if %>  
<% if isChecked(ENUM_VAT5) then %>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(16))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(17))
		</td>
<% end if %>
#ifdef ENABLE_DB12
<% if isChecked(ENUM_VAT23oo) then %>     
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(18))
		</td>
		<td align='right'>
			RXE_MONEY_VAR(ArrCurBodyVal(19))
		</td>
<% end if %>
#endif
<% if isChecked(ENUM_VAT22) then %>     
