<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Czas pracy wg pracowników
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=t_prac.strNazwisko,'c_1'=t_rcp.rcp_dDataRozp,'c_2'=t_rcp.rcp_tCzasRozp, " +_
"'c_3'=t_rcp.rcp_dDataRozp,'c_4'=t_rcp.rcp_tCzasRozp,'c_5'=t_rcp.rcp_dDataZakon," +_
"'c_6'=t_rcp.rcp_tCzasZakon,'c_7'=t_typpr.tpr_strNazwa,'c_8'=t_rcp.rcp_tCzasPrzepr " +_
"from n5plrcp as t_rcp inner join n5pracownik as t_prac on t_rcp.rcp_pPracownik = t_prac.IdObj " +_
"inner join n5pltyppracy as t_typpr on t_rcp.rcp_pTypPracy = t_typpr.IdObj " +_
"left outer join n5zadanie as t_zadanie on t_rcp.rcp_pZadanie = t_zadanie.IdObj " +_
"left outer join n5klient as t_klient on t_zadanie.pKlient = t_klient.IdObj " +_
"where  %1  and  %2  and  %3  and  %4  " +_
"order by c_0,c_1,c_2"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data rozpoczecia").bindexpr("t_rcp.rcp_dDataRozp")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa pełna").bindexpr("t_typpr.tpr_strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa pełna").bindexpr("isnull(t_klient.strNazwa,'<brak>')")

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_3)
	</td>
	<td>
		RXE_TIME(c_4)
	</td>
	<td>
		RXE_DATE(c_5)
	</td>
	<td>
		RXE_TIME(c_6)
	</td>
	<td>
		RXE_TIME(c_8)
	</td>
	<td>
		RXE_AUTO_TEXT(c_7)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data rozpoczęcia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Czas rozpoczęcia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data zakończenia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Czas zakończenia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Czas przepracowany]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Typ pracy]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
