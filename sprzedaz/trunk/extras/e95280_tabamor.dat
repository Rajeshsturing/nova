<%
function body_footer(byref pSection)
%>
<tr align='right' border='0' backcolor='#eeddee' fontsize='SMALL_FONT' name='CTRLID_BODY_FOOTER'>
  <td colspan='3'></td>
  <td><t bold='true'>Razem :</t></td><td></td><td></td>
	<td>RXE_MONEY_VAR(pSection.counter(0).result)</td>
  <td>RXE_MONEY_VAR(pSection.counter(1).result)</td>
  <td>RXE_MONEY_VAR(pSection.counter(2).result)</td>
  <td>RXE_MONEY_VAR(pSection.counter(3).result)</td>
  <td>RXE_MONEY_VAR(pSection.counter(4).result)</td>
  <td>RXE_MONEY_VAR(curUmorzZwSum)</td>
  <td>RXE_MONEY_VAR(curUmorzZmSum)</td>
  <td>RXE_MONEY_VAR(curUmorzRoczneSum)</td>  
  <td>RXE_MONEY_VAR(pSection.counter(5).result)</td>
  <td>RXE_MONEY_VAR(pSection.counter(6).result)</td>
