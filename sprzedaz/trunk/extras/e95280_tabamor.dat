%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

'gdy pierwsze uruchomienie raportu => ustaw checkbox na 1
dim bCheckBox : bCheckBox = true

VB_ROW_CHECKBOX(CTRLID_SECTION_CHECKBOX,bCheckBox,false)
VB_ROW_CHECKBOX(CTRLID_ROW_CHECKBOX,bCheckBox,true)

'---------------------------------------------------------------------------------------------------
'przelicza podsumowanie sekcji w zależności od bSimpRow (true = tylko 1 wiersz, false = cała sekcja)
'---------------------------------------------------------------------------------------------------
sub recalcSumSec(byref oRow, byref oRowPodsum, byval nNumCell, byval nNumKol, byval bSimpRow)
  dim oRowSec : set oRowSec = oRow
  dim pSecProp : pSecProp = oRowSec.userprop.prop(1)
  dim oRowSum, oRowParent
  if bSimpRow then
    'gdy pojedynczy wiersz 
    set oRowSum = page_.ctrl(clng(pSecProp))          'wiersz z podsumą sekcji
    if oRow.cell(2).element(1).value = "0" then
      'sekcja
      recalcKol oRowSum, oRow, nNumCell, nNumKol, "-"
      'cały raport
      recalcKol oRowPodsum, oRow, nNumCell, nNumKol, "-"
    else
      'sekcja
      recalcKol oRowSum, oRow, nNumCell, nNumKol, "+"
      'cały raport
      recalcKol oRowPodsum, oRow, nNumCell, nNumKol, "+"      
    end if     
    'gdy wszystkie dzieci odznaczone => odznacz rodzica
    set oRowParent = page_.ctrl(clng(pSecProp - 1)).parent.parent
    checkChild oRowParent, pSecProp
  else
    'gdy cała sekcja
    set oRowSum = page_.ctrl(clng(pSecProp + 1))      'wiersz z podsumą sekcji
    'wiersze w podsekcji (children)
    set oRow = oRow.nextelement
    do while (pSecProp + 1 = oRow.userprop.prop(1))
      if oRowSec.cell(1).element(2).value = "0" then
        if oRow.cell(2).element(1).value = "1" then
          'sekcja
          recalcKol oRowSum, oRow, nNumCell, nNumKol, "-"
          'cały raport
          recalcKol oRowPodsum, oRow, nNumCell, nNumKol, "-"
          oRow.cell(2).element(1).value = "0"
        end if
      else
        if oRow.cell(2).element(1).value = "0" then
          'sekcja
          recalcKol oRowSum, oRow, nNumCell, nNumKol, "+"
          'cały raport
          recalcKol oRowPodsum, oRow, nNumCell, nNumKol, "+"
          oRow.cell(2).element(1).value = "1"
        end if
      end if  
      set oRow = oRow.nextelement
    loop
  end if  
end sub

'-------------------------------------
'przelicza wartość pojedynczej komórki
'-------------------------------------
sub recalcKol(byref oRowSum, byref oRow, byval nNumCell, byval nNumKol, byval strZnak)
  dim iter, curKwotaSum, curKwotaRow
  for iter = nNumCell to nNumKol
    curKwotaSum = strToCur(oRowSum.cell(iter).element(1).value)
    curKwotaRow = strToCur(oRow.cell(iter + 2).element(1).value)
    if strZnak = "-" then
      oRowSum.cell(iter).element(1).value = trans_.afc.display.money(curKwotaSum - curKwotaRow,"")
    else
      oRowSum.cell(iter).element(1).value = trans_.afc.display.money(curKwotaSum + curKwotaRow,"")
    end if
  next
end sub

'-------------------------------------------------------------------------------------------
'zamienia kwotę z trans_.afc.display.money na ccur zależności od ustawień separatora windows
'-------------------------------------------------------------------------------------------
function strToCur(byval strKwota) : strToCur = ccur(0.0)
  'separator dziesiętyny windows
  dim strSep : strSep = mid(cstr(ccur(1/2)),2,1)
  if strSep = "." then
    strToCur = ccur(replace(replace(strKwota,",",".")," ",""))
  else
    strToCur = ccur(replace(strKwota," ",""))
  end if 
end function

'---------------------------------------------------
'gdy wszystkie dzieci odznaczone => odznacza rodzica
'---------------------------------------------------
sub checkChild(byref oRowParent, byval pSecProp)
  dim bCheckParent : bCheckParent = true
  dim oRowChild : set oRowChild = oRowParent.nextelement
  do while (pSecProp = oRowChild.userprop.prop(1))
    if oRowChild.cell(2).element(1).value = "1" then
      bCheckParent = false
      exit do
    end if  
    set oRowChild = oRowChild.nextelement
  loop
  if bCheckParent then
    oRowParent.cell(1).element(2).value = "0"
  else
    oRowParent.cell(1).element(2).value = "1"
  end if
end sub

]]>
</script>
</config>
<header>
</header>
<body fontsize='1'>
<p>
RAPORT_HEADER(3,1)
</p>
<p>
<t size='2'/>
</p>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
    dim pParamArray : set pParamArray = default_param() 
		rapeng_.merge_params pParamArray, rapeng_.get_raport_param()
    pRapExec.title = "RAPORT_TITLE" 

		if rapeng_.show_raport_param_dialog(pParamArray,"RAPORT_TITLE") <> 0 then
		  'zapytania pomocnicze i do raportu
      pRapExec.put_final_query query(pParamArray)
      rapeng_.set_raport_param pParamArray 
    end if 

	  .add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")) _
       .add_sumator("curWartBO" + strTypAmor).add_sumator("curWartZw" + strTypAmor).add_sumator("curWartZm" + strTypAmor) _
       .add_sumator("curWartBZ" + strTypAmor).add_sumator("curUmorzBO" + strTypAmor).add_sumator("curUmorzBZ" + strTypAmor) _
       .add_sumator("curPozost" + strTypAmor).add_sumator("cur1" + strTypAmor).add_sumator("cur2" + strTypAmor).add_sumator("cur3" + strTypAmor) _
       .add_sumator("cur4" + strTypAmor).add_sumator("cur5" + strTypAmor).add_sumator("cur6" + strTypAmor).add_sumator("cur7" + strTypAmor) _
       .add_sumator("cur8" + strTypAmor).add_sumator("cur9" + strTypAmor).add_sumator("cur10" + strTypAmor).add_sumator("cur11" + strTypAmor) _
       .add_sumator("cur12" + strTypAmor)    
	  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")) _ 
       .add_sumator("curWartBO" + strTypAmor).add_sumator("curWartZw" + strTypAmor).add_sumator("curWartZm" + strTypAmor) _
       .add_sumator("curWartBZ" + strTypAmor).add_sumator("curUmorzBO" + strTypAmor).add_sumator("curUmorzBZ" + strTypAmor) _
       .add_sumator("curPozost" + strTypAmor).add_sumator("cur1" + strTypAmor).add_sumator("cur2" + strTypAmor).add_sumator("cur3" + strTypAmor) _
       .add_sumator("cur4" + strTypAmor).add_sumator("cur5" + strTypAmor).add_sumator("cur6" + strTypAmor).add_sumator("cur7" + strTypAmor) _
       .add_sumator("cur8" + strTypAmor).add_sumator("cur9" + strTypAmor).add_sumator("cur10" + strTypAmor).add_sumator("cur11" + strTypAmor) _
       .add_sumator("cur12" + strTypAmor)
       
%>
<%
	write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end with
  on error resume next
  trans_.execsql "drop table #tabela_amort"
  on error resume next
  trans_.execsql "drop table #tabela_amort_pom"
  %>

</body>
<footer>
</footer>
</page>