	</td>
</tr>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='1100'>
		<text><![CDATA[BO]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[Zwię ksze nia]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[Zmnie jsze nia]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[BZ]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[BO]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[Zwię ksze nia]]></text>
	</td>
	<td width='1100'>
		<text><![CDATA[Zmnie jsze nia]]></text>
	</td>
	<td width='1100'>
