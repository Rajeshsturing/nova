<?xml version="1.0" encoding="windows-1250" ?>

<!-- Rezerwacja -->
<!-- 8.06.2004 - poprawka adresy-->
<!-- 18.06.2004 - godzina rezerwacji -->
<!-- 21.06.2004 adnotacje -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>


#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


#define DOSTAWCA_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define DOSTAWCA_NIP					<% so.write util_.Klient_NIP(root_.pKlient) %>
#define DOSTAWCA_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta end if end if%>
#define DOSTAWCA_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define DOSTAWCA_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define JEDNOSTKA_ORG_NAZWA				<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define JEDNOSTKA_ORG_KOD_MIASTO		<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta end if end if%>
#define JEDNOSTKA_ORG_ULICA_NUMER		<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define DOSTAWCA_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>

#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_WAZNOSCI			<% if doc_.afc.display.fulldate(root_.dDataRezerw)="????-??-??" then so.write "brak" else so.write doc_.afc.display.fulldate(root_.dDataRezerw) end if%>
#define DOKUMENT_GODZ_WAZNOSCI			<% if doc_.afc.display.fulldate(root_.dDataRezerw)<>"????-??-??" then so.write trans_.afc.display.longtime(root_.tCzasRezerw) end if %>	
#define DOKUMENT_DATA_ZAKUPU			<% if not root_.wrefDokHandl is nothing then so.write doc_.afc.display.fulldate(root_.wrefDokHandl.dDataZakupu) end if  %>
#define DOKUMENT_KWOTA					<% so.write MONEY(root_.curKwota) %>
#define DOKUMENT_KWOTA_SLOWNIE			<% so.write doc_.afc.display.slownie(root_.curKwota) %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(root_.curSumaMag)%>
#define DOKUMENT_MAGAZYN				<% if not root_.pMagZrod is nothing then so.write root_.pMagZrod.text end if%>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi%>

#define DOKUMENT_OBCY_NR				<% if not root_.wrefDokHandl is nothing then so.write root_.wrefDokHandl.strNrDok end if  %>

#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1)%>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_CENA_DOSTAWY				<% so.write MONEY(pozycja.curCenaMag) %>
#define POZ_WARTOSC						<% so.write MONEY(abs(pozycja.curWartMag)) %>

#define DOKUMENT_WARTOSC_RS				<% so.write MONEY(curSuma)%>

#define POZ_IDX							<% so.write cstr(rs.fields("p_strIndeks").value) %>
#define POZ_TOWAR_ID					<% so.write util_.Produkt_Nazwa(rs.fields("pProdZrod").value) %>
#define POZ_TOWAR_RS					<% so.write cstr(rs.fields("p_strNazwa").value) %>
#define POZ_OPAKOWANIE_RS				<% if cstr(rs.fields("c_strNazwa").value) <> "Podstawowe" then so.write " (" +  cstr(rs.fields("c_strNazwa").value) + ")" end if %>
#define POZ_ILOSC_RS					<% so.write doc_.afc.display.quantity(-ccur(rs.fields("gmo_curIlosc").value),"",clng(rs.fields("nDokladnosc").value) - 1 ) %>
#define POZ_JM_RS						<% so.write rs.fields("strSkrot").value %>
#define POZ_CENA_DOSTAWY_RS				<% so.write MONEY(rs.fields("gmo_curCena").value) %>
#define POZ_WARTOSC_RS					<% so.write MONEY( - ccur( rs.fields("wartosc").value) ) %>
#define POZ_MAGAZYN_RS					<% if not isNull(rs.fields("magazyn_nazwa").value) then so.write cstr(rs.fields("magazyn_nazwa").value) end if %>





<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>

</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left'  colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Rezerwacja towaru nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>

						

					</tbody>
				</table>
			</td>
		</tr>
		<tr>
			<td>
				<table>
					<tbody>																		
						
						<% if not root_.pKlient_JO is nothing then %>
						<!-- jednostka organizacyjna klienta-->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>				
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[JEDNOSTKA_ORG_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[JEDNOSTKA_ORG_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_JO_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<!-- /jednostka organizacyjna klienta-->
						<% else %>
						<% if not root_.pKlient is nothing then %>
						
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								<text><![CDATA[DOSTAWCA_NAZWA]]></text>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_ULICA_NUMER]]></t>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_KOD_MIASTO]]></t>
							</td>					
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_MIASTO]]></t>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[DOSTAWCA_NIP]]></t>
							</td>						
						</tr>
						<% else %>				
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nabywca:</t>
							</td>							
							<td>
								Brak danych
							</td>						
						</tr>
						<% end if %>
						<% end if %>

					

						ROW_SEPARATOR(2)
						<tr>
							<td width='min'>
								<t bold='true'>Data wystawienia:&nbsp;&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t bold='true'>Data ważności:&nbsp;&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_DATA_WAZNOSCI]]></t><t>&nbsp;</t><t><![CDATA[DOKUMENT_GODZ_WAZNOSCI]]></t>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t bold='true'>Dokument handlowy:&nbsp;&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_OBCY_NR]]></t>
							</td>						
						</tr>
						<tr>
							<td width='min'>
								<t bold='true'>Magazyn wydania:&nbsp;&nbsp;</t>
							</td>							
							<td>
								<t><![CDATA[DOKUMENT_MAGAZYN]]></t>
							</td>						
						</tr>

						ROW_SEPARATOR(2)
					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)

		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<t>&nbsp;</t><text>Nazwa towaru / usługi</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>																	
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena dostawy</text>
							</td>
							<td align='right'>
								<text>Wartość</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%	
							dim iter
							
							if doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then

								dim curSuma:curSuma = ccur(0)

								dim rs
								set rs = trans_.createadors("select * , n5magazyn.strNazwa as magazyn_nazwa , gmo_curWartosc as wartosc  from n5gmop " + _
								" join vlist_n5produkt_listOpakowania on gmo_pProd = p_idobj and gmo_pOpak = c_idobj   " + _ 
								" join n5jednostka on vlist_n5produkt_listOpakowania.c_pJednOpak = n5jednostka.idobj   " + _ 
								" left join n5magazyn on n5magazyn.idobj = gmo_pMag  " + _ 
								" where gmo_nNumOp = " + cstr(root_.nNumOper) + _ 
								" and gmo_pMag =  " + cstr(root_.pMagZrod.idobj) + _
								" order by gmo_nLP")
								
								iter = 1
								while not rs.eof

									curSuma = curSuma - ccur(rs.fields("wartosc").value)

									%>
						
						<tr>
							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<t>&nbsp;</t><text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE_RS]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>					
							<td align='right'>
								<t><![CDATA[POZ_ILOSC_RS]]></t>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_JM_RS]]></text>
							</td>					
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_RS]]></t>
							</td>
						</tr>
						<%									
									iter = iter + 1
									rs.movenext
								wend
								trans_.saveobjects

							else
						%>

								<tr border='1' fontsize='5' forecolor='red' bold='true'><td colspan='7'><t>Uwaga! Niepoprawny stan magazynu</t></td></tr>

						<% end if %>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='3' bordercolor='transparent'>
							</td>
							<td colspan='3'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_RS]]></t>
							</td>							
						</tr>	
					</tfoot>					
				</table>
			</td>
		</tr>
		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)

		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>							
							
						</tr>
						<tr>
							<td align='center' >	
								<t>................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center' width='min'>	
								<t fontsize='2'>Imię, nazwisko i podpis osoby wystawiającej dokument</t>
							</td>							
												
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>
									
	</tbody>
</table>



</body>
<footer>
</footer>
</page>
