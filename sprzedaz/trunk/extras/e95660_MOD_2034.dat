<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#include "h1231.h"

#define RAPORT_TITLE Sprzedaż węgla
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=case when t_0.strExtra1='' then '<bez nr dostawy>' else '<z nr dostawy>' end, " + vbNewLine +_
"'c_1'=t_0.dDataWyst,'c_2'=t_0.strNrDok,'c_3'=t_0.strNrDok,'c_4'=10162,'c_5'=t_0.IdObj,'c_6'=t_0.dDataWyst, " + vbNewLine +_
"'c_7'=t_0.strExtra1,'c_8'=t_1.strNazwa,'c_9'=10108,'c_10'=t_1.IdObj, " + vbNewLine +_
"'c_11'=t_1.strUlica + ' ' + t_1.strNrDomu + ' ' + t_1.strNrLokalu + ', ' + t_1.strKod + ' ' + t_2.strNazwa, " + vbNewLine +_
"'c_12'=(select -sum(gmo_curIlosc) from n5gmop where gmo_nNumOp = t_0.nNumOper) " + vbNewLine +_
"from n5dokmag as t_0 inner join n5klient as t_1 on t_0.pKlient = t_1.IdObj " + vbNewLine +_
"inner join n5miejscowosc as t_2 on t_1.pMiejscowosc = t_2.IdObj " + vbNewLine +_
"where t_0.idobj in (select p_idobj from vlist_n5dokmag_listPozycje where p_ntypdok=N5REJESTRDOK__WZ and " + vbNewLine +_
"c_pprodukt in (select idobj from n5produkt where pGrupaProd in (select IdObj from n5grupaproduktow where strNazwa = 'Węgiel'))) " + vbNewLine +_
"and %1 and  %2 and %3 " + vbNewLine +_
"order by t_0.strExtra1,t_0.dDataWyst,t_0.strNrDok"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_0.dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")
	dim pParamDost: set pParamDost = doc_.afc.rap.param.new_choice("Dostawa").bindexpr("dostawa")
	with pParamDost
		.multiple = true
		.names.add "bez nr dostawy"
		.values.add 1
		.selected.add True
		.names.add "z numerem dostawy"
		.values.add 2
		.selected.add True   
	end with
	pParamArray.add pParamDost   

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='7' />
	<td style='27' align='right'>
    RXE_QUANTITY_VVV(pSection.counter(0).result,"",3)
	</td>
</tr>
<tr border='0'><td colspan='5' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_4,c_5,c_3)
	</td>
	<td>
		RXE_DATE(c_6)
	</td>
	<td>
		RXE_AUTO_TEXT(c_7)
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_9,c_10,c_8)
	</td>
	<td>
		RXE_AUTO_TEXT(c_11)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_12,"",3)
	</td>  
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data wystawienia]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Nr dostawy]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Nazwa pełna]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Adres]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Ilość]]></text>
	</td>  
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='7' />
	<td style='27' align='right'>
    RXE_QUANTITY_VVV(pRapExec.body.counter(0).result,"",3)
	</td>
</tr>
</tfoot>  
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_12")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_12")
if .prepare("RAPORT_TITLE", default_param(), rapeng_.get_raport_param(), query()) then 
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
  'filtr dostawa
  .ReplaceQueryParam "(dostawa IN ('1','2'))", "(1=1)"
  .ReplaceQueryParam "(dostawa = '1')", "t_0.strExtra1=''"
  .ReplaceQueryParam "(dostawa = '2')", "t_0.strExtra1<>''"
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
