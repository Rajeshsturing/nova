<?xml version="1.0" encoding="windows-1250" ?>
<!--

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"



#define RAPORT_TITLE Zamówienia obce - podsumowanie miesiącami



#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_1.strIndeks
#define C_FIELD_SECOND_EXPR		t_1.strNazwa
#else
#define C_FIELD_FIRST_EXPR		t_1.strNazwa
#define C_FIELD_SECOND_EXPR		t_1.strIndeks
#endif 


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")

#define NR_MIES		<%so.write cstr(nr_mies)%>
#define WARTOSC_NETTO_0	<% so.write MONEY(0.0)%>
#define WARTOSC_VAT_0	<% so.write MONEY(0.0)%>
#define WARTOSC_BRUTTO_0	<% so.write MONEY(0.0)%>
#define MIESIAC_NAZWA 	<%'so.write cstr(ArrMiesNazwa(nr_mies - 1))%>


-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_rok'=(kartezjan_okres.rok), "+_
" 'c_mies'= (kartezjan_okres.mies),'c_mies_nazwa'= max(kartezjan_okres.strNazwa),"+_
" 'c_1'=10108, "+_
" 'c_11'=10129, "+_
" 'c_13'=sum(isnull(t_zam.curSumaNetto,0)), "+_
" 'c_14'=sum(isnull(t_zam.curSumaBrutto,0)), "+_
" 'c_15'=sum(isnull(t_zam.curSumaVAT,0)), "+_
" 'c_15_abs'=abs(sum(isnull(t_zam.curSumaBrutto,0))) "+_
" from  n5zamowienie as t_zam "+_
" right outer join (select 'mies'=n5miesiac.idobj,'strNazwa'=n5miesiac.strNazwa,'rok'=year(n5rokksieg.dDataRozp)    "+_
" from n5miesiac, n5rokksieg) kartezjan_okres  on (kartezjan_okres.mies = month(t_zam.ddataWyst)  "+_
" and kartezjan_okres.rok = year(t_zam.ddataWyst) )   "+_
" left outer join n5klient as t_1 on t_zam.pKlient = t_1.IdObj "+_
" left outer join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
" left outer join n5rejestrdok as t_3 on t_zam.pRejestrDok = t_3.IdObj "+_
" where  %1   and  %2   and  %3  and  %4 and %5 and EXTRA_CUSTOMER_FILTER_AND(6) "+_
" group by kartezjan_okres.mies, kartezjan_okres.rok "+_
" union "+ vbCrLf +_
" select 'c_rok'=(kartezjan_okres.rok), "+ vbCrLf +_
" 'c_mies'= (kartezjan_okres.mies),'c_mies_nazwa'= max(kartezjan_okres.strNazwa),"+ vbCrLf +_
" 'c_1'=10108, "+ vbCrLf +_
" 'c_11'=10172, "+ vbCrLf +_
" 'c_13'=0,'c_14'=0,'c_15'=0 , 'c_15_abs'=0 "+ vbCrLf +_
" from  (select 'mies'=n5miesiac.idobj,'strNazwa'=n5miesiac.strNazwa,'rok'=year(n5rokksieg.dDataRozp) "+ vbCrLf +_
" from n5miesiac, n5rokksieg) kartezjan_okres " +_
" where "+ vbCrLf +_
" (kartezjan_okres.rok > year(%START_DATE%) or (kartezjan_okres.rok = year(%START_DATE%) and kartezjan_okres.mies >= month(%START_DATE%)))" +_  
" and "+ vbCrLf +_
" (kartezjan_okres.rok < year(%END_DATE%) or (kartezjan_okres.rok = year(%END_DATE%) and kartezjan_okres.mies <= month(%END_DATE%)))" +_  
" group by kartezjan_okres.mies, kartezjan_okres.rok "+ vbCrLf +_
" order by c_rok asc, c_mies asc, c_15_abs desc "




end function
%>
<%
dim pParamDate
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	set pParamDate =  doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("isnull(t_zam.dDataWyst,0)")
	pParamArray.add pParamDate
	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_3.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__ZAM_OBCE) order by strNazwa "
	pParamArray.add pParam2
	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("isnull(t_1.strNazwa,0)")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("isnull(t_1.strIndeks,0)")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("isnull(t_2.strNazwa,0)")
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)

%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_rok)
</td>
</tr>
<%

nSectionPicCounter=nSectionPicCounter+1

end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='2' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>

</tr>
<tr border='0'><td colspan='5' /></tr>
<%
end function
%>


<%
function body_row(byref pSection,byref pRec)

rok = pRec("c_rok")
miesiac = pRec("c_mies")
c_15 = pRec("c_15")

if (rok=rok_pop and miesiac=miesiac_pop) then 

	'rok_pop = rok
	'miesiac_pop = miesiac	


else
	if licznik mod 2 = 0 then
	%>
	<tr bordercolor='white'>
	<%
	else
	%>
	<tr bordercolor='white' style='37'>
	<%
	end if
	%>
	<td align='right'>
		RXE_AUTO_TEXT(c_mies) 
	</td>
	<td>
		RXE_AUTO_TEXT(c_mies_nazwa) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_13,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_15,"",2)
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(c_14,"",2)
	</td>
	</tr><%
	rok_pop = rok
	miesiac_pop = miesiac
	licznik = licznik + 1
end if

end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<t><![CDATA[Miesiąc]]></t>
	</td>
	<td width='min'>
		<t><![CDATA[Wartość netto]]></t>
	</td>
	<td width='min'>
		<t><![CDATA[Wartość VAT]]></t>
	</td>	
	<td width='min'>
		<t><![CDATA[Wartość brutto]]></t>
	</td>

</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='2' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>

</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000
dim licznik : licznik = 0
dim c_15 : c_15 = 0
dim rok, rok_pop: rok_pop = 2004
dim miesiac, miesiac_pop : miesiac_pop = 0
dim numer_abs : numer_abs = 24049
dim nr_mies: nr_mies = 1
dim ArrMiesNazwa(12)
ArrMiesNazwa(0) = cstr("Styczeń")
ArrMiesNazwa(1) = cstr("Luty")
ArrMiesNazwa(2) = cstr("Marzec")
ArrMiesNazwa(3) = cstr("Kwiecień")
ArrMiesNazwa(4) = cstr("Maj")
ArrMiesNazwa(5) = cstr("Czerwiec")
ArrMiesNazwa(6) = cstr("Lipiec")
ArrMiesNazwa(7) = cstr("Sierpień")
ArrMiesNazwa(8) = cstr("Wrzesień")
ArrMiesNazwa(9) = cstr("Październik")
ArrMiesNazwa(10) = cstr("Listopad")
ArrMiesNazwa(11) = cstr("Grudzień")


%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='6' bold='true'>Kryteria selekcji:</t><br/>
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()



with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_13").add_sumator("c_14").add_sumator("c_15")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_13").add_sumator("c_14").add_sumator("c_15")
	
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	.ReplaceQueryParam "%START_DATE%", trans_.afc.convert.date2SQL(pParamDate.first_value)
	.ReplaceQueryParam "%END_DATE%", trans_.afc.convert.date2SQL(pParamDate.last_value)
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
