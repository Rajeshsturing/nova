<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Program lojalnościowy
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_klnazwa'=t_klient.strNazwa,'c_klidobj'=t_klient.idobj,'c_dataoper'=t_progloj.proloj_dDataOp, " +_
"'c_progtype'=TYPEID_N5PROGLOJAL,'c_progidobj'=t_progloj.IdObj,'c_typoper'=t_progloj.proloj_eTypOper, " +_
"'c_punkty'=case when t_progloj.proloj_eTypOper = 1 then t_progloj.proloj_curSumaPunkty  else -t_progloj.proloj_curSumaPunkty end," +_
"'c_sprzednrdok'=isnull(t_sprzed.strNrDok,''),'c_sprzedtype'=TYPEID_N5SPRZEDAZ, " +_
"'c_sprzedidobj'=isnull(t_sprzed.IdObj,0),'c_dokmagnr'=isnull(t_dokmag.strNrDok,''),'c_dokmagtype'=TYPEID_N5DOKMAG," +_
"'c_dataoper2'=isnull(t_dokmag.IdObj,0),'c_uwagi'=t_progloj.proloj_strUwagi " +_
" from n5proglojal as t_progloj " +_
" inner join n5klient as t_klient on t_progloj.proloj_pKlient = t_klient.IdObj " +_
" left outer join n5sprzedaz as t_sprzed on t_progloj.proloj_pSprzedaz = t_sprzed.IdObj " +_
" left outer join n5dokmag as t_dokmag on t_progloj.proloj_pDokMag = t_dokmag.IdObj " +_
" left outer join n5klient_pracownik as klient_prac on  t_progloj.proloj_ppracklient=klient_prac.idobj "+_
" where  %1  and  %2  and  %3  and  %4  and %5" +_
" order by c_klnazwa,c_dataoper"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data operacji").bindexpr("t_progloj.proloj_dDataOp")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa pełna").bindexpr("t_klient.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_klient.strIndeks")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwisko pracownika klienta").bindexpr("isnull(klient_prac.strNazwisko,'')")
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Typ operacji").bindexpr("t_progloj.proloj_eTypOper")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5PROGLOJAL,"proloj_eTypOper"
	pParamArray.add pParam3

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='8'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,c_klidobj,c_klnazwa)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
<tr fontsize='4'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' colspan='3' />
</tr>
<tr border='0'><td colspan='8' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(c_dataoper)
	</td>
	<td>
		RXE_ENUM_VVC(10169,proloj_eTypOper,c_typoper)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_punkty,"",2)
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_sprzedtype,c_sprzedidobj,c_sprzednrdok)
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_dokmagtype,c_dataoper2,c_dokmagnr)
	</td>
	<td>
		RXE_AUTO_TEXT(c_uwagi)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Data operacji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Typ operacji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Punkty]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Dokument sprzedaży]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Dokument wydania nagrody]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Uwagi]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' colspan='3' />
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_punkty")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("c_punkty")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
