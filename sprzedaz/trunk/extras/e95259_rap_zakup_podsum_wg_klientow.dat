<?xml version="1.0" encoding="windows-1250" ?>
<!-- 17.08.2004 v.1 --> 
<!-- 18.07.2008 IOW podsumowanie walut -->
<!--

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"



#define RAPORT_TITLE Zakup - podsumowanie wg klientów



#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_1.strIndeks
#define C_FIELD_SECOND_EXPR		t_1.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks klienta
#define C_FIELD_SECOND_HUMANNAME 	Nazwa klienta
#define C_FIELD_FIRST_ALIGN 		right
#define C_FIELD_SECOND_ALIGN 		left
#else
#define C_FIELD_FIRST_EXPR		t_1.strNazwa
#define C_FIELD_SECOND_EXPR		t_1.strIndeks
#define C_FIELD_FIRST_HUMANNAME 	Nazwa klienta
#define C_FIELD_SECOND_HUMANNAME 	Indeks klienta
#define C_FIELD_FIRST_ALIGN 		left
#define C_FIELD_SECOND_ALIGN 		right
#endif 

-->
#ifdef _IOW
<%
dim tabela(100,4)
dim iTabelaItems : iTabelaItems = clng(0)

dim tabelaSekcja(100,4)
dim iTabelaSekcjaItems : iTabelaSekcjaItems = clng(0)
dim iter : iter = 1
dim iterS : iterS = 1
%>
#endif

<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim strWaluta : strWaluta = ""
dim strWalutaJoin : strWalutaJoin = ""
dim strWalutaGroup : strWalutaGroup = ""
#ifdef _IOW
strWaluta = "'c_waluta' = max(t_0.pWaluta), 'c_wal_skrot'=max(t_wal.strSkrot), 'c_rej_typ'=max(t_3.eTyp), 'c_kurs'=max(t_0.curKurs), "+_
" 'c_suma_wal'=sum(isnull((t_0.curSumaWal-isnull(t_orgzakup.curSumaWal,0)),0)),   "

strWalutaJoin = " inner join n5jednostka as t_wal on t_0.pWaluta = t_wal.IdObj  "
strWalutaGroup = ", t_0.pWaluta "
#endif
query = "select 'c_field_first'=max(C_FIELD_FIRST_EXPR),'c_field_second'=max(C_FIELD_SECOND_EXPR), "+_
" 'c_1'=10108,'c_idobj'=max(t_1.IdObj),'c_3'=max(t_0.strNrDok), "+_
" 'c_10'=max(t_0.strNrDok),'c_11'=10176, "+_
" 'c_12'=max(t_0.IdObj),'c_13'=sum(isnull((t_0.curSumaNetto-isnull(t_orgzakup.curSumaNetto,0)),0)), "+_
" 'c_14'=sum(isnull((t_0.curSumaVAT-isnull(t_orgzakup.curSumaVAT,0)),0)), "+_
" 'c_15'=sum(isnull((t_0.curSumaBrutto-isnull(t_orgzakup.curSumaBrutto,0)),0)), "+_
strWaluta +_
" 'c_data_zak'=max(t_0.dDataZakupu) "+_
" from n5zakup as t_0 "+_
" left outer join n5zakup t_orgzakup on t_0.ppopzakup = t_orgzakup.idobj "+_
" inner join n5klient as t_1 on t_0.pDostawca = t_1.IdObj "+_
" inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
" inner join n5rejestrdok as t_3 on t_0.pRejestrDok = t_3.IdObj "+_
strWalutaJoin +_ 
" where  %1  and  %2  and  %3  and  %4  and  %5  and EXTRA_CUSTOMER_FILTER_AND(6) "+_
" group by t_1.idobj "+_
strWalutaGroup +_
" order by c_field_first,c_data_zak,c_3"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.afc.rap.param.new_date_range("Data zakupu").bindexpr("t_0.dDataZakupu")
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa rejestru").bindexpr("t_3.strNazwa")
	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_3.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
#ifdef _MILOMLYN
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP,N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) and eAktywny = N5REJESTRDOK_AKTYWNY order by strNazwa "
#else
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_FAKT_IMP,N5REJESTRDOK_KOR_FAKT_IMP,N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_KOR_FAKT_ZAK_RR,N5REJESTRDOK_IMPORT_USLUG,N5REJESTRDOK_KOR_IMPORT_USLUG) order by strNazwa "
#endif
	pParamArray.add pParam2
	
	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa dostawców").bindexpr("t_2.strNazwa")
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_field_first)
	<t size='3'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_field_second)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<tr fontsize='4'>
	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>

</tr>
<tr border='0'><td colspan='7' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td  align='C_FIELD_FIRST_ALIGN'>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_idobj,c_field_first)<t size='1'/> 
	</td>
	<td align='C_FIELD_SECOND_ALIGN'>
		RXE_AUTO_TEXT(c_field_second) 
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_13,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_14,"",2)
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(c_15,"",2)
	</td>
#ifdef _IOW
<%if  cstr(pRec("c_wal_skrot")) <> "PLN"  then %>
	<td align='right'>
		RXE_QUANTITY_CCV(c_suma_wal,c_wal_skrot,2)
	</td>
  
<%
			dim iterTabela
			dim iFoundIndex : iFoundIndex = -1
			for iterTabela = 0 to iTabelaItems
				if tabela(iterTabela,0) = clng(pRec("c_waluta")) then
					iFoundIndex = iterTabela
					exit for
				end if
			next
			if iFoundIndex = -1 then
				iFoundIndex = iTabelaItems
				iTabelaItems = iTabelaItems + 1
				tabela(iFoundIndex,0) = ccur(0.0)
			end if
			tabela(iFoundIndex,0) = clng(pRec("c_waluta"))
			tabela(iFoundIndex,1) = tabela(iFoundIndex,1) + ccur(pRec("c_suma_wal"))
			tabela(iFoundIndex,2) = cstr(pRec("c_wal_skrot"))
	end if
%>
#endif	

</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td  >
		<t><![CDATA[C_FIELD_FIRST_HUMANNAME]]></t>
	</td>
	<td  >
		<t><![CDATA[C_FIELD_SECOND_HUMANNAME]]></t>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość VAT]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Wartość brutto]]></text>
	</td>
#ifdef _IOW
	<td width='min'>
		<text><![CDATA[Wartość w walucie]]></text>
	</td>
#endif	
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>	
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
#ifdef _IOW	
	<td style='27'/>
#endif	
</tr>

#ifdef _IOW 
<%
dim iter : iter=0
for iter=0 to iTabelaItems - 1 
%>
<tr style='21'>
	<td style='27' colspan='3' >
		<t >Podsumowanie <%so.write tabela(iter,2)%></t>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>	
	<td style='27' align='right'>
		
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(tabela(iter,1))
	</td>
</tr>
<%
next
%>
#endif
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='6' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("c_13").add_sumator("c_14").add_sumator("c_15")
	
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
