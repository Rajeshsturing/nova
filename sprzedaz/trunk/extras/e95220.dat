<?xml version="1.0" encoding="windows-1250" ?>
<!-- 18.07.2004 filtr na rejestry jako checkbox-->
<!-- 16.02.2005 IG filtr na opiekuna klienta --> 
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#ifdef _DEBUG
#define RAPORT_TITLE Ranking obrotów NOWY union all
#else
#define RAPORT_TITLE Ranking obrotów
#endif

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
#ifdef _GRAJEWSCY
query = "select 'c_0'=sum(temp.c_0),'c_1'=max(temp.c_1),'c_3'=max(temp.c_3) from  (select 'c_0'=sum(t_0.curSumaNetto) - sum(isnull(t_orgsprz.curSumaNetto,0)),'c_1'=max(t_1.strNazwa),'c_3'=t_1.IdObj " +_
#else
query = "select 'c_0'=sum(t_0.curSumaNetto) - sum(isnull(t_orgsprz.curSumaNetto,0)),'c_1'=max(t_1.strNazwa),'c_3'=t_1.IdObj " +_
#endif
" from n5sprzedaz as t_0 " +_
" left outer join n5sprzedaz t_orgsprz on t_0.ppopsprzed = t_orgsprz.idobj "+_
"inner join n5klient as t_1 on t_0.pKlient = t_1.IdObj " +_
"left join n5pracownik as t_prac on  t_1.pPracownik = t_prac.Idobj  "+_
"inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj " +_
"inner join n5rejestrdok as t_3 on t_0.pRejestrDok = t_3.IdObj " +_
"left outer join n5pracownik as t_handl on t_0.sprzed_pHandlowiec = t_handl.idobj " +_
"where  %1  and  %2  and  %3  and  %4  and  %5  and  %6 and  %7 and EXTRA_CUSTOMER_FILTER_AND(8) and %9 and " +_
"t_0.pRozlVAT <> 0 " +_
#ifdef _GRAJEWSCY
" and not (t_0.pKlient = t_3.rejdok_pDefKlient and t_0.strExtra1 <> '' and t_0.strExtra1 <> '0') " +_
#endif
"group by t_1.IdObj " +_
#ifndef _GRAJEWSCY
" order by c_0 desc"
#else
"union all " +_
"select 'c_0'=sum(t_0.curSumaNetto) - sum(isnull(t_orgsprz.curSumaNetto,0)), " +_
#ifdef _GRAJEWSCY
"'c_1'=(select max(k.strNazwa) from n5klient k where k.strIndeks = t_0.strExtra1),'c_3'=(select max(k.idobj) from n5klient k where k.strIndeks = t_0.strExtra1) " +_
#else
"'c_1'=(select max(k.strNazwa) from n5klient k where k.strIndeks = t_0.strExtra1),'c_3'=max(t_1.IdObj) " +_
#endif
"from n5sprzedaz as t_0 " +_  
"left outer join n5sprzedaz t_orgsprz on t_0.ppopsprzed = t_orgsprz.idobj " +_ 
"inner join n5klient as t_1 on t_0.pKlient = t_1.IdObj " +_ 
"left join n5pracownik as t_prac on  t_1.pPracownik = t_prac.Idobj " +_  
"inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj " +_ 
"inner join n5rejestrdok as t_3 on t_0.pRejestrDok = t_3.IdObj " +_ 
"left outer join n5pracownik as t_handl on t_0.sprzed_pHandlowiec = t_handl.idobj " +_ 
"where  %1  and  %2  and  %3  and  %4  and  %5  and  %6 and  %7 and EXTRA_CUSTOMER_FILTER_AND(8) and %9 and " +_
"t_0.pRozlVAT <> 0 and (t_0.pKlient = t_3.rejdok_pDefKlient and t_0.strExtra1 <> '' and t_0.strExtra1 <> '0') " +_
#ifdef _GRAJEWSCY
"group by t_0.strExtra1) as temp  "+_
"group by temp.c_1    "+_
"order by c_0 desc  "
#else
"group by t_0.strExtra1 " +_
"order by c_0 desc "
#endif
#endif
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa pełna").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa grupy klientów").bindexpr("t_2.strNazwa")
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Klasa klienta").bindexpr("t_1.eKlasaKlienta")
	pParamFactory3.init_on_enum pParam3, TYPEID_N5KLIENT,"eKlasaKlienta"
	pParamArray.add pParam3
	
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa rejestru").bindexpr("t_3.strNazwa")
	'PARAMETR: rejestr dokumentow
	dim pParamFactory4: set pParamFactory4= doc_.afc.rap.param
	dim pParam4: Set pParam4= pParamFactory4.new_choice("Nazwa rejestru").bindexpr("t_3.idobj")
	doc_.afc.rap.param.init_on_query pParam4, trans_ ,_
#ifdef _MILOMLYN
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_WDT) and eAktywny = N5REJESTRDOK_AKTYWNY order by strNazwa "
#else 
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_WDT) order by strNazwa "
#endif    
	pParamArray.add pParam4
	

	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_0.dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(t_handl.strNazwisko,'')")
	
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
if pActualParam.value(iter).get_desc() <> "" then 
bAnyWritten = true
	so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='4'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,c_3,c_1)
	</td>
	<td align='right'>
#ifdef _IOW
    RXE_QUANTITY_CVV(c_0,"PLN",2)
#else
		RXE_QUANTITY_CVV(c_0,"",2)
#endif	
  </td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
'so.write "<p backcolor='yellow'><text><![CD"+"ATA["+pRapExec.get_final_query() + "]"+"]></text></p><br/>" 
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Nazwa pełna]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość netto]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p>

</p>
RAPORT_HEADER(3,0)
<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	
	.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=1"

	write_actual_param rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
