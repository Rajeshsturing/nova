<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
	<tr style='21'>
	    #ifdef _FRAM
	    	<td style='37' colspan='8' width='min' align='right'> <text><![CDATA[Razem]]></text></td>
	    #else
	    	<td style='37' colspan='7' width='min' align='right'> <text><![CDATA[Razem]]></text></td>
	    #endif
		<td style='37' align='right'>
			RXE_MONEY_VAR(ArrCurGlobSum(0))
		</td>
		<td style='37' align='right'>
			RXE_MONEY_VAR(ArrCurGlobSum(1))
		</td>
		<td style='37' align='right'>
#ifdef _AMPLUS
      RXE_MONEY_VAR(ArrCurGlobSum(2) + curVatImpKor)
#else
			RXE_MONEY_VAR(ArrCurGlobSum(2))
#endif		
    </td>
		<td style='37' align='right'>
#ifdef _AMPLUS
  <%
    if bFvatImp then
  %>
    RXE_QUANTITY_VVV(ArrCurGlobSum(3) - curVatImpKor,"",0)
  <%
    else
  %>  
		RXE_MONEY_VAR(ArrCurGlobSum(3) - curVatImpKor)
  <%
    end if
  %>
#else
		RXE_MONEY_VAR(ArrCurGlobSum(3))
#endif
		</td>
		<td style='37' align='right'>
			RXE_MONEY_VAR(ArrCurGlobSum(4))
		</td>
		<td style='37' align='right'>
#ifdef _AMPLUS
  <%
    if bFvatImp then
  %>
    RXE_QUANTITY_VVV(ArrCurGlobSum(5),"",0)
  <%
    else
  %>  
		RXE_MONEY_VAR(ArrCurGlobSum(5))
  <%
    end if
  %>
#else
		RXE_MONEY_VAR(ArrCurGlobSum(5))
#endif
		</td>
	</tr>
</tfoot>
<tprevfoot>
<!-- rezerwuj 2 wiersze na dynamiczną stopkę -->
<tr style='27'><td><t>&nbsp;</t></td></tr>
<tr style='27'><td><t>&nbsp;</t></td></tr>
<tr style='27'><td><t>&nbsp;</t></td></tr>
<tr style='27'><td><t>&nbsp;</t></td></tr>
</tprevfoot> 
</table>
<%
end function
%>


]]>
</script>
</config>
<header>
</header>
<body>
<p>
#ifdef _FRAM

<table fontsize='<%so.write CStr(3)%>'>	
		<tbody >	
			<tr>	
				<td ><text bold='true' ><![CDATA[H_FIRMA_NAZWA]]></text></td>	
				<td align='right'><t size='3'/><t><![CDATA[<% so.write util_.Firma_Miasto + " " + doc_.afc.display.fulldate(trans_.var(GVAR_TODAY)) %>]]></t></td>	
			</tr>	
			<tr>	
				<td><t bold='true'><![CDATA[H_FIRMA_ULICA_NUMER]]></t></td>
				<td align='right'><t size='3'>Godzina: </t><t size='3'><![CDATA[GODZINA_WYDRUKU]]></t></td>	
			</tr>	
			<% if util_.Firma.strPoczta="" or util_.Firma.pMiejscowosc.strNazwa=util_.Firma.strPoczta then %>	
			<tr>	
				<td><t bold='true'><![CDATA[H_FIRMA_KOD_MIASTO]]></t></td>	
				<td/>	
			</tr>	
			<% else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then	
				if util_.Firma.strUlica <> "" then %>	
			<tr>	
				<td><t bold='true'><![CDATA[H_FIRMA_MIASTO]]></t></td>	
				<td/>	
			</tr>	
				<%end if%> 	
			<tr>	
				<td><t bold='true'><![CDATA[H_FIRMA_KOD_POCZTA]]></t></td>	
				<td/>	
			</tr>	
			<%	end if 	
			end if
			%>	
			<%if clng(1)<>0 then %>
			<tr>	
				<td><t bold='true'><![CDATA[H_FIRMA_NIP]]></t></td>	
				<td/>	
			</tr>		
			<%end if %>	
		</tbody>	
	</table>




#else
RAPORT_HEADER(3,1)
#endif
</p>

<p><br/><br/><br/><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
	reset_global_sums
	dim pRapExec : set pRapExec = rapeng_.new_engine()
	with pRapExec
		.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
		.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
		
		if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
			rapeng_.write_actual_param so,rapeng_.get_raport_param()
			
			if not .perform then
				so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
			end if
		end if
	end with

function section_footer_1(byref pSection)
%>
<tr fontsize='4'>
	#ifdef _FRAM
	<td style='37' colspan='8' />
	#else
	<td style='37' colspan='7' />
	#endif

	<td style='37' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(0))
	</td>
	<td style='37' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(1))
	</td>
	<td style='37' align='right'>
#ifdef _AMPLUS
  <%
    if nTypRej = N5REJESTRDOK_KOR_FAKT_IMP then
  %>
		RXE_MONEY_VAR(ArrCurSecSum(2) + ArrCurSecSum(3))      
  <%
      curVatImpKor = ArrCurSecSum(3)
      nTypRej = clng(0)
    else
  %>
		RXE_MONEY_VAR(ArrCurSecSum(2))  
  <%
    end if
  %>
#else
		RXE_MONEY_VAR(ArrCurSecSum(2))
#endif    
	</td>
	<td style='37' align='right'>
#ifdef _AMPLUS
    <%
      if nTypRej = N5REJESTRDOK_FAKT_IMP then    
    %>
        RXE_QUANTITY_VVV(ArrCurSecSum(3) - curVatImpKor,"",0)
    <%
      else
    %>
			  RXE_MONEY_VAR(ArrCurSecSum(3) - curVatImpKor)    
    <%
      end if
    %>
#else
			RXE_MONEY_VAR(ArrCurSecSum(3))
#endif
	</td>
	<td style='37' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(4))
	</td>
	<td style='37' align='right'>
#ifdef _AMPLUS
    <%
      if nTypRej = N5REJESTRDOK_FAKT_IMP then    
    %>
        RXE_QUANTITY_VVV(ArrCurSecSum(5),"",0)
    <%
        nTypRej = clng(0)
      else
    %>
			  RXE_MONEY_VAR(ArrCurSecSum(5))    
    <%
      end if
    %>
#else
			RXE_MONEY_VAR(ArrCurSecSum(5))
#endif
	</td>
</tr>
<tr border='0'>
#ifdef _FRAM
    <td colspan='14' />
#else
    <td colspan='13' />

#endif
</tr>
<tr hide='true' userprop='propc_section_end="1"'>
#ifdef _FRAM
<td colspan='14' />
#else
<td colspan='13' />
#endif
</tr>
<%
end function

function section_header_1(byref pSection,byref pRec)
reset_section_sums
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
    #ifdef _FRAM
	<td style='27' colspan='15'>
	#else
		<td style='27' colspan='13'>
	#endif
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_rej_nazwa)
</td>
    
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
</body>
<footer>
</footer>
</page>
