<?xml version="1.0" encoding="windows-1250" ?>


<!-- Zamówienie własne -->
<!-- 11.06.2004 poprawki- adresy, zamowienie -->
<!-- 21.06.2004 adnotacje -->
<!-- 14.09.2004 data wystawienia z bazy, ilosc -->
<!-- 2.12.2004 poprawki adres-->

#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro QTY(_val_,_punit_)				doc_.afc.display.quantity(_val_,_punit_.strSkrot,_punit_.nDokladnosc - 1)
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane dostawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


<!-- Dane odbiorcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>


<!-- Informacje na fakturze -->
#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_ZAMOWIENIE_NR_OBCY		<% so.write root_.zam_strNrDokObcy %>

#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_DATA_AKTUALNOSCI		<% so.write doc_.afc.display.fulldate(root_.dDataAkt) %>
#define DOKUMENT_DATA_PLATNOSCI			<% so.write doc_.afc.display.fulldate(root_.dDataPlat) %>
#define DOKUMENT_DATA_REALIZACJI		<% so.write doc_.afc.display.fulldate(root_.dDataReal) %>

#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>
#define DOKUMENT_OSOBA_ODBIERAJACA		<% so.write util_.Osoba_Odbierajaca(root_)%>
#define DOKUMENT_OPIS					<% so.write root_.strUwagi %>
#define DOKUMENT_WARTOSC_NETTO			<% so.write MONEY(root_.curSumaNetto)%>
#define DOKUMENT_WARTOSC_BRUTTO			<% so.write MONEY(root_.curSumaBrutto)%>
#define DOKUMENT_POWIAZANY				<% if not root_.pZamowienie is nothing then so.write root_.pZamowienie.strNrDok end if  %>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_TOWAR						<% so.write pozycja.pProdukt.strNazwa %>
#define POZ_IDX							<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_OPAKOWANIE					<% if (pozycja.pOpak.strNazwa <> "Podstawowe") then so.write " (" + pozycja.pOpak.strNazwa + ")" end if%>
#define POZ_INDEKS						<% so.write pozycja.pProdukt.strIndeks %>
#define POZ_ILOSC						<% so.write doc_.afc.display.quantity(pozycja.curIloscOpak,"",pozycja.pOpak.pJednOpak.nDokladnosc - 1) %>
#define POZ_JM							<% so.write pozycja.pOpak.pJednOpak.strSkrot %>
#define POZ_CENA_KAT_NETTO				<% so.write MONEY(pozycja.curCenaBazNetto) %>
#define POZ_CENA_KON_NETTO				<% so.write MONEY(pozycja.curCenaNetto) %>
#define POZ_CENA_KON_BRUTTO				<% so.write MONEY(pozycja.curCenaBrutto) %>
#define POZ_RABAT						<% so.write MONEY(pozycja.curRabat) %>
#define POZ_WARTOSC_NETTO				<% so.write MONEY(pozycja.curWartNetto) %>
#define POZ_WARTOSC_BRUTTO				<% so.write MONEY(pozycja.curWartBrutto) %>



<!-- podsumowanie pozycji -->



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>

</config>
<header>
</header>
<body>
<!-- całość -->
<table >
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[ZAMÓWIENIE]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>						

						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Odbiorca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>					
							<td>
							</td>
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

													
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)



						<!-- Dane nabywcy - KLIENT - jednostka organizacyjna -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Dostawca:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						
						<% if not root_.pKlient_JO is nothing then %>
						<tr>
							<td width='min'>
								<t/>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_JO_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient_JO.strPoczta<>"") and (root_.pKlient_JO.pMiejscowosc.strNazwa <> root_.pKlient_JO.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_JO_MIASTO]]></t>
							</td>					
							<td>
							</td>
						</tr>
						<% end if %>							
						
						<%  else %>
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>
							<td>
							</td>					
						</tr>
						<% end if %>							
						


						<% end if %>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)
						<!-- płatności -->
						<tr>
							<td width='min'>
								<t bold='true'>Data wystawienia:</t>
							</td>							
							<td>
								<text><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></text>
							</td>
							<td>
								<t bold='true'>Data aktualności:&nbsp;</t><t size='2'/>
								<t><![CDATA[DOKUMENT_DATA_AKTUALNOSCI]]></t>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t bold='true'>Data płatności:</t>
							</td>							
							<td>
								<text><![CDATA[DOKUMENT_DATA_PLATNOSCI]]></text>
							</td>
							<td>
								<t bold='true'>Data realizacji:&nbsp;</t><t size='4'/>
								<t><![CDATA[DOKUMENT_DATA_REALIZACJI]]></t>

							</td>							
						</tr>
						<% if root_.zam_strNrDokObcy<>"" then %>
						<tr>
							<td>
								<t bold='true'>Obcy numer dokumentu:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE_NR_OBCY]]></t>
							</td>							
							<td>
							</td>							

						</tr>
						<%end if%>


						
						<!-- dokumenty powiazane - zamowienie -->
						<% if not root_.pZamowienie is nothing then %>				
						ROW_SEPARATOR(2)
						
						<tr>
							<td>
								<t bold='true'>Zamówienie:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_POWIAZANY]]></t>
							</td>							
							<td>
							</td>							

						</tr>
						<% end if %>						



					</tbody>
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja				
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>							
							<td align='center'>
								<t>Indeks</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right' width='min'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena katalogowa netto</text>
							</td>
							<td align='right'>
								<text>Rabat</text>
							</td>
							<td align='right'>
								<text>Cena końcowa netto</text>
							</td>
							<td align='right'>
								<text>Cena końcowa brutto</text>
							</td>
							<td align='right'>
								<text>Wartość netto</text>
							</td>
							<td align='right'>
								<text>Wartość brutto</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td width='min' align='right'>
								<text><![CDATA[POZ_INDEKS]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_JM]]></text>																
							</td>							
							<td align='right'>
								<t><![CDATA[POZ_CENA_KAT_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RABAT%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_KON_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_KON_BRUTTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1							
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='8' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>						
						
					</tfoot>
				</table>
			</td>
		</tr>		
			

		<% if root_.strUwagi <> "" then %>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_OPIS]]></text>
			</td>
		</tr>
		<% end if%>

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'>
							</td>						
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>			
							<td>
							</td>				
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia zamówienia</t>
							</td>							
							<td>
							</td>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby uprawnionej do odbioru zamówienia</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
