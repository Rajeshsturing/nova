<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_WZ_WG_WARTOSCI

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Dokumenty WZ według wartości

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'dm_idobj'=dm.p_idobj,'dm_data_wyst'=max(dm.p_ddatawyst),'dm_nrdok'=max(dm.p_strnrdok),'p_strnazwa'=max(p.strNazwa), " + vbNewLine +_
	      "	'dm_ilosc'=sum(dm.c_curiloscopak),'dm_wartosc'=-sum(c_curwartmag) " + vbNewLine +_ 
	      "from vlist_n5dokmag_listPozycje dm " + vbNewLine +_
	      "	inner join n5produkt p on dm.c_pprodukt = p.idobj " + vbNewLine +_
	      "	inner join n5opakowanie_produktu op on dm.c_popak = op.idobj " + vbNewLine +_
	      "	inner join n5rejestrdok r on dm.p_prejestrdok = r.idobj " + vbNewLine +_
	      "where r.eTyp = N5REJESTRDOK__WZ and %1 and %2 and %3 and %4 " + vbNewLine +_
	      "group by dm.p_idobj,p.idobj,op.idobj " + vbNewLine +_
	      "order by max(dm.p_strnrdok),max(p.strNazwa)"
end function
%>
<%
function default_param()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("dm.p_ddatawyst")
  pParamArray.add doc_.afc.rap.param.new_text("Nr dokumentu").bindexpr("dm.p_strnrdok")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("p.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("p.strIndeks")
	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>
    RXE_LP
  </td>
  <td>
    RXE_DATE(dm_data_wyst)
  </td>
  <td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5DOKMAG,dm_idobj,dm_nrdok)
  </td>  
  <td>
    RXE_AUTO_TEXT(p_strnazwa)
  </td>    
  <td align='right'>
    RXE_QUANTITY_CVV(dm_ilosc,"",2)
  </td>    
  <td align='right'>
    RXE_QUANTITY_CVV(dm_wartosc,"",2)
  </td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
  <td width='1700'>
    <text><![CDATA[Data wystawienia]]></text>
  </td> 
  <td width='min'>
    <text><![CDATA[Nr WZ]]></text>
  </td>
  <td width='5000'>
    <text><![CDATA[Nazwa towaru z WZ]]></text>
  </td>
  <td width='2000'>
    <text><![CDATA[Ilość]]></text>
  </td>    
  <td width='2000'>
    <text><![CDATA[Wartość]]></text>
  </td>  
</tr>
</thead>
<tbody> 
<%
end function
%>

<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<% dim nSectionPicCounter : nSectionPicCounter = 10000000 %>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>  
<p><t size='2'/></p>
  
<%
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>  
  
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
	set pPerf = nothing 

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
  
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
end if
end with
%>
</body>
<footer>
</footer>
</page>
