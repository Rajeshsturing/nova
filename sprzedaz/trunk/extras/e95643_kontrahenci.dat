<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_KREATOR_PRZY_TOW_KONTRAH

#comment Definiowanie liczby wyświetlanych kontrahentów
#define LICZBA_KONTRAHENTOW 10

#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE Lista kontrahentów

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

function query()

	query = "select top " + CStr(LICZBA_KONTRAHENTOW) + " 'klient_idobj'=max(k.IdObj),'klient_nazwa'=k.strNazwa,'klient_tel'=max(k.strTel1), " +_
          "'klient_ulica'=max(k.strUlica),'klient_nrdomu'=max(k.strNrDomu),'klient_kod'=max(k.strKod),'miejscowosc'=max(m.strNazwa), " +_
          "'zakup_idobj'=max(z.p_idobj),'zakup_data'=max(z.p_ddatawyst) " +_
          "from vlist_n5zakup_listPozycje z " +_
          "inner join n5klient k on z.p_pdostawca = k.idobj " +_
          "inner join n5miejscowosc m on k.pMiejscowosc = m.idobj " +_
          "inner join n5produkt p on z.c_pprodukt = p.idobj " +_
          "inner join n5grupaproduktow g on p.pGrupaProd = g.idobj and %1 " +_
          "group by k.strNazwa " +_
          "order by k.strNazwa "
          
end function
%>
<%

dim pParamArray

function default_param()

    set pParamArray = doc_.afc.new_navoarray()
	  'parametr lista wyboru
	  dim pParam : set pParam = doc_.afc.rap.param.new_choice("Grupa produktów").bindexpr("g.strNazwa")
    doc_.afc.rap.param.init_on_query  pParam , trans_ ,  "select strNazwa,IdObj from n5grupaproduktow"
	  pParam.multiple = true
	  pParamArray.add pParam
    
    set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,klient_idobj,klient_nazwa)
	</td>
	<td>
		RXE_AUTO_TEXT(klient_tel)
	</td>  
  <td>
    <%
      so.write "<text><![CD"+"ATA["+ cstr(pRec("klient_ulica")) + " " + cstr(pRec("klient_nrdomu")) + " " + cstr(pRec("klient_kod")) + " " +_
               cstr(pRec("miejscowosc")) + "]"+"]></text>"
		%>
	</td> 
  <td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZAKUP,zakup_idobj,zakup_data)
	</td> 
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='6000'>
		<text><![CDATA[Nazwa kontrahenta]]></text>
	</td>
	<td width='2500'>
		<text><![CDATA[Nr telefonu]]></text>
	</td>
	<td width='6000'>
		<text><![CDATA[Adres]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data ost. zakupu]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
  <table>
    <thead>
      <tr>
        <td align='center' colspan='3'>
          <text fontsize='7'><![CDATA[RAPORT_TITLE]]></text>
        </td>
      </tr>
      <tr><td colspan='3'><t/></td></tr>
    </thead>
  </table>

<%
dim pParamTypPro
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
 if not .perform then
 end if 
end if
end with
%>
</body>
<footer>
</footer>
</page>