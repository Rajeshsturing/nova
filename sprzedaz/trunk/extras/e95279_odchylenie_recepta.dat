<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Odchylenie zużycia surowców od recepty produkcyjnej

#macro RXE_PERCENT_VAR(_var_)	<t><%so.write doc_.afc.display.money(_var_,"%")%></t>


-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()


query = "select 'recepta'=max(trr_pRecepta),"+_
	" 'wyrob' = max(trr_pWyrob),"+_
	" 'surowiec' = max(trr_pSurowiec),"+_
	" 'il_realna' = sum(trr_curIloscOpakSur), 'il_idealna' = sum(trr_curIloscOpakSurIdeal), "+_
	" 'wyrob_nazwa' = max(t_wyrob.strNazwa), 'surow_nazwa' = max(t_surow.strNazwa), "+_
	" 'recepta_nazwa' = max(t_rec.strNazwa), 'jedn_sur' = max(t_jedn.strSkrot),	"+_
	" 'c_prec'=max(t_jedn.nDokladnosc) ,  "+_
	" 'c_1_rec'=TYPEID_N5RECEPTA, c_1_wyr=TYPEID_N5PRODUKT " +_
	" from #tmp_real_receptury "+_
	" inner join n5produkt as t_wyrob on trr_pWyrob = t_wyrob.IdObj "+_
	" inner join n5produkt as t_surow on trr_pSurowiec = t_surow.IdObj"+_
	" inner join n5opakowanie_produktu as t_opak_sur on trr_pSurowiecOpak= t_opak_sur.IdObj "+_
	" inner join n5jednostka as t_jedn on t_opak_sur.pJednOpak=t_jedn.IdObj "+_
	" inner join n5recepta as t_rec on t_rec.IdObj = trr_pRecepta "+_
	" where %2 "+_
	" group by trr_pSurowiec, trr_pRecepta, trr_pWyrob "+_
	" order by trr_pRecepta, trr_pWyrob, trr_pSurowiec "



end	function
%>
<%
function body_row(byref pSection,byref pRec)
dim curIloscReal : curIloscReal = ccur(pRec("il_realna"))
dim curIloscIdeal : curIloscIdeal = ccur(pRec("il_idealna"))
dim strUnit : strUnit = cstr(pRec("jedn_sur"))
dim nDokl : nDokl = clng(pRec("c_prec")) - 1 

dim curRoznica 

if curIloscIdeal <> 0.0 then 
	curRoznica = ((curIloscReal - curIloscIdeal)/curIloscIdeal) * 100
else
	curRoznica = 0.0
end if

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'
<%
else
%>
<tr bordercolor='white' style='37'
<%
end if

%>
>
<td align='right'>RXE_LP</td>
	
	<td align='left'>
		RXE_AUTO_TEXT(surow_nazwa)
	</td>
	<td align='right'>
		RXE_AUTO_TEXT(jedn_sur)
	</td>
	<td align='right'>
		RXE_QUANTITY_VVV(curIloscIdeal,"",nDokl)
	</td>
	<td align='right'>
		RXE_QUANTITY_VVV(curIloscReal,"",nDokl)
	</td>
	
	<td align='right'>
		RXE_PERCENT_VAR(curRoznica)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	
	<td width='max'>
		<text><![CDATA[Nazwa surowca]]></text>
	</td>
	<td width='min'>
		<t><![CDATA[Jednostka]]></t>
	</td>

	<td width='min'>
		<t><![CDATA[Ilość idealna]]></t>
	</td>
	<td width='min'>
		<t><![CDATA[Ilość realna]]></t>
	</td>
	
	<td width='min'>
		<t><![CDATA[Odchylenie]]></t>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>

</tfoot>
</table>
<%
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1_wyr, wyrob, wyrob_nazwa)
	<t size='3'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1_rec, recepta, recepta_nazwa)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
<td colspan='7' />
</tr>

<%
end function
%>



<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pM60249 : set pM60249 = doc_.getmodule(60249)
dim pRealRecept : set pRealRecept = pM60249.new_real_recept()
dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = pRealRecept.get_okres_param()
pParamArray.add pParamOkres
pParamArray.add doc_.afc.rap.param.new_text("Nazwa recepty").bindexpr("t_rec.strNazwa")

%>

<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")


if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRealRecept.fill_real rapeng_.get_raport_param().value(0)
		pRealRecept.fill_real_ideal
	set pPerf = nothing
	
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRealRecept.manual_done()
set pRealRecept = nothing
set pM60249 = nothing
%>
</body>
<footer>
</footer>
</page>
