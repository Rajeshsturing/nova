<%
'zwraca sumę zapisu na konto płacowe
function sumDekret(idNal, strSubKonto, strWhere)
	dim strSQL
	strSQL = "select 'suma'=isnull(sum(nal.c_curKwota),0) from vlist_n5plnaliczenie_listDekret nal " +_
			 "inner join n5plsubkonto sk on nal.c_psubkonto=sk.idobj where sk.strKod='" + strSubKonto + "' and nal.p_idobj = " + CStr(idNal)
	if strWhere <> "" then
		strSQL = strSQL + " and " + strWhere
	end if
	dim oRS: set oRS = trans_.createadors(strSQL)
	sumDekret = ccur(oRS(0).value)		 	
end function

'dane pobierane ze szczegółów naliczenia
function getItemValue(byref oNal, byval strOpis)
	dim pModule: set pModule = doc_.getmodule(60192)
	dim pRootNalStorage: set pRootNalStorage = pModule.load_naliczenie(oNal)
	dim iter: iter = 1
	do while true
		dim pDisplayItem: set pDisplayItem = pRootNalStorage.get_display_item(iter)
		if pDisplayItem is nothing then
			exit do
		end if
		if pDisplayItem.get_text() = strOpis then
			if pDisplayItem.get_type() = 2 then
				getItemValue = pDisplayItem.get_curvalue()
				exit function
			elseif pDisplayItem.get_type() = 3 then
				getItemValue = pDisplayItem.get_computed_value().curvalue
				exit function
			end if	
		end if
		iter = iter + 1
	loop			
end function

%> 
 

