								<t><![CDATA[9,76% ubezp. emeryt.]]></t>
							</td>							
							<td fontsize='DEFAULT_FONT_SIZE' align='center'>
								<t><![CDATA[NAL_UBEZP_EMERYTALNE]]></t>
							</td>
							<td fontsize='DEFAULT_FONT_SIZE' align='left'>
								<t><![CDATA[Podatek należny]]></t>
							</td>
							<td fontsize='DEFAULT_FONT_SIZE' align='center'>
								<t><![CDATA[NAL_PODATEK_NALEZNY]]></t>
							</td>		
							<td fontsize='DEFAULT_FONT_SIZE' align='left' bordercolor='transparent'>
								<t><![CDATA[]]></t>
							</td>
							<td fontsize='DEFAULT_FONT_SIZE' align='center' bordercolor='transparent'>
								<t><![CDATA[]]></t>
							</td>																																							
						</tr>																			

					</tbody>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1,5)
		ROW_SEPARATOR(1,5)
		<%
			if iter mod 5 = 0 then
		%>	
				NEW_PAGE
		<%		
				iter = 0
			end if
			iter = iter + 1
			licz = licz + 1
			oRS.movenext
		loop
		%>
	</tbody>
</table>
