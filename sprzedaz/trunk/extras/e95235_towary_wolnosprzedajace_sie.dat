<?xml version="1.0" encoding="windows-1250" ?>
<!-- 17.07.2004 filtr na grupe nie jako checkbox-->
<!-- 13.01.2005 podgrupy produktow -->

<!--
RAPTEMPLATE_TOWARY_WOLNOSPRZEDAJACE_SIE

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Towary wolnosprzedające się

#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_2.strIndeks
#define C_FIELD_SECOND_EXPR		t_2.strNazwa
#define C_FIELD_FIRST_HUMANNAME Indeks
#define C_FIELD_SECOND_HUMANNAME Nazwa
#else
#define C_FIELD_FIRST_EXPR		t_2.strNazwa
#define C_FIELD_SECOND_EXPR		t_2.strIndeks
#define C_FIELD_FIRST_HUMANNAME		Nazwa
#define C_FIELD_SECOND_HUMANNAME	Indeks
#endif

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()
query = "select 'c_mag'=t_1.strNazwa,'c_field_second'=C_FIELD_SECOND_EXPR,'c_oznprod' = max(t_2.strCecha1),'c_field_first'=C_FIELD_FIRST_EXPR,'c_prod_idobj'=max(t_2.idObj),'c_opak'=t_3.strNazwa," +_
"'c_ilosc_opak'=sum(t_stanmag.gms_curIlosc),'c_ilosc_ewid'=sum(t_stanmag.gms_curIlosc * t_stanmag.gms_curCena)," +_
"'c_jedn_opak'=max(t_4.strSkrot),'c_prec_opak'=max(t_4.nDokladnosc), " +_
"'c_jedn_ewid'=max(t_5.strSkrot),'c_prec_ewid'=max(t_5.nDokladnosc) " +_
"from n5gmstan as t_stanmag inner join n5magazyn as t_1 on t_stanmag.gms_pMag = t_1.IdObj " +_
"inner join n5produkt as t_2 on t_stanmag.gms_pProd = t_2.IdObj " +_
"inner join n5opakowanie_produktu as t_3 on t_stanmag.gms_pOpak = t_3.IdObj " +_
"inner join n5jednostka as t_4 on t_3.pJednOpak = t_4.IdObj " +_
"inner join n5jednostka as t_5 on t_2.pJednostkaEwid = t_5.IdObj " +_
"where t_2.pGrupaProd in (select tmp_group_idobj from #tmp_prod_hierarchy)   "+_
"and %1 and %2 and %3 and %5 and %7 and OKRES_NROPMAG_WHERE " +_
"group by t_1.strNazwa,t_2.strNazwa,t_2.strIndeks,t_3.strNazwa " +_
"having %6 " +_
"order by c_mag,c_field_first,c_field_second,c_opak"
end function
%>


<%

'' jest używane poza default_param()
dim RaportOkresParam

dim utilProdHierarchy : set utilProdHierarchy = doc_.getmodule(60246)
dim pProdHierarchy : set pProdHierarchy = utilProdHierarchy.new_prod_hierarchy()

dim pParamArray
dim pGrupaParam


function default_param()

	set pParamArray = doc_.afc.new_navoarray()

	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("t_1.idobj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")

	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_2.strIndeks")
	set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam

	dim pParamSTATUS: Set pParamSTATUS= doc_.afc.rap.param.new_choice("Dostępność").bindexpr("t_2.eAktywny")
	doc_.afc.rap.param.init_on_enum pParamSTATUS, TYPEID_N5PRODUKT,"eAktywny"
	pParamArray.add pParamSTATUS
	pParamSTATUS.selected.value(1) = false

	pParamArray.add doc_.afc.rap.param.new_currency("Ilość opakowań").bindexpr("sum(t_stanmag.gms_curIlosc)")	

	dim pParamOPAK: set pParamOPAK = doc_.afc.rap.param.new_text("Nazwa opakowania").bindexpr("t_3.strNazwa")
	pParamOPAK.mode = PARAM_TEXT_MODE_ANY_TEXT
	pParamArray.add pParamOPAK

	set RaportOkresParam = doc_.afc.rap.param.new_date_range("Dostawy z okresu").bindexpr("")
	pParamArray.add RaportOkresParam
		
	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
	' zwracamy puste zapytanie jeśli nie będzie żadnych pasujacych operacji
	write_actual_param = "0=1" 

	dim iter
	dim bAnyWritten : bAnyWritten = false
	if not pActualParam is nothing then

		dim nDummy1,nDummy2	
		write_actual_param = "t_stanmag.gms_nNumOp " + doc_.getmodule(43025).rap_param_date_range_2_gm_num_oper_where(RaportOkresParam,nDummy1,nDummy2)


		for iter = 0 to pActualParam.upperIndex
			if pActualParam.value(iter).get_desc() <> "" then 
				bAnyWritten = true
				so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
			end if
		next

	end if
	if not bAnyWritten then 
		so.write "<t fontsize='4'>brak</t><br/>"
	end if
	so.write "<br/>"
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
#ifdef _IOW
<td style='27' colspan='8'>
#else
<td style='27' colspan='7'>
#endif
	
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_mag)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
#ifdef _IOW
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
#else
<tr hide='true' userprop='propc_section_end="1"'><td colspan='6' /></tr>
#endif

<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_prod_idobj,c_field_first)
	</td>
#ifdef _IOW
	<td>
		RXE_AUTO_TEXT(c_oznprod)
	</td>
#endif
	<td>
		RXE_AUTO_TEXT(c_field_second)
	</td>
	<td>
		RXE_AUTO_TEXT(c_opak)
	</td>
	<td align='right'>
		RXE_QUANTITY_CCC(c_ilosc_opak,c_jedn_opak,c_prec_opak)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_ilosc_ewid,"PLN",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
'so.write "<p backcolor='yellow'><text><![CD"+"ATA["+pRapExec.get_final_query() + "]"+"]></text></p><br/>" 
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text>
	</td>
#ifdef _IOW
	<td width='max'>
		<text><![CDATA[Oznaczenie producenta]]></text>
	</td>
#endif
	<td width='max'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Opakowanie]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Ilość opakowań]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pProdHierarchy.fill_on_prodgrupa_param pGrupaParam
	set pPerf = nothing

	dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())

	'' drobna modyfikacja zapytania - parametr nropmag
	.ReplaceQueryParam "OKRES_NROPMAG_WHERE",nropmag_str

	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with

pProdHierarchy.manual_done() : set pProdHierarchy = nothing
set utilProdHierarchy = nothing


%>
</body>
<footer>
</footer>
</page>
