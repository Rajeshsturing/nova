%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4' bordercolor='black'>
	<td style='27' colspan='<% so.write cstr(10 + nNumMag) %>' bordercolor='black'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZAMOWIENIE,c_idZamow, c_strNrZamow) 
    NAGLOWEK
