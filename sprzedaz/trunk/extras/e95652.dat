<%
function body_row(byref pSection,byref pRec)
  if pRapExec.RecNr mod 2 = 0 then
%>

<tr bordercolor='black' userprop="vc0='<% so.write pRec("c_idProdukt").value %>' vc1='<% so.write clng(pRec("c_curIloscZamPoz").value) %>' vc2='<% so.write clng(pRec("c_curIloscZlecProd").value) %>' vc3='<% so.write clng(pRec("c_idKlient").value) %>' vc4 ='<% so.write clng(pRapExec.RecNr)%>'">

<%
  else
%>

<tr style='37' bordercolor='black' userprop="vc0='<% so.write pRec("c_idProdukt").value %>' vc1='<% so.write clng(pRec("c_curIloscZamPoz").value) %>' vc2='<% so.write clng(pRec("c_curIloscZlecProd").value) %>' vc3='<% so.write clng(pRec("c_idKlient").value)%>' vc4 ='<% so.write clng(pRapExec.RecNr)%>'">

<%
  end if
%>
<td bordercolor='white' backcolor='white' width='min'><t>&nbsp;</t></td>
<td bordercolor='white' backcolor='white' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT(c_strInxProd)
	</td>

	<td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,c_idProdukt,c_strNazwaProd)
	</td>
	<td align='right'>
    RXE_QUANTITY_CVV(c_curIloscZam,"",2)
	</td>
  <% if ccur(pRec("c_curIloscWZ").value) <> 0 then %>
  <td align='right'>
    <text href='varFunctionHLI = "FuncTestowa" vs200 = <% so.write cStr(pRec("c_idZamow").value) %> vs201 = <% so.write cStr(pRec("c_idProdukt").value) %>'><%so.write cstr(doc_.afc.display.quantity(pRec("c_curIloscWZ").value, "", 2))%></text>
	</td>
<% else %>
  <td align='right'>
    RXE_QUANTITY_CVV(c_curIloscWZ,"",2)
  </td>
<% end if%>
<% if ccur(pRec("c_curIloscZlecProd").value) <> 0 then %>
  <td align='right'>
    <text href='varFunctionHLI = "FuncTestowa1" vs200 = <% so.write cStr(pRec("c_idZamow").value) %> vs201 = <% so.write cStr(pRec("c_idProdukt").value) %>'><%so.write cstr(doc_.afc.display.quantity(pRec("c_curIloscZlecProd").value, "", 2))%></text>
	</td>
<% else %>
  <td align='right'>
    RXE_QUANTITY_CVV(c_curIloscZlecProd,"",2)
  </td>
<% end if %>
   <td align='right'>
    RXE_QUANTITY_CVV(c_curIloscZlecProdPoz,"",2)
	</td>
<%
  if bShowCecha1 then
%>
  <td width='min'>
    RXE_TEXT(c_strCecha1)
  </td>
<%
  end if
%> 
<%
  if bShowCecha2 then
%>
  <td width='min'>
    RXE_TEXT(c_strCecha2)
  </td>
<%
  end if
%> 
<%
  if bShowCecha3 then
%>
  <td width='min'>
    RXE_TEXT(c_strCecha3)
  </td>
<%
  end if
%> 
<% 
dim i, strNazwaMagazynu

for i = 0 to liczbaMag
  if isSelectedMag.value(i) = true then 
    strNazwaMagazynu = "curMag" + cstr(idSelectedMag.value(i))
%>

 <td align='right'>
    <text><% so.write doc_.afc.display.quantity(pRec(strNazwaMagazynu),"",2) %></text>
	</td>
  
<% 
  end if 
next
%>
  <td align='center'>   
    <checkbox border='0' customredirect='CTRLID_NOWE_ZAMOW'>
		<t/>
      <transfer mode='custom' />
		</checkbox>
	</td>
 
</tr>

<%
end function
%>

<%
dim nNumMag

function body_header(byref pSection,byref pRec)

'generowanie kolumn magazynów

  liczbaMag = pParamArray.value(FILTR_MAGAZYN).selected.UpperIndex()
  dim tempIter
  for tempIter=0 to liczbaMag
    isSelectedMag.add pParamArray.value(FILTR_MAGAZYN).selected.value(tempIter)
    strNazwaMag.add pParamArray.value(FILTR_MAGAZYN).names.value(tempIter)
    idSelectedMag.add pParamArray.value(FILTR_MAGAZYN).values.value(tempIter)
  next
  
  nNumMag = 0
  for tempIter = 0 to liczbaMag
    if isSelectedMag.value(tempIter) = true then
      nNumMag = nNumMag + 1
    end if
  next  
  
  if bShowCecha1 then
    nNumMag = nNumMag + 1
  end if
  if bShowCecha2 then
    nNumMag = nNumMag + 1
  end if
  if bShowCecha3 then
    nNumMag = nNumMag + 1
  end if   
  
%>

<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Indeks produktu]]></text>
</td>

<td width='max'>
  <text><![CDATA[Nazwa]]></text>
</td>
<td width='max'>
  <text><![CDATA[Ilość zamówiona]]></text>
</td>
<td width='min'>
    <text><![CDATA[Ilość wydana (WZ)]]></text>
</td>
<td width='min'>
  <text><![CDATA[Ilość zlecona do prod.]]></text>
</td>
  <td width='min'>
    <text><![CDATA[Ilość pozostała do realizacji]]></text>
  </td>
<%
  if bShowCecha1 then
%>
  <td width='min'>
    <text><![CDATA[Cecha 1]]></text>
  </td>
<%
  end if
%>
<%
  if bShowCecha2 then
%>
  <td width='min'>
    <text><![CDATA[Cecha 2]]></text>
  </td>
<%
  end if
%>
<%
  if bShowCecha3 then
%>
  <td width='min'>
    <text><![CDATA[Cecha 3]]></text>
  </td>
<%
  end if
%>
  
<% 
dim i

for i = 0 to liczbaMag
  if isSelectedMag.value(i) = true then 
%>

 <td align='right'>
   <text><![CDATA[<% so.write strNazwaMag.value(i) %>]]></text>
	</td>
  
<% 
  end if 
next
%>
<td width='min'>
    <text><![CDATA[Dodaj zlecenie]]></text>
</td>
  
</tr>
</thead>
<tbody>
  
<%
end function
%>

<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
  <td style='27' align='right' colspan='<% so.write cstr(8 + nNumMag) %>'>
    <t>
      &nbsp;
    </t>
  </td>
  <td style='27' align='right' colspan='2' >
      <button href='varFunction="Zlec"'>Utwórz</button>
  </td>
</tr>
</tfoot>
</table>
  
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
  doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
  RAPORT_HEADER(3,0)
</p>
  <p>
  <t size='2'/>
  </p>

  <p>
    <text fontsize='7'><![CDATA[RAPORT_TITLE]]></text>
  </p><br/><br/>
  
<%
dim pParamTypPro
%>
   
  <t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
  
<%

dim liczbaMag                                                         ''liczba magazynów zaznaczonych na filtrze (żeby nie wywoływać UpperIndex caly czas) 
dim isSelectedMag : set isSelectedMag  = doc_.afc.new_navoarray()     '' zaznaczone magazyny na filtrze         
dim strNazwaMag : set strNazwaMag  = doc_.afc.new_navoarray()         '' nazwy zaznaczonych magazynów na filtrze
dim idSelectedMag : set idSelectedMag  = doc_.afc.new_navoarray()

'czy pokazywać kolumny dodatkowe (cecha 1, cecha 2, cecha 3)
dim bShowCecha1 : bShowCecha1 = true
dim bShowCecha2 : bShowCecha2 = true
dim bShowCecha3 : bShowCecha3 = true

dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  .add_group_section 0,getref("section_header_1"),getref("section_footer_1")
  .add_group_section 1,getref("section_header_2"),getref("section_footer_2")
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

    if not pParamCechy.selected.value(0) then
      bShowCecha1 = false
    end if
    if not pParamCechy.selected.value(1) then
      bShowCecha2 = false
    end if
    if not pParamCechy.selected.value(2) then
      bShowCecha3 = false
    end if    

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

  dim nropmag_str : nropmag_str = write_actual_param(rapeng_.get_raport_param())

  '' drobna modyfikacja zapytania - parametr nropmag
  ''.ReplaceQueryParam "OKRES_NROPMAG_WHERE",nropmag_str

  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
  end if
  end if
  end with
  
  trans_.execsql " drop table WYROBY_POZ_DO_REAL"
     

%>


</body>
<footer>
</footer>
</page>
