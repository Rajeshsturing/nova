#define RAPORT_TITLE Wyroby pozostałe do realizacji
#define CTRLID_NOWE_ZAMOW 1
#define FILTR_MAGAZYN 4
#define WYROBY_POZ_DO_REAL #wyroby_poz_do_real
#define NAGLOWEK <text><% so.write "&nbsp; &nbsp;" + replace(cstr(pRec("c_strNazwaKlient")), "&", "&amp;") %></text>


-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>

<script>
<![CDATA[

'''Tablice do obsługi checkboxów'''''''''''''''''''''''''''''''''''''

dim pZlecenie : set pZlecenie = doc_.afc.new_navoarray()  'tablica z ilością produktu, która ma się znaleźć na zleceniu produkcyjnym
dim pProdukt : set pProdukt = doc_.afc.new_navoarray()    'tablica z id produktu, który ma się znaleźć na zleceniu produkcyjnym
dim pKlient : set pKlient = doc_.afc.new_navoarray()      'tablica z id klienta, tkóry ma się znaleźć na zleceniu produkcyjnym
dim pId : set pId = doc_.afc.new_navoarray()              'tablica identyfikująca wiersz checkboxa (służy do usuwania z tabel odznaczonych elementów)



'''Funkcja otwierająca nowy raport z poziomu raportu'''''''''''''''''
'''''zmiana w util60140''''''''''''''''''''''''''''''''''''''''''''''

function FuncTestowa(byval pHLI) 
  doc_.postcommand "varCmd=CMD_OPEN_STATIC_PAGE varDestPage=60140 appvar_raport_type=95653 vs111='" + cstr(pHLI(200)) +" ' vs112='" + cstr(pHLI(201)) +"'" 
end function

function FuncTestowa1(byval pHLI) 
  doc_.postcommand "varCmd=CMD_OPEN_STATIC_PAGE varDestPage=60140 appvar_raport_type=95656 vs113='" + cstr(pHLI(200)) +" ' vs114='" + cstr(pHLI(201)) +"'" 
end function

''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''

'''Funkcja obsługi checkboxa - jeśli została zmieniona wartość''''''''

function c##CTRLID_NOWE_ZAMOW##_ondataentered(pCtrl, Value)

  if pCtrl.value="1" then                                    'zapisanie danych do tablic jeśli checkbox został zaznaczony
    pProdukt.add pCtrl.parent.parent.userprop.prop(0)
    'if (pCtrl.parent.parent.userprop.prop(1) - pCtrl.parent.parent.userprop.prop(2)) >=0 then
      'pZlecenie.add (pCtrl.parent.parent.userprop.prop(1) - pCtrl.parent.parent.userprop.prop(2))
      pZlecenie.add pCtrl.parent.parent.userprop.prop(1)
    'else 
      'pZlecenie.add 0
    'end if
    pKlient.add pCtrl.parent.parent.userprop(3)
    pId.add pCtrl.parent.parent.userprop(4)
    
  else                                                         'usuwanie danych do tablic jeśli checkbox został odznaczony
    dim idRmv : idRmv = pCtrl.parent.parent.userprop(4)        'id odznaczonego wiersza
    dim idElem                                                 'indeks elementów do usunięcia
    dim iterator
    
    
    for iterator = 0 to (pId.UpperIndex+1)
      if pId.value(iterator)=idRmv then 
        idElem = iterator
        exit for
      end if
    next
    
    pProdukt.Remove idElem
    pZlecenie.Remove idElem
    pKlient.Remove idElem
    pId.Remove idElem
  end if
  
  
end function

'''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''

'''Funkcja obsługi checkboxa ''''''''''''''''''''''''''''''''''''''''''

function c##CTRLID_NOWE_ZAMOW##_ongetdata(byref pCtrl):c##CTRLID_NOWE_ZAMOW##_ongetdata=true
end function

'''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''

'''Funkcja obsługi przycisku - tworzy wypełnione Zlecenie produjcji'''' 

function Zlec
  dim pOpenFormZlec : set pOpenFormZlec = doc_.getmodule(60129).prepare_form_open_command(TYPEID_N5ZLECPROD,0,0)

  if pOpenFormZlec is nothing then
	        exit function
  end if
 
  dim pFormZlec : set pFormZlec = doc_.getpagehli(pOpenFormZlec)
  if pFormZlec is nothing then
	   exit function
  end if 
  
  '----------Wypełnianie zlecenia----------
  dim blad : blad =0
  dim iterator
  dim pPozZlec        ' obiekt pozycji zlecenia
  dim pProd           ' obiekt porduktu, pobierany przez idObj z zaznaczonego wiersza
  dim pKli            ' obiekt klienta, pobierany przez idObj z zaznaczonego wiersza
  dim pJedynyKlient :
  
  set pJedynyKlient = trans_.getobj(TYPEID_N5KLIENT, pKlient.value(0))
  
  for iterator=0 to pZlecenie.UpperIndex 
    set pProd = trans_.getobj(TYPEID_N5PRODUKT, pProdukt.value(iterator))
    set pKli = trans_.getobj(TYPEID_N5KLIENT, pKlient.value(iterator))
    
    

    if pJedynyKlient.idObj <> pKli.idObj then
      trans_.message 7000, 0, "Zaznaczone zlecenia dotyczą różnych klientów"
      blad =1
    else if pZlecenie.value(iterator)=0 then
        trans_.message 7000, 0, "Ilość zamówionego produktu i ilość produktu zleconego do produkcji są zgodne"
      else
        set pPozZlec = pFormZlec.root.listpozycje.addnew()
        pPozZlec.pProdukt = pProd
        pPozZlec.curIloscOpak=pZlecenie.value(iterator)
        pFormZlec.root.pKlient=pKli
      end if
    end if
  
  next
  
  if blad=0 then
    pFormZlec.domodalauto()
  end if
   
end function

'''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''''

<%

'''Standardowy raport''''''''''''''''''''''''''''''''''''''''''''''''''

function query()
  
  dim temp_query
  
  temp_query = " create table WYROBY_POZ_DO_REAL " + vbNewLine +_
               " ( "+_
               " idZamow	integer not null, " + vbNewLine +_
               " idProdukt integer not null, " + vbNewLine +_
               " idOpak integer not null, " + vbNewLine +_
               " idWZ integer not null, " + vbNewLine +_
               " idZlecProd integer not null, " + vbNewLine +_
               " curIloscZam decimal(14,4) not null, " + vbNewLine +_
               " curIloscZamPoz decimal(14,4) not null, " + vbNewLine +_
               " curIloscWZ decimal(14,4) not null, " + vbNewLine +_
               " curIloscZlecProd decimal(14,4) not null, " + vbNewLine +_
               " curIloscZlecProdPoz decimal(14,4) not null, " + vbNewLine +_
               " curIloscMag decimal(14,4) not null, " + vbNewLine +_
               " dDataReal datetime " + vbNewLine +_
               " )"
           
  trans_.execsql temp_query
           
  temp_query = " insert into WYROBY_POZ_DO_REAL select " + vbNewLine +_
               " v_zamow.p_idobj, v_zamow.c_pProdukt, v_zamow.c_pOpak,0,0,sum(v_zamow.c_curiloscopak),sum(v_zamow.c_curiloscopakpoz), " + vbNewLine +_
               " 0.0,0.0,0.0,0.0,c_pzam_ddatareal " + vbNewLine +_
               " from vlist_n5zamowienie_listpozycje v_zamow " + vbNewLine +_
               " join n5produkt t_prod on v_zamow.c_pProdukt=t_prod.idObj " + vbNewLine +_
               " join n5rejestrdok r on v_zamow.p_prejestrdok = r.idobj " + vbNewLine +_ 
               " where r.eTyp = N5REJESTRDOK__ZAM_OBCE " + vbNewLine +_
               " group by p_idobj,c_pzam_ddatareal,c_pProdukt,c_pOpak "
               
  trans_.execsql temp_query
           
  temp_query = " insert into WYROBY_POZ_DO_REAL select " + vbNewLine +_
               " v_dokmag.p_wrefdokhandl,v_dokmag.c_pProdukt, v_dokmag.c_pOpak,v_dokmag.p_idObj,0,0.0,0.0,sum(v_dokmag.c_curiloscopak), " + vbNewLine +_
               " 0.0,0.0,0.0,v_dokmag.c_dextra3 " + vbNewLine +_
               " from vlist_n5dokmag_listpozycje v_dokmag " + vbNewLine +_
               " join n5produkt t_prod on v_dokmag.c_pProdukt = t_prod.idObj " + vbNewLine +_
               " where p_wrefdokhandl in (select idZamow from WYROBY_POZ_DO_REAL) " + vbNewLine +_
               " and p_wrefdokhandl_wrt=10172 and p_nTypDok = N5REJESTRDOK__WZ " + vbNewLine +_
               " group by p_idObj,p_wrefdokhandl,v_dokmag.c_dextra3,c_pProdukt,c_pOpak "
               
  trans_.execsql temp_query
           
  temp_query = " insert into WYROBY_POZ_DO_REAL select " + vbNewLine +_
               " n5sprzedaz.pZamowienie,v_dokmag.c_pProdukt, v_dokmag.c_pOpak, v_dokmag.p_idObj,0,0.0,0.0,sum(v_dokmag.c_curiloscopak), " + vbNewLine +_
               " 0.0,0.0,0.0,v_dokmag.c_dextra3 " + vbNewLine +_
               " from vlist_n5dokmag_listpozycje v_dokmag " + vbNewLine +_
               " join n5sprzedaz on v_dokmag.p_wrefdokhandl = n5sprzedaz.idobj and v_dokmag.p_wrefdokhandl_wrt=10129 " + vbNewLine +_
               " inner join n5produkt t_prod on v_dokmag.c_pProdukt = t_prod.idObj " + vbNewLine +_
               " where pZamowienie in (select idZamow from WYROBY_POZ_DO_REAL) " + vbNewLine +_
               " and v_dokmag.p_nTypDok = N5REJESTRDOK__WZ " + vbNewLine +_
               " group by v_dokmag.p_idObj,n5sprzedaz.pZamowienie,v_dokmag.c_dextra3,v_dokmag.c_pProdukt,v_dokmag.c_pOpak "
               
  trans_.execsql temp_query
           
  temp_query = " insert into WYROBY_POZ_DO_REAL select " + vbNewLine +_
               " v_zlecprod.p_pzamowienie , v_zlecprod.c_pProdukt, v_zlecprod.c_pOpak,0,v_zlecprod.p_idObj,0.0,0.0,0.0, " + vbNewLine +_
               " v_zlecprod.c_curIloscOpak ,v_zlecprod.c_curIloscOpakPoz,0.0,v_zlecprod.p_ddatareal " + vbNewLine +_
               " from vlist_n5zlecprod_listpozycje v_zlecprod " + vbNewLine +_
               " inner join n5produkt t_prod on v_zlecprod.c_pProdukt = t_prod.idObj " + vbNewLine +_
               " where p_pzamowienie in (select idZamow from WYROBY_POZ_DO_REAL) "
           
  trans_.execsql temp_query    
  
  'tworzenie zapytania pobierającego nazwy magazynów do zapytania głównego
  
  dim oRecordset  
  set oRecordset = trans_.createadors(_
                                      "select" + vbnewline +_
                                      "'idMag'=idObj," + vbnewline +_ 
                                      "'strMag'=strNazwa" + vbnewline +_
                                      "from n5magazyn")
  
  dim pos
  dim strMagQuery : strMagQuery = ""
  
  while not oRecordset.eof
    strMagQuery = strMagQuery + "'curMag" + cstr(oRecordset("idMag").value) + "' = isnull((select sum(gms_curilosc) from n5gmstan where gms_pProd = t_tmp.idProdukt and n5gmstan.gms_pMag = " + cstr(oRecordset("idMag").value) + "),0), " + vbnewline
  oRecordset.movenext
	wend
  
  
           
  query =  " select "+ vbnewline +_
           " 'c_idZamow'=t_tmp.idZamow, "+ vbnewline +_
           " 'c_pzam_dDataReal'=t_tmp.dDataReal, " + vbNewLine +_
           " 'c_idZlecProd' = max(t_tmp.idZlecProd), "+ vbnewline +_
           " 'c_strNrZamow'=max(t_zam.strNrDok), "+ vbnewline +_
           " 'c_idProdukt'=t_tmp.idProdukt, "+ vbnewline +_
           " 'c_strNazwaProd'=max(t_produkt.strNazwa), "+ vbnewline +_
           " 'c_strInxProd'=max(t_produkt.strIndeks), "+ vbnewline +_
           " 'c_curIloscZam'=sum(t_tmp.curIloscZam), "+ vbnewline +_
           " 'c_curIloscZamPoz'=sum(t_tmp.curIloscZamPoz), "+ vbnewline +_
           " 'c_curIloscWZ'=sum(t_tmp.curIloscWZ), "+ vbnewline +_
           " 'c_curIloscZlecProd'=sum(t_tmp.curIloscZlecProd), "+ vbnewline +_
           " 'c_curIloscZlecProdPoz'=sum(t_tmp.curIloscZam) - sum(t_tmp.curIloscWZ) - sum(t_tmp.curIloscZlecProd), "+ vbnewline +_
           " 'c_idKlient' = max(t_zam.pKlient), "+ vbnewline +_
           strMagQuery +_
           " 'c_strNazwaKlient' = max(t_klient.strNazwa), "+ vbnewline +_
           " 'c_dDataWyst' = max(t_zam.dDataWyst), "+ vbnewline +_
           " 'c_dDataReal' = max(t_zam.dDataReal), "+ vbnewline +_
           " 'c_strCecha1'= max(t_produkt.strCecha1), " + vbnewline +_
           " 'c_strCecha2'= max(t_produkt.strCecha2), " + vbnewline +_
           " 'c_strCecha3'= max(t_produkt.strCecha3) " + vbnewline +_
           " from WYROBY_POZ_DO_REAL as t_tmp "+ vbnewline +_
           " inner join n5zamowienie t_zam on t_tmp.idZamow = t_zam.idobj " + vbnewline +_
           " inner join n5produkt t_produkt on t_tmp.idProdukt = t_produkt.idObj "+ vbnewline +_
           " inner join n5grupaproduktow t_grupa on t_produkt.pGrupaProd = t_grupa.idobj " + vbnewline +_
           " left outer join n5zlecprod t_zlec on t_tmp.idZlecProd = t_zlec.idobj "+ vbnewline +_
           " left outer join n5dokmag t_wz on t_tmp.idWZ = t_wz.idObj "+ vbnewline +_
           " inner join n5klient t_klient on t_zam.pKlient = t_klient.idObj "+ vbnewline +_
           " where %1 and %2 and %3 and %4 and %6 and %7 and %9 and %10 and %11 " + vbnewline +_
           " group by t_tmp.idZamow,t_tmp.dDataReal,t_tmp.idProdukt,t_tmp.idOpak "+ vbnewline +_
           " having max(t_tmp.curIloscZamPoz)<>0 "+ vbnewline +_
           " order by c_strInxProd,c_pzam_dDataReal,c_idZamow"
           

end function
  
%>

<%

dim pGrupaParam
dim pParamArray
dim pParamCechy 

function default_param()
  
	set pParamArray = doc_.afc.new_navoarray()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_zam.dDataWyst")
  pParamArray.add doc_.afc.rap.param.new_date_range("Data realizacji").bindexpr("t_tmp.dDataReal")
	pParamArray.add doc_.afc.rap.param.new_text("Numer zamówienia").bindexpr("t_zam.strNrDok")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_produkt.strIndeks")
  pParamArray.add doc_.getmodule(43025).new_filtr_magazyn("gms_pMag","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE")
  
	dim pGroupProd : set pGroupProd = doc_.afc.rap.param.new_choice("Grupa produktów").bindexpr("t_grupa.idobj")
	doc_.afc.rap.param.init_on_query pGroupProd, trans_, "select strNazwa, idobj from n5grupaproduktow order by strNazwa"
	pParamArray.add pGroupProd
  
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_klient.strNazwa")
  
  set pParamCechy = doc_.afc.rap.param.new_choice("Kolumny dodatkowe")
  with pParamCechy
	  .multiple = true
    .names.add "Cecha 1"
    .values.add 1
    .selected.add true
    .names.add "Cecha 2"
    .values.add 2
    .selected.add true
    .names.add "Cecha 3"
    .values.add 3
    .selected.add true    
  end with
  pParamArray.add pParamCechy
  
  pParamArray.add doc_.afc.rap.param.new_text("Cecha 1").bindexpr("t_produkt.strCecha1")
  pParamArray.add doc_.afc.rap.param.new_text("Cecha 2").bindexpr("t_produkt.strCecha2")
  pParamArray.add doc_.afc.rap.param.new_text("Cecha 3").bindexpr("t_produkt.strCecha3")
  


	set default_param = pParamArray
  
end function
%>

<%
function write_actual_param(byref pActualParam)
  dim iter
  dim bAnyWritten : bAnyWritten = false
  if not pActualParam is nothing then
  for iter = 0 to pActualParam.upperIndex
  if pActualParam.value(iter).get_desc() <> "" then 
  bAnyWritten = true
	  so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
  end if
  next
  end if
  if not bAnyWritten then 
	  so.write "<t fontsize='4'>brak</t><br/>"
  end if
	  so.write "<br/>"
end function
%>

<%
