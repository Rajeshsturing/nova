<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_NIEROZL_FAKTURY_ZALICZKOWE

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Nierozliczone faktury zaliczkowe

#define ZALICZKOWE #zaliczkowe
#define STATUS #status

#macro RXE_MONEY_VAR_BOLD(_var_)		<t bold='true'><%so.write rapeng_.process_number(doc_.afc.display.money(_var_,""))%></t>
-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
'aby wykluczyć kolejny numer faktury zaliczkowej, należy w poniższej linijce dopisać jej nr oddzielony średnikiem
dim strListNr: strListNr = "FZAL/1/2015/2/0018;FZAL/1/2016/3/0001;FZAL/2/2016/3/0009;FZAL/3/2015/12/0008;FZAL/4/2016/2/0030"

dim nPopTrans: nPopTrans = clng(0)
'podsumowania w sekcji 1
dim curSumaNettoZal: curSumaNettoZal = ccur(0)
dim curSumaVatZal: curSumaVatZal = ccur(0)
dim curSumaBruttoZal: curSumaBruttoZal = ccur(0)
dim curSumaNettoKor: curSumaNettoKor = ccur(0)
dim curSumaVatKor: curSumaVatKor = ccur(0)
dim curSumaBruttoKor: curSumaBruttoKor = ccur(0)
dim curSumaNettoKonc: curSumaNettoKonc = ccur(0)
dim curSumaVatKonc: curSumaVatKonc = ccur(0)
dim curSumaBruttoKonc: curSumaBruttoKonc = ccur(0)
dim curSumaNettoPozost: curSumaNettoPozost = ccur(0)
dim curSumaVatPozost: curSumaVatPozost = ccur(0)
dim curSumaBruttoPozost: curSumaBruttoPozost = ccur(0)

'podsumowania w sekcji 1 (stawkami)
dim curSumaNettoZal23: curSumaNettoZal23 = ccur(0)
dim curSumaVatZal23: curSumaVatZal23 = ccur(0)
dim curSumaBruttoZal23: curSumaBruttoZal23 = ccur(0)
dim curSumaNettoZal8: curSumaNettoZal8 = ccur(0)
dim curSumaVatZal8: curSumaVatZal8 = ccur(0)
dim curSumaBruttoZal8: curSumaBruttoZal8 = ccur(0)
dim curSumaNettoZal5: curSumaNettoZal5 = ccur(0)
dim curSumaVatZal5: curSumaVatZal5 = ccur(0)
dim curSumaBruttoZal5: curSumaBruttoZal5 = ccur(0)
dim curSumaNettoZal0: curSumaNettoZal0 = ccur(0)
dim curSumaNettoZalZw: curSumaNettoZalZw = ccur(0)
dim curSumaNettoZalNp: curSumaNettoZalNp = ccur(0)

'podsumowania w sekcji 2
dim curSumaNettoZal_2: curSumaNettoZal_2 = ccur(0)
dim curSumaVatZal_2: curSumaVatZal_2 = ccur(0)
dim curSumaBruttoZal_2: curSumaBruttoZal_2 = ccur(0)
dim curSumaNettoKor_2: curSumaNettoKor_2 = ccur(0)
dim curSumaVatKor_2: curSumaVatKor_2 = ccur(0)
dim curSumaBruttoKor_2: curSumaBruttoKor_2 = ccur(0)
dim curSumaNettoKonc_2: curSumaNettoKonc_2 = ccur(0)
dim curSumaVatKonc_2: curSumaVatKonc_2 = ccur(0)
dim curSumaBruttoKonc_2: curSumaBruttoKonc_2 = ccur(0)
dim curSumaNettoPozost_2: curSumaNettoPozost_2 = ccur(0)
dim curSumaVatPozost_2: curSumaVatPozost_2 = ccur(0)
dim curSumaBruttoPozost_2: curSumaBruttoPozost_2 = ccur(0)

'podsumowania w sekcji 2 (stawkami)
dim curSumaNettoZal23_2: curSumaNettoZal23_2 = ccur(0)
dim curSumaVatZal23_2: curSumaVatZal23_2 = ccur(0)
dim curSumaBruttoZal23_2: curSumaBruttoZal23_2 = ccur(0)
dim curSumaNettoZal8_2: curSumaNettoZal8_2 = ccur(0)
dim curSumaVatZal8_2: curSumaVatZal8_2 = ccur(0)
dim curSumaBruttoZal8_2: curSumaBruttoZal8_2 = ccur(0)
dim curSumaNettoZal5_2: curSumaNettoZal5_2 = ccur(0)
dim curSumaVatZal5_2: curSumaVatZal5_2 = ccur(0)
dim curSumaBruttoZal5_2: curSumaBruttoZal5_2 = ccur(0)
dim curSumaNettoZal0_2: curSumaNettoZal0_2 = ccur(0)
dim curSumaNettoZalZw_2: curSumaNettoZalZw_2 = ccur(0)
dim curSumaNettoZalNp_2: curSumaNettoZalNp_2 = ccur(0)

'podsumowania całego raportu
dim curSumaNettoZalAll: curSumaNettoZalAll = ccur(0)
dim curSumaVatZalAll: curSumaVatZalAll = ccur(0)
dim curSumaBruttoZalAll: curSumaBruttoZalAll = ccur(0)
dim curSumaNettoKorAll: curSumaNettoKorAll = ccur(0)
dim curSumaVatKorAll: curSumaVatKorAll = ccur(0)
dim curSumaBruttoKorAll: curSumaBruttoKorAll = ccur(0)
dim curSumaNettoKoncAll: curSumaNettoKoncAll = ccur(0)
dim curSumaVatKoncAll: curSumaVatKoncAll = ccur(0)
dim curSumaBruttoKoncAll: curSumaBruttoKoncAll = ccur(0)
dim curSumaNettoPozostAll: curSumaNettoPozostAll = ccur(0)
dim curSumaVatPozostAll: curSumaVatPozostAll = ccur(0)
dim curSumaBruttoPozostAll: curSumaBruttoPozostAll = ccur(0)

'podsumowania całego raportu (stawkami)
dim curSumaNettoZalAll23: curSumaNettoZalAll23 = ccur(0)
dim curSumaVatZalAll23: curSumaVatZalAll23 = ccur(0)
dim curSumaBruttoZalAll23: curSumaBruttoZalAll23 = ccur(0)
dim curSumaNettoZalAll8: curSumaNettoZalAll8 = ccur(0)
dim curSumaVatZalAll8: curSumaVatZalAll8 = ccur(0)
dim curSumaBruttoZalAll8: curSumaBruttoZalAll8 = ccur(0)
dim curSumaNettoZalAll5: curSumaNettoZalAll5 = ccur(0)
dim curSumaVatZalAll5: curSumaVatZalAll5 = ccur(0)
dim curSumaBruttoZalAll5: curSumaBruttoZalAll5 = ccur(0)
dim curSumaNettoZalAll0: curSumaNettoZalAll0 = ccur(0)
dim curSumaNettoZalAllZw: curSumaNettoZalAllZw = ccur(0)
dim curSumaNettoZalAllNp: curSumaNettoZalAllNp = ccur(0)

dim bDateTo: bDateTo = false

'--------------------------------------
'lista wykluczonych faktur zaliczkowych
'--------------------------------------
function GetNrFakt(): GetNrFakt = ""
  if Len(strListNr) > clng(0) and pParamArray.value(5).selected.value(1) then
    dim tab:tab = Split(strListNr, ";")
    dim iter, strFakt: strFakt = ""
    for iter = 0 to ubound(tab)
      if Len(tab(iter)) > 0 then
        strFakt = strFakt + "'" + tab(iter) + "',"
      end if
    next
    if Len(strFakt) > clng(1) then
      strFakt = Left(strFakt,Len(strFakt)-1)
    end if
    GetNrFakt = "s.strNrDok not in (" + strFakt + ") and "
  end if
end function

function query()
  dim strSQL

  strSQL = "create table ZALICZKOWE " + vbNewLine +_
           "( " + vbNewLine +_
           "--faktura zaliczkowa " + vbNewLine +_
           "strIndeks varchar(32) not null, " + vbNewLine +_
           "strNazwa varchar(255) not null, " + vbNewLine +_
           "IdKlient integer not null, " + vbNewLine +_
           "dDataWyst datetime not null, " + vbNewLine +_
           "strNrDok varchar(32) not null, " + vbNewLine +_
	         "IdSprzed integer not null, " + vbNewLine +_
	         "pTrans integer not null, " + vbNewLine +_
	         "curSumaNetto decimal(12,2) not null, " + vbNewLine +_
	         "curSumaVat decimal(12,2) not null, " + vbNewLine +_
	         "curSumaBrutto decimal(12,2) not null, " + vbNewLine +_
	         "--korekta " + vbNewLine +_
	         "dDataWystKor datetime not null, " + vbNewLine +_
	         "strNrDokKor varchar(32) not null, " + vbNewLine +_
	         "IdSprzedKor integer not null, " + vbNewLine +_
	         "curSumaNettoKor decimal(12,2) not null, " + vbNewLine +_
	         "curSumaVatKor decimal(12,2) not null, " + vbNewLine +_
	         "curSumaBruttoKor decimal(12,2) not null, " + vbNewLine +_
	         "--końcowa " + vbNewLine +_
	         "dDataWystKonc datetime not null, " + vbNewLine +_
	         "strNrDokKonc varchar(32) not null, " + vbNewLine +_
	         "IdSprzedKonc integer not null, " + vbNewLine +_
	         "curSumaNettoKonc decimal(12,2) not null, " + vbNewLine +_
	         "curSumaVatKonc decimal(12,2) not null, " + vbNewLine +_
	         "curSumaBruttoKonc decimal(12,2) not null, " + vbNewLine +_
	         "--rejestr faktur zaliczkowych " + vbNewLine +_
	         "IdRejestr int not null, " + vbNewLine +_ 
	         "--podsumowanie w stawce " + vbNewLine +_
	         "curNetto23 decimal(12,2) not null, " + vbNewLine +_ 
	         "curVat23 decimal(12,2) not null, " + vbNewLine +_
	         "curNetto8 decimal(12,2) not null, " + vbNewLine +_ 
	         "curVat8 decimal(12,2) not null, " + vbNewLine +_ 
	         "curNetto5 decimal(12,2) not null, " + vbNewLine +_ 
	         "curVat5 decimal(12,2) not null, " + vbNewLine +_ 
	         "curNetto0 decimal(12,2) not null, " + vbNewLine +_ 
	         "curNettoZw decimal(12,2) not null, " + vbNewLine +_ 
	         "curNettoNp decimal(12,2) not null " + vbNewLine +_           
           ")"
  trans_.execsql strSQL
  
  strSQL = "create table STATUS " + vbNewLine +_
           "( " + vbNewLine +_
           "pTrans integer not null, " + vbNewLine +_
           "nRozliczona varchar(1) not null " + vbNewLine +_
           ")"
  trans_.execsql strSQL 

  'ograniczenie na datę w przypadku wyboru Daty wystawienia: Dowolna i Do dnia (faktury od 01.06.2014)
  dim strDate2014: strDate2014 = ""
  if pParamArray.value(0).mode = clng(1) or pParamArray.value(0).mode = clng(5) then
    bDateTo = true
  end if
  
  'dodaj faktury zaliczkowe
  if bDateTo then
    strDate2014 = " and s.dDataWyst >= " + doc_.afc.convert.date2SQL(DateSerial(2014,6,1)) + " "
  end if
  
  strSQL = "insert into ZALICZKOWE " + vbNewLine +_
           "select k.strIndeks,k.strNazwa,k.IdObj,s.dDataWyst,s.strNrDok,s.IdObj,s.pTransakcja, " + vbNewLine +_ 
           "s.curSumaNetto,s.curSumaVAT,s.curSumaBrutto, " + vbNewLine +_
           "{d '1899-12-31'},'',0,0.0,0.0,0.0, " + vbNewLine +_
           "{d '1899-12-31'},'',0,0.0,0.0,0.0,r.IdObj, " + vbNewLine +_
           "s.curNetto23, s.curVat23, " + vbNewLine +_
           "s.curNetto8, s.curVat8, " + vbNewLine +_ 
           "s.curNetto5, s.curVat5, " + vbNewLine +_ 
           "s.curNetto0, " + vbNewLine +_ 
           "s.curNettoZw, " + vbNewLine +_ 
           "s.curNettoNp " + vbNewLine +_
           "from n5sprzedaz s " + vbNewLine +_ 
           "inner join n5rejestrdok r on s.pRejestrDok = r.IdObj " + vbNewLine +_ 
           "inner join n5klient k on s.pKlient = k.IdObj " + vbNewLine +_ 
           "where " + GetNrFakt + " r.eTyp = 54 and s.strNrDok like 'FZAL/%' and " + vbNewLine +_ 
           "%1 and %2 and %3 and %7 " + strDate2014
  strSQL = rapeng_.query_apply_actual_param(strSQL, pParamArray)
  trans_.execsql strSQL  

  'dodaj korekty do faktur
  if bDateTo then
    strDate2014 = " and n5sprzedaz.dDataWyst >= " + doc_.afc.convert.date2SQL(DateSerial(2014,6,1)) + " "
  end if  
  
  dim strData: strData = Replace(rapeng_.query_apply_actual_param("%1", pParamArray),"s.dDataWyst","n5sprzedaz.dDataWyst")
  strSQL = "update ZALICZKOWE " + vbNewLine +_
           "set dDataWystKor = n5sprzedaz.dDataWyst, " + vbNewLine +_
           "strNrDokKor = n5sprzedaz.strNrDok, " + vbNewLine +_
           "IdSprzedKor = n5sprzedaz.IdObj, " + vbNewLine +_
           "curSumaNettoKor = n5sprzedaz.curSumaNetto, " + vbNewLine +_
           "curSumaVatKor = n5sprzedaz.curSumaVAT, " + vbNewLine +_
           "curSumaBruttoKor = n5sprzedaz.curSumaBrutto " + vbNewLine +_
           "from n5sprzedaz " + vbNewLine +_
           "inner join n5rejestrdok r on n5sprzedaz.pRejestrDok = r.IdObj " + vbNewLine +_
           "where r.eTyp = 60 and n5sprzedaz.strNrDok like 'KFZAL%' " + vbNewLine +_
           "and " + strData + vbNewLine +_
           "and n5sprzedaz.pPopSprzed = ZALICZKOWE.IdSprzed and %7 " + strDate2014
  strSQL = rapeng_.query_apply_actual_param(strSQL, pParamArray)           
  trans_.execsql strSQL 
  
  'dodaj faktury zaliczkowe końcowe
  if bDateTo then
    strDate2014 = " and s.p_dDataWyst >= " + doc_.afc.convert.date2SQL(DateSerial(2014,6,1)) + " "
  end if    
  
  strData = Replace(rapeng_.query_apply_actual_param("%1", pParamArray),"s.dDataWyst","s.p_dDataWyst")
  strSQL = "insert into ZALICZKOWE " + vbNewLine +_
           "select '','',0,{d '1899-12-31'},'',0,max(s.p_pTransakcja),0.0,0.0,0.0,{d '1899-12-31'},'',0,0.0,0.0,0.0, " + vbNewLine +_
           "max(s.p_ddatawyst), max(s.p_strNrDok),s.p_IdObj,sum(s.c_curwartnetto),sum(s.c_curvat),sum(s.c_curwartbrutto),0 " + vbNewLine +_
           ",0,0,0,0,0,0,0,0,0 " + vbNewLine +_ 
           "from vlist_n5sprzedaz_listPozycje s " + vbNewLine +_
           "inner join n5rejestrdok r on s.p_pRejestrDok = r.IdObj " + vbNewLine +_
           "inner join n5klient k on s.p_pKlient = k.IdObj " + vbNewLine +_
           "where r.eTyp = 54 and s.p_strNrDok like 'FZALK/%' " + vbNewLine +_
           "and " + strData + vbNewLine +_ 
           "and s.p_ptransakcja in (select pTrans from ZALICZKOWE) and %7 " + strDate2014 + vbNewLine +_
           "group by s.p_idobj"
  strSQL = rapeng_.query_apply_actual_param(strSQL, pParamArray)           
  trans_.execsql strSQL    

  'status rozliczenia faktur
  strSQL = "insert into STATUS " + vbNewLine +_ 
           "select pTrans, " + vbNewLine +_
           "case when max(IdSprzedKor) > 0 then " + vbNewLine +_
           "case when (sum(curSumaBrutto) - (sum(curSumaBrutto) - sum(curSumaBruttoKor)) - sum(curSumaBruttoKonc)) = 0 then '1' else '2' end " + vbNewLine +_ 
           "else " + vbNewLine +_
           "case when (sum(curSumaBrutto) - sum(curSumaBruttoKonc)) <= 0 then '1' else '2' end  " + vbNewLine +_
           "end " + vbNewLine +_
           "from ZALICZKOWE " + vbNewLine +_ 
           "group by pTrans"
  trans_.execsql strSQL 

  query = "select 'r_nazwa'=max(r.strNazwa),'k_indeks'=max(strIndeks),'k_nazwa'=max(z.strNazwa),'k_idobj'=max(IdKlient),'k_type'=10108, " + vbNewLine +_ 
          "'s_data_wyst'=max(dDataWyst),'s_nrdok'=max(strNrDok),'s_idobj'=max(IdSprzed),'s_type'=10129,'s_ptrans'=max(z.pTrans), " + vbNewLine +_ 
          "'s_suma_netto'=sum(curSumaNetto),'s_suma_vat'=sum(curSumaVAT),'s_suma_brutto'=sum(curSumaBrutto), " + vbNewLine +_ 
          "'s_data_wyst_kor'=max(dDataWystKor),'s_nrdok_kor'=max(strNrDokKor),'s_idobj_kor'=max(IdSprzedKor), " + vbNewLine +_ 
          "'s_suma_netto_kor'=sum(curSumaNettoKor),'s_suma_vat_kor'=sum(curSumaVatKor),'s_suma_brutto_kor'=sum(curSumaBruttoKor), " + vbNewLine +_ 
          "'s_nrdok_konc'=isnull((select strNrDokKonc from ZALICZKOWE where pTrans = max(z.pTrans) and IdSprzedKonc > 0),''), " + vbNewLine +_ 
          "'s_idobj_konc'=isnull((select IdSprzedKonc from ZALICZKOWE where pTrans = max(z.pTrans) and IdSprzedKonc > 0),0), " + vbNewLine +_ 
          "'s_suma_netto_konc'=isnull((select curSumaNettoKonc from ZALICZKOWE where pTrans = max(z.pTrans) and IdSprzedKonc > 0),0), " + vbNewLine +_ 
          "'s_suma_vat_konc'=isnull((select curSumaVatKonc from ZALICZKOWE where pTrans = max(z.pTrans) and IdSprzedKonc > 0),0), " + vbNewLine +_ 
          "'s_suma_brutto_konc'=isnull((select curSumaBruttoKonc from ZALICZKOWE where pTrans = max(z.pTrans) and IdSprzedKonc > 0),0), " + vbNewLine +_ 
          "'status'=case when max(s.nRozliczona) = 1 then 'Tak' else 'Nie' end " + vbNewLine +_
          ",'s_netto_23'=sum(curNetto23),'s_vat_23'=sum(curVat23),'s_brutto_23'=sum(curNetto23) + sum(curVat23) " + vbNewLine +_ 
          ",'s_netto_8'=sum(curNetto8),'s_vat_8'=sum(curVat8),'s_brutto_8'=sum(curNetto8) + sum(curVat8) " + vbNewLine +_ 
          ",'s_netto_5'=sum(curNetto5),'s_vat_5'=sum(curVat5),'s_brutto_5'=sum(curNetto5) + sum(curVat5) " + vbNewLine +_ 
          ",'s_netto_0'=sum(curNetto0),'s_netto_zw'=sum(curNettoZw),'s_netto_np'=sum(curNettoNp) " + vbNewLine +_
          "from ZALICZKOWE z " + vbNewLine +_ 
          "inner join n5rejestrdok r on z.IdRejestr = r.IdObj " + vbNewLine +_ 
          "inner join STATUS s on z.pTrans = s.pTrans " + vbNewLine +_ 
          "where %4 and %5 and %6 " + vbNewLine +_ 
          "group by z.IdSprzed " + vbNewLine +_  
          "having z.IdSprzed > 0 " + vbNewLine +_ 
          "order by r_nazwa,k_nazwa,s_data_wyst,s_ptrans"
          
  query = rapeng_.query_apply_actual_param(query,pParamArray)
  
  query = Replace(query,"korekta = '1'","z.IdSprzedKor > 0")
  query = Replace(query,"korekta = '2'","z.IdSprzedKor = 0")
  query = Replace(query,"korekta IN ('1','2')","1=1")
  query = Replace(query,"faktura_zal = '1'","isnull((select IdSprzedKonc from ZALICZKOWE where pTrans = z.pTrans and IdSprzedKonc > 0),0) > 0")
  query = Replace(query,"faktura_zal = '2'","isnull((select IdSprzedKonc from ZALICZKOWE where pTrans = z.pTrans and IdSprzedKonc > 0),0) = 0")
  query = Replace(query,"faktura_zal IN ('1','2')","1=1")  
end function
%>
<%
dim pKorekta
dim pFakZal
dim pStatus

function default_param()
	dim pParamArray: set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("s.dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("k.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("k.strNazwa")

	set pKorekta = doc_.afc.rap.param.new_choice("Posiada korektę").bindexpr("korekta")
	with pKorekta
		.multiple = true
		.names.add "Tak"
		.values.add 1
		.selected.add true
		.names.add "Nie"
		.values.add 2
		.selected.add true    
	end with  
	pParamArray.add pKorekta 

	set pFakZal = doc_.afc.rap.param.new_choice("Posiada fakturę zaliczkową").bindexpr("faktura_zal")
	with pFakZal
		.multiple = true
		.names.add "Tak"
		.values.add 1
		.selected.add true
		.names.add "Nie"
		.values.add 2
		.selected.add true    
	end with  
	pParamArray.add pFakZal 
	
	set pStatus = doc_.afc.rap.param.new_choice("Status").bindexpr("s.nRozliczona")
	with pStatus
		.multiple = true
		.names.add "rozliczona"
		.values.add 1
		.selected.add true
		.names.add "nierozliczona"
		.values.add 2
		.selected.add true    
	end with  
	pParamArray.add pStatus 	
  
	dim pParam2: set pParam2= doc_.afc.rap.param.new_choice("Rejestr").bindexpr("r.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa, idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " +_	
		"order by strNazwa"
	pParamArray.add pParam2  
	
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
  curSumaNettoZal = ccur(0)
  curSumaVatZal = ccur(0)
  curSumaBruttoZal = ccur(0)
