	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
	<td style='27' align='right'>
	</td>
  <td style='27'></td>
</tr>
<% end if %>  
  
<% if curSumaNettoZalAll8 > ccur(0.0) then %>
<tr style='21'>
  <td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaNettoZalAll8)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(curSumaVatZalAll8)
	</td>
  <td style='27' align='center'><t>8%</t></td>
