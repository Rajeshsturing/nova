<tr style='21'>
<td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaNettoZalAll)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaVatZalAll)
	</td>
  <td style='27' align='right'></td>
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaBruttoZalAll)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaNettoKorAll)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaVatKorAll)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR_BOLD(curSumaBruttoKorAll)
	</td>
