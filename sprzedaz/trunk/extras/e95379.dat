<%
dim nRowTrans: nRowTrans = clng(0)
function body_row(byref pSection,byref pRec)

dim nIdTrans: nIdTrans = clng(pRec("s_ptrans").value)
if nIdTrans <> nPopTrans then
	nRowTrans = nRowTrans + 1
end if

if nRowTrans mod 2 = 0 then
%>
<tr bordercolor='white' style='STYLE_TABLE_BODY'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
		RXE_DATE(s_data_wyst)
	</td>
	<%
	dim curNettoZal: curNettoZal = ccur(pRec("s_suma_netto").value)
	dim curVatZal: curVatZal = ccur(pRec("s_suma_vat").value)
	dim curBruttoZal: curBruttoZal = ccur(pRec("s_suma_brutto").value)
  
  curSumaNettoZal = curSumaNettoZal + curNettoZal
  curSumaVatZal = curSumaVatZal + curVatZal
  curSumaBruttoZal = curSumaBruttoZal + curBruttoZal
  
  curSumaNettoZal_2 = curSumaNettoZal_2 + curNettoZal
  curSumaVatZal_2 = curSumaVatZal_2 + curVatZal
  curSumaBruttoZal_2 = curSumaBruttoZal_2 + curBruttoZal  
  
  'suma stawkami
  curSumaNettoZal23 = curSumaNettoZal23 + ccur(pRec("s_netto_23").value)
  curSumaVatZal23 = curSumaVatZal23 + ccur(pRec("s_vat_23").value)
  curSumaBruttoZal23 = curSumaBruttoZal23 + ccur(pRec("s_brutto_23").value)
  curSumaNettoZal8 = curSumaNettoZal8 + ccur(pRec("s_netto_8").value)
  curSumaVatZal8 = curSumaVatZal8 + ccur(pRec("s_vat_8").value)
  curSumaBruttoZal8 = curSumaBruttoZal8 + ccur(pRec("s_brutto_8").value)
  curSumaNettoZal5 = curSumaNettoZal5 + ccur(pRec("s_netto_5").value)
  curSumaVatZal5 = curSumaVatZal5 + ccur(pRec("s_vat_5").value)
  curSumaBruttoZal5 = curSumaBruttoZal5 + ccur(pRec("s_brutto_5").value)  
  curSumaNettoZal0 = curSumaNettoZal0 + ccur(pRec("s_netto_0").value)
  curSumaNettoZalZw = curSumaNettoZalZw + ccur(pRec("s_netto_zw").value)
  curSumaNettoZalNp = curSumaNettoZalNp + ccur(pRec("s_netto_np").value)
  
  curSumaNettoZal23_2 = curSumaNettoZal23_2 + ccur(pRec("s_netto_23").value)
  curSumaVatZal23_2 = curSumaVatZal23_2 + ccur(pRec("s_vat_23").value)
  curSumaBruttoZal23_2 = curSumaBruttoZal23_2 + ccur(pRec("s_brutto_23").value)
  curSumaNettoZal8_2 = curSumaNettoZal8_2 + ccur(pRec("s_netto_8").value)
  curSumaVatZal8_2 = curSumaVatZal8_2 + ccur(pRec("s_vat_8").value)
  curSumaBruttoZal8_2 = curSumaBruttoZal8_2 + ccur(pRec("s_brutto_8").value)
  curSumaNettoZal5_2 = curSumaNettoZal5_2 + ccur(pRec("s_netto_5").value)
  curSumaVatZal5_2 = curSumaVatZal5_2 + ccur(pRec("s_vat_5").value)
  curSumaBruttoZal5_2 = curSumaBruttoZal5_2 + ccur(pRec("s_brutto_5").value)  
  curSumaNettoZal0_2 = curSumaNettoZal0_2 + ccur(pRec("s_netto_0").value)
  curSumaNettoZalZw_2 = curSumaNettoZalZw_2 + ccur(pRec("s_netto_zw").value)
  curSumaNettoZalNp_2 = curSumaNettoZalNp_2 + ccur(pRec("s_netto_np").value)  
  
	%>
	<td colspan='4'>
		<table>
			<tbody>
	      <tr userprop="propc_section_start='1' propc_section_hidden='1' propc_section_req='0'">
		      <td linealign='vcenter' colspan='4' keepline='true'>
			      <picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Rozwiń' ignoresysdisable='true' image='PICTURE_SMALL_PLUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
            RXE_TEXT_LINK_FORM_CCC(s_type,s_idobj,s_nrdok)
		      </td>
	      </tr>
        <% 
        dim nStawka: nStawka = 0  'zlicza liczbę różnych stawek 
        dim strStawka: strStawka = ""
        %>
        
        <%
        '23%
        if ccur(pRec("s_netto_23").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "23%"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_23,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_vat_23,"",2)
					</td>
					<td width='2000' align='center'>
						<t>23%</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_brutto_23,"",2)
					</td>
				</tr>
        <% end if %>
        
        <%
        '8%
        if ccur(pRec("s_netto_8").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "8%"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_8,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_vat_8,"",2)
					</td>
					<td width='2000' align='center'>
						<t>8%</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_brutto_8,"",2)
					</td>
				</tr>
        <% end if %> 
        
        <%
        '5%
        if ccur(pRec("s_netto_5").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "5%"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_5,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_vat_5,"",2)
					</td>
					<td width='2000' align='center'>
						<t>5%</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_brutto_5,"",2)
					</td>
				</tr>
        <% end if %>
        
        <%
        '0%
        if ccur(pRec("s_netto_0").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "0%"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_0,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_VVV(0,"",2)
					</td>
					<td width='2000' align='center'>
						<t>0%</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_0,"",2)
					</td>
				</tr>
        <% end if %>
        
        <%
        'zw%
        if ccur(pRec("s_netto_zw").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "zw"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_zw,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_VVV(0,"",2)
					</td>
					<td width='2000' align='center'>
						<t>zw</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_zw,"",2)
					</td>
				</tr>
        <% end if %>
        
        <%
        'np%
        if ccur(pRec("s_netto_np").value) <> ccur(0.0) then 
          nStawka = nStawka + 1
          strStawka = "np%"
        %>
				<tr fontsize='1' hide='true'>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_np,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_VVV(0,"",2)
					</td>
					<td width='2000' align='center'>
						<t>np</t>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_netto_np,"",2)
					</td>
				</tr>
        <% end if %>
        
	      <tr hide='true' userprop="propc_section_end='1'">
		      <td colspan='4'  />
	      </tr>
				<tr>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_suma_netto,"",2)
					</td>
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_suma_vat,"",2)
					</td>
					<td width='2000' align='center'>
          <% if nStawka = 1 then %>
            <t><% so.write strStawka %></t>
          <% else %>
            <t>X</t>
          <% end if %>
					</td>          
					<td width='2000' align='right'>
						RXE_QUANTITY_CVV(s_suma_brutto,"",2)
					</td>
				</tr>        
			</tbody>
		</table>		  
	</td>	
	<%
  nSectionPicCounter=nSectionPicCounter+1
  
	'korekta gdy istnieje
  dim nIdKorekta: nIdKorekta = clng(pRec("s_idobj_kor").value)
	if nIdKorekta > clng(0) then
    dim strNrDokKor: strNrDokKor = cstr(pRec("s_nrdok_kor").value)
		dim curNettoKor: curNettoKor = ccur(pRec("s_suma_netto_kor").value)
		dim curVatKor: curVatKor = ccur(pRec("s_suma_vat_kor").value)
		dim curBruttoKor: curBruttoKor = ccur(pRec("s_suma_brutto_kor").value)
    
  curSumaNettoKor = curSumaNettoKor + curNettoZal - curNettoKor
  curSumaVatKor = curSumaVatKor + curVatZal - curVatKor
  curSumaBruttoKor = curSumaBruttoKor + curBruttoZal - curBruttoKor
  
  curSumaNettoKor_2 = curSumaNettoKor_2 + curNettoZal - curNettoKor
  curSumaVatKor_2 = curSumaVatKor_2 + curVatZal - curVatKor
  curSumaBruttoKor_2 = curSumaBruttoKor_2 + curBruttoZal - curBruttoKor  
	%>
		<td colspan='3'>
			<table>
				<tbody>
					<tr>
						<td colspan='3'>				
							<text href='<%so.write rapeng_.href_open_form_proxy(10129,nIdKorekta)%>'><![CDATA[<%so.write strNrDokKor %>]]></text>
						</td>
					</tr>
					<tr>
						<td width='2000' align='right'>
							<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curNettoZal - curNettoKor,"",2))%></t>
						</td>
						<td width='2000' align='right'>
							<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curVatZal - curVatKor,"",2))%></t>
						</td>
						<td width='2000' align='right'>
							<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curBruttoZal - curBruttoKor,"",2))%></t>
						</td>
					</tr>
				</tbody>
			</table>		  
		</td>		
	<%
	else
	%>
		<td colspan='3'></td>
	<%
	end if

	'faktura zaliczkowa końcowa
	'wypisz tylko raz
	if nPopTrans <> nIdTrans then
		dim nIdKoncowa: nIdKoncowa = clng(pRec("s_idobj_konc").value)
		if nIdKoncowa > clng(0) then
			dim oSprzed: set oSprzed = trans_.getobj(TYPEID_N5SPRZEDAZ,nIdKoncowa)
      dim strNrDokKonc: strNrDokKonc = cstr(pRec("s_nrdok_konc").value)
			dim curNettoKonc: curNettoKonc = ccur(pRec("s_suma_netto_konc").value)
			dim curVatKonc: curVatKonc = ccur(pRec("s_suma_vat_konc").value)
			dim curBruttoKonc: curBruttoKonc = ccur(pRec("s_suma_brutto_konc").value)
      
      curSumaNettoKonc = curSumaNettoKonc + curNettoKonc
      curSumaVatKonc = curSumaVatKonc + curVatKonc
      curSumaBruttoKonc = curSumaBruttoKonc + curBruttoKonc
      
      curSumaNettoKonc_2 = curSumaNettoKonc_2 + curNettoKonc
      curSumaVatKonc_2 = curSumaVatKonc_2 + curVatKonc
      curSumaBruttoKonc_2 = curSumaBruttoKonc_2 + curBruttoKonc      

			'pozostało do rozliczenia
			dim curNettoPoz: curNettoPoz = oSprzed.curSumaNetto
			dim curVatPoz: curVatPoz = oSprzed.curSumaVAT
			dim curBruttoPoz: curBruttoPoz = oSprzed.curSumaBrutto
		%>
			<td colspan='3'>
				<table>
					<tbody>
						<tr>
							<td colspan='3'>				
								<text href='<%so.write rapeng_.href_open_form_proxy(10129,nIdKoncowa)%>'><![CDATA[<%so.write strNrDokKonc %>]]></text>
							</td>
						</tr>
						<tr>
							<td width='2000' align='right'>
								<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curNettoKonc,"",2))%></t>
							</td>
							<td width='2000' align='right'>
								<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curVatKonc,"",2))%></t>
							</td>
							<td width='2000' align='right'>
								<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curBruttoKonc,"",2))%></t>
							</td>
						</tr>
					</tbody>
				</table>		  
			</td>		
		<%
			if curNettoKonc <> curNettoPoz and curNettoPoz > ccur(0) then
			%>
				<td colspan='3'>
					<table>
						<tbody>
							<tr>
								<td colspan='3'>				
									<text href='<%so.write rapeng_.href_open_form_proxy(10129,nIdKoncowa)%>'><![CDATA[<%so.write strNrDokKonc %>]]></text>
								</td>
							</tr>
							<tr>
								<td width='2000' align='right'>
									<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curNettoPoz,"",2))%></t>
								</td>
								<td width='2000' align='right'>
									<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curVatPoz,"",2))%></t>
								</td>
								<td width='2000' align='right'>
									<t><%so.write rapeng_.process_number(doc_.afc.display.quantity(curBruttoPoz,"",2))%></t>
								</td>
							</tr>
						</tbody>
					</table>		  
				</td>			
			<%
        curSumaNettoPozost = curSumaNettoPozost + curNettoPoz
        curSumaVatPozost = curSumaVatPozost + curVatPoz
        curSumaBruttoPozost = curSumaBruttoPozost + curBruttoPoz
        
        curSumaNettoPozost_2 = curSumaNettoPozost_2 + curNettoPoz
        curSumaVatPozost_2 = curSumaVatPozost_2 + curVatPoz
        curSumaBruttoPozost_2 = curSumaBruttoPozost_2 + curBruttoPoz        
        
			else
			%>
				<td colspan='3'></td>
			<%
			end if
		else
		%>
			<td colspan='3'></td>
      <td colspan='3'></td>
		<%
		end if
	else
	%>
		<td colspan='3'></td>
    <td colspan='3'></td>
	<%
	end if
  %>
  <td>
    RXE_TEXT(status)
  </td>
  <%   
	nPopTrans = nIdTrans
	%>
</tr><%
end function
%>
<%
