<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_KPIR_LISTA

#include "h1000.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Księga przychodów - lista wpisów

#define COUNTERS_COUNT	11

#define CTRLID_MAINTABLE				101
#define CTRLID_HEADER_ROW       102
#define CTRLID_FOOTER_ROW       103

#macro RXE_AUTO_TEXT_LEN(_val_col_,_len_)			<% if len(cstr(pRec("_val_col_"))) > _len_ then so.write "<text><![CD"+"ATA["+ cstr(pRec("_val_col_")) + "]"+"]></text>" else so.write "<t><![CDA"+"TA["+ cstr(pRec("_val_col_")) + "]"+"]></t>" %>
#macro RXE_FORCE_LEN(_val_col_,_len_)	        <%so.write "<text><![CD"+"ATA["+ left(cstr(pRec("_val_col_")),_len_) + "]"+"]></text><text><![CD"+"ATA["+mid(cstr(pRec("_val_col_")),_len_) + "]"+"]></text>"%>
#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")

-->

<page style='36' margins='500,1000,500,1000'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
VB_PRINT_LANDSCAPE_COMMON
VB_PRINTPREV_LANDSCAPE_COMMON


function c##CTRLID_MAINTABLE##_on_table_split(byref pClonedTable,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
  dim oTB, pRow		
  dim curArr(COUNTERS_COUNT)
  dim curArrPoczRoku(COUNTERS_COUNT)
  dim iter		
  for iter = 1 to COUNTERS_COUNT
    curArr(iter) = ccur(0.0)
    curArrPoczRoku(iter) = ccur(0.0)
  next 
  
  dim i:i = 1  
  dim pLastRowUserProp  
  
	if yAreaY <> yCount then

		if not page_.ctrl(CTRLID_HEADER_ROW).userprop is nothing then
      'suma od początku roku
	    for iter = 1 to COUNTERS_COUNT
		    if page_.ctrl(CTRLID_HEADER_ROW).userprop.exists(iter) then
			    curArrPoczRoku(iter) = curArrPoczRoku(iter) + ccur(page_.ctrl(CTRLID_HEADER_ROW).userprop(iter)) 
		    end if
	    next      
		end if    
    
		set oTB = doc_.afc.new_tb(page_).attach(pClonedTable).section_foot
		oTB.removeall
		
		for each pRow in pClonedTable.body
		  if not pRow.userprop is nothing then
			  for iter = 1 to COUNTERS_COUNT
				  if pRow.userprop.exists(iter) then
					  curArr(iter) = curArr(iter) + ccur(pRow.userprop(iter)) 
				  end if
			  next
			  i = i + 1
		  end if
		next
		
		'podsumowanie na stronie  ---------------------------------------------------------------------- 	
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
    oTB.newcell
		oTB.newcell.cell.colspan = 3
		oTB.addtext "Suma strony"
		set pLastRowUserProp = pClonedTable.body.row(pClonedTable.body.count).userprop
    
		dim licznik: licznik = pClonedTable.body.count
		do while licznik > 0
			if not pLastRowUserProp is nothing then
				if not pLastRowUserProp.exists(100) then
					exit do
				end if  
			end if
			licznik = licznik - 1    
			set pLastRowUserProp = pClonedTable.body.row(licznik).userprop
		loop    
		
		for iter = 1 to 3
			oTB.newcell.addtext("")
		next
    
		'kwoty
		for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
			  oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			end if
		next
    '-------------------------------------------------------------------------------------------------
    
		'przeniesienie z poprzedniej strony  ----------------------------------------------------------------
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
    oTB.newcell
		oTB.newcell.cell.colspan = 3
		oTB.addtext "Przeniesienie z poprzedniej strony"
		
		for iter = 1 to 3
			oTB.newcell.addtext("")
		next
    
		'kwoty
		for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
			  oTB.newcell.addtext(MONEY(ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)) - curArr(iter))).cell.align=ALIGN_RIGHT
			end if
		next
    '-------------------------------------------------------------------------------------------------    

		'posumowanie od początku roku  ------------------------------------------------------------------------
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
    oTB.newcell
		oTB.newcell.cell.colspan=3
		oTB.addtext "Suma od początku roku"		
		
		for iter = 1 to 3
			oTB.newcell.addtext("")
		next
    
		'wartość netto, vat, brutto
		for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
			  oTB.newcell.addtext(MONEY(ccur(curArrPoczRoku(iter)) + ccur(pLastRowUserProp.prop(iter + COUNTERS_COUNT)))).cell.align=ALIGN_RIGHT
			end if
		next
  
  else
  
		if not page_.ctrl(CTRLID_HEADER_ROW).userprop is nothing then
      'suma od początku roku
	    for iter = 1 to COUNTERS_COUNT
		    if page_.ctrl(CTRLID_HEADER_ROW).userprop.exists(iter) then
			    curArrPoczRoku(iter) = curArrPoczRoku(iter) + ccur(page_.ctrl(CTRLID_HEADER_ROW).userprop(iter)) 
		    end if
	    next      
		end if   
    
		set oTB = doc_.afc.new_tb(page_).attach(pClonedTable).section_foot
		oTB.removeall
		
		for each pRow in pClonedTable.body
		  if not pRow.userprop is nothing then
			  for iter = 1 to COUNTERS_COUNT
				  if pRow.userprop.exists(iter) then
					  curArr(iter) = curArr(iter) + ccur(pRow.userprop(iter)) 
				  end if
			  next
			  i = i + 1
		  end if
		next
		
		'podsumowanie na stronie  ---------------------------------------------------------------------- 	
		with oTB.newrow.row
			.border=0
			.fontsize = 2
		end with
    oTB.newcell
		oTB.newcell.cell.colspan = 3
		oTB.addtext "Suma strony"
		set pLastRowUserProp = pClonedTable.body.row(pClonedTable.body.count).userprop
		
		for iter = 1 to 3
			oTB.newcell.addtext("")
		next
    
		'kwoty
		for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
				oTB.newcell.addtext(MONEY(curArr(iter))).cell.align=ALIGN_RIGHT
			end if
		next
    '-------------------------------------------------------------------------------------------------
    
    if not page_.ctrl(CTRLID_FOOTER_ROW).userprop is nothing then
		  'przeniesienie z poprzedniej strony  ----------------------------------------------------------------
		  with oTB.newrow.row
			  .border=0
			  .fontsize = 2
		  end with
      oTB.newcell
		  oTB.newcell.cell.colspan = 3
		  oTB.addtext "Przeniesienie z poprzedniej strony"
  		
		  for iter = 1 to 3
			  oTB.newcell.addtext("")
		  next
      
		  'kwoty
		  for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
			    oTB.newcell.addtext(MONEY(ccur(page_.ctrl(CTRLID_FOOTER_ROW).userprop.prop(iter)) - curArr(iter))).cell.align=ALIGN_RIGHT
			end if
		  next
      '-------------------------------------------------------------------------------------------------      
      
		  'posumowanie od początku roku  ------------------------------------------------------------------------
		  with oTB.newrow.row
			  .border=0
			  .fontsize = 2
		  end with
      oTB.newcell
		  oTB.newcell.cell.colspan = 3
		  oTB.addtext "Suma od początku roku"
      
		  for iter = 1 to 3
			  oTB.newcell.addtext("")
		  next
      
		  'kwoty
		  for iter = 1 to COUNTERS_COUNT
			if iter <> 6 then
			    oTB.newcell.addtext(MONEY(ccur(curArrPoczRoku(iter)) + page_.ctrl(CTRLID_FOOTER_ROW).userprop.prop(iter))).cell.align=ALIGN_RIGHT
			end if
		  next
      '-------------------------------------------------------------------------------------------------     
		end if 

	end if
end function

function on_page_split(byref pClonedPage,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	pClonedPage.footer.removeall
	dim strText
	if yCount > 1 then
    strText = page_.topelement.title + " -  strona " + cstr(yAreaY) + " z " + cstr(yCount)
	end if
	pClonedPage.footer.addnew(0,-1).text = strText
end function

<%
dim ArrCurGlobSum(COUNTERS_COUNT)
dim ArrCurSecSum(COUNTERS_COUNT)
dim ArrCurBodyVal(COUNTERS_COUNT)
dim ArrCurBodyValSum(COUNTERS_COUNT)
dim ArrCurPoczRoku(COUNTERS_COUNT)
dim strMiesiac: strMiesiac = ""
dim pParamArray
dim nLP: nLP = clng(1)

sub reset_global_sums()
	dim iter
	for iter = 0 to ubound(ArrCurGlobSum)
		ArrCurGlobSum(iter) = ccur(0.0)
	next
end sub

sub reset_section_sums()
	dim iter
	for iter = 0 to ubound(ArrCurSecSum)
		ArrCurSecSum(iter) = ccur(0.0)
	next
end sub

sub update_sum(nIter,curVal)
	ArrCurGlobSum(nIter) = ArrCurGlobSum(nIter) + curVal
	ArrCurSecSum(nIter)  = ArrCurSecSum(nIter) + curVal
end sub

function query()
query = "select 'c_0'=t_kpir.nNumOper,'c_month'=year(t_kpir.dDataOper) * 12 + month(t_kpir.dDataOper), "+_
"'c_1'=t_kpir.dDataOper,'c_3'=t_kpir.dDataOper,'c_nrdok'=t_kpir.strNrDok,'c_month_name'=t_mc.strNazwa,'c_year'=year(t_kpir.dDataOper), "+_
"'c_klient_nazwa'=isnull(t_klient.strNazwa,''),'c_5'=isnull(t_klient.strKod + ' ' + t_miejsc.strNazwa + ' ' + t_klient.strUlica + ' ' + t_klient.strNrDomu + '/' + t_klient.strNrLokalu,''),"+_
"'c_6'=t_kpir.strOpis,'c_7'=t_kpir.curWartSprzed,'c_8'=t_kpir.curPozPrzych,"+_
"'c_9'=t_kpir.curWartSprzed + t_kpir.curPozPrzych,'c_10'=t_kpir.curZakTow," +_
"'c_11'=t_kpir.curKosztZak,'c_12'=t_kpir.curKosztRekl,'c_13'=t_kpir.curWynagrodz,'c_14'=t_kpir.curPozWyd," +_
#ifdef ENABLE_DB13
"'c_17'=t_kpir.curKosztyBR,'c_18'=t_kpir.strOpisBR," +_
#else
"'c_17'=0,'c_18'=''," +_
#endif
"'c_15'=t_kpir.curKosztRekl + t_kpir.curWynagrodz + t_kpir.curPozWyd,'c_16'=t_kpir.curKol16 from n5pkpir as t_kpir "+_
"left outer join n5klient as t_klient on t_kpir.pKlient = t_klient.IdObj "+_
"left outer join n5miejscowosc as t_miejsc on t_klient.pmiejscowosc = t_miejsc.idobj "+_
"join n5miesiac as t_mc on month(t_kpir.dDataOper) = t_mc.nnumer "+_
"where  %1  order by c_1,c_0"
end function
%>
<%
function default_param()
	set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data operacji").bindexpr("t_kpir.dDataOper")

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
if pActualParam.value(iter).get_desc() <> "" then 
bAnyWritten = true
	so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='4'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
reset_section_sums
strMiesiac = CStr(pRec("c_month_name").value)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='2'>
	<td style='27' colspan='18'> 
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	<t><%so.write pRec("c_month_name")  + " " + cstr(pRec("c_year")) %></t>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr border='0'><td colspan='16' /></tr>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='16' /></tr>
<tr fontsize='2' border='1' bordercolor='black'>
  <td style='27' />
  <td style='27' colspan='3'>
    <t><![CDATA[Suma <% so.write CStr(strMiesiac) %>]]> </t>
  </td>
	<td style='27' colspan='3' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(0))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(1))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(2))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(3))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(4))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(6))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(7))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(8))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(9))
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(ArrCurSecSum(10))
	</td>
</tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
  dim iter
  for iter = 0 to COUNTERS_COUNT - 1
    ArrCurBodyVal(iter) = trans_.afc.convert.round2(ccur(pRec("c_" + CStr(iter+7)).value))
  next
  
	for iter = 0 to COUNTERS_COUNT - 1
		ArrCurBodyValSum(iter) = ArrCurBodyValSum(iter) + ArrCurBodyVal(iter)
	next
			
	for iter = 0 to ubound(ArrCurBodyVal)
		update_sum iter,trans_.afc.convert.round2(ArrCurBodyVal(iter))
	next  
%>
	<tr fontsize='2' userprop='
	vc1=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(0))%>
	vc2=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(1))%>
	vc3=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(2))%>
	vc4=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(3))%>
	vc5=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(4))%>
	vc6=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(5))%>
	vc7=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(6))%>
	vc8=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(7))%>
	vc9=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(8))%>
	vc10=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(9))%>
  vc11=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyVal(10))%>
	vc12=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(0))%>
	vc13=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(1))%>
	vc14=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(2))%>
	vc15=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(3))%>
	vc16=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(4))%>
	vc17=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(5))%>
	vc18=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(6))%>
	vc19=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(7))%>
	vc20=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(8))%>
	vc21=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(9))%>
  vc22=<%so.write doc_.afc.convert.cur2sql(ArrCurBodyValSum(10))%>   
	%>'  
	<%
	if pRapExec.RecNr mod 2 = 0 then
	%>
	 style='37' 
	<%
	end if
	%>
	bordercolor='black' fontsize='2'>
  
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td align='right'>
    <t><%so.write cstr(nLP)%></t>
  </td>
	<td>
		RXE_DATE(c_3)
	</td>
	<td>
		RXE_AUTO_TEXT_LEN(c_nrdok,20)
	</td>
	<td>
		RXE_AUTO_TEXT_LEN(c_klient_nazwa,35)
	</td>
	<td>
		RXE_AUTO_TEXT_LEN(c_5,25)
	</td>
	<td>
		RXE_AUTO_TEXT_LEN(c_6,23)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_7,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_8,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_9,"",2)
	</td>  
	<td align='right'>
		RXE_QUANTITY_CVV(c_10,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_11,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_13,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_14,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_15,"",2)
	</td>  
	<td align='right'>
		RXE_QUANTITY_CVV(c_16,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_17,"",2)
	</td>
	<td>
		RXE_AUTO_TEXT_LEN(c_18,25)
	</td>    
</tr><%
  nLP = nLP + 1
end function
%>
<%
function body_header(byref pSection,byref pRec)
  'dodanie sumy od początku roku
  if pParamArray.value(0).mode = clng(3) or pParamArray.value(0).mode = clng(6) or pParamArray.value(0).mode = clng(7) then
    dim iter
    dim dFDate: dFDate = pParamArray.value(0).first_value
    dim dFirstDate, dLastDate
    if dFDate > DateSerial(year(dFDate),1,1) then
      dFirstDate = DateSerial(year(dFDate),1,1)
      dLastDate = DateAdd("d",-1,dFDate)
      dim strWhere: strWhere = "(t_kpir.dDataOper between " + trans_.afc.convert.date2SQL(dFirstDate) + " and " + trans_.afc.convert.date2SQL(dLastDate) + ")"
      dim strSQL: strSQL = doc_.afc.convert.formatter(query).add(strWhere).done()
      dim oRS: set oRS = trans_.createadors(strSQL)
      if oRS.recordCount > clng(0) then
        nLP = oRS.recordCount + 1
      end if
      do while not oRS.EOF
        for iter = 0 to COUNTERS_COUNT - 1
          ArrCurPoczRoku(iter) = ArrCurPoczRoku(iter) + trans_.afc.convert.round2(ccur(oRS("c_" + CStr(iter+7)).value))
        next
        oRS.movenext  
      loop
    end if
  end if
%>
<table border='1' name='CTRLID_MAINTABLE'>
<thead>
<tr style='21' name='CTRLID_HEADER_ROW' userprop='
	vc1=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(0))%>
	vc2=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(1))%>
	vc3=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(2))%>
	vc4=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(3))%>
	vc5=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(4))%>
	vc6=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(5))%>
	vc7=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(6))%>
	vc8=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(7))%>
	vc9=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(8))%>
	vc10=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(9))%>
	vc11=<%so.write doc_.afc.convert.cur2sql(ArrCurPoczRoku(10))%>
	%>'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='600'>
		<text><![CDATA[LP [1]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data operacji [2]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Nr dok. [3]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Nazwa pełna [4]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Adres [5] ]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Opis zdarzenia gosp.[6]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wartość sprzed. [7]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Pozostałe przych. [8]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Razem przychody [9]]]></text>
	</td>  
	<td width='min'>
		<text><![CDATA[Zakup towarów [10]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Koszty uboczne [11]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Wyna grodzenia [12]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Poz. wydatki [13]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Razem wydatki [14]]]></text>
	</td>  
	<td width='min'>
		<text><![CDATA[Kolumna 15 [15]]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Koszty b-r [16]]]></text>
	</td> 
	<td width='min'>
		<text><![CDATA[Opis kosztów b-r [16]]]></text>
	</td>     
</tr>
</thead>
<tbody>
<%
end function
%>
