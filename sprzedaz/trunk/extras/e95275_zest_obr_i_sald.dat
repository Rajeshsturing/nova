	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curObrN_Wn + pKontoInfo.m_curBO_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curObrN_Ma + pKontoInfo.m_curBO_Ma,strUnit,nPrec)
  </td>
#else
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curObrN_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curObrN_Ma,strUnit,nPrec)
  </td>
#endif    
	<%
	end if
	%>
	<%
	if g_bShowSalN then
	%>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curSalN_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curSalN_Ma,strUnit,nPrec)
  </td>
	<%
	end if
	%>
	<%
	if g_bShowSaSN then
	%>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curSaSN_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curSaSN_Ma,strUnit,nPrec)
  </td>
	<%
	end if
	%>
</tr>
<tr  border='1' bordercolor='black'>
	<td style='27'>
		<t>&nbsp;</t>
	</td>
	<%
	if g_bShowNazwa then
	%>
	<td style='27'/>
	<%
	end if
	%>
	<td style='27' />
	<%
	if g_bShowBO then
	%>
	<td style='27' colspan='2' />
	<%
	end if
	%>
	<%
	if g_bShowObrO then
	%>
	<td style='27' colspan='2' />	
	<%
	end if
	%>
	<%
	if g_bShowObrN then
	%>
	<td style='27' colspan='2' />
	<%
	end if
	%>
	<%
	if g_bShowSalN then
	%>
	<td style='27' colspan='2' />
	<%
	end if
	%>
	<%
	if g_bShowSaSN then
	%>
	<td style='27' colspan='2' />
	<%
	end if
	%>

</tr>
</tfoot>

<tprevfoot>
<!-- rezerwuj 2 wiersze na dynamiczną stopkę -->
<tr style='27'><td><t>&nbsp;</t></td></tr>
<tr style='27'><td><t>&nbsp;</t></td></tr>
</tprevfoot>
</table>
<%
end function
%>




]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,1)
</p>
<br/><br/>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
  dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  'ograniczenie do biezacego roku ksiegowego
  if g_pParamDate.mode = 1 then	'any date
  g_pParamDate.first_value = g_pPM.get_current_rok_ksiegowy().dDataRozp
  g_pParamDate.last_value = g_pPM.get_current_rok_ksiegowy().dDataZakon
  end if
  if g_pParamDate.mode = 5 then	'do dnia
  g_pParamDate.last_value = g_pParamDate.first_value
  g_pParamDate.first_value = g_pPM.get_current_rok_ksiegowy().dDataRozp
  end if
  if g_pParamDate.mode = 6 then	'od dnia
  g_pParamDate.last_value = g_pPM.get_current_rok_ksiegowy().dDataZakon
  end if
  '??
  g_pParamStatus.get_where_part trans_

  '---- budowanie filtru dla symbolu konta
  ' ten parametr jest nietypowo przekazywany z zewnatrz (z 60150 poprzez 60136) - musimy go pobrac
  set g_pCustParamSymbol = rapeng_.get_raport_param().Value(0)
  dim strFiltrSymbolu : strFiltrSymbolu = g_pCustParamSymbol.strWhereCustom()
  dim strFiltrSymbolu2: strFiltrSymbolu2 = strFiltrSymbolu

  '---- filtr na na analityczne
  if g_pParamAnalSynt.selected.value(0) then
  if g_pParamAnalSynt.selected.value(1) then
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAnalit in ('1','2')"
  else
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAnalit= '1'"
  end if
  else
  if g_pParamAnalSynt.selected.value(1) then
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAnalit= '2'"
  end if
  end if

  dim bFiltrBilansowe : bFiltrBilansowe = false
  '---- filtr na na bilansowe
  if g_pParamBilans.selected.value(0) then
  if g_pParamBilans.selected.value(1) then
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eBilans in ('1','2')"
  else
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eBilans= '1'"
  bFiltrBilansowe = true
  end if
  else
  if g_pParamBilans.selected.value(1) then
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eBilans= '2'"
  end if
  end if

  'trans_.message 0,0,"Fs="+strFiltrSymbolu

  '---- filtr na liczbe znakow ----
  select case g_pCustParamIloscZnakow.first_selected
  case 1
  strFiltrSymbolu = strFiltrSymbolu + " and (len(t_konto.strSymbol)=1)"
  strFiltrSymbolu2 = strFiltrSymbolu2 + " and (len(t_konto.strSymbol)>=1)"
  case 2
  strFiltrSymbolu = strFiltrSymbolu + " and (len(t_konto.strSymbol)=3)"
  strFiltrSymbolu2 = strFiltrSymbolu2 + " and (len(t_konto.strSymbol)>=3)"
  end select
  
#ifdef _DENIS
  strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAktywne = '1' "
  strFiltrSymbolu2 = strFiltrSymbolu2 + " and t_konto.eAktywne = '1' "
#endif

  '----
#ifdef _ALMA_TREND
  'aktywne/nieaktywne
  if g_pParamAktywneNieakt.selected.value(0) then
    if g_pParamAktywneNieakt.selected.value(1) then
      strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAktywne in ('1','2')"
    else
      strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAktywne = '1'"
      strFiltrSymbolu2 = strFiltrSymbolu2 + " and t_konto.eAktywne = '1'"
    end if
  else
    if g_pParamAktywneNieakt.selected.value(1) then
      strFiltrSymbolu = strFiltrSymbolu + " and t_konto.eAktywne = '2'"
      strFiltrSymbolu2 = strFiltrSymbolu2 + " and t_konto.eAktywne = '2'"
    end if
  end if
#endif  
  
  write_actual_param rapeng_.get_raport_param()

  set g_pKontoInfoMan = g_pPM.prepare_zois_bilans_filter_ex(g_pParamDate.first_value, g_pParamDate.last_value, _
  g_pParamStatus, strFiltrSymbolu2, nothing,-1, bFiltrBilansowe)

  .ReplaceQueryParam "%FILTR_SYMBOLU%",strFiltrSymbolu
  '------------------------------------------------------------------

  '------------------------------------------------------------------
  g_bTylkoZBO  = (mid(g_pCustParamFiltrSald.ctrls_obj.value(0).value, 1, 1) = "1")
  g_bTylkoZObr = (mid(g_pCustParamFiltrSald.ctrls_obj.value(0).value, 2, 1) = "1")
  g_bTylkoZSal = (mid(g_pCustParamFiltrSald.ctrls_obj.value(0).value, 3, 1) = "1")
  '------------------------------------------------------------------
  if g_bTylkoZBO or g_bTylkoZObr or g_bTylkoZSal then
  so.write "<p><t fontsize='4'>Uwaga! Zostały pominięte konta nie posiadające BO,obrotów,sald </t></p><t>&nbsp;</t><br/>"
	end if

	so.write "<t name='CTRLID_SPECIAL' hide='true' userprop='vn1="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 1, 1) = "0" then 
	 	g_bShowNazwa = false
		so.write "0 "
	else
		so.write "1 "
	end if
	so.write "vn2="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 2, 1) = "0" then 
		g_bShowBO = false
		so.write "0 "
	else
		so.write "1 "
	end if
	so.write "vn3="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 3, 1) = "0" then 
		g_bShowObrO = false
		so.write "0 "
	else
		so.write "1 "
	end if
	so.write "vn4="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 4, 1) = "0" then 
		g_bShowObrN = false
		so.write "0 "
	else
		so.write "1 "
	end if
	so.write "vn5="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 5, 1) = "0" then 
		g_bShowSalN = false
		so.write "0 "
	else
		so.write "1 "
	end if
	so.write "vn6="
	if mid(g_pCustParamKolumny.ctrls_obj.value(0).value, 6, 1) = "0" then 
		g_bShowSaSN = false
		so.write "0 "
	else
		so.write "1 "
	end if
	
	so.write "'></t>"

	if not .perform then
		so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
set g_pKontoInfoMan = nothing
%>
</body>
<footer>
</footer>
</page>
