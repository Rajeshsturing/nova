<%
function write_actual_param(byref pActualParam)
  if g_pCustParamSymbol.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pCustParamSymbol.get_desc() + "]"+"]></text><br/>"
  end if
  if g_pParamAnalSynt.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pParamAnalSynt.get_desc() + "]"+"]></text><br/>"
  end if
  if g_pParamBilans.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pParamBilans.get_desc() + "]"+"]></text><br/>"
  end if
#ifdef _ALMA_TREND
  if g_pParamAktywneNieakt.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pParamAktywneNieakt.get_desc() + "]"+"]></text><br/>"
  end if
#endif
  if g_pParamDate.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pParamDate.get_desc() + "]"+"]></text><br/>"
  end if
  if g_pParamStatus.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pParamStatus.get_desc() + "]"+"]></text><br/>"
  end if
  if g_pCustParamIloscZnakow.get_desc() <> "" then
    so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + g_pCustParamIloscZnakow.get_desc() + "]"+"]></text><br/>"
  end if
  
  so.write "<t size='5' /><text fontsize='4'><![CDATA[Obroty w okresie:   " + trans_.afc.display.fulldate(g_pParamDate.first_value) +_
  " do " + trans_.afc.display.fulldate(g_pParamDate.last_value) + "]"+"]></text><br/>"
  
  so.write "<t size='5' /><text fontsize='4'><![CDATA[Obroty narastająco:   " + trans_.afc.display.fulldate(g_pPM.get_current_rok_ksiegowy().dDataRozp) +_
  " do " + trans_.afc.display.fulldate(g_pParamDate.last_value) + "]"+"]></text><br/>"
  
  so.write "<br/>"
end function
%>
<%

function cur2ss(byval curVal)
	cur2ss = replace(cstr(curVal),",",".")
end function

function body_row(byref pSection,byref pRec)
dim strUnit : strUnit = ""'cstr(pRec("c_skrot"))
dim nPrec : nPrec = clng(pRec("c_prec")) - 1
dim pKontoInfo : set pKontoInfo = g_pKontoInfoMan.kontoinfo(clng(pRec("c_idkonto")))

'if (pRec("czy_podrzedne"))=0 then
g_arrCurRunningSum(0) = g_arrCurRunningSum(0) + pKontoInfo.m_curBO_Wn
g_arrCurRunningSum(1) = g_arrCurRunningSum(1) + pKontoInfo.m_curBO_Ma
g_arrCurRunningSum(2) = g_arrCurRunningSum(2) + pKontoInfo.m_curObrO_Wn
g_arrCurRunningSum(3) = g_arrCurRunningSum(3) + pKontoInfo.m_curObrO_Ma
g_arrCurRunningSum(4) = g_arrCurRunningSum(4) + pKontoInfo.m_curObrN_Wn
g_arrCurRunningSum(5) = g_arrCurRunningSum(5) + pKontoInfo.m_curObrN_Ma
g_arrCurRunningSum(6) = g_arrCurRunningSum(6) + pKontoInfo.m_curSalN_Wn
g_arrCurRunningSum(7) = g_arrCurRunningSum(7) + pKontoInfo.m_curSalN_Ma
g_arrCurRunningSum(8) = g_arrCurRunningSum(8) + pKontoInfo.m_curSaSN_Wn
g_arrCurRunningSum(9) = g_arrCurRunningSum(9) + pKontoInfo.m_curSaSN_Ma
'end if

dim bHasBO : bHasBO = (pKontoInfo.m_curBO_Wn <> 0.0 or pKontoInfo.m_curBO_Ma <> 0.0)
dim bHasObr: bHasObr= (pKontoInfo.m_curObrO_Wn <> 0.0 or pKontoInfo.m_curObrO_Ma <> 0.0)
dim bHasSal: bHasSal= (pKontoInfo.m_curSalN_Wn <> 0.0 or pKontoInfo.m_curSalN_Ma <> 0.0)

dim bShowRow : bShowRow = ((g_bTylkoZBO and bHasBO) or (g_bTylkoZObr and bHasObr) or (g_bTylkoZSal and bHasSal)) or _
  (not g_bTylkoZBO and not g_bTylkoZObr and not g_bTylkoZSal)

if bShowRow then
%>
<tr userprop='vs1=<%so.write cur2ss(pKontoInfo.m_curBO_Wn)%> 
	vs2=<%so.write cur2ss(pKontoInfo.m_curBO_Ma)%>
	vs3=<%so.write cur2ss(pKontoInfo.m_curObrO_Wn)%>
	vs4=<%so.write cur2ss(pKontoInfo.m_curObrO_Ma)%>
	vs5=<%so.write cur2ss(pKontoInfo.m_curObrN_Wn)%>
	vs6=<%so.write cur2ss(pKontoInfo.m_curObrN_Ma)%>
	vs7=<%so.write cur2ss(pKontoInfo.m_curSalN_Wn)%>
	vs8=<%so.write cur2ss(pKontoInfo.m_curSalN_Ma)%>
	vs9=<%so.write cur2ss(pKontoInfo.m_curSaSN_Wn)%>
	vs10=<%so.write cur2ss(pKontoInfo.m_curSaSN_Ma)%>
	vs11=<%so.write cur2ss(g_arrCurRunningSum(0))%>
	vs12=<%so.write cur2ss(g_arrCurRunningSum(1))%>
	vs13=<%so.write cur2ss(g_arrCurRunningSum(2))%>
	vs14=<%so.write cur2ss(g_arrCurRunningSum(3))%>
	vs15=<%so.write cur2ss(g_arrCurRunningSum(4))%>
	vs16=<%so.write cur2ss(g_arrCurRunningSum(5))%>
	vs17=<%so.write cur2ss(g_arrCurRunningSum(6))%>
	vs18=<%so.write cur2ss(g_arrCurRunningSum(7))%>
	vs19=<%so.write cur2ss(g_arrCurRunningSum(8))%>
	vs20=<%so.write cur2ss(g_arrCurRunningSum(9))%>'
<%
if pRapExec.RecNr mod 2 <> 0 then
%>
style='37'
<%
end if
%>
 bordercolor='white'>
	<td width='min' bold='true'>
		RXE_T_LINK_FORM_VCC(TYPEID_N5KONTO,c_idkonto,c_symbol)	
	</td>
	<%
	if g_bShowNazwa then
	%>
#ifdef _IOW
	<td width='min'>
#else
	<td>
#endif
		RXE_TEXT(c_nazwa)
	</td>
	<%
	end if
	%>
	<td>
		RXE_T(c_skrot)
	</td>
	<%
	if g_bShowBO then
	%>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curBO_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curBO_Ma,strUnit,nPrec)
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrO then
	%>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrO_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrO_Ma,strUnit,nPrec)
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrN then
	%>
#ifdef _PAKART
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrN_Wn + pKontoInfo.m_curBO_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrN_Ma + pKontoInfo.m_curBO_Ma,strUnit,nPrec)
	</td>
#else
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrN_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curObrN_Ma,strUnit,nPrec)
	</td>
#endif  
	<%
	end if
	%>
	<%
	if g_bShowSalN then
	%>

	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curSalN_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0(pKontoInfo.m_curSalN_Ma,strUnit,nPrec)
	</td>
	<%
	end if
	%>
	<%
	if g_bShowSaSN then
	%>

	<td align='right'>
		RXE_DBL_VVV_NON0( pKontoInfo.m_curSaSN_Wn,strUnit,nPrec)
	</td>
	<td align='right'>
		RXE_DBL_VVV_NON0( pKontoInfo.m_curSaSN_Ma,strUnit,nPrec)
	</td>
	<%
	end if
	%>

</tr><%

end if	'skip row

end function
%>
<%
function body_header(byref pSection,byref pRec)

dim iter
for iter = 0 to 9
	g_arrCurRunningSum(iter) = ccur(0.0)
next

%>
<table name='CTRLID_MAINTABLE' border='1'>
<thead>
<tr style='21'>
	<td rowspan='2' width='min'>
		<text><![CDATA[Symbol]]></text>
	</td>
	<%
	if g_bShowNazwa then
	%>
#ifdef _IOW
	<td rowspan='2' width='4500'>
#else
	<td rowspan='2' width='6500'>
#endif
		<text><![CDATA[Nazwa]]></text>
	</td>
	<%
	end if
	%>
	<td rowspan='2' width='min'>
		<text><![CDATA[Wal uta]]></text>
	</td>
	<%
	if g_bShowBO then
	%>
	<td colspan='2' width='min'>
		<text><![CDATA[BO]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrO then
	%>
	<td colspan='2'  width='min'>
		<text><![CDATA[Obroty w okresie]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrN then
	%>
	<td colspan='2'  width='min'>
		<text><![CDATA[Obroty narastająco]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowSalN then
	%>
	<td colspan='2'  width='min'>
		<text><![CDATA[Saldo]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowSaSN then
	%>
	<td colspan='2'  width='min'>
		<text><![CDATA[Saldo sald]]></text>
	</td>
	<%
	end if
	%>
</tr>
<tr style='21'>
	<%
	if g_bShowBO then
	%>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Ma]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrO then
	%>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Ma]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowObrN then
	%>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Ma]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowSalN then
	%>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Ma]]></text>
	</td>
	<%
	end if
	%>
	<%
	if g_bShowSaSN then
	%>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Winien]]></text>
	</td>
	<td width='CURRENCY_COL_WIDTH'>
		<text><![CDATA[Ma]]></text>
	</td>
	<%
	end if
	%>
</tr>
</thead>
<tbody>
<%
end function
%>

<%
private function str2Cur2(strValue)
	if strValue = "" then
		str2Cur2 = ccur(0.0)
	else
		dim oOrgLocale: oOrgLocale=GetLocale()
		'SetLocale(7177)

		strValue = Replace(strValue, ",", ",")
		
		str2Cur2=CCur(strValue)
		'SetLocale(oOrgLocale)
	end if
end function

function dbl_money(byval dblVal)
	dim strVal : strVal = replace(cstr(dblVal),",",",")
	dim strSgn : strSgn = ""
	'if left(strVal,1) = "-" then
	'	strSgn = "-"
	'	strVal = mid(strVal,2)
	'end if
	dim iDotPos : iDotPos = instr(strVal,",")
	dim iRChars : iRChars = 3
	if iDotPos <> 0 then
		iRChars = iRChars + len(strVal) - iDotPos + 1
	end if
	if iRChars + 1 >= len(strVal) then
		dbl_money = doc_.afc.display.money(str2Cur2(strVal),"")
	else
		dim strRPart : strRPart = "1" + right(strVal,iRChars)
		dim strLPart : strLPart = left(strVal,len(strVal) - iRChars)

		dbl_money = strSgn + doc_.afc.display.quantity(str2Cur2(strLPart),"",0) + " " +_
			mid(doc_.afc.display.quantity(str2Cur2(strRPart),"",2),3)
	end if
end function

function body_footer(byref pSection)
dim pKontoInfo : set pKontoInfo = g_pKontoInfoMan.kontoinfo(0)
dim strUnit : strUnit = ""
dim nPrec : nPrec = 2
%>
</tbody>
<tfoot >
<tr style='27' bold='true'  border='1' bordercolor='black'>
	<td style='27'>
		<t>Razem</t>
	</td>
	<%
	if g_bShowNazwa then
	%>
	<td style='27'/>
	<%
	end if
	%>
	<td style='27' />
	<%
	if g_bShowBO then
	%>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curBO_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curBO_Ma,strUnit,nPrec)
  </td>
	<%
	end if
	%>
	<%
	if g_bShowObrO then
	%>
