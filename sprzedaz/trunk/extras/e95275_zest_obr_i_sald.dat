#define RAPORT_TITLE Zestawienie obrotów i sald

#define CURRENCY_COL_WIDTH    1600
#define CTRLID_MAINTABLE      102
#define CTRLID_SPECIAL        103

#macro MONEY(_value_)					dbl_money(_value_)

<%

dim g_bShowNazwa : g_bShowNazwa = true
dim g_bShowBO : g_bShowBO = true
dim g_bShowObrO : g_bShowObrO = true  
dim g_bShowObrN : g_bShowObrN = true
dim g_bShowSalN : g_bShowSalN = true
dim g_bShowSaSN : g_bShowSaSN = true

dim g_bTylkoZBO : g_bTylkoZBO = false
dim g_bTylkoZObr : g_bTylkoZObr = false
dim g_bTylkoZSal : g_bTylkoZSal = false

#macro RXE_DBL_VVV(_val_val_,_unit_val_,_prec_val_)		 <t><%so.write dbl_money(_val_val_)%></t>
#macro RXE_DBL_VVV_NON0(_val_val_,_unit_val_,_prec_val_) <t><%if cdbl(_val_val_) <> 0.0 then so.write dbl_money(_val_val_)%></t>

%>
-->
<page fontsize='2' style='36' margins='700,700,700,700'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

VB_PRINT_LANDSCAPE_COMMON
VB_PRINTPREV_LANDSCAPE_COMMON

function ss2dbl(byval strVal)
	dim oOrgLocale: oOrgLocale=GetLocale()
	SetLocale(7177)
	ss2dbl = cdbl(strVal)
	SetLocale(oOrgLocale)
end function

private function str2Cur2(strValue)
	if strValue = "" then
		str2Cur2 = ccur(0.0)
	else
		dim oOrgLocale: oOrgLocale=GetLocale()
		'SetLocale(7177)

		strValue = Replace(strValue, ",", ",")
		
		str2Cur2=CCur(strValue)
		'SetLocale(oOrgLocale)
	end if
end function

function dbl_money(byval dblVal)
	dim strVal : strVal = replace(cstr(dblVal),",",",")
	dim strSgn : strSgn = ""
	'if left(strVal,1) = "-" then
	'	strSgn = "-"
	'	strVal = mid(strVal,2)
	'end if
	dim iDotPos : iDotPos = instr(strVal,",")
	dim iRChars : iRChars = 3
	if iDotPos <> 0 then
		iRChars = iRChars + len(strVal) - iDotPos + 1
	end if
	if iRChars + 1 >= len(strVal) then
		dbl_money = doc_.afc.display.money(str2Cur2(strVal),"")
	else
		dim strRPart : strRPart = "1" + right(strVal,iRChars)
		dim strLPart : strLPart = left(strVal,len(strVal) - iRChars)

		dbl_money = strSgn + doc_.afc.display.quantity(str2Cur2(strLPart),"",0) + " " +_
			mid(doc_.afc.display.quantity(str2Cur2(strRPart),"",2),3)
	end if
end function

function c##CTRLID_MAINTABLE##_on_table_split(byref pClonedTable,byval xAreaX,byval yAreaY,byval xCount,byval yCount)
	if yAreaY <> yCount then
	dim oTB : set oTB = doc_.afc.new_tb(page_).attach(pClonedTable).section_foot
		oTB.removeall
		dim curArr(10)
		dim iter
		for iter = 1 to 10
			curArr(iter) = cdbl(0.0)
		next
		dim pRow
		for each pRow in pClonedTable.body
			for iter = 1 to 10
				curArr(iter) = curArr(iter) + ss2dbl(pRow.userprop(iter))
			next
		next
		with oTB.newrow.row
			.border=1
			.bold = true
		end with
		oTB.newcell.addtext "Na stronie"
		oTB.newcell
		if page_.ctrl(CTRLID_SPECIAL).userprop(1) = 1 then
			oTB.newcell
		end if

		if page_.ctrl(CTRLID_SPECIAL).userprop(2) = 1 then
			oTB.newcell.addtext(MONEY(curArr(1))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(curArr(2))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(3) = 1 then
			oTB.newcell.addtext(MONEY(curArr(3))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(curArr(4))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(4) = 1 then
			oTB.newcell.addtext(MONEY(curArr(5))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(curArr(6))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(5) = 1 then
			oTB.newcell.addtext(MONEY(curArr(7))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(curArr(8))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(6) = 1 then
			oTB.newcell.addtext(MONEY(curArr(9))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(curArr(10))).cell.align=ALIGN_RIGHT
		end if


		with oTB.newrow.row
			.border=1
			.bold = true
		end with
		dim pLastRowUserProp : set pLastRowUserProp = pClonedTable.body.row(pClonedTable.body.count).userprop
		oTB.newcell.addtext "Narastająco"
		oTB.newcell
		if page_.ctrl(CTRLID_SPECIAL).userprop(1) = 1 then
			oTB.newcell
		end if

		if page_.ctrl(CTRLID_SPECIAL).userprop(2) = 1 then
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(11)))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(12)))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(3) = 1 then
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(13)))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(14)))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(4) = 1 then
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(15)))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(16)))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(5) = 1 then
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(17)))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(18)))).cell.align=ALIGN_RIGHT
		end if
		if page_.ctrl(CTRLID_SPECIAL).userprop(6) = 1 then
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(19)))).cell.align=ALIGN_RIGHT
			oTB.newcell.addtext(MONEY(ss2dbl(pLastRowUserProp.prop(20)))).cell.align=ALIGN_RIGHT
		end if
	end if
end function

<%
dim g_pPM : set g_pPM  = doc_.getmodule(60159)
dim g_pCustParamMod : set g_pCustParamMod = doc_.getmodule(43030)

dim g_pKontoInfoMan : set g_pKontoInfoMan = nothing
dim g_arrCurRunningSum(10)

'---- ---- deklaracje parametrow w kolejnosci wystepowania ---- ---- 
dim g_pCustParamSymbol : set g_pCustParamSymbol = nothing
dim g_pParamAnalSynt : set g_pParamAnalSynt = nothing
dim g_pParamBilans : set g_pParamBilans = nothing
dim g_pParamDate : set g_pParamDate = nothing
dim g_pParamStatus : set g_pParamStatus = nothing
dim g_pCustParamKolumny : set g_pCustParamKolumny = nothing
dim g_pCustParamFiltrSald : set g_pCustParamFiltrSald = nothing
dim g_pCustParamIloscZnakow : set g_pCustParamIloscZnakow = nothing
#ifdef _ALMA_TREND
dim g_pParamAktywneNieakt : set g_pParamAktywneNieakt = nothing
#endif
'---- ---- ---- ---- ---- ---- ---- ---- ---- 

dim custom_param
dim pFiltr_CustomParam
dim pFiltr_Liczba_znakow

function default_param()
  dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
'---- ---- ---- ----
  'make placeholder
	pParamArray.add nothing
'---- ---- ---- ----
	dim pParamFactory1: set pParamFactory1= doc_.afc.rap.param
	Set g_pParamAnalSynt= pParamFactory1.new_choice("Analityczne/syntetyczne").bindexpr("t_konto.eAnalit")
	pParamFactory1.init_on_enum g_pParamAnalSynt, TYPEID_N5KONTO,"eAnalit"
	pParamArray.add g_pParamAnalSynt
'---- ---- ---- ----
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	Set g_pParamBilans= pParamFactory2.new_choice("Bilansowe/pozabilansowe").bindexpr("t_konto.eBilans")
	pParamFactory2.init_on_enum g_pParamBilans, TYPEID_N5KONTO,"eBilans"
	pParamArray.add g_pParamBilans	
'---- ---- ---- ----
	set g_pParamDate = doc_.afc.rap.param.new_date_range("Data księgowania").bindexpr("dDataKsieg")
	pParamArray.add g_pParamDate
'---- ---- ---- ----
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	set g_pParamStatus= pParamFactory3.new_choice("Status").bindexpr("eStatus")
	pParamFactory3.init_on_enum g_pParamStatus, TYPEID_N5DEKRET,"eStatus"
	pParamArray.add g_pParamStatus
'---- ---- ---- ----
	set g_pCustParamKolumny = g_pCustParamMod.new_custom("Kolumny")
	g_pCustParamKolumny.ExtraXML = "<checkbox name='1111'><t>Nazwa konta</t>"+_
												  "<t>BO</t>"+_	
												  "<t>Obroty z okresie</t>"+_
												  "<t>Obroty narastająco</t>"+_
												  "<t>Saldo</t>"+_
												  "<t>Saldo sald</t></checkbox>"
	g_pCustParamKolumny.ExtraINIT = "page_.ctrl(1111).value = ""111111"" "
	g_pCustParamKolumny.Add2CtrlTable 1111
	pParamArray.add g_pCustParamKolumny
'---- ---- ---- ----
	set g_pCustParamFiltrSald = g_pCustParamMod.new_custom("Filtr sald i obrotów")
	g_pCustParamFiltrSald.ExtraXML = "<checkbox name='1211'><t>tylko z BO</t>"+_
												  "<t>tylko z obrotami</t>"+_	
												  "<t>tylko z saldem</t>"+_
												  "</checkbox>"
	g_pCustParamFiltrSald.ExtraINIT = "page_.ctrl(1211).value = ""000"" "
	g_pCustParamFiltrSald.Add2CtrlTable 1211
  pParamArray.add g_pCustParamFiltrSald
'---- ---- ---- ----	
  set g_pCustParamIloscZnakow = doc_.afc.rap.param.new_choice("Ilość znaków symbolu")
  with g_pCustParamIloscZnakow
  .multiple = false
  .names.add "Wszystkie konta"
  .values.add 1
  .selected.add True

  .names.add "Konta 1-znakowe"
  .values.add 2
  .selected.add False
  
  .names.add "Konta 3-znakowe"
  .values.add 2
  .selected.add False
  end with
  pParamArray.add g_pCustParamIloscZnakow
'---- ---- ---- ----
#ifdef _ALMA_TREND
	dim pParamFactory4: set pParamFactory4 = doc_.afc.rap.param
	set g_pParamAktywneNieakt = pParamFactory4.new_choice("Aktywne/nieaktywne").bindexpr("t_konto.eAktywne")
	pParamFactory4.init_on_enum g_pParamAktywneNieakt, TYPEID_N5KONTO,"eAktywne"
	pParamArray.add g_pParamAktywneNieakt
'---- ---- ---- ----
#endif
	
  set default_param = pParamArray

end function

function query()
#ifdef _IOW
query = "select 'c_nazwa'=left(t_konto.strNazwa,32),'c_idkonto'=t_konto.IdObj, 'c_symbol'=t_konto.strSymbol, " +_
#else
query = "select 'c_nazwa'=t_konto.strNazwa,'c_idkonto'=t_konto.IdObj, 'c_symbol'=t_konto.strSymbol, " +_
#endif
"'c_skrot'=t_jedn.strSkrot,'c_prec'=t_jedn.nDokladnosc,'c_bilans'=t_konto.eBilans " +_
"from n5konto as t_konto " +_
"inner join n5jednostka as t_jedn on t_konto.pJednostka = t_jedn.IdObj " +_
"where  %FILTR_SYMBOLU%  "
query=query + "order by dbo.ks_lex_order(t_konto.strSymbol) "
end function

