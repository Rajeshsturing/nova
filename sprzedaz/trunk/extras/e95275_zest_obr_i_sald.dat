    RXE_DBL_VVV(pKontoInfo.m_curObrO_Wn,strUnit,nPrec)
  </td>
	<td align='right'>
    RXE_DBL_VVV(pKontoInfo.m_curObrO_Ma,strUnit,nPrec)
  </td>
	<%
