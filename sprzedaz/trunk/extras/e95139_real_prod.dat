<?xml version="1.0" encoding="windows-1250" ?>

#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")

#define DOKLP_OFFSET_SUROWCE     0
#define DOKLP_OFFSET_ROBOCIZNA_ADD 10000
#define DOKLP_OFFSET_ROBOCIZNA_DEL 20000
#define DOKLP_OFFSET_WYROBY 30000

#define DOKUMENT_NUMER					<% so.write root_.strNrDok %>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto + "   " + util_.Dzisiaj%>

#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta end if end if%>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>

#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>
#define DOKUMENT_MAGAZYN				<% so.write root_.pMagazyn.strNazwa%>
#define DOKUMENT_WARTOSC				<% so.write MONEY(curSuma)%>
#define DOKUMENT_ZLECENIE				<% so.write root_.pZlecProd.strNrDok %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>

#define DOKUMENT_WARTOSC_RS				<% so.write MONEY(abs(curSuma))%>
#define DOKUMENT_WARTOSC_SC_RS			<% so.write MONEY(abs(curSumaSC))%>

<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_IDX							<% so.write cstr(rs.fields("p_strIndeks").value) %>
#define POZ_TOWAR_ID					<% so.write util_.Produkt_Nazwa(rs.fields("pProdZrod").value) %>
#define POZ_TOWAR_RS					<% so.write cstr(rs.fields("p_strNazwa").value) %>
#define POZ_OPAKOWANIE_RS				<% if cstr(rs.fields("c_strNazwa").value) <> "Podstawowe" then so.write " (" +  cstr(rs.fields("c_strNazwa").value) + ")" end if %>
#define POZ_ILOSC_RS					<% so.write doc_.afc.display.quantity(abs(ccur(rs.fields("gmo_curIlosc").value)),"",clng(rs.fields("nDokladnosc").value) - 1 ) %>
#define POZ_JM_RS						<% so.write rs.fields("strSkrot").value %>
#define POZ_CENA_DOSTAWY_RS				<% so.write MONEY(abs(ccur(rs.fields("gmo_curCena").value))) %>
#define POZ_WARTOSC_RS					<% so.write MONEY(abs(ccur(rs.fields("gmo_curWartosc").value)))%>

#define POZ_RODZ_WYCENY					<% if ccur(rs2.fields("c_erodzajwyceny").value)=1 then so.write "cena" else so.write "wsp." end if%>
#define POZ_WSPOLCZYNNIK				<% so.write ccur(rs2.fields("c_curwspolczynnik").value)*100 %>


<page style='36' margins='800,800,800,800'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>



<table border='0'>
	<tbody>
		<tr>
			<td>
				<table>
					<tbody>
						<tr>						
							<td align='left' width='max'>
								<text bold='true'><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA]]></t>
							</td>					
						</tr>
						<tr>						
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>					
						</tr>
						<tr>							
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>				
						</tr>

						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>							
							<td align='left' colspan='2'>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>				
						</tr>
						<% end if %>
						<tr>
							<td align='center' colspan='2'>
								<br/><br/><t bold='true' fontsize='6'><![CDATA[Realizacja produkcji nr DOKUMENT_NUMER]]> </t><br/><br/>
							</td>
						</tr>
						
						ROW_SEPARATOR(1)
						ROW_SEPARATOR(1)

						<tr>
							<td colspan='2'>
								<table>
									<tbody>
										<tr>
											<td width='min'>
												<t bold='true'>Data wystawienia:&nbsp;</t>
											</td>
											<td>
												<t><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></t>
											</td>
										</tr>

										<tr>
											<td width='min'>
												<t bold='true'>Magazyn:</t>
											</td>
											<td>
												<t><![CDATA[DOKUMENT_MAGAZYN]]></t>
											</td>
										</tr>
										<% if not root_.pZlecProd is nothing then %>
										<tr>
											<td width='min'>
												<t bold='true'>Zlecenie produkcyjne:&nbsp;</t>
											</td>							
											<td>
												<t><![CDATA[DOKUMENT_ZLECENIE]]></t>
											</td>						
										</tr>
										<%end if%>


									</tbody>
								</table>
							</td>							
						</tr>



						ROW_SEPARATOR(1)
						ROW_SEPARATOR(1)

					</tbody>
				</table>
			</td>
		</tr>
		<tr>
			<td>
				<text bold='true'>LISTA WYROBÓW</text> 
			</td>
		</tr>
		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa wyrobu</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>							
						
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Rodzaj wyceny</text>
							</td>
							<td align='right'>
								<text>Udział w kosztach</text>
							</td>
							<td align='right'>
								<text>Cena dostawy</text>
							</td>
							<td align='right'>
								<text>Wartość</text>
							</td>
						</tr>
					</thead>
						
					<tbody>
						<%
	
							dim iter
							dim prod
							if doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
							if root_.n5realprod_update_wartosc then
							
								dim curSuma:curSuma = ccur(0)

								dim rs
								set rs = trans_.createadors("select * from n5gmop " + _
								" join vlist_n5produkt_listOpakowania on gmo_pProd = p_idobj and gmo_pOpak = c_idobj   " + _ 
								" join n5jednostka on vlist_n5produkt_listOpakowania.c_pJednOpak = n5jednostka.idobj   " + _ 								
								" where gmo_nNumOp = " + cstr(root_.nNumOper) + _ 							
								" and gmo_nLp > DOKLP_OFFSET_WYROBY" + _ 							
								" order by gmo_nLP")
								
								dim rs2
								set rs2 = trans_.createadors("select * from vlist_n5realprod_listWyrob " + _
								" where p_strnrdok = '" + cstr(root_.strnrdok) + "' " +_												
								" order by coll_lp")
								
								prod = cstr(rs.fields("gmo_nLp").value)
								rs.movefirst
								iter = 1
								while not rs.eof
								
								curSuma = curSuma - ccur(rs.fields("gmo_curWartosc").value)
								if prod <> cstr(rs.fields("gmo_nLp").value) then									
									rs2.movenext
									prod = cstr(rs.fields("gmo_nLp").value)
								end if
								
						%>
						<tr>

							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td keepline='true' width='4000'>
								<text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE_RS]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>

							<td align='right'>
								<t><![CDATA[POZ_ILOSC_RS]]></t>			
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM_RS]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_RODZ_WYCENY]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WSPOLCZYNNIK%]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_RS]]></t>
							</td>
						</tr>
							<%									
									
									
									iter = iter + 1
							
								
								rs.movenext
								wend
							else
						
						%>
							<tr border='1' fontsize='5' forecolor='red' bold='true'><td colspan='7'><t>Uwaga! Niepoprawny stan magazynu</t></td></tr>
						<% end if %>
						<% end if %>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='5' bordercolor='transparent'>
							</td>
							<td colspan='3'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_RS]]></t>
							</td>							
						</tr>	
					
					</tfoot>
				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
</tbody>
</table>
<table border='0' >
	<tbody>	
		<tr>		
			<td>
				<text bold='true'>LISTA SKŁADNIKÓW</text> 
			</td>
		</tr>
	</tbody>
</table>	
<table border='1' >
<tbody>
		<tr>
		<td colspan='3'>
		<table border='0'>
		<tbody>
		<tr>
			
			<td>
				<text bold='false' fontsize='2'>TOWARY</text> 
			</td>
		</tr>
		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa surowca</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>							
						
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena dostawy</text>
							</td>
							<td align='right' width='3000'>
								<text>Wartość</text>
							</td>
							
						</tr>
					</thead>
						
					<tbody>
						<%	
								
								dim curSumaSC:curSumaSC = ccur(0)
								
								curSuma = ccur(0)

								
								set rs = trans_.createadors("select * from n5gmop " + _
								" join vlist_n5produkt_listOpakowania on gmo_pProd = p_idobj and gmo_pOpak = c_idobj   " + _ 
								" join n5jednostka on vlist_n5produkt_listOpakowania.c_pJednOpak = n5jednostka.idobj   " + _ 								
								" where gmo_nNumOp = " + cstr(root_.nNumOper) + _ 							
								" and gmo_nLp < DOKLP_OFFSET_ROBOCIZNA_ADD" + _ 							
								" order by gmo_nLP")
								
								iter = 1
								while not rs.eof
									curSuma = curSuma - ccur(rs.fields("gmo_curWartosc").value)	
									
						%>
						<tr>

							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td width='4000'>
								<text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE_RS]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>

							<td align='right'>
								<t><![CDATA[POZ_ILOSC_RS]]></t>			
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM_RS]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_RS]]></t>
							</td>

						</tr>
						<%	
									iter = iter + 1
									rs.movenext
								wend
								curSumaSC = curSumaSC + abs(curSuma)
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='4' bordercolor='transparent'>
							</td>
							<td colspan='2'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_RS]]></t>
							</td>							
						</tr>	
					
					</tfoot>

				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<text bold='false' fontsize='2'>CZYNNOŚCI</text> 
			</td>
		</tr>
		<tr>
			<td>
				<table border='1'>
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td width='min' align='center'>
								<t>LP</t>
							</td>
							<td>
								<text>Nazwa czynności</text>
							</td>	
							<td align='right'>
								<text>Indeks</text>
							</td>							
						
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>
							<td align='right'>
								<text>Cena</text>
							</td>
							<td align='right' width='3000'>
								<text>Wartość</text>
							</td>

						</tr>
					</thead>
						
					<tbody>
						<%	
								curSuma = ccur(0)

								
								set rs = trans_.createadors("select * from n5gmop " + _
								" join vlist_n5produkt_listOpakowania on gmo_pProd = p_idobj and gmo_pOpak = c_idobj   " + _ 
								" join n5jednostka on vlist_n5produkt_listOpakowania.c_pJednOpak = n5jednostka.idobj   " + _ 								
								" where gmo_nNumOp = " + cstr(root_.nNumOper) + _ 							
								" and gmo_nLp > DOKLP_OFFSET_ROBOCIZNA_DEL and gmo_nLp < DOKLP_OFFSET_WYROBY" + _ 							
								" order by gmo_nLP")
								
								iter = 1
								while not rs.eof
									curSuma = curSuma - ccur(rs.fields("gmo_curWartosc").value)	
									
						%>
						<tr>

							<td width='min' align='right'>
								<t>POZ_LP</t>
							</td>
							<td width='4000'>
								<text><![CDATA[POZ_TOWAR_RS]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE_RS]]></text>
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>
							</td>

							<td align='right'>
								<t><![CDATA[POZ_ILOSC_RS]]></t>			
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM_RS]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_DOSTAWY_RS]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_RS]]></t>
							</td>

						</tr>
						<%	
									iter = iter + 1
									rs.movenext
								wend
								curSumaSC = curSumaSC + abs(curSuma)
						%>
					</tbody>

					<tfoot>
						<tr>
							<td colspan='4' bordercolor='transparent'>
							</td>
							<td colspan='2'  backcolor='#E0E0E0'>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_RS]]></t>
							</td>							
						</tr>	
					
					</tfoot>

				</table>
			</td>
		</tr>
		ROW_SEPARATOR(1)
		</tbody>
		</table>
		</td>
		</tr>
		
		
		<tr>
			
							
							<td colspan='2' align='right' backcolor='#E0E0E0' width='8700'>
								<text bold='true'>Koszt razem</text>
							</td>
							<td align='right'  backcolor='#E0E0E0' align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_SC_RS]]></t>
							</td>							
						
		</tr>
</tbody>
</table>
<table border='0' >
<tbody>			
		ROW_SEPARATOR(3)
		ROW_SEPARATOR(3)
		ROW_SEPARATOR(3)
		<tr>
			<td>
			<text bold='true'>Wprowadził: &nbsp;</text><text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
			</td>
			<td></td>
			<td></td>
		</tr>
		
		
											
	</tbody>
</table>





</body>
<footer>
</footer>
</page>
