							<td align='right' keepline='true'>
								<t bold='true'>Warunki dostawy:</t>
								<t size='1'/>
								<t><![CDATA[DOKUMENT_TRANSPORT]]></t>
							</td>
						</tr>
						<%end if%>
						ROW_SEPARATOR(3)
						<tr>
							<td>
								<t bold='true'>Nr. obcy zamówienia:</t>						
							</td>
							<td>
								<t><![CDATA[DOKUMENT_ZAMOWIENIE_NR_OBCY]]></t>
							</td>							
							<td>
							</td>							

						</tr>
					</tbody>
				</table>
			</td>
		</tr>
	

		
		ROW_SEPARATOR(1)	
		<%if not root_.pZamowienie is nothing then %>
		<tr>
			<td>
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Nazwa towaru / usługi</text>
							</td>
							<td align='right'>
								<text>Indeks</text>
							</td>
							<td align='right'>
								<t>PKWiU</t>
							</td>
							<td align='right'>
								<text>Ilość</text>
							</td>
							<td align='right'>
								<text>J.m.</text>
							</td>							
							<td align='right'>
								<text>Cena netto DOKUMENT_WALUTA</text>
							</td>
							<td align='right'>
								<text>Wartość netto DOKUMENT_WALUTA</text>
							</td>
							<td align='center'>
								<text>VAT</text>
							</td>
							<td align='right'>
								<text>Wartość VAT DOKUMENT_WALUTA</text>
							</td>
							<td align='right'>
								<text>Wartość brutto DOKUMENT_WALUTA</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% 
						dim iter, pozycja
						dim rs
						dim pVATArray:set pVATArray = trans_.afc.new_navoarray()
						iter = 1
						for each pozycja in root_.pZamowienie.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t>
								<text><![CDATA[POZ_OPAKOWANIE]]></text>
								
							</td>
							<td align='right'>
								<text><![CDATA[POZ_IDX]]></text>								
							</td>
							<td width='min' align='right'>
								<text><![CDATA[POZ_PKWIU]]></text>																
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right'>
							    <t><![CDATA[POZ_JM]]></t>			
							</td>
							<td align='right'>
								<t><![CDATA[POZ_CENA_NETTO]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[POZ_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
						iter = iter + 1
						if not pVATArray.exists(clng(pozycja.eVat)) then
								pVATArray.add(clng(pozycja.eVat))
						end if

						next
						%>
				</tbody>
				<tfoot>


						<tr>
							<td colspan='6' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[ZAMOWIENIE_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[ZAMOWIENIE_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[ZAMOWIENIE_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>	
						<%
						set rs = trans_.createadors("select 'stawka'=max(c_evat), 'netto'=sum(c_curwartnetto),'vat'=sum(c_curvat), 'brutto'=sum(c_curwartbrutto)  "+_
								" from dbo.vlist_n5zamowienie_listPozycje "+_
								" where p_idobj= " + cstr(root_.pZamowienie.idobj)+_
								" group by c_evat order by c_evat")
							dim strNazwaStawki
						%>				
						<%	
							iter = 1
								while not rs.eof

							
						%>
						<tr>
							<td colspan='7' bordercolor='transparent'>
							</td>
							<td  align='right'>
								<t><% 
								so.write MONEY(rs.fields("netto").value)
							%></t>
							</td>
							<td align='center'>
								<t><![CDATA[<%so.write util_.vat_to_name(rs.fields("stawka").value)%>]]></t>								
							</td>
							<td align='right'>
								<t><%
								so.write MONEY(rs.fields("vat").value)
								%></t>
							</td>
							<td align='right'>
								<t><% 
								so.write MONEY(rs.fields("brutto").value)
							%></t>
							</td>					
						</tr>
						<%
							iter = iter + 1
									rs.movenext
								wend
							
						%>	
<!--podsumowanie pozycji-->	
						

<!-- zaliczki-->

						
<%
						
							set rs = trans_.createadors("select 'strNrDok'=t_sprzed.strnrdok, " +_
							" 'curSumaNetto'=isnull(t_sprzed.curSumaNetto-isnull(t_orgsprz.curSumaNetto,0),0), " +_
							"  'curSumaBrutto'=isnull(t_sprzed.curSumaBrutto-isnull(t_orgsprz.curSumaBrutto,0),0), " +_
							"  'curSumaVat'=isnull(t_sprzed.curSumaVAT-isnull(t_orgsprz.curSumaVAT,0),0), "  +_
							" 'data'=t_sprzed.dDataSprzed " +_
							" from n5sprzedaz as t_sprzed" +_
							" left outer join n5sprzedaz t_orgsprz on t_sprzed.ppopsprzed = t_orgsprz.idobj " +_
							" left join n5transakcja  t_trans on t_sprzed.pTransakcja=t_trans.idobj  " +_
							" left join n5transakcja t_transorg on t_orgsprz.pTransakcja=t_transorg.idobj  " +_
							" where t_trans.strSymTrans like '" + cstr(root_.pTransakcja.strSymTrans)+"'"+_
							" and t_sprzed.strNrDok not like '" + cstr(root_.strNrDok)+"'" )

							if not rs.eof then
							%>
						<tr bordercolor='transparent'>
							<td colspan='11' bordercolor='transparent'>
							<t size='1'/>
							</td>
						</tr>
						<tr>
							<td colspan='5' bordercolor='transparent'/>
							<td  colspan='5' bordercolor='transparent' align='right'>
								<text bold='true' ><![CDATA[ZALICZKI]]></text><t size='2'/>
							</td>
							<td colspan='6' bordercolor='transparent'/>
						</tr>
							<%
							end if
							
							iter = 1
								while not rs.eof
	
						%>
						
						<tr>
							<td colspan='1' bordercolor='transparent'/>
							<td  colspan='6' bordercolor='transparent' align='right'>
								<text bold='true' ><![CDATA[ZALICZKA_SYMBOL]]></text><t size='2'/><text><![CDATA[(z dnia  ZALICZKA_DATA)]]></text><t size='2'/>
							</td>
							
							<td  align='right'>
								<t><![CDATA[ZALICZKA_NETTO]]></t>
							</td>	
							<td align='center'>
								<t>X</t>								
							</td>
							<td align='right'>
								<t><![CDATA[ZALICZKA_VAT]]></t>
							</td>	
							<td align='right'>
								<t><![CDATA[ZALICZKA_BRUTTO]]></t>
							</td>
									
						</tr>
						
						

						


						<%
							iter = iter + 1
									rs.movenext
								wend
						%>			
		
<!-- /zaliczki-->

						<tr>
							<td colspan='11' bordercolor='transparent'>
							<t size='1'/>
							</td>
						</tr>


<!-- pozostało do zapłaty-->
					
					<tr>
							
							<td colspan='2' bordercolor='transparent'/>
							<td  colspan='5' bordercolor='transparent' align='right'>
								<text bold='true' >POZOSTAŁO DO ZAPŁATY:</text><t size='2'/>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_NETTO]]></t>
							</td>
							<td align='center'>
								<t bold='true'>X</t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_VAT]]></t>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_WARTOSC_BRUTTO]]></t>								
							</td>
						</tr>	
						<%
						for iter=0 to pVATArray.UpperIndex()
						%>

						<tr>
							<td colspan='7' bordercolor='transparent'/>
							<td  align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_NETTO(pVATArray.value(iter))]]></t>
							</td>
							<td align='center'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_STAWKA(pVATArray.value(iter))]]></t>								
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_VAT(pVATArray.value(iter))]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[DOKUMENT_PODSUMOWANIE_BRUTTO(pVATArray.value(iter))]]></t>
							</td>	
						</tr>
						<%
						next
						%>

						
					</tfoot>

				
				
				</table>
			</td>
		</tr>

		<%end if%>
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		

		<!-- Podsumowanie -->
		<tr>
			<td keepline='true'>
				<t fontsize='6' bold='true'>Pozostało do zapłaty:</t>
				<t size='3'/>
				<t fontsize='6' bold='true'><![CDATA[DOKUMENT_DO_ZAPLATY]]></t>
			</td>
		</tr>
		<tr>
			<td>
				<t bold='true'>Słownie:</t>
				<t size='3'/>
				<t><![CDATA[DOKUMENT_DO_ZAPLATY_SLOWNIE]]></t>
			</td>
		</tr>






		
		<% if root_.strUwagi <> "" then %>
		
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>		<% end if%>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		
		<tr>
			<td>
				<table>
					<tbody>				
						<tr>
							<td align='center'>	
								<text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>
							</td>	
							<td width='max'></td>						
							<td align='center'>	
								<text><![CDATA[DOKUMENT_OSOBA_ODBIERAJACA]]></text>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
							<td></td>
							<td align='center'>	
								<t>.........................................................................</t>
							</td>							
						</tr>
						<tr>
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby upoważnionej do wystawienia faktury VAT</t>
							</td>				
							<td></td>			
							<td align='center'>	
								<t fontsize='2'>Imię i nazwisko osoby uprawnionej do odbioru faktury VAT</t>
							</td>							
						</tr>
					</tbody>				
				</table>
			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr valign='bottom'>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
		
	</tbody>
</table>
</body>
<footer>
