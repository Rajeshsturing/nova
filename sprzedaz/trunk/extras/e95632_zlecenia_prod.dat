<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_ZLECPROD_WG_NUMERU

#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE REJESTR PRZEWODNIKÓW

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC
VB_PRINT_LANDSCAPE_COMMON
VB_PRINTPREV_LANDSCAPE_COMMON
<%

function query()
 
	query = "select 'p_strnrdok'=p.strNrDok,'p_idobj'=p.IdObj,'pr_idobj'=pr.idobj,'pr_produkt'=pr.strNazwa,'r_strnorma'=r.strNorma, " +_
          "'r_idobj'=r.idobj,'c_curiloscopak'=c.curIloscOpak, " +_
          "'p_ddatawyst'=p.dDataWyst,'k_idobj'=k.idobj,'k_pklient'=k.strSkrot,'z_idobj'=isnull(z.idobj,0),'z_strnrdok'=isnull(z.strNrDok,'') " +_
          "from n5zlecprod as p " +_
          "inner join collections on p.idobj=collections.idparent and collections.idcollection = 10187012 " +_
          "inner join n5pozzlecprod as c on c.idobj = collections.idobj " +_
          "left join n5produkt as pr on c.pProdukt = pr.idobj " +_
          "inner join n5recepta as r on c.pRecepta = r.idobj " +_
          "inner join n5klient as k on p.pKlient = k.idobj " +_
          "left join n5zamowienie as z on p.pZamowienie = z.idobj " +_
          "where %1 and %2 and %3 and %4 " +_
          "order by p.strNrDok"
          
end function
%>
<%

dim RaportOkresParam
dim pParamArray

function default_param()
	set pParamArray = doc_.afc.new_navoarray()
  set RaportOkresParam = doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("p.dDataWyst")
	pParamArray.add RaportOkresParam
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa części").bindexpr("pr.strNazwa")
  pParamArray.add doc_.afc.rap.param.new_text("Odbiorca").bindexpr("k.strSkrot")
	pParamArray.add doc_.afc.rap.param.new_text("Numer katalogowy").bindexpr("r.strNorma")
	set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
%>
<tr>	
  <td align='left'>
		RXE_T_LINK_FORM_VCC(TYPEID_N5ZLECPROD,p_idobj,p_strnrdok)
	</td>
	<td align='left' width='min'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,pr_idobj,pr_produkt)
  </td>
  <td align='left' width='min'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5RECEPTA,r_idobj,r_strnorma)
	</td>
  <td align='right'>
		RXE_QUANTITY_CVV(c_curiloscopak,"",0)
	</td>
  <td align='left'>
		RXE_DATE(p_ddatawyst)
	</td>
  <td align='left' width='min'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,k_idobj,k_pklient)
  </td>
  <td align='left' width='min'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5ZAMOWIENIE,z_idobj,z_strnrdok)
  </td>
  <% 
   dim strSQL : strSQL = "select 'p_idobj'=p.idobj,'p_ddatawyst'=p.dDataWyst,'c_curiloscopak'=c.curIloscOpak " +_
                         "from n5dokmag as p " +_
                         "join collections on p.idobj=collections.idparent and collections.idcollection = 10162011 " +_
                         "join n5pozdokmag as c on c.idobj = collections.idobj " +_
                         "where wrefDokHandl = " + cstr(pRec("p_idobj")) + " and pRejestrDok = 22 "
   dim oRS : set oRS = trans_.createadors(strSQL)
  %> 
  <td align='left'>
    <%
     do while not oRS.EOF  
    %>			
  <t href='<%so.write rapeng_.href_open_form_proxy(TYPEID_N5DOKMAG,oRS("p_idobj"))%>'><![CDATA[<%so.write cstr(oRS("p_ddatawyst"))%>]]></t>
  <%
     oRS.MoveNext
     loop
    %>
	</td>
  <td align='right'>
    <%
     set oRS = trans_.createadors(strSQL)
     do while not oRS.EOF
    %>
    <t><![CDATA[<% so.write doc_.afc.display.quantity(oRS("c_curiloscopak"),"",0) %>]]></t><br></br>
    <%
     oRS.MoveNext
     loop
    %>
  </td>    
</tr><%
end function
%>
<%
