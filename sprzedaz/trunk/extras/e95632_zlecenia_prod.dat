  </td>
</tr>  
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
  <table border='1'>
    <thead>
      <tr>
        <td align='center' width='9666'>
          <text bold='true'><![CDATA[P-703]]></text>
        </td>
        <td align='center' width='9666'>
          <text bold='true'><![CDATA[Numer wydania: II]]></text>
        </td>
        <td align='center' width='9666'>
          <text bold='true'><![CDATA[F-3/P-703]]></text>
        </td>
      </tr>
    </thead>
