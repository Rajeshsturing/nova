    </td>
    <td width='2200' align='center' rowspan='2'>
      <text bold='true'><![CDATA[Ilość zlecona]]></text>
    </td>
    <td width='3200' align='center' rowspan='2'>
      <text bold='true'><![CDATA[Data wystawienia]]></text>
    </td>
    <td width='3200' align='center' rowspan='2'>
      <text bold='true'><![CDATA[Odbiorca]]></text>
    </td>
    <td width='3200' align='center' rowspan='2'>
      <text bold='true'><![CDATA[Nr zlecenia]]></text>
    </td>
    <td width='3200' align='center' colspan='2'>
      <text bold='true'><![CDATA[Zrealizowano]]></text>
    </td>
  </tr>
  <tr>
