<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_MAG_DOKUMENTY_MM_WG_PRACOW

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1231.h"
#include "h1250.h"

#define RAPORT_TITLE Rozliczenie MM wg pracowników

#macro RXE_T_LINK_FORM_VVV(_type_val_,_idobj_,_val_)	\
<t href='<%so.write rapeng_.href_open_form_proxy(_type_val_,_idobj_)%>'><![CDATA[<%so.write cstr(_val_)%>]]></t>

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%

function query()
	query = "select 'p_nazwisko_imie'=max(p.strNazwisko) + ' ' + max(p.strImie) + ' ' + max(p.strFax),'p_nrewid'=max(p.strFax),'pr_indeks'=max(pr.strIndeks), " + vbNewLine +_
	        "'pr_nazwa'=max(pr.strNazwa),'vl_ilosc'=sum(vl.c_curiloscopak),'op_skrot'=max(j.strSkrot),'op_prec'=max(j.nDokladnosc), " + vbNewLine +_
	        "'p_idobj'=max(p.idobj),'pr_idobj'=pr.idobj " + vbNewLine +_
	        "from vlist_n5dokmag_listPozycje vl " + vbNewLine +_
	        "inner join n5produkt pr on vl.c_pprodukt = pr. idobj " + vbNewLine +_
	        "inner join n5opakowanie_produktu op on vl.c_popak = op.idobj " + vbNewLine +_
	        "inner join n5jednostka j on op.pJednOpak = j.idobj " + vbNewLine +_
	        "inner join n5rejestrdok r on vl.p_prejestrdok = r.idobj " + vbNewLine +_
	        "inner join n5magazyn mz on vl.p_pmagzrod = mz.idobj " + vbNewLine +_
	        "inner join n5magazyn md on vl.p_pmagdocel = md.idobj " + vbNewLine +_
	        "inner join n5pracownik p on vl.c_curextra4 = (case when p.strFax = '' then 0 else cast(p.strFax as decimal(12,2)) end) " + vbNewLine +_
	        "where p.eAktywny <> N5PRACOWNIK_AKTYWNY_NIEAKTYWNY and vl.c_curextra4 <> 0 and %1 and %2 and %3 and %4 and %5 and %6 and %7 and %8 " + vbNewLine +_
	        "group by p.idobj,pr.idobj,op.idobj " + vbNewLine +_
	        "order by p_nazwisko_imie,pr_nazwa"
end function
%>
<%

function default_param()
	dim pParamArray: set pParamArray = doc_.afc.new_navoarray()
  pParamArray.add doc_.afc.rap.param.new_text("Indeks pracownika").bindexpr("p.prac_strIndeks")
  pParamArray.add doc_.afc.rap.param.new_text("Nazwisko pracownika").bindexpr("p.strNazwisko")
  pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("vl.p_ddatawyst")
	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn_ext("mz.IdObj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE","Magazyn wydania")
	pParamArray.add doc_.getmodule(43025).new_filtr_magazyn_ext("md.IdObj","N5TYPMAG_PODSTAWOWY,N5TYPMAG_ZWROTY,N5TYPMAG_PRODUKCJAWTOKU,N5TYPMAG_REZERWACJE","Magazyn przyjęcia")  
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("pr.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("pr.strNazwa")
  
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("r.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_,"select strNazwa, idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__MM) order by strNazwa"
	pParamArray.add pParam2  

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td style='27' colspan='5'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
    RXE_T_LINK_FORM_VVV(TYPEID_N5PRACOWNIK,clng(pRec("p_idobj").value),CStr(pRec("p_nazwisko_imie").value))
  </td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>

<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='5' />
</tr>
<tr fontsize='4'>
	<td style='27' colspan='4' />
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
</tr>
<tr border='0'><td colspan='5' /></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td align='right'>RXE_LP</td>
	<td>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRODUKT,pr_idobj,pr_indeks)
	</td>
	<td>
		RXE_TEXT(pr_nazwa)
	</td>
  <td align='right'>
    <t>
		RXF_QUANTITY_CCC(vl_ilosc,op_skrot,op_prec)
    </t>
	</td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='3000'>
		<text><![CDATA[Indeks produktu]]></text>
	</td>
	<td width='6000'>
		<text><![CDATA[Nazwa produktu]]></text>
	</td>
	<td width='2000'>
		<text><![CDATA[Ilość]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
  
<%
function body_footer(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'>
  <td colspan='5' />
</tr>
<tr fontsize='6'>
  <td style='27' colspan='4' />
  <td style='27' align='right'>
    RXE_MONEY_VAR(pSection.counter(0).result)
  </td>
</tr>
<tr border='0'>
  <td colspan='5' />
</tr>
</tbody>
</table>
<%
end function
%>
  
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("vl_ilosc")
  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("vl_ilosc")

if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then

  dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
  set pPerf = nothing

  rapeng_.write_actual_param so,rapeng_.get_raport_param()
  if not .perform then
  so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
 end if 
end if
end with
%>
</body>
<footer>
</footer>
</page>
