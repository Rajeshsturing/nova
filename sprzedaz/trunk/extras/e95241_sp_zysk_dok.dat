<?xml version="1.0" encoding="windows-1250" ?>
<!-- 16.02.2005 IG filtr na opiekuna klienta -->

<!--
RAPTEMPLATE_ZYSK_NA_SPRZEDAZY_DOK
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Rentowność sprzedaży - dokumenty



#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_klient.strIndeks
#define C_FIELD_SECOND_EXPR		t_klient.strNazwa
#else
#define C_FIELD_FIRST_EXPR		t_klient.strNazwa
#define C_FIELD_SECOND_EXPR		t_klient.strIndeks
#endif 

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
dim strFiltr : strFiltr = ""
#ifdef _CDNOLAWA 
  strFiltr = " where t_sprz.pRozlVAT<>0 and %2 and %3 and %4 and %7 and EXTRA_CUSTOMER_FILTER_AND(8) and %9 and %10 and %11 and %12 and %14 and " +_
             " %15 and %TYPPRO% and t_trans.IdObj in (select idobj from n5transakcja where %TYPTRANS% ) "
#else
  strFiltr = " where t_sprz.pRejestrDok not in (select IdObj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)) and t_sprz.pRozlVAT<>0 and %2 and %3 and %4 and %6 and EXTRA_CUSTOMER_FILTER_AND(7) and %8 and %9 and %10 and %11 and %TYPPRO% "
#endif

query = "select 'sp_nrdok'=max(t_sprz.strNrDok),'t_kontrah'=max(t_klient.strNazwa), " +_
	"'c_field_first'=max(C_FIELD_FIRST_EXPR),'c_field_second'=max(C_FIELD_SECOND_EXPR), "+_
	"'sp_idobj'=trs_pSprz, " +_
	"'c_ilsp'=sum(trs_curIloscOpakSP),'c_ilmag'=sum(trs_curIloscOpakMag)," +_
	"'sp_wartosc'=sum(trs_curWartSP),'dm_wartosc'=-sum(trs_curWartMag), " +_
	"'c_zysk'=sum(trs_curWartSP) + sum(trs_curWartMag), " +_
	"'c_marza'= case sum(trs_curWartSP) when 0 then 0 else 100.0 * (sum(trs_curWartSP)+sum(trs_curWartMag)) / sum(trs_curWartSP) end, " +_
	"'c_narzut'= case sum(trs_curWartMag) when 0 then 0 else 100.0 * (sum(trs_curWartSP)) / -sum(trs_curWartMag) - 100.0 end, " +_
	"'id_klient'=max(t_klient.IdObj),'prac_ded'= max(isnull(t_prac.strImie,'')) + ' ' + max(isnull(t_prac.strNazwisko,'')) " +_
	"from #tmp_rentowsp " +_
	" inner join n5sprzedaz as t_sprz on trs_pSprz = t_sprz.idobj " +_
  " inner join n5transakcja as t_trans on t_sprz.pTransakcja = t_trans.IdObj " +_
  " inner join n5uzytkownik as t_uzyt on t_sprz.pUzytRej = t_uzyt.IdObj " +_
	" inner join n5produkt as t_prod on trs_pProdukt = t_prod.idobj " +_
	" inner join n5klient as t_klient on t_sprz.pKlient = t_klient.IdObj "+_
	" left join n5pracownik as t_prac on  t_klient.pPracownik = t_prac.Idobj  "+_
	" left outer join n5pracownik as t_handl on t_sprz.sprzed_pHandlowiec = t_handl.idobj " +_
	" left outer join n5klient as t_dost on t_prod.prod_pDostawca = t_dost.idobj " +_
	" inner join n5grupaklient as t_grklient on t_klient.pGrupaKlient = t_grklient.IdObj "+_
	strFiltr +_
	" group by trs_pSprz " +_
#ifdef _ALMA_TREND
	" having %13 " +_  
	" order by max(t_sprz.dDataWyst)"
#else  
	" order by sp_nrdok"
#endif  
end function
%>
<%
function body_row(byref pSection,byref pRec)
dim bUzgod : bUzgod = (ccur(pRec("c_ilsp")) = ccur(pRec("c_ilmag")))
dim bZysk: bZysk = (ccur(pRec("c_zysk")) >= 0.0)

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'
<%
else
%>
<tr bordercolor='white' style='37'
<%
end if

if not bUzgod then
	so.write "italic='true'"
end if
%>
>
<td align='right'>RXE_LP</td>
	<td>
		RXE_T_LINK_FORM_VCC(TYPEID_N5SPRZEDAZ,sp_idobj,sp_nrdok)
	</td>
#ifdef _CDNOLAWA  
  <td width='6000'>
		RXE_TEXT(t_kontrah)
	</td>
#endif  
#ifdef _ALMA_TREND
  <td width='min'>
    RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,id_klient,c_field_second)
  </td>
  <td width='min'>
    RXE_TEXT(prac_ded)
  </td>  
#endif
	<td align='right'>
		RXE_QUANTITY_CVV(sp_wartosc,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(dm_wartosc,"",2)
	</td>
	<td align='right'
	<%
	if not bZysk then
		so.write "forecolor='red'"
	end if
	%>
	>
		RXE_QUANTITY_CVV(c_zysk,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_marza,"%",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_narzut,"%",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
#ifdef _CDNOLAWA  
  <td width='max'>
    <text><![CDATA[Klient]]></text>
  </td>
#endif  
#ifdef _ALMA_TREND
  <td width='min'>
    <text><![CDATA[Indeks klienta]]></text>
  </td>
  <td width='min'>
    <text><![CDATA[Pracownik dedykowany]]></text>
  </td>  
#endif
	<td width='min'>
#ifdef _IOW
    <text><![CDATA[Wartość sprzedaży PLN]]></text>
#else
		<text><![CDATA[Wartość sprzedaży]]></text>
#endif    
	</td>
	<td width='min'>
#ifdef _RAND
		<text><![CDATA[Cena hurtowa nr.4]]></text>
#else
		<text><![CDATA[Wartość zakupu]]></text>
#endif
	</td>
	<td width='min'>
#ifdef _IOW
    <text><![CDATA[Zysk PLN]]></text>
#else
		<text><![CDATA[Zysk]]></text>
#endif
	</td>
	<td width='min'>
		<text><![CDATA[Marża]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Narzut]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
#ifdef _CDNOLAWA
  <td style='27' colspan='3' />
#else
#ifdef _ALMA_TREND
  <td style='27' colspan='4' />
#else
  <td style='27' colspan='2' />
#endif  
#endif  
	<td style='27' align='right'>
#ifdef _IOW
    <t><%so.write doc_.afc.display.money(pRapExec.body.counter(0).result,"PLN")%></t>
#else
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
#endif	
  </td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
#ifdef _IOW
    <t><%so.write doc_.afc.display.money(pRapExec.body.counter(2).result,"PLN")%></t>
#else
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
#endif
	</td>
	<td style='27' align='right'
		<%
			dim curSrMarza
			if pRapExec.body.counter(0).result <> 0.0 then
				curSrMarza =  ccur(pRapExec.body.counter(2).result * 100 / pRapExec.body.counter(0).result)
			else
				curSrMarza = 0.0
			end if
		%>
		>
		RXE_QUANTITY_VVV(curSrMarza,"%",2)
	</td>
	<td style='27' />
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pM60233 : set pM60233 = doc_.getmodule(60233)
dim pRentSP : set prentsp = pM60233.new_rent_sp()

  dim strIdRokKsieg: strIdRokKsieg = ""
#ifdef _ALMA_TREND
	strIdRokKsieg = doc_.getmodule(60106).GetIdRokKsieg()
#endif 

dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = pRentSP.get_okres_param()

pParamArray.add pParamOkres
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " + strIdRokKsieg + " " +_
#ifdef _IOW
		"and strNazwa not like 'Faktury VAT Fundusz Reprezentacyjny' " +_
#endif		
#ifdef _MILOMLYN
		"and eAktywny = N5REJESTRDOK_AKTYWNY " +_
#endif
		"order by strNazwa "
	pParamArray.add pParam2

	
pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_klient.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_klient.strIndeks")

	dim pParamTypPro : set pParamTypPro = doc_.afc.rap.param.new_choice("Typ produktu")
	with pParamTypPro
		.multiple = true

		.names.add "Materiał"
		.values.add 1
		.selected.add True

		.names.add "Wyrób"
		.values.add 2
		.selected.add True

		.names.add "Półprodukt"
		.values.add 3
		.selected.add True

		.names.add "Towar"
		.values.add 4
		.selected.add True

	end with
	pParamArray.add pParamTypPro 'dodanie zakladnki "Typ produktu" 
  
#ifdef _CDNOLAWA  
  dim pParamTypTrans : set pParamTypTrans = doc_.afc.rap.param.new_choice("Transakcja")
  with pParamTypTrans
	  .multiple = false
    .names.add "Rozliczone"
    .values.add 1
    .selected.add false
    .names.add "Nierozliczone"
    .values.add 2
    .selected.add false 
    .names.add "Wszystkie"
    .values.add 3
    .selected.add true    
  end with  
  pParamArray.add pParamTypTrans  
#endif  
	
pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_grklient.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("t_prac.strNazwisko")
pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(t_handl.strNazwisko,'')")
	
EXTRA_CUSTOMER_FILTER_PARAM(t_klient)

pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("isnull(t_dost.strNazwa,'')")
pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("isnull(t_dost.strIndeks,'')")

dim pGrupaParam:set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam

#ifdef _CDNOLAWA
  pParamArray.add doc_.afc.rap.param.new_text("Nazwa użytkownika").bindexpr("isnull(t_uzyt.strNazwa,'')")
  pParamArray.add doc_.afc.rap.param.new_text("Uwagi z FVAT").bindexpr("isnull(t_sprz.strUwagi,'')")
#endif

#ifdef _ALMA_TREND
  pParamArray.add doc_.afc.rap.param.new_currency("Wartość marży").bindexpr("%MARZA%")
#endif

if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("c_zysk")

if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
		pRentSP.fill_dok_mag_related
#ifdef _ALMA_TREND  
		pRentSP.fill_dok_mag_ZZ
		pRentSP.fill_dok_mag_not_related
#endif
'		pRentSP.fill_dok_mag_unrelated rapeng_.get_raport_param().value(0)
	set pPerf = nothing

	.ReplaceQueryParam "t_prac.strNazwisko is not null", "1=1"
	
	dim strTypPro
		
		dim strTypPro1 : strTypPro1 = "(t_prod.eRodzaj=1 and t_prod.prod_cWyrob='0' and t_prod.prod_cSurowiec='1')" 
		dim strTypPro2 : strTypPro2 = "(t_prod.eRodzaj=1 and t_prod.prod_cWyrob='1' and t_prod.prod_cSurowiec='0')"
		dim strTypPro3 : strTypPro3 = "(t_prod.eRodzaj=1 and t_prod.prod_cWyrob='1' and t_prod.prod_cSurowiec='1')"
		dim strTypPro4 : strTypPro4 = "(t_prod.eRodzaj=1 and t_prod.prod_cWyrob='0' and t_prod.prod_cSurowiec='0')"
		strTypPro = "((1=2)"
		
	if pParamTypPro.selected.value(0) then		
			strTypPro = strTypPro +" or "+ strTypPro1
		end if
	if pParamTypPro.selected.value(1) then	
			strTypPro = strTypPro +" or "+ strTypPro2
		end if
	if pParamTypPro.selected.value(2) then
			strTypPro = strTypPro +" or "+ strTypPro3
		end if		
	if pParamTypPro.selected.value(3) then
			strTypPro = strTypPro +" or "+ strTypPro4
		end if
	if pParamTypPro.selected.value(4) then
			strTypPro = strTypPro +" and "+"(t_prod.eRodzaj<>1)"
		end if
	strTypPro = strTypPro + ")"
		.ReplaceQueryParam "%TYPPRO%",strTypPro
    
#ifdef _CDNOLAWA
  dim strTypTrans : strTypTrans = ""
  if pParamTypTrans.selected.value(0) then
    strTypTrans = strTypTrans + " curWn <= curMa "
  elseif pParamTypTrans.selected.value(1) then
    strTypTrans = strTypTrans + " curWn > curMa "
  else
    strTypTrans = strTypTrans + " 1=1 " 
  end if
  .ReplaceQueryParam "%TYPTRANS%",strTypTrans
#endif

#ifdef _ALMA_TREND
  .ReplaceQueryParam "%MARZA% is not null","1=1"
  .ReplaceQueryParam "%MARZA%","(case sum(trs_curWartSP) when 0 then 0 else 100.0 * (sum(trs_curWartSP)+sum(trs_curWartMag)) / sum(trs_curWartSP) end)"  
#endif

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
