<?xml version="1.0" encoding="windows-1250" ?>

<!--
RAPTEMPLATE_RENT_WG_PRACOWNIKA_DEDYK

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"


#define RAPORT_TITLE Rentowność klientów wg handlowców

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'prac_ded'= case when max(prac.IdObj) is null then '<brak>' else max(isnull(prac.strImie,'')) + ' ' + max(isnull(prac.strNazwisko,'')) end, " + vbNewLine +_
	"'klient_nazwa'=max(klient.strNazwa),'miejscowosc'=max(m.strNazwa),'id_klient'=max(klient.IdObj), " + vbNewLine +_
	"'sp_wartosc'=sum(trs_curWartSP),'dm_wartosc'=-sum(trs_curWartMag), " + vbNewLine +_ 
	"'zysk'=sum(trs_curWartSP) + sum(trs_curWartMag), 'marza'= case sum(trs_curWartSP) when 0 then " + vbNewLine +_ 
	"0 else 100.0 * (sum(trs_curWartSP)+sum(trs_curWartMag)) / sum(trs_curWartSP) end, " + vbNewLine +_
	"'narzut'= case sum(trs_curWartMag) when 0 then 0 else 100.0 * (sum(trs_curWartSP)) / -sum(trs_curWartMag) - 100.0 end " + vbNewLine +_
	"from #tmp_rentowsp " + vbNewLine +_
	"inner join n5sprzedaz as sprz on trs_pSprz = sprz.idobj " + vbNewLine +_
	"inner join n5uzytkownik as uzyt on sprz.pUzytRej = uzyt.IdObj " + vbNewLine +_
	"inner join n5produkt as prod on trs_pProdukt = prod.idobj " + vbNewLine +_
	"inner join n5klient as klient on sprz.pKlient = klient.IdObj " + vbNewLine +_
	"inner join n5miejscowosc as m on klient.pMiejscowosc = m.IdObj " + vbNewLine +_
	"left join n5pracownik as prac on  klient.pPracownik = prac.Idobj " + vbNewLine +_
	"left outer join n5pracownik as handl on sprz.sprzed_pHandlowiec = handl.idobj " + vbNewLine +_
	"left outer join n5klient as dost on prod.prod_pDostawca = dost.idobj " + vbNewLine +_
	"inner join n5grupaklient as grklient on klient.pGrupaKlient = grklient.IdObj " + vbNewLine +_
	"where sprz.pRejestrDok not in (select IdObj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)) and " + vbNewLine +_
	"sprz.pRozlVAT <> 0 and %2 and %3 and %4 and %6 and EXTRA_CUSTOMER_FILTER_AND(7) and %8 and %9 and %10 and %11 and %TYPPRO% " + vbNewLine +_
	"group by klient.IdObj " + vbNewLine +_
	"order by prac_ded,klient_nazwa"
end function
%>

<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
<td style='27' colspan='11'>
	<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(prac_ded)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
<tr fontsize='5'>
	<td style='27' colspan='3' /> 
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pSection.counter(2).result)
	</td>
	<td style='27' align='right'
		<%
			dim curSrMarza
			if pSection.counter(0).result <> 0.0 then
				curSrMarza =  ccur(pSection.counter(2).result * 100 / pSection.counter(0).result)
			else
				curSrMarza = 0.0
			end if
		%>
		>
		RXE_QUANTITY_VVV(curSrMarza,"%",2)
	</td>
	<td style='27' />
</tr>
<tr border='0'><td colspan='11' /></tr>
<%
end function
%>

<%
function body_row(byref pSection,byref pRec)
dim bZysk: bZysk = (ccur(pRec("zysk")) >= 0.0)

if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'
<%
else
%>
<tr bordercolor='white' style='37'
<%
end if
%>
>
<td align='right'>RXE_LP</td>
	<td>
		RXE_TEXT_LINK_FORM_VCC(TYPEID_N5KLIENT,id_klient,klient_nazwa)
	</td>
	<td>
		RXE_TEXT(miejscowosc)
	</td>	
	<td align='right'>
		RXE_QUANTITY_CVV(sp_wartosc,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(dm_wartosc,"",2)
	</td>
	<td align='right'
	<%
	if not bZysk then
		so.write "forecolor='red'"
	end if
	%>
	>
		RXE_QUANTITY_CVV(zysk,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(marza,"%",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(narzut,"%",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Nazwa klienta]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Miejscowość]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Wartość sprzedaży]]></text>   
	</td>
	<td width='min'>
		<text><![CDATA[Wartość zakupu]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Zysk]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Marża]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Narzut]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
	<td style='27' colspan='3' /> 
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' align='right'
		<%
			dim curSrMarza
			if pRapExec.body.counter(0).result <> 0.0 then
				curSrMarza =  ccur(pRapExec.body.counter(2).result * 100 / pRapExec.body.counter(0).result)
			else
				curSrMarza = 0.0
			end if
		%>
		>
		RXE_QUANTITY_VVV(curSrMarza,"%",2)
	</td>
	<td style='27' />
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
dim pM60233 : set pM60233 = doc_.getmodule(60233)
dim pRentSP : set prentsp = pM60233.new_rent_sp()

dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
dim pParamOkres : set pParamOkres = pRentSP.get_okres_param()

	pParamArray.add pParamOkres
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("sprz.pRejestrDok")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_KOR_FAKT_SP, " +_
		"N5REJESTRDOK_RACH,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_KOR_PARAGON, " +_
		"N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_KOREKTA_WDT, " +_
		"N5REJESTRDOK_WDT,N5REJESTRDOK_WNT,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR) " +_		
		"order by strNazwa "
	pParamArray.add pParam2

	
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("klient.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("klient.strIndeks")

	dim pParamTypPro : set pParamTypPro = doc_.afc.rap.param.new_choice("Typ produktu")
	with pParamTypPro
		.multiple = true

		.names.add "Materiał"
		.values.add 1
		.selected.add True

		.names.add "Wyrób"
		.values.add 2
		.selected.add True

		.names.add "Półprodukt"
		.values.add 3
		.selected.add True

		.names.add "Towar"
		.values.add 4
		.selected.add True

	end with
	pParamArray.add pParamTypPro 'dodanie zakladnki "Typ produktu" 
	
pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("grklient.strNazwa")
pParamArray.add doc_.afc.rap.param.new_text("Pracownik dedykowany").bindexpr("prac.strNazwisko")
pParamArray.add doc_.afc.rap.param.new_text("Handlowiec").bindexpr("isnull(handl.strNazwisko,'')")
	
EXTRA_CUSTOMER_FILTER_PARAM(klient)

pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("isnull(dost.strNazwa,'')")
pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("isnull(dost.strIndeks,'')")

dim pGrupaParam:set pGrupaParam = doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("strNazwa")
	pParamArray.add pGrupaParam

if not doc_.getmodule(60253).gm_ensure_accuracy_ui(true) then
%>
<p border='1' fontsize='5' forecolor='red' bold='true'><t>Uwaga! Niepoprawny stan magazynu</t></p><br/><br/>
<%
end if
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%

dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("zysk")
	.add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("sp_wartosc").add_sumator("dm_wartosc").add_sumator("zysk")

if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then
%>
<%
	dim pPerf : set pPerf = doc_.performing("Trwa przygotowywanie wyników...")
		pRentSP.fill_dok_handl rapeng_.get_raport_param().value(0)
		pRentSP.fill_dok_mag_related
	set pPerf = nothing

	.ReplaceQueryParam "prac.strNazwisko is not null", "1=1"
	
	dim strTypPro
		
		dim strTypPro1 : strTypPro1 = "(prod.eRodzaj=1 and prod.prod_cWyrob='0' and prod.prod_cSurowiec='1')" 
		dim strTypPro2 : strTypPro2 = "(prod.eRodzaj=1 and prod.prod_cWyrob='1' and prod.prod_cSurowiec='0')"
		dim strTypPro3 : strTypPro3 = "(prod.eRodzaj=1 and prod.prod_cWyrob='1' and prod.prod_cSurowiec='1')"
		dim strTypPro4 : strTypPro4 = "(prod.eRodzaj=1 and prod.prod_cWyrob='0' and prod.prod_cSurowiec='0')"
		strTypPro = "((1=2)"
		
	if pParamTypPro.selected.value(0) then		
			strTypPro = strTypPro +" or "+ strTypPro1
		end if
	if pParamTypPro.selected.value(1) then	
			strTypPro = strTypPro +" or "+ strTypPro2
		end if
	if pParamTypPro.selected.value(2) then
			strTypPro = strTypPro +" or "+ strTypPro3
		end if		
	if pParamTypPro.selected.value(3) then
			strTypPro = strTypPro +" or "+ strTypPro4
		end if
	if pParamTypPro.selected.value(4) then
			strTypPro = strTypPro +" and "+"(prod.eRodzaj<>1)"
		end if
	strTypPro = strTypPro + ")"
		.ReplaceQueryParam "%TYPPRO%",strTypPro

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
pRentSP.manual_done()
set pRentSP = nothing
set pM60233 = nothing
%>
</body>
<footer>
</footer>
</page>
