							</td>
						</tr>
						<%
							iter = iter + 1	
							end if						
						next
						for iter_puste = iter to 10
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[]]></text><t>&nbsp;</t><text><![CDATA[]]></text>
							</td>
							<td>
								<text><![CDATA[]]></text><t>&nbsp;</t><text><![CDATA[]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
						next
						%>
						
					</tbody>

					<tfoot>	
