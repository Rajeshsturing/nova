							</td>
							<td align='right' width='min'>
								<t><![CDATA[<% so.write MONEY(suma_czesc_netto) %>]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[<% so.write MONEY(suma_czesc_brutto) %>]]></t>
							</td>
						</tr>
					</tfoot>	
					
				</table>
			</td>
		</tr>	


		ROW_SEPARATOR(1)		

	</tbody>
</table>

