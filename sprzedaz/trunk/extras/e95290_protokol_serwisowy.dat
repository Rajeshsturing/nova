		<tr>
			<td>
				<%
				dim iter : iter = 1 
				dim pozycja
				dim suma_czynnosc_netto
				dim suma_czynnosc_brutto				
				dim suma_czesc_netto
				dim suma_czesc_brutto
				%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<t size='30'>Czynność</t>
							</td>							
							<td align='right'>
								<t>Jedn. miary</t>
							</td>
							<td align='right'>
								<t>Szt.</t>
							</td>
							<td align='right' width='min'>
								<t>Wart netto</t>
							</td>
							<td align='right' width='min'>
								<t>Wart brutto</t>
							</td>							
						</tr>
					</thead>
					<tbody>
						<% 
						for each pozycja in root_.listPozycje 
						if pozycja.pProdukt.eRodzaj <> 1 then
						suma_czynnosc_netto = suma_czynnosc_netto + pozycja.curWartNetto
						suma_czynnosc_brutto = suma_czynnosc_brutto + pozycja.curWartBrutto
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TOWAR]]></text><t>&nbsp;</t><text><![CDATA[POZ_OPAKOWANIE]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_JM]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_ILOSC]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[POZ_WARTOSC_NETTO]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[POZ_WARTOSC_BRUTTO]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1	
							end if						
						next
						dim iter_puste
						for iter_puste = iter to 5
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[]]></text><t>&nbsp;</t>
							</td>
							<td align='right'>
								<t><![CDATA[Szt.]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[1]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
						next
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[Szkolenie obsługi]]></text><t>&nbsp;</t>
							</td>
							<td align='right'>
								<t><![CDATA[Szt.]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[1]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1							
						%>

						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[Instrukcja obsługi urządzenia]]></text><t>&nbsp;</t>
							</td>
							<td align='right'>
								<t><![CDATA[Szt.]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[1]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1							
						%>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[Karta gwarancyjna]]></text><t>&nbsp;</t>
							</td>
							<td align='right'>
								<t><![CDATA[Szt.]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[1]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[----------------]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1							
						%>

					</tbody>

					<tfoot>	
						<tr backcolor='#E0E0E0'>
							<td colspan='4' align='right'>
								<text>RAZEM</text>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[<% so.write MONEY(suma_czynnosc_netto) %>]]></t>
							</td>
							<td align='right' width='min'>
								<t><![CDATA[<% so.write MONEY(suma_czynnosc_brutto) %>]]></t>
							</td>							
						</tr>
					</tfoot>	
					
				</table>
			</td>
		</tr>
		
		
		
		ROW_SEPARATOR(1)

	</tbody>
</table>

<t>&nbsp;</t><br/><ff/>
	
<table>
<tbody>		

		<tr>
			<td>
				<!-- nagłówek -->
