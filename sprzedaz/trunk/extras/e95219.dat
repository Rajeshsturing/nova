<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Indywidualna lista płac
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()
query = "select 'c_prac_id'=vl_dekr.p_pPracownik,'c_nal_id'=vl_dekr.p_idobj,'c_prac_naz'=max(t_prac.strNazwisko + ' ' + t_prac.strImie), " +_
"'c_subk'=max(t_subk.strnazwa),'c_wn'=sum(vl_dekr.c_curKwota),'c_nal_data_od'=max(vl_dekr.p_dDataOd),'c_nal_data_do'=max(vl_dekr.p_dDataDo) " +_
"from vlist_n5plnaliczenie_listDekret vl_dekr " +_
"inner join n5plsubkonto t_subk on vl_dekr.c_pSubKonto = t_subk.idobj " +_
"inner join n5pracownik t_prac on vl_dekr.p_pPracownik = t_prac.idobj " +_
"inner join n5pllistaplac t_listaplac on vl_dekr.p_pListaPlac = t_listaplac.idobj " +_
"inner join vlist_choicelist_listElement vlist on t_subk.idobj = vlist.c_idelement and  " +_
"vlist.p_ntypeid = TYPEID_N5PLSUBKONTO " +_
"where  %1  and  %2  and  %3 and %4 " +_
"group by vl_dekr.p_pPracownik,vlist.coll_lp,vl_dekr.p_idobj " +_
"order by c_prac_naz,c_nal_id,vlist.coll_lp"

end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwisko").bindexpr("t_prac.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa").bindexpr("t_listaplac.strNrDok")
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin naliczenia").bindexpr("vl_dekr.c_dDataNal")

	'parametr lista wyboru
	dim pParam : set pParam = doc_.afc.rap.param.new_choice("Widok").bindexpr("vlist.p_idobj")
	doc_.afc.rap.param.init_on_query  pParam , trans_ ,  "select strNazwa,IdObj from choicelist where nTypeId=TYPEID_N5PLSUBKONTO order by strNazwa"
	pParam.multiple = false
	pParamArray.add pParam

	set default_param = pParamArray
end function
%>
<%
function write_actual_param(byref pActualParam)
dim iter
dim bAnyWritten : bAnyWritten = false
if not pActualParam is nothing then
for iter = 0 to pActualParam.upperIndex
if pActualParam.value(iter).get_desc() <> "" then 
bAnyWritten = true
	so.write "<t size='5' /><text fontsize='4'><![CD"+"ATA[" + pActualParam.value(iter).get_desc() + "]"+"]></text><br/>"
end if
next
end if
if not bAnyWritten then 
	so.write "<t fontsize='4'>brak</t><br/>"
end if
	so.write "<br/>"
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='5'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(TYPEID_N5PRACOWNIK,c_prac_id,c_prac_naz)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='5' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='4'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_DATE(c_nal_data_od)
	<t>-</t>
	RXE_DATE(c_nal_data_do)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='5' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTO_TEXT(c_subk)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_wn,"",2)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
'so.write "<p backcolor='yellow'><text><![CD"+"ATA["+pRapExec.get_final_query() + "]"+"]></text></p><br/>" 
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Składnik]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)	
</p>
<br/><br/>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 1,getref("section_header_2"),getref("section_footer_2")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	write_actual_param rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
