<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_INFO_DOSTAWCA

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Informacja o dostawcy

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[

<%
function query()
query = "select 'd_indeks'=d.strIndeks,'d_type'=TYPEID_N5KLIENT,'d_idobj'=d.idobj,'d_nip'=d.strNIP,'d_nazwa'=d.strNazwa, " + vbNewLine +_
        "'d_klas'=d.strCecha1,'d_wielkosc'=d.strCecha3, " + vbNewLine +_
        "'d_ter_skonta'=d.kli_iTerminSkonta,'d_wart_skonta'=d.kli_curWartSkonta,'d_lim_kred'=d.curLimitKred, " + vbNewLine +_
        "'d_min_zam'=d.kli_curMinWartZam,'d_min_zam_opis'=d.kli_strOpisZam,'d_czas_real'=d.kli_strCzasRealZam, " + vbNewLine +_
        "'d_war_dost'=d.kli_strDostawa,'d_bonusy'=d.kli_strBonusy, " + vbNewLine +_
        "'d_umowa'=case when d.kli_cUmowa = '1' then 'Tak' else case when d.kli_cUmowa = '2' then 'Nie' else '' end end, " + vbNewLine +_
        "'d_cennik'=case when d.kli_cCennik = '1' then 'Tak' else case when d.kli_cCennik = '2' then 'Nie' else '' end end, " + vbNewLine +_
        "'d_data_akt'=d.kli_dDataKart,'p_imie'=isnull(p.strImie,''),'p_nazw'=isnull(p.strNazwisko,''), " + vbNewLine +_
        "'sp_nazwa'=isnull(sp.strNazwa,''),'gp_nazwa'=isnull(gp.strNazwa,'') " + vbNewLine +_
        "from n5klient d " + vbNewLine +_
        "	inner join n5grupaklient gd on d.pGrupaKlient = gd.idobj " + vbNewLine +_
        "	left join n5pracownik p on d.pPracownik = p.idobj " + vbNewLine +_
        "	left join n5sposplat sp on d.pSposobPlatnosci = sp.idobj " + vbNewLine +_
        "	left join n5grupaproduktow gp on d.kli_pGrupaProd = gp.idobj " + vbNewLine +_
        "where d.strIndeks like 'D%' and %1 and %2 and %3 and %4 and %5 and %6 and %7 " + vbNewLine +_
        "order by d_indeks, d_nazwa"
end function
%>

<%
function body_row(byref pSection,byref pRec)           
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
  <td align='right'>RXE_LP</td>
  <td>
    RXE_AUTOTEXT_LINK_FORM_CCC(d_type,d_idobj,d_indeks)
  </td> 
  <td>
    RXE_TEXT(d_nip)
  </td>  
  <td>
    RXE_TEXT(d_nazwa)
  </td>  
  <td>
    <text><![CDATA[<%so.write cstr(pRec("p_imie") + " " + pRec("p_nazw"))%>]]></text>
  </td>	  
  <td>
    RXE_TEXT(sp_nazwa)
  </td>    
  <td>
    RXE_TEXT(d_klas)
  </td> 
  <td>
    RXE_TEXT(d_wielkosc)
  </td>
  <td align='right'>
    RXE_QUANTITY_CVV(d_ter_skonta,"",0)
  </td>   
  <td align='right'>
    RXE_QUANTITY_CVV(d_wart_skonta,"",2)
  </td>
  <td align='right'>
    RXE_QUANTITY_CVV(d_lim_kred,"",2)
  </td>  
  <td align='right'>
    RXE_QUANTITY_CVV(d_min_zam,"",2)
  </td>   
  <td>
    RXE_TEXT(d_czas_real)
  </td>
  <td>
    RXE_TEXT(d_war_dost)
  </td>
  <td>
    RXE_TEXT(d_bonusy)
  </td>
  <td>
    RXE_TEXT(gp_nazwa)
  </td>
  <td>
    RXE_TEXT(d_umowa)
  </td>
  <td>
    RXE_TEXT(d_cennik)
  </td>
  <td>
    RXE_DATE(d_data_akt)
  </td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='min'>
		<text><![CDATA[Indeks]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[NIP]]></text>
	</td>
	<td width='3000'>
		<text><![CDATA[Nazwa dostawcy]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Osoba obsługująca]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Sposób platności]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Klasyfikacja]]></text>
	</td>	
	<td width='min'>
		<text><![CDATA[Wielkość dostawcy]]></text>
	</td>	  
	<td width='1500'>
		<text><![CDATA[Termin skonta]]></text>
	</td>  
	<td width='2000'>
		<text><![CDATA[Wartość skonta]]></text>
	</td>    
	<td width='min'>
		<text><![CDATA[Limit kredytowy]]></text>
	</td>
	<td width='3000'>
		<text><![CDATA[Min. wartość zamówienia]]></text>
	</td>	  
	<td width='3000'>
		<text><![CDATA[Czas real. zamówienia]]></text>
	</td>	  
	<td width='3000'>
		<text><![CDATA[Warunki dostawy]]></text>
	</td>  
	<td width='3000'>
		<text><![CDATA[Bonusy]]></text>
	</td>    
	<td width='min'>
		<text><![CDATA[Grupa produktów]]></text>
	</td> 
	<td width='min'>
		<text><![CDATA[Umowa]]></text>
	</td>   
	<td width='min'>
		<text><![CDATA[Cennik]]></text>
	</td>   
	<td width='min'>
		<text><![CDATA[Data aktualizacji kartoteki]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<%
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Indeks dostawcy").bindexpr("d.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa dostawcy").bindexpr("d.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Osoba obsługująca").bindexpr("p.strNazwisko")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("isnull(gp.strNazwa,'')")
	pParamArray.add doc_.afc.rap.param.new_text("Klasyfikacja dostawcy").bindexpr("d.strCecha1")
	pParamArray.add doc_.afc.rap.param.new_text("Wielkość dostawcy").bindexpr("d.strCecha3")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa dostawców").bindexpr("gd.strNazwa")
%>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>

<%  
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")

if .prepare("RAPORT_TITLE",pParamArray,rapeng_.get_raport_param(),query()) then

	.ReplaceQueryParam "p.strNazwisko is not null", "1=1"

	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
