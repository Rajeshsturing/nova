<?xml version="1.0" encoding="windows-1250" ?>


<!-- Nota odsetkowa -->

<!-- 2.12.2004 adresy poprawki -->


#macro MONEY(_value_)					doc_.afc.display.money(_value_,"")
#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
#define MIEJSCOWOSC_DATA				<% so.write util_.Firma_Miasto%>

<!-- Dane sprzedawcy -->
#define FIRMA_NAZWA						<% so.write util_.Firma_Nazwa %>
#define FIRMA_ULICA_NUMER				<% so.write util_.Firma_Ulica %>
#define FIRMA_KOD_MIASTO				<% if util_.Firma.strPoczta="" then so.write util_.Firma_Kod_Miasto else if util_.Firma.strPoczta<>"" and util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma.strKod + " " + util_.Firma.strPoczta else if util_.Firma.strPoczta=util_.Firma.pMiejscowosc.strNazwa then so.write util_.Firma_Kod_Miasto end if end if%>
#define FIRMA_NIP						<% so.write util_.Firma_NIP %>
#define FIRMA_RACHUNEK_BANKOWY_BANK		<% so.write util_.Firma_Bank %>
#define FIRMA_RACHUNEK_BANKOWY_NUMER	<% so.write util_.Firma_Bank_Numer %>
#define FIRMA_MIASTO					<% so.write util_.Firma.pMiejscowosc.strNazwa %>


<!-- Dane nabywcy -->
#define KLIENT_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient) %>
#define KLIENT_NIP						<% so.write util_.Klient_NIP(root_.pKlient) %>
#define KLIENT_KOD_MIASTO				<% if root_.pKlient.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient) else if root_.pKlient.strPoczta<>"" and  root_.pKlient.strPoczta<>root_.pKlient.pMiejscowosc.strNazwa then so.write root_.pKlient.strKod + " " + root_.pKlient.strPoczta else if  root_.pKlient.strPoczta=root_.pKlient.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient) end if end if end if%>
#define KLIENT_ULICA_NUMER				<% so.write util_.Klient_Ulica(root_.pKlient) %>
#define KLIENT_MIASTO					<% so.write root_.pKlient.pMiejscowosc.strNazwa %>

#define KLIENT_JO_NAZWA					<% so.write util_.Klient_Nazwa(root_.pKlient_JO) %>
#define KLIENT_JO_KOD_MIASTO			<% if root_.pKlient_JO.strPoczta="" then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) else if root_.pKlient_JO.strPoczta<>"" and  root_.pKlient_JO.strPoczta<>root_.pKlient_JO.pMiejscowosc.strNazwa then so.write root_.pKlient_JO.strKod + " " + root_.pKlient_JO.strPoczta else if  root_.pKlient_JO.strPoczta=root_.pKlient_JO.pMiejscowosc.strNazwa then so.write util_.Klient_Kod_Miasto(root_.pKlient_JO) end if end if end if%>
#define KLIENT_JO_ULICA_NUMER			<% so.write util_.Klient_Ulica(root_.pKlient_JO) %>
#define KLIENT_JO_MIASTO				<% so.write root_.pKlient_JO.pMiejscowosc.strNazwa %>



#define DOKUMENT_NUMER					<% so.write root_.text %>
#define DOKUMENT_UWAGI					<% so.write root_.strUwagi %>
#define DOKUMENT_UZYTKOWNIK_REJESTRUJACY	<% so.write root_.pUzytRej.text%>


<!-- pozycje faktury -->
#define POZ_LP							<% so.write cstr(iter) %>
#define POZ_DATA						<% so.write doc_.afc.display.fulldate(pozycja.dDataZaplaty) %>
#define POZ_TRANSAKCJA					<% so.write pozycja.pTransakcja.strSymTrans %>
#define POZ_STAWKA						<% so.write doc_.afc.display.quantity(pozycja.curStawka,"%",2) %>
#define POZ_KWOTA_ZAL					<% so.write MONEY(pozycja.curKwotaZal) %>
#define POZ_LICZBA_DNI					<% so.write doc_.afc.display.quantity(ccur(pozycja.nLiczbaDni),"",0) %>
#define POZ_KWOTA_ODSETEK				<% so.write MONEY(pozycja.curKwotaOds) %>



#define DOKUMENT_DATA_WYSTAWIENIA		<% so.write doc_.afc.display.fulldate(root_.dDataWyst) %>



<!-- podsumowanie pozycji -->
#define DOKUMENT_SUMA					<% so.write MONEY(root_.curSumaOds) %>



<page style='36' margins='700,700,700,700'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
<script><![CDATA[ 
#include "h1250.h"
VB_PRINT_DPC
VB_PRINTPREV_DPC 
]]></script>
</config>
<header>
</header>
<body>
<!-- całość -->
<table>
	<tbody>
		<tr>
			<td>
				<!-- nagłówek -->
				<table >
					<tbody>
						
						<tr>
							<td>
								<!-- miejsce na logo -->
							</td>							
							<td>
							</td>
							<td align='right'>
								<t><![CDATA[MIEJSCOWOSC_DATA DOKUMENT_DATA_WYSTAWIENIA]]></t>
							</td>
						</tr>


						<!-- Nagłówek faktury -->
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='8'><![CDATA[Nota odsetkowa]]></t>
							</td>
						</tr>
						<tr>
							<td colspan='3' align='center'>
								<t bold='true' fontsize='6'><![CDATA[DOKUMENT_NUMER]]></t>
							</td>
						</tr>


						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)						
						
						<!-- Dane sprzedawcy - FIRMA -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Nadawca:</t>
							</td>							
							<td>
								<text><![CDATA[FIRMA_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_ULICA_NUMER]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_KOD_MIASTO]]></t>
							</td>
							<td>
							</td>							
						</tr>
						<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[FIRMA_MIASTO]]></t>
							</td>
							<td>
							</td>					
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<t><![CDATA[FIRMA_NIP]]></t>
							</td>
							<td>
							</td>							
						</tr>

						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Rach. bankowy:</t>
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_BANK]]></t>
							</td>
							<td>
							</td>
						</tr>
						<tr>
							<td width='min'>								
							</td>																					
							<td>
								<t><![CDATA[FIRMA_RACHUNEK_BANKOWY_NUMER]]></t>
							</td>
							<td>
							</td>
						</tr>

							
						ROW_SEPARATOR(3)
						ROW_SEPARATOR(3)



						<!-- Dane nabywcy - KLIENT -->
						<tr>
							<td width='min'>
								<t bold='true' fontsize='5' size='16'>Płatnik:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NAZWA]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>Adres:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_ULICA_NUMER]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<text><![CDATA[KLIENT_KOD_MIASTO]]></text>
							</td>
							<td>
							</td>							
						</tr>
						<% if (root_.pKlient.strPoczta<>"") and (root_.pKlient.pMiejscowosc.strNazwa <> root_.pKlient.strPoczta) then %>
						<tr>
							<td width='min'>								
							</td>							
							<td>
								<t><![CDATA[KLIENT_MIASTO]]></t>
							</td>					
							<td>
							</td>
						</tr>
						<% end if %>							
						
						<tr>
							<td width='min'>
								<t size='3'/><t bold='true'>NIP:</t>
							</td>							
							<td>
								<text><![CDATA[KLIENT_NIP]]></text>
							</td>
							<td>
							</td>							
						</tr>

						ROW_SEPARATOR(3)	
						ROW_SEPARATOR(3)	

						<tr>
							<td >
								<t bold='true'>Data wystawienia:</t>
							</td>
							<td>
								<text><![CDATA[DOKUMENT_DATA_WYSTAWIENIA]]></text>
							</td>
							<td>
							</td>							

						</tr>


					</tbody>
				</table>
			</td>
		</tr>

		ROW_SEPARATOR(1)	

		<tr>
			<td>
			<%
				dim iter : iter = 1 
				dim pozycja
			%>
				<!-- pozycje -->
				<table border='1' >
					<thead bold='true'>
						<tr backcolor='#E0E0E0'>
							<td align='center'>
								<t>LP</t>
							</td>
							<td>
								<text size='30'>Symbol transakcji</text>
							</td>							
							<td align='right'>
								<text>Data zapłaty</text>
							</td>
							<td align='right'>
								<text>Stawka</text>
							</td>
							<td align='right'>
								<text>Kwota zaległości</text>
							</td>
							<td align='right'>
								<text>Liczba dni</text>
							</td>
							<td align='right'>
								<text>Kwota odsetek</text>
							</td>
						</tr>
					</thead>
					<tbody>
						<% for each pozycja in root_.listPozycje %>
						<tr>
							<td align='right'>
								<t>POZ_LP</t>
							</td>
							<td>
								<text><![CDATA[POZ_TRANSAKCJA]]></text>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_DATA]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_STAWKA]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_KWOTA_ZAL]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_LICZBA_DNI]]></t>
							</td>
							<td align='right'>
								<t><![CDATA[POZ_KWOTA_ODSETEK]]></t>
							</td>
						</tr>
						<%
							iter = iter + 1
						next
						%>
					</tbody>
					<tfoot>
						<tr>
							<td colspan='5' bordercolor='transparent'>
							</td>
							<td>
								<text bold='true'>Razem</text>
							</td>
							<td align='right'>
								<t bold='true'><![CDATA[DOKUMENT_SUMA]]></t>
							</td>
						</tr>
					</tfoot>
				</table>
			</td>
		</tr>		

		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		<% if root_.strUwagi <> "" then %>
		<tr>
			<td>
				<t bold='true'>Adnotacje:</t>
			</td>
		</tr>
		<tr>
			<td>
				<text><![CDATA[DOKUMENT_UWAGI]]></text>
			</td>
		</tr>
		<% end if%>
		
		ROW_SEPARATOR(1)
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<text bold='true'>Wprowadził: &nbsp;</text><text><![CDATA[DOKUMENT_UZYTKOWNIK_REJESTRUJACY]]></text>

			</td>
		</tr>


		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	
		ROW_SEPARATOR(1)	

		<tr>
			<td>
				<t fontsize='1'>Dokument wyemitowany przez EuroBusiness 5.0</t>
			</td>
		</tr>
	</tbody>
</table>
</body>
<footer>
</footer>
</page>
