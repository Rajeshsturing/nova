<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_TRANSAKCJE_NIEPOWIAZANE

#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Transakcje niepowiązane
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query =_
"select 'c_0'=t_0.strSymTrans,'c_1'=t_0.dDataRozp,'c_2'=t_0.strSymTrans,'c_3'=10154,'c_4'=t_0.IdObj,'c_5'=t_0.dDataRozp,'c_6'=t_0.curWn,'c_7'=t_0.curMa," +_
"'c_8'= CASE t_0.wrefPodmiot_wrt WHEN 10108 THEN t_1.strNazwa ELSE '' END ,'c_9'= CASE t_0.wrefPodmiot_wrt WHEN 10108 THEN 10108 ELSE '' END ," +_
"'c_10'= CASE t_0.wrefPodmiot_wrt WHEN 10108 THEN t_1.IdObj ELSE '' END  from n5transakcja as t_0 left outer join n5klient as t_1 on t_0.wrefPodmiot = t_1.IdObj" +_
" AND t_0.wrefPodmiot_wrt = 10108 where " +_
"t_0.idobj not in (select ptransakcja from n5sprzedaz) and  " +_
"t_0.idobj not in (select ptransakcja from n5zakup) and " +_
"t_0.idobj not in (select pTransakcjaImport from n5zakup) and " +_
"t_0.idobj not in (select ptransakcja from n5pozplatnosc) and " +_
"t_0.idobj not in (select ptransakcja from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaUS from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaZUS51 from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaZUS52 from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaZUS53 from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaInne from n5plnaliczenie) and " +_
"t_0.idobj not in (select plnal_pTransakcjaInne2 from n5plnaliczenie) and " +_
"t_0.idobj not in (select ptransakcja from n5dekret) and " +_
"t_0.idobj not in (select trop_pTransakcja from n5transakcja_operacja) " +_
"and  %1  and  %2  order by t_0.strSymTrans,t_0.dDataRozp"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Symbol transakcji").bindexpr("t_0.strSymTrans")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data rozpoczęcia").bindexpr("t_0.dDataRozp")

	set default_param = pParamArray
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_3,c_4,c_2)
	</td>
	<td>
		RXE_DATE(c_5)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_6,"",2)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVV(c_7,"",2)
	</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_9,c_10,c_8)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Symbol transakcji]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Data rozpoczęcia]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota Wn (w wal. transakcji)]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[Kwota Ma (w wal. transakcji)]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Nazwa pełna]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
