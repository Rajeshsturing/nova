<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h" 
#define RAPORT_TITLE Zamówienia obce do realizacji wg klientów

#ifdef APPCONFIG_RAPORT_BY_PROD_INX
#define C_FIELD_FIRST_EXPR		t_3.strIndeks
#define C_FIELD_SECOND_EXPR		t_3.strNazwa
#define C_FIELD_FIRST_HUMANNAME 	Indeks produktu
#define C_FIELD_SECOND_HUMANNAME 	Nazwa produktu
#else
#define C_FIELD_FIRST_EXPR		t_3.strNazwa
#define C_FIELD_SECOND_EXPR		t_3.strIndeks
#define C_FIELD_FIRST_HUMANNAME		Nazwa produktu
#define C_FIELD_SECOND_HUMANNAME	Indeks produktu
#endif

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query = "select 'c_0'=t_1.strNazwa,'c_1'=10108,'c_2'=t_1.IdObj,'c_3'=t_0.p_strNrDok, "+_
"'c_field_second' = (C_FIELD_SECOND_EXPR), 'c_op' = t_3.strCecha1 ,'c_field_first'= (C_FIELD_FIRST_EXPR), " +_
"'c_14'=t_0.p_idobj,'c_5'=10131,'c_6'=t_3.IdObj,'c_7'=t_4.strNazwa, "+_
"'c_8'=t_0.c_curIloscOpak,'c_9'=t_0.c_curIloscOpakPoz, 'c_10'=t_0.p_dDataReal, "+_
"'c_11'=t_5.strSkrot,'c_12'=t_5.nDokladnosc, 'c_13'=t_0.c_curIloscOpak - t_0.c_curIloscOpakPoz "+_
"from vlist_n5zamowienie_listPozycje as t_0 "+_
"inner join n5klient as t_1 on t_0.p_pKlient = t_1.IdObj  "+_
"inner join n5grupaklient as t_2 on t_1.pGrupaKlient = t_2.IdObj "+_
"inner join n5produkt as t_3 on t_0.c_pProdukt = t_3.IdObj "+_
"inner join n5opakowanie_produktu as t_4 on t_0.c_pOpak = t_4.IdObj "+_
"inner join n5jednostka as t_5 on t_4.pJednOpak = t_5.IdObj "+_
"inner join n5GrupaProduktow as t_grupy on t_3.pGrupaProd = t_grupy.idobj " + _
"inner join n5rejestrdok as t_6 on t_0.p_pRejestrDok = t_6.IdObj "+_
"where %1 and %2 and %3 and %4 and %5 and %6 and %7 and %8 and %9 and EXTRA_CUSTOMER_FILTER_AND(10) and t_0.c_curIloscOpakPoz <> 0 "+_
"order by c_0,c_3"
end function
%>


<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_0.p_dDataWyst")
	pParamArray.add doc_.afc.rap.param.new_date_range("Termin realizacji").bindexpr("t_0.p_dDataReal")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa klienta").bindexpr("t_1.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks klienta").bindexpr("t_1.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa klientów").bindexpr("t_2.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_3.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("t_3.strIndeks")
	pParamArray.add doc_.afc.rap.param.new_text("Grupa produktów").bindexpr("t_grupy.strNazwa") 
	'pParamArray.add doc_.afc.rap.param.new_text("Nazwa opakowania").bindexpr("t_4.strNazwa")
	
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("t_6.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK__ZAM_OBCE) order by strNazwa "
	pParamArray.add pParam2
	EXTRA_CUSTOMER_FILTER_PARAM(t_1)

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>

#ifdef _IOW
<td style='27' colspan='11'>
#else
<td style='27' colspan='10'>
#endif


	
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTOTEXT_LINK_FORM_CCC(c_1,c_2,c_0)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>

#ifdef _IOW
<tr border='0'><td colspan='9' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='9' /></tr>
#else
<tr border='0'><td colspan='8' /></tr>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='8' /></tr>
#endif



<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>

#ifdef _IOW
<td style='27' colspan='10'>
#else
<td style='27' colspan='9'>
#endif

	
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_TEXT_LINK_FORM_VCC(10172,c_14,c_3) <t> &nbsp;&nbsp;(Termin:&nbsp;  </t> RXE_DATE(c_10) <t>)</t>
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<!-- -->


#ifdef _IOW
<tr border='0'><td colspan='9' /></tr>
#else
<tr border='0'><td colspan='8' /></tr>
#endif


<tr hide='true' userprop='propc_section_end="2"'><td colspan='8' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_5,c_6,c_field_first)
	</td>

#ifdef _IOW

	<td>
		RXE_AUTO_TEXT(c_op)
	</td>

#endif


	<td>
		RXE_AUTO_TEXT(c_field_second)
	</td>
	<td>
		RXE_AUTO_TEXT(c_7)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVC(c_8,"",c_12)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVC(c_13,"",c_12)
	</td>
	<td align='right'>
		RXE_QUANTITY_CVC(c_9,"",c_12)
	</td>
	<td align='right'>
		RXE_AUTO_TEXT(c_11)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>

<tr style='21'>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td rowspan='2' width='min'><t>LP</t></td>
	<td rowspan='2' width='min'>
		<text><![CDATA[C_FIELD_FIRST_HUMANNAME]]></text> 
	</td>


#ifdef _IOW

	<td rowspan='2' width='min'>
		<text><![CDATA[Oznaczenie producenta]]></text> 
	</td>

#endif


	<td rowspan='2' width='min'>
		<text><![CDATA[C_FIELD_SECOND_HUMANNAME]]></text> 
	</td>
	<td rowspan='2' width='min'>
		<text><![CDATA[Opakowanie]]></text>
	</td>

	<td colspan='3' width='min' align='center'>
		<text><![CDATA[Ilość opakowań]]></text>
	</td>

	<td rowspan='2' width='min'>
		<text><![CDATA[Jednostka]]></text>
	</td>

</tr>
<tr style='21'>
	<td width='min'>
		<text><![CDATA[zamówionych]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[zrealizowanych]]></text>
	</td>
	<td width='min'>
		<text><![CDATA[pozostałych]]></text>
	</td>
	
</tr>

</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>

<!-- -->
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p>
RAPORT_HEADER(3,0)
</p>

<p>
<t size='2'/>
</p>

<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 3,getref("section_header_2"),getref("section_footer_2")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
