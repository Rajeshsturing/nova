<?xml version="1.0" encoding="windows-1250" ?>

#include "1203"
#include "h1250.h"


#comment MOZLIWE CZCIONKI BARCODE
#define FONTFACE_CODE39			Code39
#define FONTFACE_CODE39TT		Code39 TT
#define FONTFACE_CODE3920		Code-39-20
#define FONTFACE_CODE128		IDAutomationHC39M


#comment MOZLIWE CZCIONKI TEXT
#define FONTACE_TNR				Times New Roman

#comment MOZLIWE CHARSETS
#define ANSI_CHARSET        0
#define DEFAULT_CHARSET     1
#define SYMBOL_CHARSET      2
#define SHIFTJIS_CHARSET    128
#define HANGUL_CHARSET      129
#define GB2312_CHARSET      134
#define CHINESEBIG5_CHARSET 136
#define GREEK_CHARSET       161
#define TURKISH_CHARSET     162
#define HEBREW_CHARSET      177
#define ARABIC_CHARSET      178
#define BALTIC_CHARSET      186
#define RUSSIAN_CHARSET     204
#define THAI_CHARSET        222
#define EE_CHARSET          238
#define OEM_CHARSET         255

#define FONTFACE_TEXT_CURRENT		FONTACE_TNR
#define FONTFACE_BARCODE_CURRENT	FONTFACE_CODE128
#define FONTCHARSET_BARCODE			DEFAULT_CHARSET

#define FONTSIZE_BAR_CODE			4
#define	FONTSIZE_PROD_INDEKS		5
#define FONTSIZE_PROD_NAZWA			5
#define FONTSIZE_ETYKIETA_NRDOK		6
#define FONTSIZE_OPIS_PROD			5

#define SZER_ETYK				5000
#define WYS_ETYK				15000

#define MARGIN_LEFT				1200
#define MARGIN_TOP				400
#define LABELS_OFFSET_BETWEEN	1

#comment dla ustwa_druk_poziom jest 0-ustawienie druku etyk. jedna obok drugiej z zastosowaniem PRINt_LANDSCAPE 1-druk normalny etykieta pod etykieta
#define USTAW_DRUK_POZIOM			1	
#define SHOW_TEXT_BAR_CODE			<%so.write "*" + UCASE(oProd.strIndeks) + "*"%>
#define SHOW_TEXT_NAZWA				<%so.write oProd.strNazwa%>
#define SHOW_TEXT_INDEKS			<%so.write oProd.strIndeks%>
#define SHOW_TEXT_OPIS				<%so.write oProd.strOpis%>



#ifdef _ARTECH
	#undef USTAW_DRUK_POZIOM
	#define USTAW_DRUK_POZIOM		0	
	#undef SHOW_TEXT_BAR_CODE
	#define SHOW_TEXT_BAR_CODE		<%so.write "*" + UCASE(oProd.strIndeks) + "*"%>
	#undef SHOW_TEXT_NAZWA
	#define SHOW_TEXT_NAZWA			<%so.write oProd.strOpis%>
	#undef SHOW_TEXT_INDEKS
	#define SHOW_TEXT_INDEKS		<%so.write left(oProd.strNazwa,25)%>
	#undef SHOW_TEXT_OPIS
	#define SHOW_TEXT_OPIS			<%so.write "www.widlak.net"%>
#endif

#ifdef _BARON
	#undef USTAW_DRUK_POZIOM
	#define USTAW_DRUK_POZIOM		1	
	#undef SHOW_TEXT_BAR_CODE
	#define SHOW_TEXT_BAR_CODE		<%so.write "*" + UCASE(oOpak.strEAN) + "*"%>
	#undef SHOW_TEXT_NAZWA
	#define SHOW_TEXT_NAZWA			<%so.write oProd.strNazwa%>
	#undef SHOW_TEXT_INDEKS
	#define SHOW_TEXT_INDEKS		<%so.write oProd.strIndeks%>
	#undef SHOW_TEXT_OPIS
	#define SHOW_TEXT_OPIS			
#endif

#ifdef _GRAJEWSCY
	#undef USTAW_DRUK_POZIOM
	#define USTAW_DRUK_POZIOM		1	
	#undef SHOW_TEXT_BAR_CODE
	#define SHOW_TEXT_BAR_CODE		<%so.write "*" + UCASE(oProd.strIndeks) + "*"%>
	#undef SHOW_TEXT_NAZWA
	#define SHOW_TEXT_NAZWA			<%so.write oProd.strNazwa%>
	#undef SHOW_TEXT_INDEKS 
	#define SHOW_TEXT_INDEKS		<%so.write oProd.strIndeks%>
	#undef SHOW_TEXT_OPIS
	#define SHOW_TEXT_OPIS			<%so.write right(root_.m_nazwaDok,4)%>
#endif



#macro ROW_SEPARATOR(_colspan_,_wysokosc_)			<tr><td colspan='_colspan_'><t fontsize='_wysokosc_' size='1'></t></td></tr>

<page style='36' high='WYS_ETYK'>
<config>
	<title>Wydruk dokumentu DOKUMENT_NUMER</title>
</config>

<script>
<![CDATA[
function fprint_on_dpc_org_kopia_custom(byref pPage, byval strOrg , byval strKop) : fprint_on_dpc_org_kopia_custom = true

	dim strDevice,strConfig
	doc_.getmodule(60182).get_device_and_config strDevice,strConfig
	dim oPrinting : set oPrinting = doc_.system.activex("navoperif.printing")
	dim oDocConfig : set oDocConfig = oPrinting.docconfig
	oDocConfig.fromstring strConfig

		oDocConfig.copies = trans_.var(2928)
		pPage.print strDevice, oDocConfig.tostring(), doc_.getmodule(60263).new_print_sink_info()

end function

 function fprint
    fprint = fprint_on_dpc_org_kopia_custom(page_.get_this , "" , "" )
end function
'#if USTAW_DRUK_POZIOM = 0
'	VB_PRINT_LANDSCAPE_COMMON
'	VB_PRINTPREV_LANDSCAPE_COMMON
'#endif
]]>
</script>
<header>
</header>
<body>

<%function pokaz_barCode%>
#if USTAW_DRUK_POZIOM = 1
<tr width='min'>
#endif
	<td width='SZER_ETYK' align='center'><t fontcharset='FONTCHARSET_BARCODE' font='FONTFACE_BARCODE_CURRENT' fontsize='FONTSIZE_BAR_CODE'>				
			 <![CDATA[SHOW_TEXT_BAR_CODE]]>
	</t></td>
#if USTAW_DRUK_POZIOM = 1
</tr>
#endif
<%end function%>

<%function pokaz_indeks%>
#if USTAW_DRUK_POZIOM = 1
<tr>
#endif
	<td width='SZER_ETYK'><t fontsize='FONTSIZE_PROD_INDEKS' font='FONTFACE_TEXT_CURRENT'>
			<![CDATA[SHOW_TEXT_INDEKS]]>
	</t></td>
#if USTAW_DRUK_POZIOM = 1
</tr>
#endif
<%end function%>

<%function pokaz_nazwe%>
#if USTAW_DRUK_POZIOM = 1
<tr>
#endif
	<td width='SZER_ETYK'><t fontsize='FONTSIZE_PROD_NAZWA' font='FONTFACE_TEXT_CURRENT'>
			<![CDATA[SHOW_TEXT_NAZWA]]>
	</t></td>
#if USTAW_DRUK_POZIOM = 1
</tr>
#endif
<%end function%>			

<%function pokaz_opis%>
#if USTAW_DRUK_POZIOM = 1
<tr>
#endif
	<td width='SZER_ETYK'><t fontsize='FONTSIZE_OPIS_PROD' font='FONTFACE_TEXT_CURRENT'>
			<![CDATA[SHOW_TEXT_OPIS]]>	
	</t></td>
#if USTAW_DRUK_POZIOM = 1
</tr>
#endif
<%end function%>


<table border='0' high='WYS_ETYK'><tbody high='WYS_ETYK'>
<%	
		dim oProd,x,kol
		dim iter,pozycja

		dim TabDruku: set TabDruku=root_.zwroc_ArrayIdobjToPrint()	

	iter = 1%>
#if USTAW_DRUK_POZIOM = 0
<%for x=1 to 4%> 
<tr> 
#endif
<%
	dim iDoIluDruk
	if root_.ZwrocParamDruku-1 < TabDruku.upper_index then
		iDoIluDruk = root_.ZwrocParamDruku-1
	else
		iDoIluDruk = TabDruku.upper_index
	end if
	

	
		set oProd = trans_.getobj(10131,root_.m_licznikDlaKOPI)
		dim oOpak : set oOpak = oProd.listOpakowania.get(1)
		%>
		<%if x = 1 or (1=USTAW_DRUK_POZIOM) then 
				pokaz_barCode 
			end if
			if x = 2 or (1=USTAW_DRUK_POZIOM) then 
				pokaz_indeks 
			end if
			if x = 3 or (1=USTAW_DRUK_POZIOM) then  
				pokaz_nazwe 
			end if
			if x = 4 or (1=USTAW_DRUK_POZIOM) then 
				pokaz_opis 
			end if%>
		

#if USTAW_DRUK_POZIOM = 0
</tr> 
<%next%>
#endif

</tbody></table>
</body>
<footer>
</footer>
</page>
