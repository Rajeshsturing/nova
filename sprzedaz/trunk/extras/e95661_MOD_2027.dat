<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Operacje magazynowe na egzemplarzu
-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function query()
query =_
"select 'c_prodnazwa'=t_produkt.strNazwa, 'c_nrseryjny'=t_egzemplarz.egze_strNrSeryjny, 'c_numoper'=t_dokmag.nNumOper, 'c_nrdokmag'=t_dokmag.strNrDok, "+_
"'c_magzrod'=isnull(t_magzrod.strNazwa,''), 'c_magdocel'=isnull(t_magdocel.strNazwa,''), 'c_datadokmag'=t_dokmag.dDataWyst, "+_
"'c_4'=10162,'c_5'=t_dokmag.IdObj " +_
"from n5egzemplarz as t_egzemplarz inner join n5produkt as t_produkt on t_egzemplarz.egze_pProdukt = t_produkt.IdObj " +_
"inner join n5pozdokmag_egz as t_pozdokmag on t_pozdokmag.pdmeg_pEgz = t_egzemplarz.IdObj " +_
"inner join collections as t_dokmag_c on t_dokmag_c.IdObj = t_pozdokmag.IdObj " +_
"inner join n5dokmag as t_dokmag on t_dokmag.IdObj = t_dokmag_c.IdParent AND t_dokmag_c.IdCollection = 10162030 " +_
"left outer join n5magazyn as t_magzrod on t_dokmag.pMagZrod = t_magzrod.IdObj " +_
"left outer join n5magazyn as t_magdocel on t_dokmag.pMagDocel = t_magdocel.IdObj where  %1  and  %2  and  %3" +_
"order by t_produkt.strNazwa,t_egzemplarz.egze_strNrSeryjny,t_dokmag.nNumOper"
end function
%>
<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("t_produkt.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Numer seryjny").bindexpr("t_egzemplarz.egze_strNrSeryjny")
	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("t_dokmag.dDataWyst")

	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='5'>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_prodnazwa)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'><td colspan='7' /></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='6'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	RXE_AUTO_TEXT(c_nrseryjny)
</td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='7' /></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='white'>
<%
else
%>
<tr bordercolor='white' style='37'>
<%
end if
%>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
<td align='right'>RXE_LP</td>
	<td>
		RXE_AUTOTEXT_LINK_FORM_CCC(c_4,c_5,c_nrdokmag)
	</td>
	<td>
		RXE_DATE(c_datadokmag)
	</td>
  <td>
		RXE_AUTO_TEXT(c_magzrod)
	</td>
	<td>
		RXE_AUTO_TEXT(c_magdocel)
	</td>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
<tr style='21'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td width='min'><t>LP</t></td>
	<td width='max'>
		<text><![CDATA[Numer dokumentu]]></text>
	</td>
  <td width='max'>
    <text><![CDATA[Data operacji]]></text>
  </td>
  <td width='max'>
		<text><![CDATA[Magazyn wydania]]></text>
	</td>
	<td width='max'>
		<text><![CDATA[Magazyn przyjęcia]]></text>
	</td>
</tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
	.add_group_section 0,getref("section_header_1"),getref("section_footer_1")
	.add_group_section 1,getref("section_header_2"),getref("section_footer_2")
if .prepare("RAPORT_TITLE", default_param(), rapeng_.get_raport_param(), query()) then
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
