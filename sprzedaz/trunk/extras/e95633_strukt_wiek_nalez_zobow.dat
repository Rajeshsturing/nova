<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_STRUKTURA_WIEKOWA_NAL_ZO

#include "h1000.h"
#include "h1200.h"
#include "h1203.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"
#define RAPORT_TITLE Należności i zobowiązania

-->
<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim pRokKsieg : set pRokKsieg = getCurrentRKS()
dim tytul : tytul = ""
dim pParamRaport

function query()
  dim strRokKsieg
  if not pRokKsieg is nothing then
    strRokKsieg = CStr(Year(pRokKsieg.dDataRozp))
  end if

query = "select distinct " + vbNewLine +_
  "'kategoria'=max( " + vbNewLine +_
  "case " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) = -9999) then 'C' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > -9999 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 0) then 'A' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 0) then 'B' " + vbNewLine +_
  "end), " +_  
  "'przedzial'=max( " + vbNewLine +_
  "case " + vbNewLine +_ 
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) = -9999) then 'K' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > -9999 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) < -90) then 'D' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) >= -90 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) < -60) then 'C' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) >= -60 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) < -30) then 'B' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) >= -30 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 0) then 'A' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 0 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 30) then 'E' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 30 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 60) then 'F' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 60 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 90) then 'G' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 90 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 180) then 'H' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 180 and isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) <= 365) then 'I' " + vbNewLine +_
  "  when (isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999) > 365) then 'J' " + vbNewLine +_
  "end), " +_          
  "'k_strnazwa'=max(k.strNazwa),'kn_strsymbol'=max(kn.strSymbol),'t_strsymtrans'=max(isnull(t.strSymTrans,'------')),'t_idobj'=max(isnull(t.idobj,0)), " + vbNewLine +_
  "'t_ddatarozp'=max(isnull(t.dDataRozp,'')),'t_ddatawym'=max(isnull(t.dDataWym,'')), " + vbNewLine +_
  "'kwota'=sum(isnull((d.curWn - d.curMa),0)), " + vbNewLine +_
  "'liczba_dni'=sum(isnull(DATEDIFF(day,t.dDataWym,[%2]),-9999)) " + vbNewLine +_
  "from n5dekret as d " + vbNewLine +_
  "inner join n5konto as kn on d.pKonto = kn.idobj " + vbNewLine +_
  "inner join n5klient as k on kn.wrefPodmiotRozrach = k.idobj and kn.wrefPodmiotRozrach_wrt = TYPEID_N5KLIENT " + vbNewLine +_
  "left join n5transakcja as t on d.pTransakcja = t.idobj " + vbNewLine +_
  "where kn.pJednostka in (select idobj from n5jednostka where strSkrot = 'PLN') and year(d.dDataKsieg) = " + strRokKsieg + " and ((t.eTyp = [%3]) or " + vbNewLine +_ 
  "(t.strSymTrans is null)) and (d.dDataKsieg <= [%2]) and %1 " + vbNewLine +_
#ifdef _PRINTY_LAND
  "and t.strSymTrans is not null " + vbNewLine +_
#endif
  "group by d.pKonto, d.pTransakcja " + vbNewLine +_
  "having sum(isnull((d.curWn - d.curMa),0)) <> 0 " + vbNewLine +_
  "order by kategoria,przedzial,k_strnazwa,kn_strsymbol,t_ddatarozp,t_strsymtrans "
  
end function
%>
<%
'pobiera IdObj roku księgowego
function getCurrentRKSId()
	if trans_.isvar(GVAR_ROKKSIEG) then
		getCurrentRKSId = trans_.var(GVAR_ROKKSIEG)
	else
		getCurrentRKSId = 0
	end if
end function

'pobiera aktualny rok księgowy
function getCurrentRKS()
	set getCurrentRKS = nothing
	dim id:id = getCurrentRKSId
	if id > 0 then
		set getCurrentRKS = trans_.getobj(TYPEID_N5ROKKSIEG,id)
	end if
end function


dim g_custom_param_class:set g_custom_param_class = doc_.getmodule(43030)

function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()

	'pParamArray.add doc_.afc.rap.param.new_text("Symbol").bindexpr("kn.strSymbol COLLATE latin1_general_cs_as")
'------------------------------
dim pParamSymbol
	set pParamSymbol = doc_.afc.new_navoarray()
	dim custom_param
	set custom_param = g_custom_param_class.new_custom("Symbol").bindexpr("kn.strSymbol")
	custom_param.ExtraXML = "<radio name='r13' border='0'>"+_
													"<transfer mode='custom'>"+_
													"</transfer>"+_
													"<table><tbody><tr><td width='3300'><t>Wszystko</t>										</td>																									</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Dokładnie</t>									</td>	<td><edit width='2000' name='e151'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_	
												  "<table><tbody><tr><td width='3300'><t>Początek</t>										</td>	<td><edit width='2000' name='e161'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Zawiera</t>										</td>	<td><edit width='2000' name='e171'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Zakres od</t>									</td>	<td><edit width='2000' name='e182'><transfer mode='custom'/></edit>	</td><td><t> do </t></td><td><edit width='2000' name='e183'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Tylko konta</t>								</td>	<td><edit width='5000' name='e181'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
												  "<table><tbody><tr><td width='3300'><t>Konta rozpoczynające się	</t>	</td>	<td><edit width='5000' name='e191'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"<table><tbody><tr><td width='3300'><t>Konta zawierające</t>					</td>	<td><edit width='5000' name='e192'><transfer mode='custom'/></edit>	</td>	</tr></tbody></table>"+_
													"</radio> "+_
													"<br/> "+_
													"<t></t><br/> "+_
													"<text bold='true' name='t199'></text><br/> "
	custom_param.Add2CtrlTable 13
		custom_param.Add2CtrlTable 151
			custom_param.Add2CtrlTable 161
				custom_param.Add2CtrlTable 171
					custom_param.Add2CtrlTable 181
					custom_param.Add2CtrlTable 182
					custom_param.Add2CtrlTable 183
						custom_param.Add2CtrlTable 191
						custom_param.Add2CtrlTable 192
custom_param.ExtraINIT =	"page_.ctrl(13).value = clng(1) " + vbCrLf + _
													" page_.ctrl(151).disable = true " + vbCrLf + _
													" page_.ctrl(161).disable = true " + vbCrLf + _
													" page_.ctrl(171).disable = true " + vbCrLf + _
													" page_.ctrl(181).disable = true " + vbCrLf + _
													" page_.ctrl(182).disable = true " + vbCrLf + _
													" page_.ctrl(183).disable = true " + vbCrLf + _
													" page_.ctrl(191).disable = true " + vbCrLf + _
													" page_.ctrl(192).disable = true " 
	pParamArray.add custom_param

'------------------------------
  dim pRaportMomentParam : set pRaportMomentParam = doc_.afc.rap.param.new_date("Analizowany moment").bindexpr("")
	if trans_.isvar(APPVAR_RAPORT_FROM_OUTSIDE) then
		pRaportMomentParam.first_value = trans_.var(1007)
		pRaportMomentParam.mode = clng(1)
	end if
	pParamArray.add pRaportMomentParam

	dim pParamFactory: set pParamFactory = doc_.afc.rap.param
  Set pParamRaport = pParamFactory.new_choice("Typ transakcji")
  with pParamRaport
	  .multiple = false
    .names.add "zobowiązanie"
    .values.add 1
    .selected.add True
    
    .names.add "należność"
    .values.add 2
    .selected.add False
  end with  
  pParamArray.add pParamRaport
	set default_param = pParamArray
end function
%>
<%
function section_header_1(byref pSection,byref pRec)
%>
  <tr userprop='propc_section_start="1" propc_section_hidden="0" propc_section_req="0"' fontsize='4'>
	  <td style='27' colspan='8'>
		  <picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Zwiń' ignoresysdisable='true' image='PICTURE_SMALL_MINUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<%so.write cstr(nSectionPicCounter)%>"'/>
	          <text><![CDATA[<% 
              if cstr(pRec("kategoria")) = "A" then 
                so.write "Nieprzeterminowane" 
              else if cstr(pRec("kategoria")) = "B" then 
                so.write "Przeterminowane" 
              else if cstr(pRec("kategoria")) = "C" then 
                so.write "Bez transakcji"
              end if end if end if %>]]></text>
    </td>
  </tr>
<%
  nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_1(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="1"'> <td colspan='8'></td> </tr>
<tr fontsize='4'>
  <td style='27' colspan='7'></td>
  <td style='27' align='right'> RXE_MONEY_VAR(pSection.counter(0).result) </td>
</tr>
<tr border='0'><td colspan='8'></td></tr>
<%
end function
%>
<%
function section_header_2(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="2" propc_section_hidden="1" propc_section_req="0"' fontsize='4'>
	<td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
	<td style='27' colspan='7'>
		<picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Rozwiń' ignoresysdisable='true' image='PICTURE_SMALL_PLUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<% so.write cstr(nSectionPicCounter) %>"'/>
		          <text><![CDATA[<% 
              if cstr(pRec("przedzial")) = "A" then 
                so.write "Płatne do 30 dni" 
              else if cstr(pRec("przedzial")) = "B" then 
                so.write "Płatne do 60 dni"
              else if cstr(pRec("przedzial")) = "C" then 
                so.write "Płatne do 90 dni"
              else if cstr(pRec("przedzial")) = "D" then 
                so.write "Płatne powyżej 90 dni"
              else if cstr(pRec("przedzial")) = "E" then 
                so.write "Do 30 dni"
              else if cstr(pRec("przedzial")) = "F" then 
                so.write "Do 60 dni"
              else if cstr(pRec("przedzial")) = "G" then 
                so.write "Do 90 dni"
              else if cstr(pRec("przedzial")) = "H" then 
                so.write "Do 180 dni"
              else if cstr(pRec("przedzial")) = "I" then 
                so.write "Do 1 roku"
              else if cstr(pRec("przedzial")) = "J" then 
                so.write "Powyżej 1 roku"
              else if cstr(pRec("przedzial")) = "K" then 
                so.write "bez przedziału"  
              end if end if end if end if end if end if end if end if end if end if end if %>]]></text>
        </td>
    </tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_2(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="2"'><td colspan='8'></td></tr>
<tr fontsize='4'>
  <td style='27' colspan='7' />
  <td style='27' align='right'> RXE_MONEY_VAR(pSection.counter(0).result) </td>
</tr>
<tr border='0'><td colspan='8'></td></tr>
<%
end function
%>
<%
function section_header_3(byref pSection,byref pRec)
%>
<tr userprop='propc_section_start="3" propc_section_hidden="1" propc_section_req="0"' fontsize='4' hide='true'>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td style='27' colspan='6'>
    <picture name='<%so.write cstr(nSectionPicCounter)%>' tip='Rozwiń' ignoresysdisable='true' image='PICTURE_SMALL_PLUS' width='SIZE_FOR_PLUS' height='SIZE_FOR_PLUS' href='vs1022="section_hideshow_hli" vn100="<% so.write cstr(nSectionPicCounter) %>"'/>
		          <text><![CDATA[<% so.write cstr(pRec("k_strnazwa") + "  (" + pRec("kn_strsymbol") + ")") %>]]></text>
  </td>
</tr>
<%
nSectionPicCounter=nSectionPicCounter+1
end function
%>
<%
function section_footer_3(byref pSection)
%>
<tr hide='true' userprop='propc_section_end="3"'><td colspan='8'></td></tr>
<tr fontsize='4' hide='true'>
  <td style='27' colspan='7' />
  <td style='27' align='right'> RXE_MONEY_VAR(pSection.counter(0).result) </td>
</tr>
<tr border='0'><td colspan='8' hide='true'></td></tr>
<%
end function
%>
<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then %>
<tr bordercolor='white' hide='true'>
 <% else %>
   <tr bordercolor='white' style='37' hide='true'>
 <% end if %>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td align='right'>RXE_LP</td> 
  <td> RXE_TEXT_LINK_FORM_VCC(TYPEID_N5TRANSAKCJA,t_idobj,t_strsymtrans) </td>
  <td> RXE_DATE(t_ddatarozp) </td>   
  <td> RXE_DATE(t_ddatawym) </td>    
  <td align='right'> RXE_QUANTITY_CVV(kwota,"",2) </td>
 </tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
  <tr style='21'>
    <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
    <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
    <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
    <td width='3500' align='right'><text>LP</text></td>
    <td width='4000'>
      <text><![CDATA[Symbol transakcji]]></text>
    </td>
    <td width='3000'>
      <text><![CDATA[Data wystawienia]]></text>
    </td>
    <td width='3000'>
      <text><![CDATA[Termin płatności]]></text>
    </td>
    <td width='2500' align='right'>
      <text><![CDATA[Kwota]]></text>
    </td>
  </tr>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
  <tfoot> 
<tr fontsize='5' style='21'>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td bordercolor='transparent' width='min'><t>&nbsp;</t></td>
  <td colspan='4'><text><![CDATA[Wszystkie]]></text></td>
  <td align='right'> RXE_MONEY_VAR(pSection.counter(0).result) </td>
</tr>
<tr border='0'><td colspan='8'></td></tr>
  </tfoot>
</table>
<%
end function
%>
<% dim nSectionPicCounter : nSectionPicCounter = 10000000 %>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function

<%function header()%>
<table>
<tbody>
<tr>
	<td><t fontsize='3' bold='true'><![CDATA[<% so.write util_.Firma_Nazwa %>]]></t></td>
	<td align='right'><t fontsize='3'><![CDATA[<% so.write util_.Firma_Miasto + " " + util_.Dzisiaj%>]]></t></td>
</tr>
<tr>
	<td><t fontsize='3' bold='true'><![CDATA[<% so.write util_.Firma_Ulica %>]]></t></td>
	<td/>
</tr>
<% if util_.Firma.strPoczta="" then %>
   <tr><td><t fontsize='3' bold='true'><![CDATA[<% so.write util_.Firma_Kod_Miasto %>]]></t></td><td/></tr>
<% else if util_.Firma.strPoczta <> util_.Firma.pMiejscowosc.strNazwa then %>
   <tr><td><t fontsize='3' bold='true'><![CDATA[<% so.write util_.Firma.strKod + " " + util_.Firma.strPoczta %>]]></t></td><td/></tr>
<% end if end if %>
  
<% if (util_.Firma.strPoczta<>"") and (util_.Firma.pMiejscowosc.strNazwa <> util_.Firma.strPoczta) then %>
<tr>
	<td><t fontsize='3' bold='true'><![CDATA[<% so.write util_.Firma.pMiejscowosc.strNazwa %>]]></t></td>
	<td/>
</tr>
<%end if%>
<% if util_.Firma_NIP <> "" then %>
<tr>
  <td align='left' bold='true' colspan='2'><t fontsize='3'><![CDATA[<% so.write "NIP " + util_.Firma_NIP %>]]></t></td>
</tr>  
<% end if %>  
</tbody>
</table>
<%end function%>  
  
]]>
</script>
</config>
<header>
</header>
<body>
<p>
<%header()%>
</p>

<br/><br/>
  
<p><text fontsize='7'><![CDATA[RAPORT_TITLE]]></text></p><br/><br/>
<t fontsize='5' bold='true'>Kryteria selekcji:</t><br/>
<%
dim pRapExec : set pRapExec = rapeng_.new_engine()
with pRapExec
	.add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("kwota")
  .add_group_section (0,getref("section_header_1"),getref("section_footer_1")).add_sumator("kwota")
  .add_group_section (1,getref("section_header_2"),getref("section_footer_2")).add_sumator("kwota")
  .add_group_section (3,getref("section_header_3"),getref("section_footer_3")).add_sumator("kwota")
if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
    .ReplaceQueryParam "[( = ",""
    .ReplaceQueryParam ")]",""
    .ReplaceQueryParam "['1']","<"
    .ReplaceQueryParam "['2']",">"
%>
<%
	rapeng_.write_actual_param so,rapeng_.get_raport_param()
	if not .perform then
	so.write "<p style='21'><t>Brak danych spełniających podane kryteria</t></p>"
	end if
%>
<%
end if
end with
%>
</body>
<footer>
</footer>
</page>
