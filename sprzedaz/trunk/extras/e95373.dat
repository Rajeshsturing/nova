<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_KPIR_PODSUMOWANIE

#include "h1000.h"
#include "h1220.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Podsumowanie PKPiR

#macro ROW_SEPARATOR(_colspan_)			      <tr><td colspan='_colspan_'><t/></td></tr>
#define RAPORT_PODSUMOWANIE_ROKU          <% so.write WriteHeader %>
#define RAPORT_ROW_PRZYCHOD               <% so.write trans_.afc.display.money(pRec("przychod").value,"") %>
#define RAPORT_ROW_WARTOSC_SPISU_POCZATEK <% so.write trans_.afc.display.money(pParamArray.value(1).first_value,"") %>
#define RAPORT_ROW_ZAKUP_TOWAROW          <% so.write trans_.afc.display.money(pRec("zakup_towarow").value,"") %>
#define RAPORT_ROW_KOSZTY_UBOCZNE         <% so.write trans_.afc.display.money(pRec("koszty_uboczne").value,"") %>
#define RAPORT_ROW_WARTOSC_SPISU_KONIEC   <% so.write trans_.afc.display.money(pParamArray.value(2).first_value,"") %>
#define RAPORT_ROW_POZOSTALE_WYDATKI      <% so.write trans_.afc.display.money(pRec("pozostale_wydatki").value,"") %>
#define RAPORT_ROW_WYN_W_NATURZE          <% so.write trans_.afc.display.money(pParamArray.value(3).first_value,"") %>
#define RAPORT_ROW_KOSZTY_RAZEM           <% so.write trans_.afc.display.money(curKosztRazem,"") %>
#define RAPORT_ROW_DOCHOD                 <% so.write trans_.afc.display.money(ccur(pRec("przychod").value) - ccur(curKosztRazem),"") %>
-->

<page style='36' margins='1000,1000,1000,1000'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
function WriteHeader():WriteHeader = ""
  select case pParamArray.value(0).mode
    case 2:
      WriteHeader = "Podsumowanie roku " + CStr(Year(pParamArray.value(0).first_value))
    case 3:
      WriteHeader = "Podsumowanie miesiąca " + Left(trans_.afc.display.fulldate(pParamArray.value(0).first_value),7)
    case 7:
      WriteHeader = "Podsumowanie PKPiR od " + trans_.afc.display.fulldate(pParamArray.value(0).first_value) + " do " + trans_.afc.display.fulldate(pParamArray.value(0).last_value)
    case else:
      WriteHeader = "Podsumowanie PKPiR"
  end select
end function

function query()
query = "select 'przychod'=sum(curWartSprzed)+sum(curPozPrzych),'zakup_towarow'=sum(curZakTow), " + vbNewLine +_
        "'koszty_uboczne'=sum(curKosztZak),'pozostale_wydatki'=sum(curKosztRekl + curWynagrodz + curPozWyd), " + vbNewLine +_
        "'koszty_razem'=sum(curZakTow) + sum(curKosztZak) + sum(curKosztRekl + curWynagrodz + curPozWyd) " + vbNewLine +_
        "from n5pkpir " + vbNewLine +_
        "where %1"
end function
%>

<%
dim pParamArray
function default_param()
  set pParamArray = doc_.afc.new_navoarray()
  pParamArray.add doc_.afc.rap.param.new_date_range("Data operacji").bindexpr("dDataOper")
  pParamArray.add doc_.afc.rap.param.new_currency("Spis z natury początek roku").bindexpr("")
  pParamArray.add doc_.afc.rap.param.new_currency("Spis z natury koniec roku").bindexpr("")
  pParamArray.add doc_.afc.rap.param.new_currency("Wartość  wynagrodzeń").bindexpr("")    
  set default_param = pParamArray
end function
%>

<%
function body_row(byref pSection,byref pRec)
  dim curKosztRazem
  curKosztRazem = ccur(pParamArray.value(1).first_value) + ccur(pRec("koszty_razem").value) - _
                  ccur(pParamArray.value(2).first_value) - ccur(pParamArray.value(3).first_value)

%>
<tr>
  <td>
    <table>
      <tbody>
        <tr>
          <td align='left'><t><![CDATA[1) Przychód (kolumna 9)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_PRZYCHOD]]></text></td>
        </tr>
        ROW_SEPARATOR(2)
        <tr>
          <td align='left' width='min'><t><![CDATA[2) Wysokość kosztów uzyskania przychodów poniesionych w roku podatkowym:]]></t></td>
          <td />
        </tr>
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[a) wartość spisu z natury na początek roku podatkowego]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_WARTOSC_SPISU_POCZATEK]]></text></td>
        </tr> 
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[b) plus wydatki na zakup towarów handlowych i materiałów (kolumna 10)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_ZAKUP_TOWAROW]]></text></td>
        </tr>
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[c) plus wydatki na koszty uboczne zakupu (kolumna 11)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_KOSZTY_UBOCZNE]]></text></td>
        </tr>
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[d) minus wartość spisu z natury na koniec roku podatkowego]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_WARTOSC_SPISU_KONIEC]]></text></td>
        </tr>
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[e) plus kwota pozostałych wydatków (kolumna 14)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_POZOSTALE_WYDATKI]]></text></td>
        </tr> 
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[f) minus wartość wynagrodzeń w naturze ujętych w innych kolumnach księgi]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_WYN_W_NATURZE]]></text></td>
        </tr> 
        <tr>
          <td />
          <td align='right'><text><![CDATA[______________]]></text></td>
        </tr>
        <tr>
          <td align='left'><t><![CDATA[Razem koszty uzyskania przychodu]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_KOSZTY_RAZEM]]></text></td>
        </tr>   
        ROW_SEPARATOR(2)
        <tr>
          <td align='left'><t><![CDATA[3) Ustalenie dochodu osiągniętego w roku podatkowym:]]></t></td>
          <td />
        </tr>  
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[a) przychód (pkt 1)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_PRZYCHOD]]></text></td>
        </tr>  
        <tr>
          <td align='left'><t size='2' /><t><![CDATA[b) minus koszty uzyskania przychodów (pkt 2)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_KOSZTY_RAZEM]]></text></td>
        </tr>
        <tr>
          <td />
          <td align='right'><text><![CDATA[______________]]></text></td>
        </tr>  
        <tr>
          <td align='left'><t><![CDATA[Dochód (a-b)]]></t></td>
          <td align='right'><text><![CDATA[RAPORT_ROW_DOCHOD]]></text></td>
        </tr>  
      </tbody>
    </table>
  </td>
</tr>
<%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table>
<thead>
<tr>
	<td align='center'><text><![CDATA[RAPORT_PODSUMOWANIE_ROKU]]></text></td>
</tr>
  ROW_SEPARATOR(1)
  ROW_SEPARATOR(1) 
  ROW_SEPARATOR(1) 
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
</table>
<%
end function
%>

<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>

<p>  
	<table fontsize='3'>
		<tbody>
			<tr>
				<td align='right'><t size='3'/><t><![CDATA[<% so.write util_.Firma_Miasto + " " + doc_.afc.display.fulldate(trans_.var(GVAR_TODAY)) %>]]></t></td>
			</tr>
      <tr>
        <td align='center'>
          <text><![CDATA[Podatkowa Księga Przychodów i Rozchodów]]></text>
        </td>
      </tr>
      ROW_SEPARATOR(1)
      <tr>
        <td align='center'><text><![CDATA[H_FIRMA_NAZWA]]></text></td>
      </tr>
			<tr>
				<td align='center'><text><![CDATA[H_FIRMA_ULICA_NUMER]]></text></td>
			</tr>
			<% if util_.Firma.strPoczta="" or util_.Firma.pMiejscowosc.strNazwa=util_.Firma.strPoczta then %>
			<tr>
				<td align='center'><text><![CDATA[H_FIRMA_KOD_MIASTO]]></text></td>
			</tr>
			<% 
        else if util_.Firma.strPoczta<>util_.Firma.pMiejscowosc.strNazwa then
				  if util_.Firma.strUlica <> "" then 
      %>
			    <tr>
				    <td align='center'><text><![CDATA[H_FIRMA_MIASTO]]></text></td>
			    </tr>
				<% end if %>
			  <tr>
				  <td align='center'><text><![CDATA[H_FIRMA_KOD_POCZTA]]></text></td>
			  </tr>
			<%	
        end if
			end if
			%>
      ROW_SEPARATOR(1)  
		</tbody>
	</table>
</p>
<p>
<t size='2'/>
</p>
<p>
<%  
dim pRapExec : set pRapExec = rapeng_.new_engine()
  with pRapExec
  .add_body_ex getref("body_header"),getref("body_footer"),getref("body_row")
  
  if .prepare("RAPORT_TITLE",default_param(),rapeng_.get_raport_param(),query()) then
	
    if not .perform then
	  end if
  end if
end with
%>
</p>
</body>
<footer>
</footer>
</page>
