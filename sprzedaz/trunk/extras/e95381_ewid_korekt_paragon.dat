<?xml version="1.0" encoding="windows-1250" ?>
<!--
RAPTEMPLATE_EWIDENCJA_KOREKT_PARAGONOW

#include "h1000.h"
#include "h1200.h"
#include "h1203_appconfig.h"
#include "h1220.h"
#include "h1231.h"
#include "h1240.h"
#include "h1250.h"

#define RAPORT_TITLE Ewidencja korekt paragonów

#macro ROW_SEPARATOR(_colspan_)			<tr><td colspan='_colspan_'><t/></td></tr>
-->

<page style='36'>
<config>
<title>RAPORT_TITLE</title>
<script>
<![CDATA[
<%
dim bEwidPomylek: bEwidPomylek = false

function query()
  if bEwidPomylek then
    query = "select 'data_sprzed'=s.dDataSprzed,'data_wyst'=s.dDataWyst, " + vbNewLine +_
    " 'nr_dok'=org.strNrDok,'org_type'=10129,'org_idobj'=org.IdObj, " + vbNewLine +_
#ifdef _KES
    " 'wart_brutto'=case when s.curSumaBrutto - org.curSumaBrutto <> 0 then abs(s.curSumaBrutto - org.curSumaBrutto) else 0 end, " + vbNewLine +_  
    " 'wart_vat'=case when s.curSumaVAT - org.curSumaVAT <> 0 then abs(s.curSumaVAT - org.curSumaVAT) else 0 end, " + vbNewLine +_  
#else
    " 'wart_brutto'=case when s.curSumaBrutto - org.curSumaBrutto <> 0 then org.curSumaBrutto else 0 end, " + vbNewLine +_  
    " 'wart_vat'=case when s.curSumaVAT - org.curSumaVAT <> 0 then org.curSumaVAT else 0 end, " + vbNewLine +_
#endif    
    " 'wart_brutto_czesc'=0, " + vbNewLine +_  
    " 'wart_vat_czesc'=0, " + vbNewLine +_    
    " 'uwagi'=s.strUwagi " + vbNewLine +_
    " from n5sprzedaz as s " + vbNewLine +_  
    " left outer join n5sprzedaz org on s.pPopSprzed = org.IdObj " + vbNewLine +_
    " inner join n5rejestrdok as r on s.pRejestrDok = r.IdObj" + vbNewLine +_
    " where (s.curSumaBrutto - org.curSumaBrutto <> 0) and s.pRozlVAT <> 0 " + vbNewLine +_
    " and %1 and %2 and %3 and %6 and %7 and %8 " + vbNewLine +_
    " order by data_wyst,nr_dok "    
  else
    query = "select 'data_sprzed'=max(s.p_ddatasprzed),'data_wyst'=max(s.p_ddatawyst), " + vbNewLine +_
    " 'produkt'=max(p.strNazwa),'prod_type'=10131,'prod_id'=max(p.IdObj),  " + vbNewLine +_
    " 'nr_dok'=max(org.p_strnrdok),'org_type'=10129,'org_idobj'=max(org.p_idobj), " + vbNewLine +_
    " 'wart_brutto'=case when sum(s.c_curWartBrutto) = 0 then sum(org.c_curWartBrutto) else 0 end, " + vbNewLine +_
    " 'wart_vat'=case when sum(s.c_curVAT) = 0 then sum(org.c_curVAT) else 0 end, " + vbNewLine +_
    " 'wart_brutto_czesc'=case when sum(s.c_curWartBrutto) > 0 then abs(sum(s.c_curWartBrutto) - sum(org.c_curWartBrutto)) else 0 end, " + vbNewLine +_
    " 'wart_vat_czesc'=case when sum(s.c_curvat) > 0 then abs(sum(s.c_curvat) - sum(org.c_curvat)) else 0 end " + vbNewLine +_
    " from vlist_n5sprzedaz_listpozycje as s " + vbNewLine +_
    " left outer join vlist_n5sprzedaz_listpozycje org on s.p_ppopsprzed = org.p_idobj and s.coll_lp = org.coll_lp " + vbNewLine +_
    " inner join n5produkt as p on s.c_pProdukt = p.IdObj " + vbNewLine +_  
    " inner join n5opakowanie_produktu as op on s.c_pOpak  = op.IdObj " + vbNewLine +_
    " inner join n5rejestrdok as r on s.p_pRejestrDok = r.IdObj" + vbNewLine +_
    " where s.p_pRozlVAT <> 0 " + vbNewLine +_
    " and %1 and %2 and %3 and %4 and %5 and %6 and %7 and %8 " + vbNewLine +_
#ifdef _KES
    " group by s.p_idobj,p.IdObj,op.idobj " + vbNewLine +_
#else
    " group by p.IdObj,op.idobj " + vbNewLine +_
#endif    
    " having (sum(s.c_curWartBrutto) - sum(org.c_curWartBrutto)) <> 0 " + vbNewLine +_
    " order by data_wyst,produkt "
  end if
	query = rapeng_.query_apply_actual_param(query,pParamArray)
  
  if bEwidPomylek then
    query = Replace(query,"s.p_strextra2", "s.strExtra2")
    query = Replace(query,"s.p_dDataWyst", "s.dDataWyst")
    query = Replace(query,"org.p_strnrdok", "org.strNrDok")
    query = Replace(query,"s.p_pRozlVAT", "s.pRozlVAT")
    query = Replace(query,"s.p_struwagi", "s.strUwagi")
  end if
end function

function getCurrentUser(): getCurrentUser = ""
	if (trans_.var(GVAR_USER) <> 0) then
		getCurrentUser = trans_.getobj(TYPEID_N5UZYTKOWNIK, trans_.var(GVAR_USER)).strNazwa
	end if
end function
%>

<%
function default_param()
	dim pParamArray : set pParamArray = doc_.afc.new_navoarray()	
	dim pPowodKor: set pPowodKor = doc_.afc.rap.param.new_choice("Powód korekty").bindexpr("s.p_strextra2")
	with pPowodKor
		.multiple = false
		.names.add "Pomyłki"
		.values.add 1
		.selected.add true
		.names.add "Reklamacje"
		.values.add 2
		.selected.add false
		end with
	pParamArray.add pPowodKor

	pParamArray.add doc_.afc.rap.param.new_date_range("Data wystawienia").bindexpr("s.p_dDataWyst")
  pParamArray.add doc_.afc.rap.param.new_text("Nr paragonu").bindexpr("org.p_strnrdok")
	pParamArray.add doc_.afc.rap.param.new_text("Nazwa produktu").bindexpr("p.strNazwa")
	pParamArray.add doc_.afc.rap.param.new_text("Indeks produktu").bindexpr("p.strIndeks")  
  
	dim pParamFactory2: set pParamFactory2= doc_.afc.rap.param
	dim pParam2: Set pParam2= pParamFactory2.new_choice("Rejestr").bindexpr("r.IdObj")
	doc_.afc.rap.param.init_on_query pParam2, trans_ ,_
		"select strNazwa , idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_KOR_PARAGON) " +_		
#ifdef _TORAL
		"or (eTyp in (N5REJESTRDOK_KOR_FAKT_SP) and strNazwa like '%S F%') " +_		
#endif
		"order by strNazwa "
	pParamArray.add pParam2
  
	dim pParamFactory3: set pParamFactory3= doc_.afc.rap.param
	dim pParam3: Set pParam3= pParamFactory3.new_choice("Okres VAT").bindexpr("s.p_pRozlVAT")
	doc_.afc.rap.param.init_on_query pParam3, trans_ , _
		"select 'bez odliczeń',0 union select ltrim(str(year(vat7_ddataod))) + '/' + substring(ltrim(str(100+month(vat7_ddataod))),2,2),idobj " +_
		"from n5rozlvat where datediff(month,vat7_ddataod," + trans_.afc.convert.date2SQL(trans_.var(GVAR_TODAY)) + ") < 12 order by 1 desc"
	pParamArray.add pParam3
  
  pParamArray.add doc_.afc.rap.param.new_text("Uwagi").bindexpr("s.p_struwagi")
  pParamArray.add doc_.afc.rap.param.new_text("Nr kasy fiskalnej").bindexpr("")

	set default_param = pParamArray
end function
%>

<%
function GetOkres(): GetOkres = ""
  dim iter
  for iter = 0 to pParamArray.value(6).selected.upperIndex
    if pParamArray.value(6).selected.value(iter) then
      GetOkres = GetOkres + pParamArray.value(6).names.value(iter) + ", "
    end if
  next
  if Len(GetOkres) > 2 then
    GetOkres = Left(GetOkres,Len(GetOkres) - 2)
  end if
end function
%>

<%
function body_row(byref pSection,byref pRec)
if pRapExec.RecNr mod 2 = 0 then
%>
<tr bordercolor='#515151'>
<%
else
%>
<tr bordercolor='#515151' style='37'>
<%
end if
%>
  <td align='right'>RXE_LP</td>
  <% if bEwidPomylek then %>
	  <td>
		  RXE_DATE(data_wyst)
	  </td>  
	  <td>
		  RXE_DATE(data_sprzed)
	  </td>     
	  <td align='left'>
		  RXE_AUTOTEXT_LINK_FORM_CCC(org_type,org_idobj,nr_dok)
	  </td>      
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_brutto,"",2)
	  </td>    
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_vat,"",2)
	  </td>  
	  <td>
		  RXE_TEXT(uwagi)
	  </td>    
  <% else %>
	  <td>
		  RXE_DATE(data_sprzed)
	  </td>   
	  <td align='left'>
		  RXE_AUTOTEXT_LINK_FORM_CCC(prod_type,prod_id,produkt)
	  </td>
	  <td align='left'>
		  RXE_AUTOTEXT_LINK_FORM_CCC(org_type,org_idobj,nr_dok)
	  </td>  
	  <td>
		  RXE_DATE(data_wyst)
	  </td>   
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_brutto,"",2)
	  </td>
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_vat,"",2)
	  </td>
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_brutto_czesc,"",2)
	  </td>
	  <td align='right'>
		  RXE_QUANTITY_CVV(wart_vat_czesc,"",2)
	</td>  
  <% end if %>
</tr><%
end function
%>
<%
function body_header(byref pSection,byref pRec)
%>
<table border='1'>
<thead>
  <% if bEwidPomylek then %>
    <tr style='21'>
	    <td width='min' rowspan='2'><t>LP</t></td>
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Data]]></text>
	    </td>  
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Data sprzedaży]]></text>
	    </td>
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Nr paragonu]]></text>
	    </td>   
	    <td width='min' colspan='2'>
		    <text><![CDATA[Błędnie ewidencjonowana sprzedaż]]></text>
	    </td>
	    <td width='max' rowspan='2'>
		    <text><![CDATA[Przyczyny/okoliczności popełniania pomyłki]]></text>
	    </td>  
    </tr>
    <tr style='21'>
	    <td width='3500'>
		    <text><![CDATA[Wartość sprzedaży brutto]]></text>
	    </td>
	    <td width='3500'>
		    <text><![CDATA[Podatek należny]]></text>
	    </td>
    </tr>  
  <% else %>  
    <tr style='21'>
	    <td width='min' rowspan='2'><t>LP</t></td>
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Data sprzedaży]]></text>
	    </td>  
	    <td width='max' rowspan='2'>
		    <t><![CDATA[Nazwa towaru/usługi]]></t>
	    </td>
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Nr paragonu]]></text>
	    </td>
	    <td width='min' rowspan='2'>
		    <text><![CDATA[Termin zwrotu / reklamacji]]></text>
	    </td>   
	    <td width='min' colspan='2'>
		    <text><![CDATA[Zwrot całości należności]]></text>
	    </td> 
	    <td width='min' colspan='2'>
		    <text><![CDATA[Zwrot części należności]]></text>
	    </td>
    </tr>
    <tr style='21'>
	    <td width='min'>
		    <text><![CDATA[Wartość brutto towaru/usługi]]></text>
	    </td>
	    <td width='min'>
		    <text><![CDATA[Podatek należny]]></text>
	    </td>
	    <td width='min'>
		    <text><![CDATA[Zwracana kwota brutto]]></text>
	    </td>
	    <td width='min'>
		    <text><![CDATA[Podatek należny]]></text>
	    </td>  
    </tr>
  <% end if %>
</thead>
<tbody>
<%
end function
%>
<%
function body_footer(byref pSection)
%>
</tbody>
<tfoot>
<tr style='21'>
<% if bEwidPomylek then %>
  <td style='27' colspan='4' align='right'><t>RAZEM:</t></td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
  <td style='27'></td>
<% else %>
  <td style='27' colspan='5' align='right'><t>RAZEM:</t></td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(0).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(1).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(2).result)
	</td>
	<td style='27' align='right'>
		RXE_MONEY_VAR(pRapExec.body.counter(3).result)
	</td>  
<% end if %>  
</tr>
</tfoot>
</table>
<%
end function
%>
<%dim nSectionPicCounter : nSectionPicCounter = 10000000%>
function section_hideshow_hli(byref pHLI)
doc_.afc.formsection.section_hideshow page_, pHLI.prop(100)
end function
]]>
</script>
</config>
<header>
</header>
<body>
  <table>
    <tbody>
      <tr>
        <td>
          RAPORT_HEADER(3,1)
        </td>
      </tr>
      <tr><td><t/></td></tr>
      <%
      dim pRapExec : set pRapExec = rapeng_.new_engine()
      with pRapExec
      dim pParamArray : set pParamArray = default_param()
      rapeng_.merge_params pParamArray,rapeng_.get_raport_param()
      pRapExec.title = "RAPORT_TITLE"

      if rapeng_.show_raport_param_dialog(pParamArray,"RAPORT_TITLE") <> 0 then
      if pParamArray.value(0).selected.value(0) then
        bEwidPomylek = true
      end if

      pRapExec.put_final_query query()
      rapeng_.set_raport_param pParamArray

      .add_body_ex (getref("body_header"),getref("body_footer"),getref("body_row")).add_sumator("wart_brutto").add_sumator("wart_vat").add_sumator("wart_brutto_czesc").add_sumator("wart_vat_czesc")

      %>
      <tr>
        <td>          
          <table>
            <tbody>
              <tr>
                <td align="center">
                  <%
                  if bEwidPomylek then
                    so.write "<text fontsize='3' bold='true'>Ewidencja pomyłek</text><br/>"
                  else
                    so.write "<text fontsize='3' bold='true'>Ewidencja zwrotów towarów i uznanych reklamacji</text><br/>"
                  end if
                  %>
                </td>
              </tr>
              <tr>
                <td align="center">
                  <text>Nr ewidencyjny kasy fiskalnej:&nbsp;</text>
                  <%
                    dim strNrKasy: strNrKasy = pParamArray.value(8).first_value
                    so.write "<text fontsize='3'>" + strNrKasy + "</text><br/>" 
                  %>
                </td>
              </tr>
              <tr>
                <td align="center">
                  <text>Okres rozliczeniowy:&nbsp;</text>
                  <% so.write "<text fontsize='3'>" + GetOkres() + "</text><br/>" %>
                </td>
              </tr>
            </tbody>
          </table>
        </td>
      </tr>
      <tr>
        <td>
          <%
		        if not .perform then
              so.write "<t bold='true'>Brak danych spełniających podane kryteria</t>"
            end if
	        end if
          end with
          %>           
        </td>    
      </tr>
      ROW_SEPARATOR(1)
      ROW_SEPARATOR(1)
      ROW_SEPARATOR(1)
      <tr>
         <td>
            <table>
              <tbody>
                <tr>
                  <td align='center'>
                  </td>
                  <td width='max'></td>
                  <td align='center'>
                    <text><![CDATA[<% so.write getCurrentUser() %>]]></text>
                  </td>
                </tr>
                <tr>
                  <td align='center'>
                  </td>
                  <td></td>
                  <td align='center'>
                    <t>.........................................................................</t>
                  </td>
                </tr>
                <tr>
                  <td align='center'>
                  </td>
                  <td></td>
                  <td align='center'>
                    <t fontsize='2'>imię i nazwisko osoby wystawiającej dokument</t>
                  </td>
                </tr>
              </tbody>
            </table>           
         </td>
       </tr>
       <tr><td><t/></td></tr>
       <tr>
         <td align='left'>
           <t fontsize='2'>W załączeniu:</t>
         </td>
       </tr>
       <tr>
         <td align='left'>
           <t fontsize='2'>1. Dokumenty potwierdzające sprzedaż</t>
         </td>
       </tr>
       <tr>
         <td align='left'>
           <t fontsize='2'>2. Protokoły przyjęcia zwrotu towaru/uznanej reklamacji towaru/usługi.</t>
         </td>
       </tr>        
    </tbody>
  </table>
</body>
<footer>
</footer>
</page>
