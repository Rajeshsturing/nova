'-----------------------------------------------------------------------
' Pobiera Table Builder i pokazuje tabelke
'-----------------------------------------------------------------------
function Rules_GetTB()
	page_.ctrl(1).hide = false
	set Rules_GetTB = doc_.afc.new_tb(page_).attach(page_.ctrl(1)).removeall
end function

'-----------------------------------------------------------------------
' To nie wizzard Zawsze nothing
'-----------------------------------------------------------------------
function container()
	set container = nothing
end function

'-----------------------------------------------------------------------
' Umożliwia wybór odpowiedniego separatora i zwraca wynik wyboru
'-----------------------------------------------------------------------
function Rules_GetSeparator(byval strSeparators): Rules_GetSeparator = ""

	'Tablica separatorów
	dim pSeparators
	set pSeparators = Rules_GetConnector(strSeparators)

	'Dobieramy się do tabelki
	dim pTable
	set pTable = Rules_GetTB()

	dim i
	for i = 0 to pSeparators.UpperIndex()

		'Wstaw wiersz do tabelki
		pTable.newrow

		'Wstaw komorke i elementy
		pTable.newcell.addctrl CTRL_TYPE_STATIC, -1
		
		dim pStatic
		set pStatic = pTable.element
		pStatic.text = pSeparators.Value(i)
		pStatic.width = CLng(MAXIMIZE_SIZE)

		dim pShortCutHli
		set pShortCutHli = doc_.createhli()

		pShortCutHli.prop(GVAR_FUNCTIONHLI) = "Rules_ChoiceElem"
		pShortCutHli.prop(100) = CStr(pSeparators.Value(i))

		set pStatic.hli = pShortCutHli
	next

	if (page_.domodalauto()=CMD_CHOICE) then
		Rules_GetSeparator = getChoice()
	end if
end function

dim g_varChoice

'-----------------------------------------------------------------------
' Pobierz wynik dokonanego wyboru
'-----------------------------------------------------------------------
function getChoice()
	getChoice = g_varChoice
end function

'-----------------------------------------------------------------------
' Dokonano wyboru odpowiedniego elementu
'-----------------------------------------------------------------------
function Rules_ChoiceElem(byref pHli)
	g_varChoice = pHli.prop(100)
	page_.result = CMD_CHOICE
	page_.goback
end function

'-----------------------------------------------------------------------
' Wybór liczby currency
'-----------------------------------------------------------------------
function Rules_GetCurrency(): Rules_GetCurrency = false
	page_.topelement.title = "Podaj liczbę"
	page_.ctrl(500).hide = false
	
	page_.ctrl(3).hide = false
	page_.ctrl(2).value = CCur(0)

	if (page_.domodalauto()=CMD_CHOICE) then
		Rules_GetCurrency = true
		g_varChoice = CCur(page_.ctrl(2).value)
	end if
end function

'-----------------------------------------------------------------------
' Wybór daty
'-----------------------------------------------------------------------
function Rules_GetDate(): Rules_GetDate = false
	page_.topelement.title = "Podaj date"
	page_.ctrl(500).hide = false
	
	page_.ctrl(5).hide = false
	page_.ctrl(4).value = srvDate()

	if (page_.domodalauto()=CMD_CHOICE) then
		Rules_GetDate = true
		g_varChoice = CDate(page_.ctrl(4).value)
	end if
end function

'-----------------------------------------------------------------------
' Wybór tekstu bedącego wzorcem
'-----------------------------------------------------------------------
function Rules_GetString(): Rules_GetString = false
	page_.topelement.title = "Podaj wzorzec"
	page_.ctrl(500).hide = false
	
	page_.ctrl(7).hide = false
	page_.ctrl(6).value = ""

	if (page_.domodalauto()=CMD_CHOICE) then
		Rules_GetString = true
		g_varChoice = CStr(page_.ctrl(6).value)
	end if
end function

function fOK()
	page_.result = CMD_CHOICE
	page_.goback
end function

function fCancel()
	page_.result = 0
	page_.goback
end function

