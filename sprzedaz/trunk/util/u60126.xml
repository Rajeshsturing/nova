#include "h1000.h"

<?xml version="1.0" encoding="windows-1250" ?>
<page>
<config>
<script>
<!--
	Instalacja komponentów MAPI
-->
<![CDATA[

function install_mapi() : install_mapi = false
	dim instses : set instses = createobject("navoinstall.session")
	

	instses.setlogname "navoSPRZEDAZ - Components Setup log.txt"

	'1. copy files
	'msmapi32.ocx
	dim strSource : strSource = instses.getmediaurl("", "components\other\", "msmapi32.ocx", "Komponent MSMAPI")
	if strSource = "" then
	end if

	strSource = strSource + "components\other\"
	if not instses.installfile(strSource+"msmapi32.ocx",doc_.system.sysdir + "\msmapi32.ocx") then
		instses.addlogmsg "MSMAPI32.OCX copying failed. Error = " + CStr(instses.lasterror)
		exit function
	end if
	
	'comcat.dll
	if not instses.installfile(strSource + "comcat.dll", doc_.system.sysdir + "\comcat.dll") then
		instses.addlogmsg "COMCAT.DLL copying failed. Error = " + CStr(instses.lasterror)
		exit function
	end if

	'2. register file
	'msmapi32.ocx
	dim nRegRes : nRegRes = doc_.system.registerdll(doc_.system.sysdir + "\msmapi32.ocx")
	if nRegRes <> 0 then
		instses.addlogmsg "MSMAPI32.OCX registration failed. Error = " + CStr(nRegRes)
		exit function
	end if

	'3. register licence
	doc_.system.registry(hKey_ClassesRoot,"Licenses\899B3E80-6AC6-11cf-8ADB-00AA00C00905","") = "wjsjjjlqmjpjrjjjvpqqkqmqukypoqjquoun"
	install_mapi = true
end function

]]>
</script>
</config>
	<body>
		<t>Instalacja komponentów MAPI</t>
	</body>
</page>
