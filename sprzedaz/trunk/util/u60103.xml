dim bFormatText		'true jeżeli tekst ma być formatowany spacjami
					'false gdy ma być formatowany tabami

function fopen()
	bFormatText=true
	fopen=true
end function

function DontFormatWithSpaces()
	bFormatText=false
end function

'---------------------------------------------------------------------
'informacja o eksporcie do pliku tekstowego
'---------------------------------------------------------------------
class CTextInfo
	public nChars
	public bWriteToStream
	public strComposedText
	public nTable	'zaglebienie w tabelce

	private sub class_initialize()
		nChars=clng( 0 )
		bWriteToStream=true
		strComposedText=""
		nTable=0
	end sub

end class

dim pTextInfo

'---------------------------------------------------------------------
'Rozpocznij eksport naglowka strony jako HTML
'---------------------------------------------------------------------
function text_header(byref pPage, byref pStream)
	pStream.write UCase( pPage.topelement.title ) + vbNewLine + vbNewLine
end function

'---------------------------------------------------------------------
'Ekportuj poszczegolne elementy strony
'---------------------------------------------------------------------
function text_elems(byref pPage, byref pStream)
	text_single_elem pPage, pStream, pPage.topelement
end function

'---------------------------------------------------------------------
'Eksport kontrolki z property text
'---------------------------------------------------------------------
function text_text(byref pStream, byref pCtrl)
	dim strValue
	if (pCtrl.type = CTRL_TYPE_INTEDIT) then
		strValue = CStr(pCtrl.value)
	else
		strValue = pCtrl.text
	end if

	text_write pStream, strValue + " "
	text_update_chars len( strValue )
end function

'---------------------------------------------------------------------
'Waluta
'---------------------------------------------------------------------
function text_currency(byref pStream, byref pCtrl)
	text_write pStream, doc_.afc.display.money(pCtrl.value, "") + " "
	text_update_chars len( cstr(pCtrl.value) )
end function

'---------------------------------------------------------------------
'Eksportuj date
'---------------------------------------------------------------------
function text_date(byref pStream, byref pCtrl)
	text_write pStream, CStr(pCtrl.value) + " "
	text_update_chars len( CStr(pCtrl.value) )
end function

'---------------------------------------------------------------------
'Zejscie linie nizej
'---------------------------------------------------------------------
function text_br(byref pStream, byref pCtrl)
	text_write pStream, vbNewLine
end function

'---------------------------------------------------------------------
'Eksport multiline
'---------------------------------------------------------------------
function text_multiline(byref pStream, byref pCtrl)

	dim strMultiText:strMultiText=pCtrl.value
	dim strNewMulti:strNewMulti=""

	do
		dim strLine, bWasNewLine: bWasNewLine=false
		
		if (len(strMultiText)>=40) then
			
			dim nCutPlus: nCutPlus=0
			if (Asc(mid(strMultiText, 40, 40))=13) then
				nCutPlus=1
			end if

			strLine=mid(strMultiText, 1, 40+nCutPlus)
			strMultiText=mid(strMultiText, 41+nCutPlus, len(strMultiText)-40+nCutPlus)
		else
			strLine=strMultiText
			strMultiText=""
		end if
		strNewMulti=strNewMulti+strLine+vbNewLine
		
	loop until len(strMultiText)=0

	text_write pStream, strNewMulti
	text_update_chars len( strMultiText )
end function

'---------------------------------------------------------------------
' Eksport richedit'a
'---------------------------------------------------------------------
function text_richedit(byref pStream, byref pCtrl)
	dim so
	set so = doc_.createstreamobj
	so.attach pCtrl.value

	dim strMultiText:strMultiText=so.getstring
	dim strNewMulti:strNewMulti=""

	do
		dim strLine

		if (len(strMultiText)>=40) then
			strLine=mid(strMultiText, 1, 40)
			strMultiText=mid(strMultiText, 41, len(strMultiText)-41)
		else
			strLine=strMultiText
			strMultiText=""
		end if
		strNewMulti=strNewMulti+strLine+vbNewLine

	loop until len(strMultiText)=0

	text_write pStream, strNewMulti
	text_update_chars len( strMultiText )
end function

