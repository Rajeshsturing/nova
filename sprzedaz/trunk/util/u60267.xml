		<t name='t##ID_STATIC_PROGRESS' align='center' width='max'></t>
		<br/>
		<t/><br/>
	</p>
	
	<table name='t##ID_TABLE_RESULT' border='1'>
		<thead style='STYLE_TABLE_HEADER'>
			<tr>
				<td colspan='2'>
					<t>Wyniki sprawdzania reguł</t>
				</td>
			</tr>
		</thead>

		<tbody style='STYLE_TABLE_BODY'>
		</tbody>
	</table>

</body>

