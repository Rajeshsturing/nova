#define ID_TABLE_RESULT			100
#define ID_CONTAINER_BREAK		101
#define ID_BUTTON_BREAK			102
#define ID_STATIC_PROGRESS		103

<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE'>
<config>
<title>Sprawdzanie reguł</title>
<script>
<![CDATA[

#include "50623"
#include "50625"

'-----------------------------------------------------------------------
' (c) 2002 NAVO Ltd.
