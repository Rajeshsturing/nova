function showHelp(byval strHelpText)
	page_.ctrl(ID_DOC_HELP).text=strHelpText
	page_.ctrl(ID_DOC_HELP_FRAME).hide=false
end function

'----------------------------------------------------------------------
'wolane z zewnatrz - pokazuje okienko i w zaleznosci od tego co
'zostanie wybrane wypozycza (edit) lub robi view
'----------------------------------------------------------------------
function SSDocument(byref pDocument): SSDocument=false
	dim pFD, bOK
	set pFD=CFileDrive(bOK)

	if (not bOK) then
		' 1, 0, "Nie udało się utworzyć obiektu ""FileSystemObject"""
		view_message 6161, 0
		exit function
	end if

	page_.ctrl(ID_DOC_NAME).text="""" + pDocument.strTematDokum + """"
	page_.ctrl(ID_DOC_HELP_FRAME).hide=true
	page_.ctrl(ID_DETAILT).hide=true

	'---------------------------------------------------------
	'wypelnij zmienne globalne dla dodatkowych informacji
	'---------------------------------------------------------
	strNumDok=pDocument.strNumDok
	if (not pDocument.pTypDokumentu is nothing) then
		strTypDok=pDocument.pTypDokumentu.strNazwa
	else
		strTypDok="<nie określono>"
	end if

	if (not pDocument.fPlik.isEmpty()) then
		strFileName=pFD.GetFileName(RemoveComputerName(pDocument.strFileName))
	else
		strFileName="<brak pliku>"
	end if

	if (not pDocument.pUzytkWypoz is nothing) then
		strCheckedOutAs=FormatPathWithCompName(pDocument.strCheckoutFileName)
	else
		strCheckedOutAs="<dokument nie został wypożyczony>"
	end if
	
	'---------------------------------------------------------
	'dokument nie posiada pliku
	'---------------------------------------------------------
	if (pDocument.fPlik.isEmpty()) then
		page_.ctrl(ID_BTN_VIEW).disable=true
		page_.ctrl(ID_BTN_EDIT).disable=true

		showHelp "Wybrany przez Ciebie dokument nie posiada pliku. Jego edycja/podgląd nie jest możliwa."
	end if

	'---------------------------------------------------------
	'dokument zostal wypozyczony przez kogos
	'---------------------------------------------------------
	if (not pDocument.pUzytkWypoz is nothing) then
		'i user inny od nas
		if (pDocument.pUzytkWypoz.idobj<>getCurrentUserID()) then
			page_.ctrl(ID_BTN_EDIT).disable=true
			showHelp "Wybrany przez Ciebie dokument jest wypożyczony przez """ + pDocument.pUzytkWypoz.strNazwa + """. Edycja nie będzie możliwa."
		end if
	end if

	'---------------------------------------------------------
	'otwarcie strony i rekacja na otwracie
	'---------------------------------------------------------
	dim nResult
	nResult=page_.domodalauto()

	if (nResult=0 or nResult=CMD_GOBACK) then
		exit function
	end if

	if (nResult=CMD_EDIT) then
		SSDocument=Edit(pDocument)
	elseif (nResult=CMD_VIEW) then
		SSDocument=View(pDocument)
	end if

end function

function back(byref pHli)
	page_.result=clng( pHli.prop(100) )
	page_.goback
end function

function details()
	page_.ctrl(ID_DETAILT).hide=(not page_.ctrl(ID_DETAILT).hide)
	if (page_.ctrl(ID_DETAILT).hide) then
		page_.ctrl(ID_BTN_DETAIL).text="Szczegóły >>>"
	else
		page_.ctrl(ID_BTN_DETAIL).text="Szczegóły <<<"
	end if
end function

dim strNumDok
dim strTypDok
dim strFileName
dim strCheckedOutAs

function fopen()
	strNumDok=""
	strTypDok=""
	strFileName=""
	strCheckedOutAs=""

	fopen=true
end function

function c201_ongetdata(ctrl)
	ctrl.text=strNumDok
	c201_ongetdata=true
end function

function c202_ongetdata(ctrl)
	ctrl.text=strTypDok
	c202_ongetdata=true
end function

function c203_ongetdata(ctrl)
	ctrl.text=strFileName
	c203_ongetdata=true
end function

function c204_ongetdata(ctrl)
	ctrl.text=strCheckedOutAs
	c204_ongetdata=true
end function

