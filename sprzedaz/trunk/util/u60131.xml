#define PAGE_WIZZARD_EXPORT_BUSSINESSCARD_STEP1			20410
#define PAGE_WIZZARD_EXPORT_BUSSINESSCARD_STEP2			20411
#define PAGE_WIZZARD_EXPORT_BUSSINESSCARD_STEP3			20412
#define PAGE_WIZZARD_EXPORT_BUSSINESSCARD_RESUM			20413


