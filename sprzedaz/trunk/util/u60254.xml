class CTasksWzrd

	public m_nTypeID
	public m_nIdObj
	public m_nDest
	public m_strName
	public m_strWhere

	public m_nIdObj_wyk
	public m_nDest_wyk
	public m_strName_wyk
	public m_strWhere_wyk

	public m_nTaskID

	public m_nObjectCounter

	public pZadanie
	public pZadanie_New

	public m_nPrzydzial
	public m_bDedyk

	public m_nCountC
	public m_nCountW


	private sub Class_Initialize()
		m_nDest = clng(1)
		m_nObjectCounter = 1
		m_nTypeID = TYPEID_N5KLIENT
		m_nIdObj = 0

		m_nIdObj_wyk = 0
		m_nDest_wyk = clng(1)

		m_nTaskID = 0


		set pZadanie = nothing
		set pZadanie_New = trans_.newobj(TYPEID_N5ZADANIE)
		pZadanie_New.nStatus = clng(0)
		pZadanie_New.dDataRozp = srvDate
		pZadanie_New.tCzasRozp = srvTime
		pZadanie_New.dDataZakon = srvDate
		pZadanie_New.tCzasZakon = srvTime


		m_nPrzydzial = clng(1)
		m_bDedyk = "1"


	end sub

end class


function count_clients()

	dim cursor:set cursor = trans_.createrawcursor(TYPEID_N5KLIENT , pParamClass.m_strWhere , "" , "" )

	dim i:i = 0

	do

		if cursor.exists(i+1) then
			i = i + 1
		else
			exit do
		end if

	loop


	count_clients = i
	pParamClass.m_nCountC = count_clients

end function



function count_wyk()

	dim strQuery:strQuery = "select max(n5wykonawca.idobj) , count(n5zadanie.idobj) from n5wykonawca left outer join n5zadanie on n5zadanie.pWykonawca = n5wykonawca.idobj LEFT OUTER JOIN n5pracownik f60114n1 ON f60114n1.IdObj = n5wykonawca.wrefObiekt  LEFT OUTER JOIN n5klient_pracownik f60114n2 ON f60114n2.IdObj = n5wykonawca.wrefObiekt LEFT OUTER JOIN n5klient f60114n3 ON f60114n3.IdObj = n5wykonawca.wrefObiekt %WHERE% group by n5wykonawca.idobj order by 2"	

	dim strWhere:strWhere = ""
	if pParamClass.m_strWhere_wyk <> "" then
		strWhere = " where " + pParamClass.m_strWhere_wyk
	end if
	strQuery = replace(strQuery , "%WHERE%" , strWhere)
	dim rs:set rs = trans_.createadors(strQuery)

	count_wyk = clng(rs.RecordCount)

	pParamClass.m_nCountW = count_wyk

end function

private function max_tasks()
	max_tasks = 0
end function

private function min_tasks()
	min_tasks = 0
end function


dim pParamClass

function fopen()
	if HARUI(UAR_CMDID(CMDID_WIZZARD_PRZYDZIAL_ZADAN)) then
		run_this
	end if
	fopen=false
end function

function run_this()

	if (getCurrentWykonawca() is nothing) then
		if MessageBoxCustom ("Aktualnie zalogowany użytkownik nie ma podanego domyślnego wykonawcy. Naciśnij ""OK"" jeśli chcesz zakończyć działanie kreatora.", "Kreator przydziału zadań", vbYesNo, vbQuestion ,"OK;Popraw") = vbYes then
			exit function
		else
			doc_.getmodule(60129).form_domodal TYPEID_N5UZYTKOWNIK , getCurrentUserID() , USAGE_USER_MY_DATA
		end if		
	end if
	
	'pytamy się o konkretny rejestr typu nRejTyp
	dim idRejestr : idRejestr = choose_rejestr_dok("N5REJESTRDOK_ZADANIA", true , "Wybierz rejestr zadan")
	if idRejestr <= 0 then
		exit function
	end if
	
	trans_.var(APPVAR_REJESTR_TYP) = trans_.getobj(TYPEID_N5REJESTRDOK,idRejestr).eTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = idRejestr


	dim pWizzard
	set pParamClass = new CTasksWzrd
	set pWizzard=CWizzard(false)
	pWizzard.add_container pParamClass
	pWizzard.add_step PAGE_FORM_WIZZARD_TASKS_STEP1
	pWizzard.add_step PAGE_FORM_WIZZARD_TASKS_STEP2
	pWizzard.add_step PAGE_FORM_WIZZARD_TASKS_STEP3
	pWizzard.add_step PAGE_FORM_WIZZARD_TASKS_STEP4
	pWizzard.add_step PAGE_FORM_WIZZARD_TASKS_STEP5

	pWizzard.run
end function

function onPageEnter(byref pWizzardPage)
	select case ( pWizzardPage.m_nPage )
		case PAGE_FORM_WIZZARD_TASKS_STEP1:
		case PAGE_FORM_WIZZARD_TASKS_STEP2:
		case PAGE_FORM_WIZZARD_TASKS_STEP3:
			pWizzardPage.m_pPage.fill_zal_table
		case PAGE_FORM_WIZZARD_TASKS_STEP4:			
		case PAGE_FORM_WIZZARD_TASKS_STEP5:

			pWizzardPage.m_pPage.ctrl(100).text = cstr(pParamClass.m_nCountC)
			pWizzardPage.m_pPage.ctrl(101).text = cstr(pParamClass.m_nCountW)

			pWizzardPage.m_pPage.ctrl(104).text = cstr(max_tasks)
			pWizzardPage.m_pPage.ctrl(105).text = cstr(min_tasks)

	end select
end function

function onPageExit(pWizzardPage)

	onPageExit=PAGE_DEFAULT

	dim pRaport
	dim pList
	dim pPM
	dim strColumns, strDescription, strIds
	dim strJoin, strWhere, strOrderBy, strGroupBy
	dim strButtons

	dim elem


	select case ( pWizzardPage.m_nPage )
		case PAGE_FORM_WIZZARD_TASKS_STEP1:
			if pWizzardPage.m_pPage.is_empty() then
				MessageBox "Nic nie wybrano" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			else
				select case pParamClass.m_nDest
					case 3:			
						'uruchom raport i pobierz z niego czesci 
						'zapytania
						set pRaport = trans_.getobj(TYPEID_SEARCHTYPE,pParamClass.m_nIdObj)
						if pRaport is nothing then
							onPageExit = PAGE_DONOTEXIT
							exit function
						end if
						set pPM = doc_.getmodule(60114)
						strButtons = "OK"

						if (pPM.get_search_filter_result(pRaport, _
						strButtons, strColumns, _
						strJoin, _
						strWhere, _
						strOrderBy, _
						strGroupBy, _
						strDescription, strIds)<>1) then
							MessageBox "Musisz podać kryteria raportu i następnie go zastosować." , "Nie zastosowano raportu.", vbOKOnly, vbInformation
							onPageExit=PAGE_DONOTEXIT
							exit function
						end if						
						pParamClass.m_strWhere = strWhere

					case 2:
						set pList = trans_.getobj(TYPEID_CHOICELIST,pParamClass.m_nIdObj)
						if pList is nothing then
							onPageExit = PAGE_DONOTEXIT
							exit function
						end if
						pParamClass.m_strWhere = " idobj=0 "
						for each elem in pList.listElement
							pParamClass.m_strWhere = pParamclass.m_strWhere + " or idobj=" + cstr(elem.idElement)
						next
					case 1:
						pParamClass.m_strWhere = " eAktywny=1 "																								
				end select
			end if
			if count_clients = 0 then
				MessageBox "Żaden klient nie odpowiada wybranemu kryterium selekcji" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			end if
		case PAGE_FORM_WIZZARD_TASKS_STEP2:
			if pWizzardPage.m_pPage.is_empty() then
				MessageBox "Nic nie wybrano" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			else
				select case pParamClass.m_nDest_wyk
					case 3:			
						'uruchom raport i pobierz z niego czesci 
						'zapytania
						set pRaport = trans_.getobj(TYPEID_SEARCHTYPE,pParamClass.m_nIdObj_wyk)
						if pRaport is nothing then
							onPageExit = PAGE_DONOTEXIT
							exit function
						end if
						set pPM = doc_.getmodule(60114)
						strButtons = "OK"						

						if (pPM.get_search_filter_result(pRaport, _
						strButtons, strColumns, _
						strJoin, _
						strWhere, _
						strOrderBy, _
						strGroupBy, _
						strDescription, strIds)<>1) then
							MessageBox "Musisz podać kryteria raportu i następnie go zastosować." , "Nie zastosowano raportu.", vbOKOnly, vbInformation
							onPageExit=PAGE_DONOTEXIT
							exit function
						end if						
						pParamClass.m_strWhere_wyk = strWhere

					case 2:

						set pList = trans_.getobj(TYPEID_CHOICELIST,pParamClass.m_nIdObj_wyk)
						if pList is nothing then
							onPageExit = PAGE_DONOTEXIT
							exit function
						end if
						pParamClass.m_strWhere_wyk = " n5wykonawca.idobj in (0 "
						for each elem in pList.listElement
							pParamClass.m_strWhere_wyk = pParamclass.m_strWhere_wyk + ", " + cstr(elem.idElement)
						next
						pParamClass.m_strWhere_wyk = pParamClass.m_strWhere_wyk + ") "
					case 1:
						pParamClass.m_strWhere_wyk = " f60114n1.eAktywny = 1 OR f60114n2.eAktywny = 1 OR f60114n3.eAktywny = 1 "
				end select				
			end if
			if count_wyk = 0 then
				MessageBox "Żaden wykonawca nie odpowiada wybranemu kryterium selekcji" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			end if
		case PAGE_FORM_WIZZARD_TASKS_STEP3:

			if pWizzardPage.m_pPage.is_empty() then
				MessageBox "Nic nie wybrano" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			end if

			if not pWizzardPage.m_pPage.can_save() then
				MessageBox "Zadania nie da się zapisać" , "Kreator przydziału zadań" , vbOkOnly, vbInformation
				onPageExit = PAGE_DONOTEXIT
			end if
		case PAGE_FORM_WIZZARD_TASKS_STEP4:
		case PAGE_FORM_WIZZARD_TASKS_STEP5:
	end select
end function

function onPageInit(pWizzardPage)
	select case ( pWizzardPage.m_nPage )
		case PAGE_FORM_WIZZARD_TASKS_STEP1:
		case PAGE_FORM_WIZZARD_TASKS_STEP2:
		case PAGE_FORM_WIZZARD_TASKS_STEP3:
		case PAGE_FORM_WIZZARD_TASKS_STEP4:
		case PAGE_FORM_WIZZARD_TASKS_STEP5:
	end select
end function



function onWizzardComplete(pWizzardPage)	
	onWizzardComplete=false


	dim perf : set perf = doc_.performing("Trwa przydzielanie zadań")
	
	dim iter_w
	dim wyk:set wyk = getCurrentWykonawca()
	dim w
	dim pUsed:set pUsed = trans_.afc.new_navoarray()
	dim pTemplateTask
	if pParamClass.m_nTaskID then
		set pTemplateTask = pParamClass.pZadanie
	else
		set pTemplateTask = pParamClass.pZadanie_New
		pTemplateTask.ignore = true
	end if
	pParamClass.pZadanie_New.ignore = true
	set pParamClass.pZadanie = nothing
	
	dim cursor_c:set cursor_c = trans_.createrawcursor(TYPEID_N5KLIENT , pParamClass.m_strWhere , "" , "" )
	dim elem_c
	
	if pParamClass.m_nPrzydzial=1 then
		dim cursor_w:set cursor_w = trans_.createrawcursor(TYPEID_N5WYKONAWCA , pParamClass.m_strWhere_wyk , "" , doc_.getmodule(60115).trim_first_join("join n5wykonawca f on f.idobj = n5wykonawca.idobj LEFT OUTER JOIN n5pracownik f60114n1 ON f60114n1.IdObj = n5wykonawca.wrefObiekt  LEFT OUTER JOIN n5klient_pracownik f60114n2 ON f60114n2.IdObj = n5wykonawca.wrefObiekt LEFT OUTER JOIN n5klient f60114n3 ON f60114n3.IdObj = n5wykonawca.wrefObiekt") )
		iter_w = 1
		cursor_w.forwardonly = false
	else

		dim strQuery:strQuery = "select max(n5wykonawca.idobj) , count(n5zadanie.idobj) from n5wykonawca left outer join n5zadanie on n5zadanie.pWykonawca = n5wykonawca.idobj LEFT OUTER JOIN n5pracownik f60114n1 ON f60114n1.IdObj = n5wykonawca.wrefObiekt  LEFT OUTER JOIN n5klient_pracownik f60114n2 ON f60114n2.IdObj = n5wykonawca.wrefObiekt LEFT OUTER JOIN n5klient f60114n3 ON f60114n3.IdObj = n5wykonawca.wrefObiekt %WHERE% group by n5wykonawca.idobj order by 2"
		dim strWhere:strWhere = ""
		if pParamClass.m_strWhere_wyk <> "" then
			strWhere = " where " + pParamClass.m_strWhere_wyk
		end if
		strQuery = replace(strQuery , "%WHERE%" , strWhere)
		dim rs:set rs = trans_.createadors(strQuery)
		iter_w = clng(rs.fields(1).value) ' watchdog
	end if

	dim elem_w	
		
	for each elem_c in cursor_c

		dim pZadanie
		set pZadanie = trans_.newobj(TYPEID_N5ZADANIE)

		pZadanie.strTemat = pTemplateTask.strTemat
		pZadanie.strOpis = pTemplateTask.strOpis
		pZadanie.dDataZlec = pTemplateTask.dDataZlec
		pZadanie.dDataRozp = pTemplateTask.dDataRozp
		pZadanie.dDataZakon = pTemplateTask.dDataZakon
		pZadanie.dDataPrzyp = pTemplateTask.dDataPrzyp

		pZadanie.eTypTerminRozp = pTemplateTask.eTypTerminRozp
		pZadanie.eTypTerminZak = pTemplateTask.eTypTerminZak
		pZadanie.ePriorytet = pTemplateTask.ePriorytet

		pZadanie.tCzasRozp = pTemplateTask.tCzasRozp
		pZadanie.tCzasZakon = pTemplateTask.tCzasZakon
		pZadanie.tCzasPrzyp = pTemplateTask.tCzasPrzyp

		pZadanie.nStatus = clng(N5ZADANIE_ZLECONE)

		set pZadanie.pTypDzialania = pTemplateTask.pTypDzialania
		set pZadanie.pZlecajacy = getCurrentWykonawca()
		dim zal,zal_new
		for each zal in pTemplateTask.listZalaczniki
			set zal_new =  pZadanie.listZalaczniki.addnew
			set zal_new.wrefZal = zal.wrefZal
		next

		set pZadanie.pKlient = elem_c
		
		if pParamClass.m_nPrzydzial = 1 then ' przydział równomierny

			
			if pParamClass.m_bDedyk then ' najpierw dedykowany
				if not elem_c.pPracownik is nothing then
					set w = getWykonawcaFromPracownik(elem_c.pPracownik)
					if not w is nothing then
						set pZadanie.pWykonawca = w
						pUsed.add(w.idobj)						
					end if			
				end if
			end if

			if pZadanie.pWykonawca is nothing then
				do
					if not cursor_w.exists(iter_w) then
						pUsed.removeAll
						iter_w = 1						
					end if

					set elem_w = cursor_w.get(iter_w)
					iter_w = iter_w + 1	

				loop until not pUsed.exists(elem_w.idobj)

				set pZadanie.pWykonawca = elem_w
				
			end if
			
		else


			if pParamClass.m_bDedyk then ' najpierw dedykowany
				if not elem_c.pPracownik is nothing then
					set w = getWykonawcaFromPracownik(elem_c.pPracownik)
					if not w is nothing then
						set pZadanie.pWykonawca = w
					end if			
				end if
			end if

			if pZadanie.pWykonawca is nothing then
				set w = trans_.getobj(TYPEID_N5WYKONAWCA , clng(rs.fields(0).value))
				set pZadanie.pWykonawca = w
				if rs.absoluteposition = rs.recordCount then
					rs.movefirst
				else
					rs.movenext
				end if
				if iter_w < clng(rs.fields(1).value) then
					iter_w = iter_w + 1
					rs.movefirst
				end if
			end if 

						
		end if
		
	next

	set perf = nothing	

	if MessageBox ("Stworzono zadania - czy napewno chcesz je zapisać?", "Kreator przydziału zadań", vbYesNo, vbQuestion) = vbYes then		
		set perf = doc_.performing("Trwa zapis zadań")
		onWizzardComplete=trans_.saveobjects()
		set perf = nothing	
	else
		onWizzardComplete=false
	end if
		

	if not onWizzardComplete then
		MessageBox "Działanie kreatora zakończyło się niepowodzeniem - nie udało się zapisać zadań lub zapis został anulowany" , "Kreator przydziału zadań" , vbOkOnly, vbInformation		
	else
		MessageBox "Działanie kreatora zakończyło się pomyślnie" , "Kreator przydziału zadań" , vbOkOnly, vbInformation		
	end if
end function

private function getWykonawcaFromPracownik(pracownik)
	set getWykonawcaFromPracownik = nothing
	dim wyk_id:wyk_id = trans_.findobjid(TYPEID_N5WYKONAWCA, "wrefObiekt="+cstr(pracownik.idobj)+" and wrefObiekt_wrt=TYPEID_N5PRACOWNIK")
	if wyk_id > 0 then 
		set getWykonawcaFromPracownik = trans_.getobj(TYPEID_N5WYKONAWCA , wyk_id)
	end if
end function





]]>
</script>
