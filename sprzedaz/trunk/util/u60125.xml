#define CMD_REGISTER	3002


#define PAGE_WIZZARD_WYSYLKI_STEP1				20305
#define PAGE_WIZZARD_WYSYLKI_STEP2				20306
#define PAGE_WIZZARD_WYSYLKI_STEP3				20307
#define PAGE_WIZZARD_WYSYLKI_STEP4				20309
#define PAGE_WIZZARD_WYSYLKI_STEP5				20310


