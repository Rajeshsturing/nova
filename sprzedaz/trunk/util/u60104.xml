#include "h1000.h"
#include "h1001.h"

<?xml version="1.0" encoding="windows-1250" ?>
<page>
<config>
<script>
<!--
	Eksport strony w postaci XML
-->
<![CDATA[

#include "50126"

class CExpXMLContext

	public m_nID	'aktualny identyfikator kontrolki
	public m_pfopen_SO

	private sub class_initialize()
		set m_pfopen_SO = doc_.createstreamobj()
		m_nID = CLng(0)
	end sub

	private sub class_terminate()   'OK
		set m_pfopen_SO = nothing
	end sub

	public function getSetID()
		m_nID = m_nID + 1
		getSetID = CLng(m_nID)
	end function

	public function getCurrentID()
		getCurrentID = CLng(m_nID)
	end function

	public function add2fopen(byval strFopenCode)
		m_pfopen_SO.write CStr(strFopenCode)
	end function

end class

public function convert_rgb(byval rgbval)
    convert_rgb = CLng(CLng(rgbval Mod 256) * 65536 + CLng((rgbval \ 256) Mod 256) * 256 + CLng(rgbval \ 65536))
end function

function write_ident(byref pCtrl,byref pCtxt, byval bBackColor) :write_ident = ""

	write_ident = write_ident + "name='i" + CStr(pCtxt.getSetID()) + "' "

	if (bBackColor) then
		write_ident = write_ident + "backcolor='#" + Hex(convert_rgb(pCtrl.backcolor)) + "'" + _
			"backcolor2='#" + Hex(convert_rgb(pCtrl.backcolor2)) + "'"
	end if
	
	write_ident = write_ident + "forecolor='#" + Hex(convert_rgb(pCtrl.forecolor)) + "'" + _
		"bordercolor='#" + Hex(convert_rgb(pCtrl.bordercolor)) + "'" + _
		"style='" + CStr(pCtrl.styleitem) + "' " + _
		"border='" + CStr(pCtrl.border) + "' " + _
		"borderwidth='" + CStr(pCtrl.borderwidth) + "' " + _
		"fontsize='" + CStr(pCtrl.fontsize) + "' "
			
	if (pCtrl.bold) then
		write_ident = write_ident + " bold='true' "
	end if

	if (pCtrl.underline) then
		write_ident = write_ident + " underline='true' "
	end if

	if (pCtrl.italic) then
		write_ident = write_ident + " italic='true' "
	end if

	if (pCtrl.strike) then
		write_ident = write_ident + " strike='true' "
	end if

	if (pCtrl.readonly) then
		write_ident = write_ident + " readonly='true' "
	end if

	if (pCtrl.disable) then
		write_ident = write_ident + " disable='true' "
	end if

end function

function write_common(byref pCtrl,byref pCtxt)
	write_common = write_ident(pCtrl, pCtxt, true)
end function

function write_common2(byref pCtrl,byref pCtxt)
	write_common2 = write_ident(pCtrl, pCtxt, false)
end function

sub exp_start(byref pSO, byref pCtxt, byref pPage)
	pSO.write "<?xml version=""1.0"" encoding=""windows-1250"" ?>"+ vbCrLf

	pSO.write "<page " + write_common(pPage,pCtxt) + ">"+ vbCrLf
	exp_config pSO, pPage, pCtxt
	pSO.write "<body>"+ vbCrLf
end sub

sub exp_end(byref pSO,byref pCtxt)
	pSO.write "</body>"+ vbCrLf
	pSO.write "</page>"+ vbCrLf
end sub

sub exp_config(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<config srcapp='#*varApplication'>"
	pSO.write "<title>" + pCtrl.title + "</title>"

	pSO.write "<script>" + vbNewLine
	pSO.write "<![CDA" + "TA[" + vbNewLine
	pSO.write "function fopen()" + vbNewLine

	pCtxt.m_pfopen_SO.copyto pSO

	pSO.write "fopen=true" + vbNewLine
	pSO.write "end function" + vbNewLine
	pSO.write "]" + "]>" + vbNewLine
	pSO.write "</script>" + vbNewLine

	pSO.write "</config>"
end sub

sub exp_pageman(byref pSO, byref pCtrl,byref pCtxt)

	dim pElement
	for each pElement in pCtrl
		exp_element pSO,pElement,pCtxt
	next

end sub

sub exp_paragraph(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<p " + write_common(pCtrl, pCtxt) + ">"
	dim pElement
	for each pElement in pCtrl
		exp_element pSO,pElement,pCtxt
	next
	pSO.write "</p>"
end sub

sub exp_cell(byref pSO,byref pCell,byref pCtxt)
	if pCell.hide then
		exit sub
	end if
	pSO.write "<td " + write_common(pCell,pCtxt)
	if pCell.colspan > 1 then
		pSO.write " colspan='"+cstr(pCell.colspan) + "' "
	end if

	if pCell.rowspan > 1 then
		pSO.write " rowspan='"+cstr(pCell.rowspan) + "' "
	end if

	pSO.write ">"
	dim pElement
	for each pElement in pCell
		exp_element pSO,pElement,pCtxt
	next
	pSO.write "</td>" + vbCrLf
end sub

sub exp_row(byref pSO,byref pRow,byref pCtxt)
	if pRow.hide then
		exit sub
	end if

	pSO.write "<tr " + write_common(pRow,pCtxt) + ">"

	dim pCell
	for each pCell in pRow
		exp_cell pSO,pCell,pCtxt
	next
	
	pSO.write "</tr>" + vbCrLf
end sub

sub exp_tablesection(byref pSO,byref pSection,byref pCtxt)
	dim pRow
	for each pRow in pSection
		exp_row pSO, pRow, pCtxt
	next
end sub

sub exp_table(byref pSO,byref pCtrl,byref pCtxt)
	pSO.write "<table " + write_common(pCtrl,pCtxt)
	pSO.write ">" + vbCrLf
	
	pSO.write "<thead>" + vbCrLf
		exp_tablesection pSO, pCtrl.header, pCtxt
	pSO.write "</thead>" + vbCrLf

	pSO.write "<tbody>" + vbCrLf
		exp_tablesection pSO, pCtrl.body, pCtxt
	pSO.write "</tbody>" + vbCrLf

	pSO.write "<tfooter>" + vbCrLf
		exp_tablesection pSO, pCtrl.footer, pCtxt
	pSO.write "</tfooter>" + vbCrLf

	pSO.write "</table>" + vbCrLf
end sub

sub exp_checkbox_radio(byref pSO, byref pCtrl,byref pCtxt)

	if pCtrl.type = CTRL_TYPE_RADIO then
		pSO.write "<radio " + write_common(pCtrl,pCtxt) + " >"
	else
		pSO.write "<checkbox " + write_common(pCtrl,pCtxt) + " >"
	end if

	dim pElement
	for each pElement in pCtrl
		exp_element pSO,pElement,pCtxt
	next
	if pCtrl.type = CTRL_TYPE_RADIO then
		pSO.write "</radio>"
	else
		pSO.write "</checkbox>"
	end if
end sub

sub exp_static(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<t " + write_common2(pCtrl,pCtxt) + " ><![CD"+"ATA["
	pSO.write pCtrl.text
	pSO.write "]"+"]></t>"
end sub

sub exp_staticex(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<text " + write_common2(pCtrl,pCtxt) + " ><![CD"+"ATA["
	pSO.write pCtrl.text
	pSO.write "]"+"]></text>"
end sub

sub exp_button(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<button " + write_common2(pCtrl, pCtxt) + " ><![CD"+"ATA["
	pSO.write pCtrl.text
	pSO.write "]"+"]></button>"
end sub

sub exp_br(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<br/>"+ vbCrLf
end sub

sub exp_edit(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<edit " + write_common(pCtrl, pCtxt) + " size='" + CStr(pCtrl.size) + "'><![CD"+"ATA["
	pSO.write pCtrl.value
	pSO.write "]"+"]></edit>"
end sub

sub exp_multiline(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<multiline " + write_common(pCtrl, pCtxt) + " width='" + CStr(pCtrl.width) + "' height='" + CStr(pCtrl.height) + "'><![CD"+"ATA["
	pSO.write pCtrl.value
	pSO.write "]"+"]></multiline>"
end sub

sub exp_time(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<time " + write_common(pCtrl, pCtxt) + "></time>"

	pCtxt.add2fopen "page_.ctrl(" + CStr(pCtxt.getCurrentID()) + ").value = " + _
		"CLng(" + CStr(pCtrl.value) + ")" + vbNewLine
end sub

sub exp_currency(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<currency " + write_common(pCtrl, pCtxt) + " size='" + CStr(pCtrl.size) + "'></currency>"

	pCtxt.add2fopen "page_.ctrl(" + CStr(pCtxt.getCurrentID()) + ").value = " + _
		"CCur(" + doc_.afc.convert.cur2sql(CCur(pCtrl.value)) + ")" + vbNewLine
end sub

sub exp_date(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<date " + write_common(pCtrl, pCtxt) + " size='" + CStr(pCtrl.size) + "'></date>"
	
	dim dData
	dData = CDate(pCtrl.value)

	pCtxt.add2fopen "page_.ctrl(" + CStr(pCtxt.getCurrentID()) + ").value = " + _
		"DateSerial(" + CStr(dData) + ", " + CStr(dData) + ", " + CStr(dData) + ")" + vbNewLine
	
end sub

sub exp_intedit(byref pSO, byref pCtrl,byref pCtxt)
	pSO.write "<intedit " + write_common(pCtrl, pCtxt) + " size='" + CStr(pCtrl.size) + "'><![CD"+"ATA["
	pSO.write pCtrl.value
	pSO.write "]"+"]></intedit>"
end sub

sub exp_picture(byref pSO, byref pCtrl,byref pCtxt)
	'pSO.write "<picture " + write_common(pCtrl,pCtxt) + " >"
	'pSO.write "</picture>"
end sub 

sub exp_element(byref pSO, byref pCtrl,byref pCtxt)
	if pCtrl.hide then
		exit sub
	end if
	select case pCtrl.type
		case CTRL_TYPE_STATIC
			exp_static pSO,pCtrl,pCtxt

		case CTRL_TYPE_STATICEX
			exp_staticex pSO,pCtrl,pCtxt

		case CTRL_TYPE_BUTTON
			exp_button pSO,pCtrl,pCtxt

		case CTRL_TYPE_EDIT
			exp_edit pSO,pCtrl,pCtxt

		case CTRL_TYPE_INTEDIT
			exp_intedit pSO,pCtrl,pCtxt

		case CTRL_TYPE_DATE
			exp_edit pSO,pCtrl,pCtxt	'to_do

		case CTRL_TYPE_CURRENCY
			exp_currency pSO, pCtrl, pCtxt

		case CTRL_TYPE_RADIO,CTRL_TYPE_CHECKBOX
			exp_checkbox_radio pSO,pCtrl,pCtxt

		case CTRL_TYPE_PARAGRAPH
			exp_paragraph pSO,pCtrl,pCtxt

		case CTRL_TYPE_PAGEMAN, CTRL_TYPE_TOPLEVELPAGE
			exp_pageman pSO,pCtrl,pCtxt

		case CTRL_TYPE_BREAKLINE
			exp_br pSO,pCtrl,pCtxt

		case CTRL_TYPE_TABLE
			exp_table pSO,pCtrl,pCtxt

		case CTRL_TYPE_GRID
			exp_table pSO,pCtrl,pCtxt

		case CTRL_TYPE_PICTURE
			'to_do: gdzie umieszczaÄ‡ obrazki (podkatalog files ? / napisaÄ‡ moniker navo:file:80004:environment ?)
			exp_picture pSO,pCtrl,pCtxt

		case CTRL_TYPE_OLECONTROL

		case CTRL_TYPE_WEB

		case CTRL_TYPE_RICHEDIT

		case CTRL_TYPE_TREE

		case CTRL_TYPE_BREAKPAGE

		case CTRL_TYPE_MULTILINE
			exp_multiline pSO, pCtrl, pCtxt

		case CTRL_TYPE_TIME
			exp_time pSO, pCtrl, pCtxt

	end select 
end sub

sub export_page_as_xml_internal(byref pSO, byref pPage, byref pCtxt)
	dim pPageStream
	set pPageStream = doc_.createstreamobj()
	
	exp_element pPageStream, pPage.topelement, pCtxt

	exp_start pSO, pCtxt, pPage.topelement

	pPageStream.copyto pSO
	
	exp_end pSO, pCtxt
end sub

function std_copy(byref page, byref destStream)
	dim pCtxt
	set pCtxt = new CExpXMLContext
	
	export_page_as_xml_internal destStream, page, pCtxt

	std_copy = true
end function

]]>
</script>
</config>
	<body>
		<t>Eksport strony w postaci XML</t>
	</body>
</page>
