function fopen()
	if not HARUI(UAR_CMDID(CMDID_SEGREGOWANIE_POCZTY)) then
		fopen=false
		exit function
	end if
	
	'parametry startowe dla formularza
	bAllMessages=false
	page_.ctrl(50).value = clng(2)
	HideShow
	dim strDateOd:strDateOd = getuserprofile(USERPROF_MAIL_LAST_UPDATE)
	if strDateOd ="" then
		dDataOd=doc_.afc.globals.nulldate()
		nTime=clng(1200)
	else
		strDateOd = cdate(strDateOd)
		dDataOd =DateValue(strDateOd)
		
		dim strHour:strHour = cstr(hour(strDateOd))
		dim strMinute:strMinute = cstr(minute(strDateOd))
		if len(strMinute)=1 then strMinute = strMinute+"0"
		if len(strHour)=1 then strHour = "0" + strHour
		nTime = strHour+strMinute
		'nTime=trans_.afc.convert.time2long(Hour(strDateOd)+))
	end if
	bIgnore=false

	page_.ctrl(ID_RUN_FROM_PROC).hide=true
	page_.ctrl(ID_RUN_FROM_PAGE).hide=false

end function

function continue()
	page_.result=CMD_CONTINUE
	page_.goback
end function

