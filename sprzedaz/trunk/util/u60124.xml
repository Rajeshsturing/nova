'jezeli wszystkie to nie pokazuj daty i czasu
function HideShow()
	select case page_.ctrl(50).value
		case 1
			page_.ctrl(ID_ROW_DATE).hide=true
			page_.ctrl(ID_ROW_TIME).hide=true

		case 2
			page_.ctrl(ID_ROW_DATE).hide=false
			page_.ctrl(ID_ROW_TIME).hide=false
			page_.ctrl(ID_CTRL_DATE).disable=true
			page_.ctrl(ID_CTRL_TIME).disable=true

		case 3
			page_.ctrl(ID_ROW_DATE).hide=false
			page_.ctrl(ID_ROW_TIME).hide=false
			page_.ctrl(ID_CTRL_DATE).disable=false
			page_.ctrl(ID_CTRL_TIME).disable=false

	end select

end function

