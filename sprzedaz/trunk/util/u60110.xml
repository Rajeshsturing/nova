'wyswietla wygenerowana strone
function page_open()
	dim pHli
	set pHli=doc_.createhlistr("varCmd=CMD_OPEN_WIZARD_PAGE")
	
	'przypisz strumien strony i otworz stone
	set pHli.prop(GVAR_DESTPAGE) = m_pSO.getstream
	dim pPage: set pPage=doc_.getpagehli(pHli)
	page_open=pPage.domodalauto()

	m_strNewFileInit=pPage.getFileNames()

	if (page_open=CMD_CHOICE) then
		'zmien folder
		
		dim nIndex
		nIndex=trans_.var(GVAR_MODALRES)

		dim strNewPath
		if (nIndex>=0) then
			strNewPath=m_pSubFolders.Value( nIndex ).Path
		else
			strNewPath=trans_.var(GVAR_MODALRES2)
		end if

		Dim pDrive: set pDrive=nothing

		on error resume next
		Set pDrive = m_pFSO.GetDrive( m_pFSO.GetDriveName( strNewPath ) )
		on error goto 0

		if (not pDrive is nothing) then
			if (pDrive.IsReady) then
				dim pFolderToAccess
				set pFolderToAccess=m_pFSO.GetFolder(strNewPath)

				'Sprawdzamy czy mamy uprawnienia do wejscia do wybranego
				'katalogu i jezeli tak to wchodzimy do niego
				err.clear
				on error resume next

				dim iTestCount
				iTestCount=pFolderToAccess.SubFolders.Count
				iTestCount=pFolderToAccess.Files.Count

				if (err.number=0) then
					m_strPath=strNewPath
				else
					view_message1 4102, 0, err.description
				end if

				on error goto 0
			else
				view_message 6205, 0
			end if
		else
			view_message 6205, 0
		end if

	end if

	if (page_open=FILE_CHOICE) then
		'dodaj wybrane pliki
		m_pFiles.Add m_pFilesInFolder.Value( trans_.var(GVAR_MODALRES) ).Path

		if (m_pFiles.Count()=m_nFiles) then
			'jeżeli liczba wybranych plików równa jest
			'maksymalnej dozwolonej liczbie plikow do
			'wybrania to zakończ wybieranie
			page_open=END_CHOICE
		end if
    
	end if
  
	set pPage=nothing
end function

'generuj poczatek strony - naglowek itp.
'i czesc skryptowa potrzebno do nawigacji
