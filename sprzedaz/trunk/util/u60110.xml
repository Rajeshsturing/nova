	m_pSO.write	"<page width='20000' style='STYLE_PAGE'>"

	m_pSO.write "<config>"
	m_pSO.write "<script><![CD" + "ATA["

	'zmienne globalne
	m_pSO.write "dim strFileName"+vbNewLine

	'kod dla fopen
	m_pSO.write "function fopen()"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_ENABLEEDIT, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_UNDO, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_FIRSTINCURSOR, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_PREVINCURSOR, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_NEXTINCURSOR, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_LASTINCURSOR, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_SEARCH, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_NEWFORM, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_DELETEFORM, false"+vbNewLine
	m_pSO.write "page_.cmdenabled CMD_SAVEFORM, false"+vbNewLine
	m_pSO.write "strFileName=""" + CStr(m_strNewFileInit) + """"+vbNewLine
	m_pSO.write "fopen=true"+vbNewLine
	m_pSO.write "end function"+vbNewLine

	'funkcja transferu 100 entered
	m_pSO.write "function c100_ondataentered(byref oCtrl, byval newValue)"+vbNewLine
	m_pSO.write	"strFileName=CStr(newValue)"+vbNewLine
	m_pSO.write	"c100_ondataentered=true"+vbNewLine
	m_pSO.write "end function"+vbNewLine

	'funkcja transferu 100 get
	m_pSO.write "function c100_ongetdata(byref oCtrl)"+vbNewLine
	m_pSO.write "oCtrl.value=CStr(strFileName)"+vbNewLine
	m_pSO.write "c100_ongetdata=true"+vbNewLine
	m_pSO.write "end function"+vbNewLine

	'funkcja zwracajaca nazwe pliku
	m_pSO.write "function getFileNames()"+vbNewLine
