function dekoduj(byval strInitialDir, byval strPathCodeExe)
  
  'katalog docelowy
  dim strDestDir : strDestDir = Left(strInitialDir,Len(strInitialDir) - 1) + "_coded\"
  
  'obiekt zdefiniowany w bibliotece 50211 używany do tworzenia katalogów oraz kopiowania plików ...\extras\
  dim CFileDrive : set CFileDrive = new CFilesDrives
  
  'stwórz katalog z plikami zdekodowanymi
  if (not CFileDrive.IsFolder(strDestDir)) then
    if (not CFileDrive.CreateFolder(strDestDir)) then
      exit function
    end if
  end if
  
  'inicjacja zmiennych
  init strInitialDir, "", "", 100
	
	dim pActiveFolder
	set pActiveFolder = m_pFSO.GetFolder(m_strPath)

	'wypelnij liste katalogow
	m_pSubFolders.RemoveAll

	dim oFolder, pFolder
  
  'utwórz tablicę z podkatalogami
	for each pFolder in pActiveFolder.SubFolders
		set oFolder = new CFolder
		oFolder.Name=pFolder.Name
		oFolder.Path=pFolder.Path
		m_pSubFolders.Add oFolder
		set oFolder=nothing
	next

	'dla wszystkich podkatalogów
	dim i, pFile
	for i = 0 to m_pSubFolders.Count() - 1
    dim pActiveFolder1
	  set pActiveFolder1 = m_pFSO.GetFolder(m_pSubFolders.value(i).Path)
    
    'pomiń ekstras
    if m_pSubFolders.value(i).Name <> "extras" then
        
        if (not CFileDrive.IsFolder(strDestDir + m_pSubFolders.value(i).Name + "\")) then
			    if (not CFileDrive.CreateFolder(strDestDir + m_pSubFolders.value(i).Name + "\")) then
				    exit function
			    end if
		    end if
        
	      for each pFile in pActiveFolder1.Files
          doc_.system.execute strPathCodeExe, m_pSubFolders.value(i).Path, " -i " + pFile.Path + " -o " +_
                              strDestDir + m_pSubFolders.value(i).Name + "\" + pFile.Name, true, true
		    next
     else
        'skopiuj extras
        if (not CFileDrive.IsFolder(strDestDir + m_pSubFolders.value(i).Name + "\")) then
			    if (not CFileDrive.CreateFolder(strDestDir + m_pSubFolders.value(i).Name + "\")) then
				    exit function
			    end if
		    end if     
        for each pFile in pActiveFolder1.Files
           CFileDrive.CopyFile strInitialDir + m_pSubFolders.value(i).Name + "\" + pFile.Name,strDestDir +_
                               m_pSubFolders.value(i).Name + "\" + pFile.Name 
        next
        
     end if   
    
	next

end function


