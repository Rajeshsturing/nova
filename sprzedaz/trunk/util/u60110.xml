'--------------------------------------------------------------------------
function select_folder(byval strInitialDir)
	init strInitialDir, "", "", 1
	m_bOnlyFolders=true

	dim strFolder
	strFolder=page_loop()

	if (len(strFolder)>0) then
		
		if (mid(strFolder, len(strFolder), 1)="\") then
			strFolder=mid(strFolder, 1, len(strFolder)-1)
		end if
	end if

	select_folder=strFolder

	destroy
end function

