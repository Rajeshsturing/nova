	public function kod_isOK():kod_isOK = false	
#ifdef _DEBUG
		kod_isOK = true
		exit function
#endif


#ifdef _NZOS
		kod_isOK = true
		trans_.message 7000 , 0 , "wersja dla 'NZOS Nowy Dwór'"
		exit function
#endif

		if isnumeric(rtrim(ltrim(m_strCodeFirma))) and isnumeric(rtrim(ltrim(kod)))  then
			kod_isOK = clng(rtrim(ltrim(m_strCodeFirma))) = clng(rtrim(ltrim(kod))) - 1
		else
			if rtrim(ltrim(m_strCodeFirma)) = "<brak>" then
				trans_.message 1002,0,"Posiadana przez Ciebie aplikacja, z której dane chcesz eksportować nie jest zarejestrowana"
			end if
		end if

	end function


