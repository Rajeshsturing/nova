	public function connect_firma():connect_firma = false
		'łączymy się do źródla danych
		if (not firma_sql) then
			if (not pParamClass.import.database_logon("", "", "", false, ado_man)) then
				Export_DestroyPerforming ado_man
				exit function
			end if
		else
			if (m_bDefault) then
				if (not import.database_logon("sa", "", ".", true, ado_man)) then					
					Export_DestroyPerforming ado_man
					exit function
				end if
			else
				if (not import.database_logon(m_strLogin, m_strPass, m_strServer, true, ado_man)) then
					Export_DestroyPerforming ado_man
					exit function
				end if
			end if
		end if		
		
		
		'wybieramy firme
		if not import.choiceFirma(ado_man) then
			Export_DestroyPerforming ado_man
			exit function
		end if

		Export_DestroyPerforming ado_man

		m_nFirmaId = import.idFirmy
		if m_nFirmaId = 0 then
			trans_.message 7000 , 0 , "W wybranym źródle danych nie ma żadnej firmy"
			exit function
		end if

		dim rs_temp:set rs_temp = ado_man.getConnection().execute("select count(*) as ilosc from pracownik where idFirmy=" +cstr(m_nFirmaId))
		m_nCount = clng(rs_temp.fields("ilosc").value)								


		connect_firma = true
	end function

	public function connect_kadry():connect_kadry = false
		if (m_bDefault) then
			if (not import.database_logon_kadry("sa", "", ".", ado_man)) then					
				Export_DestroyPerforming ado_man
				exit function
			end if
		else
			if (not import.database_logon_kadry(m_strLogin, m_strPass, m_strServer, ado_man)) then
				Export_DestroyPerforming ado_man
				exit function
			end if
		end if

		on error resume next
		dim rs_temp:set rs_temp = ado_man.getConnection().execute("select count(*) as ilosc from pracownik")
		m_nCount = clng(rs_temp.fields("ilosc").value)

		if (err.number<>0) then
			view_message1 6343, 0, err.description
			pContainer.cancel
			Export_DestroyPerforming ado_man
			exit function
		end if

		on error goto 0

		Export_DestroyPerforming ado_man

		connect_kadry = true
	end function

	public function get_connection()
		set get_connection = ado_man.getConnection()
	end function


	public property get osoba_prawna()
		osoba_prawna = clng(m_nOsobaPrawna)
	end property
	public property let osoba_prawna(nOsoba)
		m_nOsobaPrawna = clng(nOsoba)
	end property


	public function fill_platnik():fill_platnik = false		

		set m_pPlatnik = new CPlatnik
		
		dim pRecordset

		'najpierw wypelnienie m_bOsobaFizyczna i m_nApp
		'dane platnika
		if NavoFirma then 'tutaj nie wiadomo - pytalismy na jednej ze stron kreatora i to wstawiamy			
			m_pPlatnik.setApp EXPPLATNIK_APP_NAVOFIRMA
			m_pPlatnik.m_bOsobaPrawna = (osoba_prawna = EXPPLATNIK_OSOBA_PRAWNA)
		elseif ePlatnik then 'w platniku forma spolki musi byc taka jak nizej
			m_pPlatnik.setApp EXPPLATNIK_APP_EPLATNIK
			m_pPlatnik.m_bOsobaPrawna = (getCurrentFirma.eForma = N5FIRMA_FORMA_ZOO) or (getCurrentFirma.eForma = N5FIRMA_FORMA_AKCYJNA)
		else
			m_pPlatnik.setApp EXPPLATNIK_APP_KADRYPLACE			
			set pRecordset = ado_man.getConnection().execute("select osobafiz from firma")
			if pRecordset.EOF then
				exit function
			end if			
			m_pPlatnik.m_bOsobaPrawna = (clng(pRecordset.fields("osobafiz").value) = clng(0))			
		end if

		dim iter
		dim perf:set perf = doc_.performing("Tworzenie listy dokumentów . . .")


		dim pUbezpieczony
		dim rs,rs_temp
		dim bRCA,bZUA

		iter = 1


		'Tworzenie propozycji 
		'Domyslnie zaden dokument nie jest zaznaczony
		'Jesli analiza danych wykaze koniecznosc tworzenia - flaga zastanie przestawiona
		'***********************************
		'Navo Firma
		if NavoFirma then			
			
			
			set rs = ado_man.getConnection().execute("select * from pracownik where idFirmy="+cstr(m_nFirmaId)+" order by nazwisko,imie1")
			while not rs.eof

				

				perf.text = "Tworzenie listy dokumentów - zrobiono  " + cstr(cint((iter/m_nCount)*100))  + "%"

				bRCA = false

				set pUbezpieczony = new CUbezpieczony
				'wypelniam
				pUbezpieczony.m_strAsText = cstr(rs.fields("Nazwisko").value) + " " + cstr(rs.fields("Imie1").value)
				pUbezpieczony.m_nId = clng(rs.fields("IdPrac").value)


				'***********************************
				'RCA
				'gdy było coś w ewidencji wynagrodzeń w okresie exportu jeśli typ umowy jest inny niż "Umowa zlecenia bez ZUS"
				set rs_temp = ado_man.getConnection().execute("select * from wynagrodzenie where dataod between "+trans_.afc.convert.date2SQL(m_dDataOd)+" and "+trans_.afc.convert.date2SQL(m_dDataDo)+" and (idPrac="+cstr(pUbezpieczony.m_nId)+") and (typwynagr <> TYP_WYNAGR_UM_ZLEC_BEZ_ZUS)")
				if not rs_temp.eof then
					pUbezpieczony.rca = "1"
					m_pPlatnik.m_nDRA = "1"
					bRCA = true
				end if


				'***********************************
				'RZA
				'gdy wszytko w ewidencji wynagrodzeń w okresie exportu ma typ umowy równy "Umowa zlecenia bez ZUS"
				if not bRCA then
					set rs_temp = ado_man.getConnection().execute("select * from wynagrodzenie where dataod between "+trans_.afc.convert.date2SQL(m_dDataOd)+" and "+trans_.afc.convert.date2SQL(m_dDataDo)+" and (idPrac="+cstr(pUbezpieczony.m_nId)+")")
					if not rs_temp.eof then
						'jezeli cos jest to sprawdzamy czy wszystko ma typ
						'zakladamy ze tak
						pUbezpieczony.rza = "1"
						while not rs_temp.eof
							'jesli jednak nie to nie generujemy
							if clng(rs_temp.fields("typwynagr").value) <> TYP_WYNAGR_UM_ZLEC_BEZ_ZUS then
								pUbezpieczony.rza = "0"
								m_pPlatnik.m_nDRA = "1"
							end if
							rs_temp.movenext						 	
						wend					
					end if
				end if


				'***********************************
				'RSA
				'gdy w ewidencji jest liczba dni choroby <> 0
				set rs_temp = ado_man.getConnection().execute("select * from wynagrodzenie where dataod between "+trans_.afc.convert.date2SQL(m_dDataOd)+" and "+trans_.afc.convert.date2SQL(m_dDataDo)+" and (idPrac="+cstr(pUbezpieczony.m_nId)+") and (dnichoroby <> 0)")
				if not rs_temp.eof then
					pUbezpieczony.rsa = "1"
					m_pPlatnik.m_nDRA = "1"
				end if


				'dodaje
				m_pPlatnik.addUbezpieczony pUbezpieczony
				rs.movenext

				iter = iter + 1

			wend
			
										
		elseif ePlatnik then

			dim pracownik
			dim cursor:set cursor = trans_.createrawcursor(TYPEID_N5PRACOWNIK,"eAktywny=N5PRACOWNIK_AKTYWNY_AKTYWNY","strNazwisko","")
			m_nCount = cursor.count
			#ifdef _AMPLUS
				dim dDataPocz : dDataPocz = m_dDataOd
				dim dDataOdPocz : dDataOdPocz = dateserial(year(dDataPocz),month(dDataPocz) - 1,1)
				dim dDataDoPocz : dDataDoPocz = dateserial(year(dDataPocz),month(dDataPocz),1) - 1
			#endif
			for each pracownik in cursor

				perf.text = "Tworzenie listy dokumentów - zrobiono  " + cstr(cint((iter/m_nCount)*100))  + "%"

				bRCA = false

				set pUbezpieczony = new CUbezpieczony
				'wypelniam
				pUbezpieczony.m_strAsText = pracownik.text
				pUbezpieczony.m_nId = pracownik.idobj

				
				dim strWhere
				strWhere = doc_.afc.convert.formatter( _ 				
				" pPracownik = %1  and " + _
				" idobj not in (select pUmowaPop from n5plumowa where pPracownik=%1) " ) _
				.add(cstr(pUbezpieczony.m_nId)) _
				.done()
				
				dim umowa
				dim cursor_umowy: set cursor_umowy = trans_.createrawcursor(TYPEID_N5PLUMOWA,strWhere,"","")

				for each umowa in cursor_umowy
					'ZUA 
					'data zawarcia umowy w okresie exportu i zaznaczone inne ubezpieczenie oprócz zdrowotnego
					if (umowa.dDataOd >= m_dDataOd and umowa.dDataOd <= m_dDataDo) and (umowa.cUbEm = "1" or umowa.cUbRe = "1" or umowa.cUbCh = "1" or umowa.cUbWyp = "1" ) then
						'gdy kontynuacja umowy - nie zgłaszaj ZUA
						dim dDateYest : dDateYest = DateAdd("d",-1,umowa.dDataOd)
						dim oRSbef : set oRSbef = trans_.createrawcursor(TYPEID_N5PLUMOWA,"pPracownik = " + cstr(pUbezpieczony.m_nId) + " and dDataDo = " + trans_.afc.convert.date2SQL(dDateYest), "" , "")
						if oRSbef.exists(1) then
							pUbezpieczony.zua = "0"
						else
							pUbezpieczony.zua = "1"
							bZua = true
						end if
					end if       
          
					'ZWUA 
					'data zakończenia umowy w okresie exportu - typ umowy odpowiada za wartość pola w ZWUA.
					if (umowa.dDataDo >= m_dDataOd and umowa.dDataDo <= m_dDataDo) then
						'gdy kontynuacja umowy - nie zgłaszaj ZWUA
						dim dDateTom : dDateTom = DateAdd("d",1,umowa.dDataDo)
						dim oRSaft : set oRSaft = trans_.createrawcursor(TYPEID_N5PLUMOWA,"pPracownik = " + cstr(pUbezpieczony.m_nId) + " and dDataOd = " + trans_.afc.convert.date2SQL(dDateTom), "" , "")
						if oRSaft.exists(1) then
							pUbezpieczony.zwua = "0"
						else
							pUbezpieczony.zwua = "1"
						end if
					end if


					'ZZA 
					'data zawarcia umowy w okresie exportu i zaznaczone tylko ubezpieczenie zdrowotne
					if (umowa.dDataOd >= m_dDataOd and umowa.dDataOd <= m_dDataDo) and (umowa.cUbEm = "0" and umowa.cUbRe = "0" and umowa.cUbCh = "0" and umowa.cUbWyp = "0" and umowa.cUbZdr = "1"  ) then
						pUbezpieczony.zza = "1"
					end if


					'RCA
					'gdy wszystkie naliczenia w okresie exportu pochodzą z umowy/umów mającej zaznaczone cos wiecej niz tylko zdropwotne
					strWhere = doc_.afc.convert.formatter( _ 				
					" pPracownik = %1  and " + _
					" dDataOd between %2 and %3  and " + _
					" dDataDo between %2 and %3 " + _
					"  " ) _
					.add(cstr(pUbezpieczony.m_nId)) _
#ifdef _AMPLUS
					.add(trans_.afc.convert.date2SQL(dDataOdPocz)) _
					.add(trans_.afc.convert.date2SQL(dDataDoPocz)) _
#else
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
#endif
					.done()
					bRca = false
					dim naliczenie
					dim cursor_naliczenia: set cursor_naliczenia = trans_.createrawcursor(TYPEID_N5PLNALICZENIE,strWhere,"","")
					for each naliczenie in cursor_naliczenia
						'teraz sprawdzamy, ktore naliczenie ma w skladnikach te pochodzące od umowy
						dim skladnik
						for each skladnik in naliczenie.listSkladnik
							if skladnik.wrefDokument.type = TYPEID_N5PLUMOWA then
								set umowa = skladnik.wrefDokument
								if (umowa.cUbEm = "1" or umowa.cUbRe = "1" or umowa.cUbCh = "1" or umowa.cUbWyp = "1") and umowa.cUbZdr = "1" then
									bRca = true
									pUbezpieczony.rca = "1"
									m_pPlatnik.m_nDRA = "1"
								end if
							end if
						next 
					next

					
					'RZA
					dim bRza:bRza = false
					dim bExit:bExit = false
					for each naliczenie in cursor_naliczenia
						'teraz sprawdzamy, ktore naliczenie ma w skladnikach te pochodzące od umowy
						for each skladnik in naliczenie.listSkladnik
							if skladnik.wrefDokument.type = TYPEID_N5PLUMOWA then
								set umowa = skladnik.wrefDokument
								if (umowa.cUbEm = "1" or umowa.cUbRe = "1" or umowa.cUbCh = "1" or umowa.cUbWyp = "1") and umowa.cUbZdr = "1" then
									bExit = true
									exit for
								end if
								bRza = true
							else
								bExit = true
								exit for
							end if
						next
						if bExit then
							exit for
						end if
					next
					if bExit then
						bRza = false
					end if
					if bRza then 
						pUbezpieczony.rza = "1"
						m_pPlatnik.m_nDRA = "1"
					end if
				next




				strWhere = doc_.afc.convert.formatter( _ 				
					" pPracownik = %1  and " + _
					" ((dDataOd between %2 and %3) or (dDataDo between %2 and %3) or (dDataOd<=%2 and dDataDo>=%3 ) ) and " + _
					" eTyp = N5PL_NIEOB_URL_WYCHOW  " + _
					"  " ) _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
					.done()

				dim nieobecnosc
				dim cursor_nieobecnosci: set cursor_nieobecnosci = trans_.createrawcursor(TYPEID_N5PLNIEOB,strWhere,"","")
				if cursor_nieobecnosci.exists(1) then
					pUbezpieczony.rsa = "1"
				end if
				
				'--- jesli nie bylo urlopow to sprawdz choroby --
				if pUbezpieczony.rsa <> "1" then
#ifdef _AMPLUS
					strWhere = doc_.afc.convert.formatter( _
					" pPracownik = %1  and " + _
					" ((dDataOd between %2 and %3) or (dDataDo between %2 and %3) or (dDataOd<=%2 and dDataDo>=%3 ) ) " ) _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(dDataOdPocz)) _
					.add(trans_.afc.convert.date2SQL(dDataDoPocz)) _
					.done()
#else
					strWhere = doc_.afc.convert.formatter( _
					" pPracownik = %1  and " + _
					" ((dDataOd between %2 and %3) or (dDataDo between %2 and %3) or (dDataOd<=%2 and dDataDo>=%3 ) ) " ) _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
					.done()
#endif
					dim oCrsrChoroby : set oCrsrChoroby = trans_.createrawcursor(TYPEID_N5PLCHOROBA,strWhere,"","")
					if oCrsrChoroby.exists(1) then
						pUbezpieczony.rsa = "1"
					end if
				end if 


				m_pPlatnik.addUbezpieczony pUbezpieczony
				iter = iter + 1
				
			next


		'***********************************
		'Kadry i płące
		else

			iter = 1
		
			set rs = ado_man.getConnection().execute("select * from pracownik order by nazwisko,imie1")
			dim strQuery

			while not rs.eof

				perf.text = "Tworzenie listy dokumentów - zrobiono  " + cstr(cint((iter/m_nCount)*100)) + "%"
				
				bZua = false
				bRca = false

				set pUbezpieczony = new CUbezpieczony
				pUbezpieczony.m_strAsText = cstr(rs.fields("Nazwisko").value) + " " + cstr(rs.fields("Imie1").value)
				pUbezpieczony.m_nId = clng(rs.fields("IdObj").value)


				'***********************************
				'ZUA 
				'data zawarcia umowy w okresie exportu i zaznaczone inne ubezpieczenie oprócz zdrowotnego				

				strQuery = doc_.afc.convert.formatter( _ 
				" select * from GlobPrac join pracownik on pracownik.idobj = globprac.idosoba where   " + _
				" GlobPrac.idosoba = %1  and " + _
				" GlobPrac.idobj not in (select idAneks from GlobPrac) and " +_
				" dataod between %2 and %3 and " + _				
				" (ubEmeryt like '1' or ubRentowe like '1' or ubChorob like '1' or ubWypad like '1' )") _
				.add(cstr(pUbezpieczony.m_nId)) _
				.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
				.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
				.done()

				set rs_temp = ado_man.getConnection().execute(strQuery)

				if not rs_temp.eof then
					pUbezpieczony.zua = "1"
					bZua = true
				end if


				'***********************************
				'ZWUA 
				'data zakończenia umowy w okresie exportu - typ umowy odpowiada za wartość pola w ZWUA.
				strQuery = doc_.afc.convert.formatter( _ 
				" select * from GlobPrac join pracownik on pracownik.idobj = globprac.idosoba where   " + _
				"((GlobPrac.TypUmowy = TYP_UM_PRACE " + _
				"and GlobPrac.Status = STATUS_UMOWA_ROZWIAZANA) " + _
				" or GlobPrac.TypUmowy = TYP_UM_ZLEC or GlobPrac.TypUmowy = TYP_UM_AGEN or GlobPrac.TypUmowy = TYP_UM_DZIELO or GlobPrac.TypUmowy = TYP_UM_ZLEC_ZRYCZ ) " + _
				"and (ubEmeryt like '1' or ubRentowe like '1' or ubChorob like '1' or ubWypad like '1' ) " + _
				"and GlobPrac.DataDo BETWEEN %2 and %3 " + _
				"and Pracownik.IdObj = %1 " ) _
				.add(cstr(pUbezpieczony.m_nId)) _
				.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
				.add(trans_.afc.convert.date2SQL(m_dDataDo)) _				
				.done()
				set rs_temp = ado_man.getConnection().execute(strQuery)
				if not rs_temp.eof then
					pUbezpieczony.zwua = "1"
				end if

				'***********************************
				'ZZA 
				'data zawarcia umowy w okresie exportu i zaznaczone tylko ubezpieczenie zdrowotne
				if not bZua then
					strQuery = doc_.afc.convert.formatter( _ 
					" select * from GlobPrac join pracownik on pracownik.idobj = globprac.idosoba where   " + _
					" GlobPrac.idosoba = %1  and " + _
					" dataod between %2 and %3 and " + _				
					" ubEmeryt like '0' and ubRentowe like '0' and ubChorob like '0' and ubWypad like '0' and ubZdrow like '1' ") _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
					.done()

					set rs_temp = ado_man.getConnection().execute(strQuery)
					if not rs_temp.eof then
						pUbezpieczony.zza = "1"
					end if
					
				end if


				'***********************************
				'RCA
				'gdy dowolne nalicznie w okresie exportu pochodzi z umowy mającej zaznaczone coś więcej niż tylko zdrowotne
				strQuery = doc_.afc.convert.formatter( _ 
				" select * from naliczenie join GlobPrac on naliczenie.pGlobPrac = globprac.idobj where   " + _
				" GlobPrac.idosoba = %1  and " + _
				" naliczenie.DataPlat between %2 and %3 and " + _				
				" ubZdrow like '1' and " + _
				" (ubEmeryt like '1' or ubRentowe like '1' or ubChorob like '1' or ubWypad like '1')") _
				.add(cstr(pUbezpieczony.m_nId)) _
				.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
				.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
				.done()
				set rs_temp = ado_man.getConnection().execute(strQuery)
				if not rs_temp.eof then
					pUbezpieczony.rca = "1"
					m_pPlatnik.m_nDRA = "1"
					bRca = true
				end if


				'***********************************
				'RZA
				'gdy wszystkie naliczenia w okresie exportu pochodzą z umowy/umów mającej zaznaczone wyłącznie tylko zdrowotne
				if not bRCA then
					strQuery = doc_.afc.convert.formatter( _ 
					" select * from naliczenie join GlobPrac on naliczenie.pGlobPrac = globprac.idobj where   " + _
					" GlobPrac.idosoba = %1  and " + _
					" naliczenie.DataPlat between %2 and %3 and " + _				
					" ubZdrow like '1' and" + _
					" ubEmeryt like '0' and ubRentowe like '0' and ubChorob like '0' and ubWypad like '0'") _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
					.done()

					set rs_temp = ado_man.getConnection().execute(strQuery)
					if not rs_temp.eof then
						pUbezpieczony.rza = "1"
						m_pPlatnik.m_nDRA = "1"
					end if

				end if


				'***********************************
				'RSA
				'nieobecność <> (urlop wypoczynkowy, okolicznościowy)
				'1. szukamy naliczenia
				strQuery = doc_.afc.convert.formatter( _ 
					" select * from naliczenie where idosoba = %1 and DataPlat between %2 and %3") _				
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(m_dDataOd)) _
					.add(trans_.afc.convert.date2SQL(m_dDataDo)) _
					.done()

				set rs_temp = ado_man.getConnection().execute(strQuery)

				if not rs_temp.eof then

					dim dtDataNaliczeniaOd : dtDataNaliczeniaOd = cdate(rs_temp("DataOd").value)
					dim dtDataNaliczeniaDo : dtDataNaliczeniaDo = cdate(rs_temp("DataDo").value)

					'2. szukamy rozliczenieCP ale dla okresu z naliczenia
					strQuery = doc_.afc.convert.formatter( _ 
					" select  * from rozliczenieCP where   " + _
					" idosoba = %1  and " + _
					" dataod between %2 and %3 and " + _				
					" datado between %2 and %3 and " + _								
					" DniChorobyRob + DniUrlopuWychowRob + DniUrlopuBezplRob + DniNieobNieuspRob + DniOpiekiRob + DniUrlopuMacierob <> 0" ) _
					.add(cstr(pUbezpieczony.m_nId)) _
					.add(trans_.afc.convert.date2SQL(dtDataNaliczeniaOd)) _
					.add(trans_.afc.convert.date2SQL(dtDataNaliczeniaDo)) _
					.done()

					set rs_temp = ado_man.getConnection().execute(strQuery)
					if not rs_temp.eof then
						pUbezpieczony.rsa = "1"
						m_pPlatnik.m_nDRA = "1"
					end if

				end if

				'***********************************
				'RSA

				m_pPlatnik.addUbezpieczony pUbezpieczony
				rs.movenext
				iter = iter + 1
			wend
			
		end if

		set perf = nothing

		fill_platnik = true

	end function




