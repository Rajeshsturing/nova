function run_this()

	dim pWizzard
	set pParamClass = new CEXPlatnik

	set pWizzard=CWizzard(false)
	pWizzard.add_container pParamClass

	'to po to, aby dobrze preprocesorwac plik z wybotrem wersji navo  firmy
	trans_.var(APPVAR_IMPORT_KIND) = clng(IMPFRM)

	pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_WITAMY
	
	if not trans_.isvar(APPVAR_MODE) then	
	end if

	pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_OKRES
	pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_LOKALIZACJA_PLIKU

	if not trans_.isvar(APPVAR_MODE) then	
		pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_OSOBA_PRAWNA
	end if

	pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_WYBOR_DOKUMENTOW
	pWizzard.add_step PAGE_FORM_WIZZARD_EXPPLAT_PODSUMOWANIE

	pWizzard.run

end function

