function onPageExit(pWizzardPage)

	onPageExit=PAGE_DEFAULT
	select case ( pWizzardPage.m_nPage )
	
		case PAGE_FORM_WIZZARD_EXPPLAT_LOKALIZACJA_PLIKU
			if pParamClass.m_strPath = "" then
				
				trans_.message 7000 , 0 , "Musisz podać docelową lokalizacje pliku KDU"
				onPageExit=PAGE_DONOTEXIT				
				exit function
			end if
			if not pParamClass.NavoFirma then
				'jezeli nie mamy doczynienia z navo firmą
				'nie pokazyjemy strony do wskazania, czy osoba prawna czy fizyczna
				'przed wyborem listy dokumantow tworzymy propozycje
				pWizzardPage.m_pPage.updateview
				pParamClass.fill_platnik 
				onPageExit=PAGE_FORM_WIZZARD_EXPPLAT_WYBOR_DOKUMENTOW
			end if
		case PAGE_FORM_WIZZARD_EXPPLAT_OSOBA_PRAWNA:
			'przed wyborem listy dokumantow tworzymy propozycje
			pWizzardPage.m_pPage.updateview
			pParamClass.fill_platnik			

	end select
end function

function onPageInit(pWizzardPage)
	select case ( pWizzardPage.m_nPage )
		case PAGE_FORM_WIZZARD_EXPPLAT_OSOBA_PRAWNA:
			pParamClass.getPrawna()
			
	end select
end function

function onWizzardComplete(pWizzardPage): onWizzardComplete = false
	dim pContainer : set pContainer = pWizzardPage.m_pContainer

	dim pExportModule : set pExportModule = doc_.getmodule(60303)
	if (pExportModule is nothing) then
		exit function
	end if

	dim pPerforming : set pPerforming = doc_.performing( "Trwa eksport danych do Płatnika ..." )

	onWizzardComplete = pExportModule.export2platnik(pContainer)

	set pPerforming = nothing

	if (onWizzardComplete) then
		MessageBox "Eksport zakończył się pomyślnie.", "Zakończono eksport", vbOKOnly, vbInformation
	else
		MessageBox "Eksport nie powiódł się", "UWAGA", vbOKOnly, vbInformation
	end if

#ifdef _DEBUG
	onWizzardComplete = false
#endif

end function


