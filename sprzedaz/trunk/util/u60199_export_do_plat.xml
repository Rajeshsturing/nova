	private sub class_initialize()
		m_nProgram = clng(DEFAULT_PROGRAM)		

		'mamy do czynienia z europracownikiem
		if trans_.isvar(APPVAR_MODE) then
			m_nProgram = EXPPLATNIK_APP_EPLATNIK
		end if

		m_strNazwaFirmy = ""
		m_nFirmaId = clng(0)
		m_bDefault = true
		m_nNavoVersion = ""
		m_strLogin = "sa"
		m_strPass = ""
		m_strServer = "."
		m_nNavoShow = NV_NONE

		fromRegistry()

		set m_pImportContainer = new CImportContainer
		set m_pExportManager = new CADOExportManager					

		setInitDates CDate(trans_.var(GVAR_SYSDATE))

		m_nOsobaPrawna = EXPPLATNIK_OSOBA_PRAWNA

	end sub

	public sub setInitDates(byval dDate)

		m_dDataOd = dateserial (year(dDate) , month(dDate) -1 , 1)
		m_dDataDo = dateserial (year(dDate) , month(dDate) , 1) -1

	end sub


	public function license()
		license = m_strLicense
	end function

	public function readLicense()
		dim pRecordset		
		if NavoFirma then
			set pRecordset = ado_man.getConnection().execute("select * from navolicence where Code<>'' and (ModName like 'NAVOFK' or ModName like 'KPIR100') order by modname desc ")
			if not pRecordset.eof then
				m_strModuleName = cstr(pRecordset.fields("ModName").value)
				select case ltrim(rtrim(m_strModuleName))
					case "NAVOFK"
						m_strModuleName = "NAVO Finanse i księgowość"
					case "KPIR100"
						m_strModuleName = "NAVO Księga przychodów i rozchodów"
				end select
				m_strLicense = cstr(pRecordset.fields("Licence").value)
				m_strCodeFirma = cstr(pRecordset.fields("Code").value)
			else
				m_strLicense = "<brak>"
				m_strCodeFirma = ""
			end if
		else
			m_strModuleName = "NAVO Kadry i Płace"
			'tu mamy juz polaczenie
			set pRecordset = ado_man.getConnection().execute("select * from master..neflicence where navomatch <> ''")
			if not pRecordset.eof then
				m_strLicense = cstr(pRecordset.fields("NAVOUniCode").value)
				m_strCodeFirma = cstr(pRecordset.fields("NAVOMatch").value)				
			else
				m_strLicense = "<brak>"
				m_strCodeFirma = ""
			end if


		end if		
	end function


