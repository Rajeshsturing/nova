class CPlatnik

	public m_bOsobaPrawna

	public m_nZPA
	public m_nZFA

	public m_nZBA
	public m_nZAA

	'proponowane gdy choc raz jest rsa, rza lub rca
	public m_nDRA

	private m_paUbezpieczeni

	private m_nApp	'jaka aplikacja - od tego zalezy odpowiednie prełączanie mozliwosci 
					'generowania pewnych dokumentów

	
	private sub class_initialize()
		m_nZPA =  clng(DOK_NIEGENERUJ)
		m_nZFA =  clng(DOK_NIEGENERUJ)

		m_nZBA =  clng(DOK_NIEGENERUJ)
		m_nZAA =  clng(DOK_NIEGENERUJ)

		m_nDRA =  "0"

		set m_paUbezpieczeni = trans_.afc.new_navoarray()

	end sub

	public sub addUbezpieczony(pUbezpieczony)
		m_paUbezpieczeni.add(pUbezpieczony)	
	end sub

	public property get ubezpieczeni()
		set ubezpieczeni = m_paUbezpieczeni
	end property	
	
	
	public sub setApp(nApp)	
		m_nApp = nApp
	end sub


	'wykorzystywane w kroku kreatora
	public property get dra()
		dra = m_nDRA =  "1"
	end property

	public property get zpa()
		zpa = clng(m_nZPA)
	end property
	public property get zba()
		zba = clng(m_nZBA)
	end property
	public property get zaa()
		zaa = clng(m_nZAA)
	end property
	'gdy generujemy ZPA/AFA to:
	'dla wszystkich procz navofirmy apklikacji generujemy ZBA
	'dla platnika generujemy ZAA - dla kazdej jo
	public property let zpa(byref nZPA)
		m_nZPA = nZPA
		if (nZPA <> DOK_NIEGENERUJ) and (m_nApp <>EXPPLATNIK_APP_NAVOFIRMA) then
			m_nZBA = clng(DOK_GENERUJ)
		end if

		if (nZPA <> DOK_NIEGENERUJ) and (m_nApp = EXPPLATNIK_APP_EPLATNIK) then
			m_nZAA = clng(DOK_GENERUJ)
		end if

		if (nZPA = DOK_NIEGENERUJ) then
			m_nZBA = clng(DOK_NIEGENERUJ)
			m_nZAA = clng(DOK_NIEGENERUJ)
		end if

	end property

	'wykorzystywane w kroku kreatora
	public property get zfa()
		zfa = m_nZFA
	end property
	'gdy generujemy ZPA/AFA to:
	'dla wszystkich procz navofirmy apklikacji generujemy ZBA
	'dla platnika generujemy ZAA - dla kazdej jo
	public property let zfa(byref nZFA)
		m_nZFA = clng(nZFA)
		if (nZFA <> DOK_NIEGENERUJ) and (m_nApp<>EXPPLATNIK_APP_NAVOFIRMA) then
			m_nZBA = clng(DOK_GENERUJ)
		end if

		if (nZFA <> DOK_NIEGENERUJ) and (m_nApp = EXPPLATNIK_APP_EPLATNIK) then
			m_nZAA = clng(DOK_GENERUJ)
		end if

		if (nZFA = DOK_NIEGENERUJ) then
			m_nZBA = clng(DOK_NIEGENERUJ)
			m_nZAA = clng(DOK_NIEGENERUJ)
		end if
	end property

end class


