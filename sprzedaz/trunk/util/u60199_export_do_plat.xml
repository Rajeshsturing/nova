	public function checkNavoFirmaVer

		dim pInstallModule
		set pInstallModule = doc_.getmodule(60116)

		dim pNVInfo
		set pNVInfo = pInstallModule.get_navo_firma_info()

		if (pNVInfo.m_Sybase and pNVInfo.m_MsSQL) then
			m_nNavoVersion = "SQL"
			m_nNavoShow = NV_ALL
		elseif (pNVInfo.m_MsSQL) then
			m_nNavoVersion = "SQL"
			m_nNavoShow = NV_SQL
		elseif (pNVInfo.m_Sybase) then
			m_nNavoVersion = "SYBASE"
			m_nNavoShow = NV_SYB
		end if
	end function

