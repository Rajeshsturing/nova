		"<TITLE>Dossier</TITLE>"  + vbNewLine +_
		"</HEAD>" + vbNewLine +_
		"<body>" + vbNewLine +_
		"<p align=""center""><b><font face=""Tahoma"" size=""5"">Dossier klienta</font></b></tabitem>" + vbNewLine +_
		"<p align=""center"">&nbsp;</tabitem>"  + vbNewLine
end function

private function get_html_page_footer()
	get_html_page_footer = "</BODY>" + vbNewLine +_
		"</HTML>"  + vbNewLine
end function

private function generate_NXP_dossier(byval Obj)	
	dim cDossier:set cDossier = new CDossierAsNXP	
	cDossier.set_obj(Obj)
	set generate_NXP_dossier = generate_dosier(cDossier)
end function

private function generate_HTML_dossier(byval Obj)
	dim cDossier:set cDossier = new CDossierAsHTML	
	cDossier.set_obj(Obj)
	set generate_HTML_dossier = generate_dosier(cDossier)
end function

private function generate_dosier(byval pDossier)
	dim so:set so = doc_.createstreamobj()
'	so.write pDossier.generate_page_header
	if page_.ctrl(1001).value="1" then
'		msgbox replace(pDossier.generate_page_header,"style='STYLE_PAGE'","")
		so.write replace(pDossier.generate_page_header,"style='STYLE_PAGE'","")
	else	
		so.write pDossier.generate_page_header
	end if

	if mid(page_.ctrl(1002).value , 1 , 1) = "1" then
		so.write pDossier.generate_main_info
	end if

	if mid(page_.ctrl(1002).value , 2 , 1) = "1" then
		so.write pDossier.generate_workers_info
	end if

	if mid(page_.ctrl(1002).value , 3 , 1) = "1" then
		so.write pDossier.generate_tasks_info
	end if

	if mid(page_.ctrl(1002).value , 4 , 1) = "1" then
		so.write pDossier.generate_products_info
	end if

	so.write pDossier.generate_page_footer
	set generate_dosier = so

end function

public function generate

'debug_now
	dim pObj:set pObj = trans_.getobj(TYPEID_N5KLIENT,trans_.var(GVAR_CURRENT_CUSTOMER))
	if page_.ctrl(1000).value = 1 then		
		dim so:set so = generate_HTML_dossier(pObj)

		dim strTempFileName
		'Przygotowanie do podgladu lub edycji pliku

		'create pFD object
		if (not Create_FileDriveObject()) then
			exit function
		end if

		dim bView:bView = false

				if (not bView) then
			'tworzymy katalog user'a jezeli go nie ma
			if (not checkUserDirectory()) then
				' 1, 0, "Utworzenie katalogu lub jego sprawdzenie nie jest możliwe (" + getUserDirectory() + ")"
				view_message1 6078, 0, getUserDirectory()
				exit function
			end if

			dim strDossierFolder
			strDossierFolder=getUserDirectory() + "\" + "Dossier"

			if (not pFD.IsFolder( strDossierFolder )) then
				if (not pFD.CreatePath( strDossierFolder )) then
					' 1, 0, "Utworzenie katalogu lub jego sprawdzenie nie jest możliwe - " + strWizytFolder
					view_message1 6079, 0, strDossierFolder
					exit function
				end if
			end if

			strTempFileName=strDossierFolder+"\"+ FormatStringToFileName(pObj.strNazwa) + "."
		end if
		

		strTempFileName = strTempFileName + "htm"
					
		if (not ExistFileContinue(strTempFileName)) then
			exit function
		end if
		
				
		'zapis
		so.save strTempFileName

'		if (bView) then
'			doc_.getmodule(PAGE_FORM_WEB).navigate "file://" + strTempFileName
'		end if


		view_message1 4103, 0, strTempFileName
		if MessageBox("Dossier zostało zapisane jako """ + strTempFileName + """ Uruchomić podgląd?", "Chcesz obejrzeć teraz?", vbYesNo, vbQuestion) =vbYes then
			Run strTempFileName
		end if		

	else
		dim pHli: set pHli=doc_.createhlistr("varCmd=CMD_OPEN_STATIC_PAGE")		
		set pHli.prop(GVAR_DESTPAGE)=generate_NXP_dossier(pObj).getstream()
		dim pPage:set pPage=doc_.getpagehli(pHli)
		if not pPage is nothing then
			pPage.domodalauto()
		end if
	end if
	page_.goback
end function


function c1000_ondataentered(oCtrl, newValue)
	if oCtrl.value=clng(1) then
		page_.ctrl(1001).disable=true
	else
		page_.ctrl(1001).disable=false
	end if
	c1000_ondataentered = true
end function

function c1000_ongetdata(byref oCtrl)
  c1000_ongetdata=true
end function



