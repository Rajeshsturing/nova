		so.write "<td width=13%>"
		so.write "<font color=#FFFFFF face=Tahoma><b>LP</b></font></td>"
		so.write "<td width=321%>"
		so.write "<font color=#FFFFFF face=Tahoma><b>Nazwa,opakowanie</b></font></td>"
		so.write "<td width=36%>"
		so.write "<font color=#FFFFFF face=Tahoma><b>Ilość</b></font></td>"
		so.write "<td width=58%>"
