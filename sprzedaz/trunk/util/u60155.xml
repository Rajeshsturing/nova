private function get_adress_string(byval m_pObj)

		dim strAdres

		if m_pObj.strKod <> "" then
			strAdres = strAdres + m_pObj.strKod
		end if

		strAdres = strAdres + " " + m_pObj.pMiejscowosc.strNazwa
				
		if m_pObj.strUlica <> "" then
			strAdres = strAdres + ", ul. " + m_pObj.strUlica
		end if

		if m_pObj.strNrDomu <> "" then
			strAdres = strAdres + " " + m_pObj.strNrDomu
		end if

		if m_pObj.strNrLokalu <> "" then
			strAdres = strAdres + "/" + m_pObj.strNrLokalu
		end if

		get_adress_string = strAdres

end function

private function get_SDBadress_string(byval m_pObj)

		dim strAdresSDB

		if m_pObj.strKodSDB <> "" then
			strAdresSDB = strAdresSDB + m_pObj.strKodSDB
		end if
		
		if not m_pObj.pMiejscowoscSDB is nothing then
			strAdresSDB = strAdresSDB + " " + m_pObj.pMiejscowoscSDB.strNazwa
		end if
				
		if m_pObj.strUlicaSDB <> "" then
			strAdresSDB = strAdresSDB + ", ul. " + m_pObj.strUlicaSDB
		end if

		if m_pObj.strNrDomuSDB <> "" then
			strAdresSDB = strAdresSDB + " " + m_pObj.strNrDomuSDB
		end if

		if m_pObj.strNrLokaluSDB <> "" then
			strAdresSDB = strAdresSDB + "/" + m_pObj.strNrLokaluSDB
		end if

		get_SDBadress_string = strAdresSDB
	
end function

private function get_telefony_string(byval m_pObj)
		dim strTelefony
		if m_pObj.strTel1 <> "" then
			strTelefony = strTelefony + m_pObj.strTel1
		end if

		if m_pObj.strTel2 <> "" then
			strTelefony = strTelefony + ", " +  m_pObj.strTel2
		end if

		if m_pObj.strTel3 <> "" then
			strTelefony = strTelefony + ", "+ m_pObj.strTel3
		end if
		

		if m_pObj.strTel4 <> "" then
			strTelefony = strTelefony + ", "+ m_pObj.strTel4
		end if

		get_telefony_string = strTelefony
end function

