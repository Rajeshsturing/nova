	public function generate_workers_info()
		dim pCrsr,elem
		set pCrsr=trans_.createrawcursor(TYPEID_N5KLIENT_PRACOWNIK, "eAktywny=" + CStr(N5KLIENT_PRACOWNIK_AKTYWNY) + " and pKlient=" + CStr(m_pObj.idobj), "strNazwisko, strImie, strImie2", "")
		if not pCrsr.exists(1) then
			generate_workers_info = ""
			exit function
		end if

		dim so:set so = doc_.createstreamobj()		
		so.write "<text style='STYLE_RAPORTTITLE' width='max' align='center'>Pracownicy</text><br/>"
		so.write "<table>"
		so.write "<tbody style='STYLE_TABLE_BODY'>"

		'to aby nie bylo ramek przy wierszach
		so.write "<tr><td><table border='0'><tbody>" + vbNewline

		for each elem in pCrsr
			so.write  "<tr ><td colspan='2' style='STYLE_TABLE_HEADER'><text bold='true' align='center'>"+elem.strImie + " " + elem.strNazwisko+"</text></td></tr>" + vbNewline
			if elem.strStanowisko <> "" then
				so.write  "<tr ><td><text bold='true'>Stanowisko</text></td><td><text><![CDA"+"TA["+elem.strStanowisko+"]"+"]></text></td></tr>" + vbNewline
			end if

			if elem.strEmail <> "" then
				so.write  "<tr ><td><text bold='true'>E-mail służbowy</text></td><td><text><![CDA"+"TA["+elem.strEmail+"]"+"]></text></td></tr>" + vbNewline
			end if

			if elem.strEmail2 <> "" then
				so.write  "<tr ><td><text bold='true'>E-mail prywatny</text></td><td><text><![CDA"+"TA["+elem.strEmail2+"]"+"]></text></td></tr>" + vbNewline
			end if

			if elem.strTel1 <> "" then
				so.write  "<tr ><td><text bold='true'>Telefon służbowy</text></td><td><text><![CDA"+"TA["+elem.strTel1+"]"+"]></text></td></tr>" + vbNewline
			end if

			if elem.strTel2 <> "" then
				so.write  "<tr ><td><text bold='true'>Telefon prywatny</text></td><td><text><![CDA"+"TA["+elem.strTel2+"]"+"]></text></td></tr>" + vbNewline
			end if



			if elem.strUwagi <> "" then
				so.write  "<tr ><td><text bold='true'>Uwagi</text></td><td><text><![CDA"+"TA["+elem.strUwagi+"]"+"]></text></td></tr>" + vbNewline
			end if
			if elem.strUpodobania <> "" then
				so.write  "<tr ><td><text bold='true'>Upodobania</text></td><td><text><![CDA"+"TA["+elem.strUpodobania+"]"+"]></text></td></tr>" + vbNewline
			end if						
		next

		'to aby nie bylo ramek przy wierszach
		so.write "</tbody></table></td></tr>"

		so.write  "</tbody></table>" + vbNewline

		generate_workers_info = so.getstring()		
	end function

	public function generate_tasks_info()

		dim pCrsr,elem
		set pCrsr=trans_.createrawcursor(TYPEID_N5ZADANIE, "pKlient=" + CStr(m_pObj.idobj), "dDataZlec desc, tCzasZlec desc", "")
		if not pCrsr.exists(1) then
			generate_tasks_info = ""
			exit function
		end if							
		dim so:set so = doc_.createstreamobj()

		so.write "<text style='STYLE_RAPORTTITLE' width='max' align='center'>Działania</text><br/>"

		for each elem in pCrsr
			so.write "<table>"
			so.write "<tbody style='STYLE_TABLE_BODY'>"
			so.write "<tr><td><table border='0'><tbody>" + vbNewline
			so.write  "<tr ><td colspan='2' style='STYLE_TABLE_HEADER'><text bold='true' align='center'><![CDA"+"TA["+elem.strTemat+"]"+"]></text></td></tr>" + vbNewline
			so.write  "<tr ><td colspan='2'><text bold='true'>Data zlecenia:</text><text>"+trans_.afc.display.fulldate(elem.dDataZlec)+"</text><text size='1'></text><text bold='true'>Status:</text><text>"+elem.n5zadanie_getStatusName()+"</text><text size='1'></text><text  bold='true'>Typ:</text><text>"+elem.pTypDzialania.strNazwa+"</text></td></tr>" + vbNewline

			if not elem.pZlecajacy is nothing then
				so.write  "<tr ><td  width='min'><text bold='true' width='min'>Zlecający</text></td><td><text><![CDA"+"TA["+elem.pZlecajacy.strIndeks+"]"+"]></text></td></tr>" + vbNewline				
			end if

			if not elem.pWykonawca is nothing then
				so.write  "<tr ><td  width='min'><text bold='true' width='min'>Wykonawca</text></td><td><text><![CDA"+"TA["+elem.pWykonawca.strIndeks+"]"+"]></text></td></tr>" + vbNewline				
			end if

			if elem.strOpis <> "" then
				so.write  "<tr ><td colspan='2'><text bold='true'>Opis</text></td></tr>" + vbNewline
				so.write  "<tr ><td colspan='2'><text><![CDA"+"TA["+elem.strOpis+"]"+"]></text></td></tr>" + vbNewline
			end if
			if elem.strUwagi <> "" then
				so.write  "<tr ><td  colspan='2'><text bold='true'>Uwagi wykonawcy</text></td></tr>" + vbNewline
				so.write  "<tr ><td  colspan='2'><text><![CDA"+"TA["+elem.strUwagi+"]"+"]></text></td></tr>" + vbNewline
			end if

			if zad_pop_info(elem) <> "" or zad_nad_info(elem) <> "" then
				so.write  "<tr ><td colspan='2'><text bold='true'>Różne uwagi</text></td></tr>" + vbNewline

				if zad_pop_info(elem) <> "" then
					so.write  "<tr ><td  colspan='2'><text><![CDA"+"TA[" + zad_pop_info(elem) + "]"+"]></text></td></tr>" + vbNewline	
				end if

				if zad_nad_info(elem) <> "" then
					so.write  "<tr ><td  colspan='2'><text><![CDA"+"TA[" + zad_nad_info(elem) + "]"+"]></text></td></tr>" + vbNewline	
				end if

			end if

			if elem.listZalaczniki.exists(1) then
				so.write  "<tr ><td colspan='2'><text bold='true'>Załączniki</text></td></tr>" + vbNewline
				dim elem2
				for each elem2 in elem.listZalaczniki
					so.write  "<tr ><td colspan='2'><text><![CDA"+"TA["+zal_info(elem2)+"]"+"]></text></td></tr>" + vbNewline
				next
			end if

			so.write "</tbody></table></td></tr>"
			so.write  "</tbody></table>" + vbNewline
			so.write "<text width='max' align='center'></text><br/>"
		next

		generate_tasks_info = so.getstring()
	end function


	public function generate_products_info
		'robimy zapytanie
		dim strQuery: strQuery= doc_.getmodule(60161).sql_for_products(m_pObj)		

		dim oRecordset
		set oRecordset=trans_.createadors(strQuery)

		if oRecordset.RecordCount = 0 then
			generate_products_info = ""
			exit function
		end if

		dim so:set so = doc_.createstreamobj()

		so.write "<text style='STYLE_RAPORTTITLE' width='max' align='center'>Produkty</text><br/>"
		so.write "<table>"
		so.write "<tbody style='STYLE_TABLE_BODY'>"
		so.write  "<tr style='STYLE_TABLE_HEADER'><td width='min'><t>LP</t></td><td width='max'><text>Nazwa</text></td><td><text>Opakowanie</text></td><td width='min'><t>Ilość</t></td><td width='min'><t>Wartość</t></td></tr>" + vbNewline

		while not oRecordset.eof
			so.write "<tr><td width='min'><t>"+cstr(oRecordset.AbsolutePosition)+"</t></td><td><text><![CDA"+"TA["+cstr(oRecordset.fields("pname").value) +"]"+"]></text></td><td><text><![CDA"+"TA["+cstr(oRecordset.fields("oname").value) +"]"+"]></text></td><td width='min'><t>"+doc_.afc.display.money(CCur(oRecordset.fields("curSUMIloscOpak").value),"")+"</t></td><td width='min'><t>"+doc_.afc.display.money(CCur(oRecordset.fields("curSUMWartBrutto").value),"")+"</t></td></tr>" + vbNewline
			oRecordset.movenext
		wend

		so.write  "</tbody></table>" + vbNewline
		
		generate_products_info = so.getstring()
	end function

end class

private function zal_info(byval elem)
	if elem.wrefZal.type = TYPEID_N5ZADANIE then
		zal_info = " - Typ: działanie;    Temat: " + elem.wrefZal.strTemat
	else
		zal_info = " - Typ: dokument;    Temat: " + elem.wrefZal.strTematDokum
	end if
end function

private function zad_pop_info(byval elem)
	if not elem.pPopZadanie is nothing then
		zad_pop_info = " - działanie jest kontynuacją działania """+elem.pPopZadanie.strTemat+""""
	end if
end function

private function zad_nad_info(byval elem)
	if not elem.pNadZadanie is nothing then
		zad_nad_info = " - działanie jest poddziałaniem działania """ + elem.pNadZadanie.strTemat + """"
	end if
end function


class CDossierAsHTML

