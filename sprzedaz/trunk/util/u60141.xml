#include "h1000.h"

#define IDCTRL_CHART	100
#define IDCTRL_NAME		110
#define IDCTRL_NAME1	111
#define IDCTRL_NAME2	112

<?xml version="1.0" encoding="windows-1250" ?>
<page style='STYLE_PAGE'>
<config>
<title>Wykres</title>
<script>
<!--
	Tworzenie wykresów
-->
<![CDATA[
#include "L50218"

dim pChartMaker : set pChartMaker = nothing

function fill : fill = true
	if pChartMaker is nothing then
		exit function
	end if
	pChartMaker.fill
end function

function showChart_SQL(byVal chartType, byVal SQLquery, byVal bShowLegend, byVal bShowChartTypeChange, byVal strHeader, byVal strFooter,byVal maxRows, byVal maxCols, byVal bNormalize)

	dim DS_SQL
	set DS_SQL=new CChartDataSource_SQL
	DS_SQL.connect SQLquery

	set pChartMaker = new CChartMaker
	set pChartMaker.DataSource = DS_SQL
	pChartMaker.chartType=chartType
	pChartMaker.maxRows=maxRows
	pChartMaker.maxCols=maxCols
	pChartMaker.strHeader=strHeader
	pChartMaker.strFooter=strFooter
	pChartMaker.ShowLegend=bShowLegend
	pChartMaker.Normalize=bNormalize
	
	if not pChartMaker.setup(IDCTRL_CHART) then	exit function

	if bShowChartTypeChange=false then
		page_.ctrl(IDCTRL_NAME).hide=true
		page_.ctrl(IDCTRL_NAME1).hide=true
		page_.ctrl(IDCTRL_NAME2).hide=true
	end if
	
	
	showChart_SQL = true

end function


function on_ZoomIn
   pChartMaker.ZoomIn
end function

function on_ZoomOut
   pChartMaker.ZoomOut
end function

function on_PrevView
   page_.ctrl(IDCTRL_NAME).value=pChartMaker.PrevView
end function

function on_NextView
   page_.ctrl(IDCTRL_NAME).value=pChartMaker.NextView
end function

]]>
</script>
</config>
	<body>
		<olecontrol 
				name='o##IDCTRL_CHART' 
				progid='mschart20lib.mschart.2'
				width='18000'
				height='10000'>
		</olecontrol>
		<button style='STYLE_BUTTON' href='varFunction="on_ZoomIn"'>Powiększ</button>
		<button style='STYLE_BUTTON' href='varFunction="on_ZoomOut"'>Pomniejsz</button>
		<button style='STYLE_BUTTON' name='o##IDCTRL_NAME1' href='varFunction="on_PrevView"'>Poprzedni widok</button>
		<button style='STYLE_BUTTON' name='o##IDCTRL_NAME2' href='varFunction="on_NextView"'>Następny widok</button>
		<text name='o##IDCTRL_NAME' >                                              </text>
	</body>
</page>
