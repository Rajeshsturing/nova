	end function

	'************************************************************************
	'* EVENT Zapisz aktywny dokument jezeli nie byl jeszcze zapisany
	'************************************************************************
	public function EVENT_closeOpenedFile(byref pNavoCommandExecution)
		EVENT_closeOpenedFile = m_pfncloseOpenedFile(pNavoCommandExecution)
	end function

	
	'************************************************************************
	'* EVENT Otworz plik
	'************************************************************************
	public function EVENT_OpenFile(byref pNavoCommandExecution)
		EVENT_OpenFile = m_pfnOpenFile(pNavoCommandExecution)
	end function


	'************************************************************************
	'* EVENT Sprawdzaj czy plik zostal juz otwarty
	'************************************************************************
	public function EVENT_isFileOpen(byref pNavoCommandExecution)
		EVENT_isFileOpen = m_pfnisFileOpen(pNavoCommandExecution)
	end function
	
	
end class

function CNavoCommandExecution(byref pApplication)
	set CNavoCommandExecution = new CNavoCommandExecution_A
	
	'wykonujemy konstruktor z parametrami
	if (not CNavoCommandExecution.class_init(pApplication)) then
		'jezeli cos sie nie dualo zainicjowac
		set CNavoCommandExecution = nothing
	end if
