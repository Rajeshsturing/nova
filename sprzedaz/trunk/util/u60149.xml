'****************************************


'----------------------------------------------------------------------------------
'* OUTLOOK: Zapisz zaznaczone listy
'----------------------------------------------------------------------------------
function OUTLOOKCommand(ByRef oApp, ByRef strCommand)

	dim pPage 'pobieranie poczty
	set pPage = doc_.getmodule( 60124 )
	
	if (not pPage is nothing) then

		'Sprawdzamy czy uzytkownik ma domyslnego wykonawce
		dim bIsPerformer
		bIsPerformer = false
		
		while (not bIsPerformer)
			bIsPerformer = pPage.CanReadMail()
			
			if (not bIsPerformer) then
				Enterprise_Bring2Top
				if (MessageBox ("Czy chcesz zrezygnować z importu wiadomości?","Brak wykonawcy", vbYesNo, vbInformation) = vbYes) then
					exit function
				end if
			end if
		wend
 
		dim oMail 'As Outlook.MailItem
		set oMail = nothing
		
		dim oExpl 'As Outlook.Explorer
		set oExpl = nothing
		
		'Czy ignorowac 2'jne wiadomosci
		dim bIgnoreDoubleMail
		bIgnoreDoubleMail = false

		on error resume next
		set oExpl = oApp.ActiveExplorer
		if (err.number<>0) then
			Enterprise_Bring2Top
			MessageBox "Nie udało się pobrać obiektu aktywnego okna z aplikacji Offic'a.", "Zapis poczty", vbOkOnly, vbInformation 
			exit function
		end if
		on error goto 0

		'Liczba zaznaczonych elementow
		dim nSelectionCount: nSelectionCount = CLng(0)
		
		on error resume next
		nSelectionCount = oExpl.Selection.count
		on error goto 0

		if (nSelectionCount>0) then

			dim nProcessedItems: nProcessedItems=0

			dim i
			for i = 1 To nSelectionCount
			
				set oMail = nothing

				on error resume next
				set oMail = oExpl.Selection.Item(i)
				on error goto 0

				if (not oMail is nothing) then
					
					on error resume next
					dim strItemType
					strItemType = TypeName( oMail )

					if (strItemType="MailItem" or _
						strItemType="PostItem") then

						pPage.saveMailItemToDB oMail, bIgnoreDoubleMail
						nProcessedItems = nProcessedItems + 1

					end if
					on error goto 0

				end if 'NOT oMail is nothing

			next

			if (nProcessedItems=0) then
				Enterprise_Bring2Top
				MessageBox "Eksportować można tylko wiadomości e-mail.", "Zapis poczty", vbOkOnly, vbInformation 
				exit function
			end if

		else
			Enterprise_Bring2Top
			MessageBox "Nie zaznaczono wiadomości do eksportu.", "Zapis poczty", vbOkOnly, vbInformation 
			exit function			
		end if

	end if 'not pPage is nothing

end function


