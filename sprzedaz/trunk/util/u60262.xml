#include "h1000.h"
#include "h1001.h"

<?xml version="1.0" encoding="windows-1250" ?>
<page>
<config>
<script>
<!--
	Eksport strony w postaci HTML

-->
<![CDATA[

sub Debug()
end sub

function PutCtrlData( byref Form)
	dim ctrlName
	dim ctrlType
	dim dataType
	dim ctrlID
	
	dim count: count = Form.Count
	dim i

	for i = 1 To count
		ctrlName = Form.Key(i)
		ctrlType = mid( ctrlName, 1, 1)
		dataType = mid( ctrlName, 2, 1)
		
		if ctrlType = "d" then
			ctrlID = clng( mid( ctrlName, 3, len(ctrlName)))
			
			if dataType = "s" then
				doc_.PutCtrlData ctrlID, Form.Item(i)
			elseif dataType = "l" then
				doc_.PutCtrlData ctrlID, clng( Form.Item(i))
			end if
			
		elseif ctrlType = "c" then
			PutCtrlData = Form.Item(i)
		end if
	next

	doc_.ApplyCtrlData
	doc_.WaitIdle
end function


function RoundTrip( byref Request, byref Response, byref currentRoundTripNo)
	
	dim actionFile:	actionFile = Request.ServerVariables("SCRIPT_NAME")
	
	if( clng( Request.Form("roundTripNo")) = currentRoundTripNo) then
		dim	strCommand: strCommand  = PutCtrlData( Request.Form)

		if strCommand <> "" then
			dim strPagePref: strPagePref = Mid( strCommand, 1, 1)
			dim ctrlId: ctrlId = clng( Mid( strCommand, 2, Len( strCommand)))	
			dim command
			
			if strPagePref = "t" then
				command = doc_.GetToolBar().ctrl(ctrlId).hli.GetString()
			elseif strPagePref = "o" then
				command = doc_.GetOutlookBar().ctrl(ctrlId).hli.GetString()
			elseif strPagePref = "p" then
				command = doc_.GetTopPage().ctrl(ctrlId).hli.GetString()
			elseif strPagePref = "m" then
				command = doc_.GetMenuObj().node(ctrlId).hli.GetString()
			end if
			
			doc_.PostCommand command
			doc_.WaitIdle
		end if
	end if

	dim pTopPage: set pTopPage = doc_.GetTopPage()
	dim pToolBar: set pToolBar = doc_.GetToolBar()
	dim pOutlookBar: set pOutlookBar = doc_.GetOutlookBar()
	dim pMenuObj: set pMenuObj = doc_.GetMenuObj()
	dim pStream: set pStream = doc_.CreateStreamObj()
	dim pHtmlGenerator: set pHtmlGenerator = doc_.GetModule(60102)

	currentRoundTripNo = currentRoundTripNo + 1
	pHtmlGenerator.ExportDesktop pStream, pMenuObj, pToolBar, pOutlookBar, pTopPage, actionFile, currentRoundTripNo
	
	Response.Write "<top>" + pStream.GetString() + "</top>"
	
	set pHtmlGenerator = nothing
	set pStream = nothing
	set pMenuObj = nothing
	set pOutlookBar = nothing
	set pToolBar = nothing
	set pTopPage = nothing
end function

]]>
</script>
</config>
	<body>
		<t>Eksport strony w postaci HTML</t>
	</body>
</page>
