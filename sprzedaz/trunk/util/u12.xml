<script>
<![CDATA[

#include "50629"

'-------------------------------------------------------------------
' Funckja wolana przez user_notification - dostaje tylko te komunikaty
' ktore maja dotrzec do strony odpowiedzialnej za wyswietlanie chata
'
' nOrigCookie - identyfikator user'a
' nEventCode  - typ wiadomosci
' varData     - wiadomosc
'
'-------------------------------------------------------------------
function on_user_message(byval nOrigCookie, byval nEventCode, byref varData)

	'jezeli nie jestesmy zalogowani to nie wolno nam
	'chat'owac. Nie wolamy getCurrentUserID bo nie
	'chcemy include'owac 50203 by bylo szybciej
	if (not trans_.isvar(GVAR_USER)) then
		exit function
	end if

	dim nUser: nUser=clng(trans_.var(GVAR_USER))
	if (nUser=0) then
		exit function
	end if

	'sprawdzamy czy chat jest uruchomiony
	dim bIsChat
	bIsChat=false

	if (trans_.isvar(GVAR_CHAT_OPEN)) then
		if (trans_.var(GVAR_CHAT_OPEN)=CLng(1)) then
			bIsChat=true
		end if 
	end if

	'specjalny filtering komunikatow zanim zaczniemy otwieranie strony
	select case nEventCode
		case NOTIFY_CODE_PERFORMER

			dim pMsgArray
			set pMsgArray=trans_.afc.new_navoarray()

			pMsgArray.Separate varData, MESSAGE_DELIMITER

			dim nActualWykonawca:nActualWykonawca=0
			dim pUser:set pUser=trans_.getobj(TYPEID_N5UZYTKOWNIK, nUser)
			if pUser is nothing then
				exit function
			end if
			dim pWykonawca:set pWykonawca=pUser.pWykonawca

			if (not pWykonawca is nothing) then
				nActualWykonawca=pWykonawca.idobj
				set pWykonawca=nothing
			end if

			'ten komunikat nie byl do nas
			if (nActualWykonawca<>clng(pMsgArray.Value(1))) then
				exit function
			end if

	end select

	dim pPage
	set pPage = find_page_on_iid( 20010 )

	if ((not bIsChat) and (pPage is nothing)) then

		'jezeli strona z chat'em nie jest otwarta
		'to ja otwieramy

		dim pNewHli
		set pNewHli = doc_.createhli()

		pNewHli.prop(GVAR_CMD) = CLng( CMD_OPEN_RECORD_PAGE )
		pNewHli.prop(GVAR_DESTPAGE) = CLng( 20010 )
		pNewHli.prop(GVAR_NEWTHREAD) = CLng(1)

		set pPage = doc_.getpagehli(pNewHli)

		doc_.pushpage( pPage )

	end if

	if (not pPage is nothing) then
		pPage.chat_OnNewMessage nOrigCookie, nEventCode, varData
	end if

	on_user_message=true
end function


'-------------------------------------------------------------------
' Funckja jest wolana gdy przychodzi nowy komunikat dla chat'a
'
' nOrigCookie - identyfikator user'a
' nEventCode  - typ wiadomosci
' varData     - wiadomosc
'
' !! engine hardcoded function name !!
'-------------------------------------------------------------------
function user_notification(byval nOrigCookie, byval nEventCode, byref varData)

	select case nEventCode
		case NOTIFY_CODE_TEXTOBJECT, NOTIFY_CODE_OBJECT, _
			NOTIFY_CODE_SYS_MESSAGE, NOTIFY_CODE_PERFORMER, _
			NOTIFY_CODE_PERFORMER_USER

			on_user_message nOrigCookie, nEventCode, varData
	
	end select

	user_notification=true
end function

'-------------------------------------------------------------------
' Funckja jest wolana gdy użytkownik kliknie w tło areny
'
'nButtonCode =
'	0 - left
'	2 -	right
'
' !! engine hardcoded function name !!
'-------------------------------------------------------------------
function arena_left_click(byval nButtonCode)
	if nButtonCode = 0 then
		'Uwaga! to okno ma być modalne: varNewThread=0
		doc_.postcommand("varCmd=CMD_OPEN_STATIC_PAGE varDestPage=72004 varNewThread=0")
	end if
end function

]]>

	</script>
</config>

