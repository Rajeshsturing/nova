'-----------------------------------------------------------------------
' Uruchamia nasz wizzard
'-----------------------------------------------------------------------
function fopen()
	if not HARUI(UAR_CMDID(CMDID_WIZZARD_RULES)) then
		fopen = false
		exit function
	end if

	'Strona uzywana tylko do uruchomienia wizzarda
	fopen = false

	'Tworzymy staly zestaw regul (rules). Trzymany on jest
	'w zmiennej globalnej g_pRules
	Rules_CreateConst

	'Wybór z listy dostępnych rules
	dim pRuleChoiceModule
	set pRuleChoiceModule = doc_.getmodule(60266)

	'IdObj wybranej zasady lub zero gdy nowa
	dim nRuleID
	nRuleID = pRuleChoiceModule.getRuleID()

	'Wychodzimy - zrezygnowano z wyboru
	if (nRuleID<0) then
		exit function
	end if

	'Uruchom nasz wizzard
	RulesWizzard_Start nRuleID
end function

