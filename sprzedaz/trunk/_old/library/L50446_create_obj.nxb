	@pt4_curSuma_EmKraj_par=pt4_curSuma_EmKraj,
	@pt4_curNalZal_EmKraj_par=pt4_curNalZal_EmKraj,
	@pt4_nLPod_EmZagr_par=pt4_nLPod_EmZagr,
