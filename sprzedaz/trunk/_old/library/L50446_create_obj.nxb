	@pt4_curNalZal_AresztSkaz_par=pt4_curNalZal_AresztSkaz,
	@pt4_nLPod_Fund_par=pt4_nLPod_Fund,
	@pt4_curSuma_Fund_par=pt4_curSuma_Fund,
	@pt4_curNalZal_Fund_par=pt4_curNalZal_Fund,
	@pt4_nLPod_Inne_par=pt4_nLPod_Inne,
	@pt4_curSuma_Inne_par=pt4_curSuma_Inne,
	@pt4_curNalZal_Inne_par=pt4_curNalZal_Inne,
	@pt4_curNalZal_RAZEM_par=pt4_curNalZal_RAZEM,
