	@prac_strIndeks_par varchar(32),
	@prac_strNrAkt_par varchar(32),
	@prac_strKodWyksztalcenia_par varchar(4),
	@prac_strKodZawodu_par varchar(4)) with encryption as 
	insert into n5pracownik values(@idobj_par,@versionid_par,
	@strNazwisko_par,
	@strImie_par,
	@strImie2_par,
	@dDataUr_par,
	@strMiejsceUr_par,
