	@strNazwa_par varchar(64),
	@pGrupaNadrzedna_par integer) with encryption as 
	update n5grupasrtrw set VersionId=@versionid_par,
	strNazwa=@strNazwa_par,
	pGrupaNadrzedna=@pGrupaNadrzedna_par
