create procedure n5pit11_delete(@idobj_par integer) with encryption as 
	delete from n5pit11 where idobj=@idobj_par
return @@rowcount
go

create procedure n5pit11_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5pit11
go

create procedure n5pit11_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10138
go

-- table: n5powiat
create procedure n5powiat_select(@idobj_par integer,@versionid_par integer output,
	@pow_strNazwa_par varchar(64) output,
	@pow_pWojewodztwo_par integer output) with encryption as 
	select @versionid_par=VersionId,
	@pow_strNazwa_par=pow_strNazwa,
	@pow_pWojewodztwo_par=pow_pWojewodztwo from n5powiat where IdObj=@idobj_par
return @@rowcount
go

create procedure n5powiat_insert(@idobj_par integer,@versionid_par integer,
	@pow_strNazwa_par varchar(64),
	@pow_pWojewodztwo_par integer) with encryption as 
	insert into n5powiat values(@idobj_par,@versionid_par,
	@pow_strNazwa_par,
	@pow_pWojewodztwo_par)
return @@rowcount
go

create procedure n5powiat_update(@idobj_par integer,@versionid_par integer,
	@pow_strNazwa_par varchar(64),
	@pow_pWojewodztwo_par integer) with encryption as 
	update n5powiat set VersionId=@versionid_par,
	pow_strNazwa=@pow_strNazwa_par,
	pow_pWojewodztwo=@pow_pWojewodztwo_par
	where idobj=@idobj_par
return @@rowcount
go

create procedure n5powiat_delete(@idobj_par integer) with encryption as 
	delete from n5powiat where idobj=@idobj_par
return @@rowcount
go

create procedure n5powiat_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5powiat
go

create procedure n5powiat_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10111 as integer),idobj from n5miejscowosc where mie_pPowiat=@idobj_par
union
select TOP 5 'typeid'=cast(10140 as integer),idobj from n5gmina where gmi_pPowiat=@idobj_par
go

-- table: n5gmina
create procedure n5gmina_select(@idobj_par integer,@versionid_par integer output,
	@gmi_strNazwa_par varchar(64) output,
	@gmi_pWojewodztwo_par integer output,
	@gmi_pPowiat_par integer output) with encryption as 
	select @versionid_par=VersionId,
