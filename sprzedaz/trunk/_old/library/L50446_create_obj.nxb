	@pt4_curKwotaDoPobOgrPop_par,
	@pt4_curKwotaPobPodUbRok_par,
	@pt4_curZaliczenieNadplUbRok_par,
	@pt4_curZwrotNadplGotUbRok_par,
	@pt4_curKwotaPobrPFRON_par,
