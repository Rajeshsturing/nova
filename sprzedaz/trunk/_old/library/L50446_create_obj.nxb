create procedure choicelist_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10127 as integer),idobj from n5WizzardEmail where pChoiceList=@idobj_par
union
select TOP 5 'typeid'=cast(10145 as integer),idobj from n5rejestrdok where wrefParam1=@idobj_par and wrefParam1_wrt=10124
union
select TOP 5 'typeid'=cast(10145 as integer),idobj from n5rejestrdok where wrefParam2=@idobj_par and wrefParam2_wrt=10124
go

