	@strNrDokTozsamosci_par,
	@strEmail2_par,
	@pJednostkaOrg_par,
	@pUrzadSkarbowy_par,
	@nLicznikNal_par,
	@strprac_Ulica_zameld_par,
	@strprac_NrDomu_zameld_par,
	@strprac_NrLokalu_zameld_par,
	@strprac_Kod_zameld_par,
	@strprac_Poczta_zameld_par,
	@pprac_Miejscowosc_zameld_par,
	@pprac_Kraj_zameld_par,
	@curprac_SzerGeogr_zameld_par,
	@curprac_DlugGeogr_zameld_par,
	@strprac_Ulica_koresp_par,
	@strprac_NrDomu_koresp_par,
