	@pprac_Miejscowosc_koresp_par,
	@pprac_Kraj_koresp_par,
	@curprac_SzerGeogr_koresp_par,
	@curprac_DlugGeogr_koresp_par,
	@strprac_Nazwisko_rod_par,
	@strprac_Imie_ojca_par,
	@strprac_Imie_matki_par,
	@strprac_Nazwisko_rod_mat_par,
	@strprac_Obywatelstwo_par,
	@strprac_Organ_wyd_dok_toz_par,
	@eprac_Oddział_NFZ_par,
	@prac_strIndeks_par,
	@prac_strNrAkt_par,
	@prac_strKodWyksztalcenia_par,
	@prac_strKodZawodu_par)
return @@rowcount
go

