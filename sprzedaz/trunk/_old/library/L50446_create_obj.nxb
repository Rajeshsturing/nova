	@strprac_Nazwisko_rod_par varchar(32),
	@strprac_Imie_ojca_par varchar(32),
	@strprac_Imie_matki_par varchar(32),
	@strprac_Nazwisko_rod_mat_par varchar(32),
	@strprac_Obywatelstwo_par varchar(64),
