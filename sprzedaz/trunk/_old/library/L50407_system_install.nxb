-- NAVO Enterprise 2002 System script for MS SQL Server 7.0+
-- version: release version 1.00 (2003-12-31)

raiserror('system_install begin ....',0,1)
GO

set nocount    on
set dateformat dmy
SET ANSI_PADDING OFF

USE master

-- creating logins
if not exists (select * from master..sysxlogins where name = N'navo2002user')
	BEGIN
		declare @logindb nvarchar(132), @loginlang nvarchar(132) select @logindb = N'navo2002', @loginlang = N'polski'
		if @loginlang is null or (not exists (select * from master..syslanguages where name = @loginlang) and @loginlang <> N'us_english')
			select @loginlang = @@language
		exec sp_addlogin N'navo2002user', N'y7410xru3', N'master', @loginlang
	END
else
	BEGIN
		exec sp_password @new='y7410xru3', @loginame='navo2002user'
	END
GO


-- general granting procedure

if exists (select * from sysobjects where name = 'n2001_makegrants')
	drop procedure n2001_makegrants
go

create procedure n2001_makegrants(@username nchar(50)) with encryption
as
	declare cur cursor for select o.name as name, o.type as type from sysobjects o where ObjectProperty(o.id, 'IsMSShipped') = 0
	open cur

	declare @name nchar(100)
	declare @type nchar(2)
	fetch next from cur into @name, @type
	while @@FETCH_STATUS = 0
		begin
			declare @text nchar(200), @what nchar(50)
			set @what = NULL
			set @type = rtrim(@type)
			if ((@type = N'P') or (@type = N'FN'))
				set @what = N'exec'
			if ((@type = N'U') or (@type = N'V'))
				set @what = N'select,insert,update,delete'
			if @what IS NOT NULL
				begin
					set @text = N'grant ' + RTRIM(@what) + N' on ' + RTRIM(@name) + N' to ' + RTRIM(@username)
					execute sp_executesql @text
				end
			fetch next from cur into @name, @type
		end
	close cur
	deallocate cur
	return 0
go


-- creating users on master
if exists (select * from sysusers where name = N'navo2002user' and uid < 16382)
	EXEC sp_revokedbaccess N'navo2002user'
GO
EXEC sp_grantdbaccess N'navo2002user', N'navo2002user'
GO

-- granting on master
n2001_makegrants 'navo2002user'
go

if exists (select * from sysdatabases where name='%DBNAME%')
begin
	raiserror('dropping existing %DBNAME% database ....',0,1)
	drop database %DBNAME%
end
go

if (1=%LOCAL_INSTALL%)
begin

	exec master..xp_cmdshell 'md "%DBDIR%"'

	-- create specified database
	-- %DBDIR% - trzeba zamienic w skrypcie na path do katalogu Database
	create database %DBNAME% on
	(
		NAME = %DBNAME%_dat,
		FILENAME = '%DBDIR%\%DBNAME%.mdf'
	)
	log on
	(
		NAME = '%DBNAME%_log',
		FILENAME = '%DBDIR%\%DBNAME%_log.ldf'
	)

end else begin
	create database %DBNAME%
end
go

CHECKPOINT
GO

USE %DBNAME%	

-- general granting procedure

if exists (select * from sysobjects where name = 'n2001_makegrants')
	drop procedure n2001_makegrants
go
create procedure n2001_makegrants(@username nchar(50)) with encryption
as
	declare cur cursor for select o.name as name, o.type as type from sysobjects o where ObjectProperty(o.id, 'IsMSShipped') = 0
	open cur

	declare @name nchar(100)
	declare @type nchar
	fetch next from cur into @name, @type
	while @@FETCH_STATUS = 0
		begin
			declare @text nchar(200), @what nchar(50)
			set @what = NULL
			if (@type = N'P')
				set @what = N'exec'
			if ((@type = N'U') or (@type = N'V'))
				set @what = N'select,insert,update,delete'
			if @what IS NOT NULL
				begin
					set @text = N'grant ' + RTRIM(@what) + N' on ' + RTRIM(@name) + N' to ' + RTRIM(@username)
					execute sp_executesql @text
				end
			fetch next from cur into @name, @type
		end
	close cur
	deallocate cur
	return 0
go

execute sp_dboption '%DBNAME%' ,'trunc. log on chkpt.' ,'true'
GO


-- creating users on user database
if exists (select * from sysusers where name = N'navo2002user' and uid < 16382)
	EXEC sp_revokedbaccess N'navo2002user'
GO
EXEC sp_grantdbaccess N'navo2002user', N'navo2002user'
GO

-- for restore 
sp_addsrvrolemember 'navo2002user','dbcreator'
go
-- adding roles (it can be tighter just for backup purpose i.e. db_backupoperator)
