<class>
  <identifier>TYPEID_N5DOKSTATUS</identifier>
  <table>n5dokstatus</table>
  <humanname>Status dokumentu</humanname>
  <idobj/>
  <embedded>
    <name>dcs_strNazwa</name>
    <sqltype>SQLvc64</sqltype>
    <humanname>Nazwa statusu</humanname>
    <nonempty/>
  </embedded>
  <!-- 
  kolejne znaki ('0'/'1') odpowiadaja typom dokumentow:
    SPRZEDAZ
    KOREKTA_SPRZEDAZY    
    ZAKUP
    KOREKTA_ZAKUPU
    ZAPYTANIE_OFERTOWE_OBCE
    ZAPYTANIE_OFERTOWE_WLASNE
    OFERTA_OBCA
    OFERTA_WLASNA
    ZAMOWIENIE_OBCE
    ZAMOWIENIE_WLASNE
    PZ
    WZ
    MM
    MM-
    MM+
    RW
    PW
    IR
    IP
    RP
    PP
    REAL_PROD
    PLATNOSC_WYDATEK
    PLATNOSC_WPLYW
    ZADANIE
  -->
  <embedded>
    <name>dcs_strTypDok</name>
    <sqltype>SQLvc32</sqltype>
    <humanname>Typ dokumentu</humanname>
    <nonempty/>
  </embedded>    
  <cursors>
    DEFAULT_CURSOR(wg nazwy,dcs_strNazwa)
    DOCUMENTS_CURSORS
  </cursors>

  <script>
    <![CDATA[
    
function n5dokstatus_initnew()
  this_.dcs_strTypDok = "0000000000000000000000000"
	n5dokstatus_initnew = true
end function    
    
function n5dokstatus_as_text()
  n5dokstatus_as_text = this_.dcs_strNazwa
end function

]]>
  </script>
</class>
