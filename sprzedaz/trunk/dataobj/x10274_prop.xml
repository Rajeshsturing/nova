<?xml version="1.0" encoding="windows-1250" ?>
<!--
prefix: prop_

#define _RECALC_TABLENAME_	n5prop

#include "h1000.h" 
#include "h1200.h" 
#include "h1231.h"

-->
<class>
  <identifier>TYPEID_N5PROP</identifier>
  <table>n5prop</table>
  <humanname>Operacja produkcyjna</humanname>
  <idobj/>
  <embedded>
    <name>prop_iNumOp</name>
    <sqltype>SQLlong</sqltype>
    <humanname>Numer operacji</humanname>
  </embedded>
  <enum>
    <name>prop_eStatus</name>
    <humanname>Status</humanname>
    <item>symulacja</item>
    <item>zlecone</item>
    <item>dowykonania</item>
    <item>wrealizacji</item>
    <item>zrealizowane</item>
    <item>inny</item>
    <default>N5PROPS_SYMULACJA</default>
  </enum>
  <enum>
    <name>prop_eTyp</name>
    <humanname>Typ</humanname>
    <item>Surowiec</item>
    <item>Wyrób</item>
    <item>Praca</item>
    <item>Zasób</item>
  </enum>
  <!--  powiązanie ze zleceniem prod-->
  <ref>
    <name>prop_pZlecProd</name>
    <humanname>Zlecenie produkcyjne</humanname>
    <typeid>TYPEID_N5ZLECPROD</typeid>
  </ref>
  <embedded>
    <name>prop_iLPZP</name>
    <sqltype>SQLlong</sqltype>
    <humanname>Pozycja zlecenia prod.</humanname>
  </embedded>
  <embedded>
    <name>prop_strOP</name>
    <sqltype>SQLvc256</sqltype>
    <humanname>Ścieżka operacji</humanname>
  </embedded>
  <!-- daty i terminy -->
  <embedded>
    <name>prop_dDataRozp</name>
    <sqltype>SQLdate</sqltype>
    <humanname>Data rozpoczęcia</humanname>
  </embedded>
  <embedded>
    <name>prop_tCzasRozp</name>
    <sqltype>SQLtime</sqltype>
    <humanname>Czas rozpoczęcia</humanname>
  </embedded>
  <embedded>
    <name>prop_dDataZak</name>
    <sqltype>SQLdate</sqltype>
    <humanname>Data zakończenia</humanname>
  </embedded>
  <embedded>
    <name>prop_tCzasZak</name>
    <sqltype>SQLtime</sqltype>
    <humanname>Czas zakończenia</humanname>
  </embedded>
  <!-- -->
  <ref>
    <name>prop_pEgzemplarz</name>
    <humanname>Egzemplarz</humanname>
    <typeid>TYPEID_N5EGZEMPLARZ</typeid>
    <optional/>
  </ref>
  <ref>
    <name>prop_pZasob</name>
    <humanname>Zasób</humanname>
    <typeid>TYPEID_N5ZASOBPROD</typeid>
    <optional/>
  </ref>
  <ref>
    <name>prop_pTypZasobu</name>
    <humanname>Typ zasobu</humanname>
    <typeid>TYPEID_N5TYPZASOBPROD</typeid>
    <optional/>    
  </ref>  
  <ref>
    <name>prop_pOperacja</name>
    <humanname>Operacja</humanname>
    <typeid>TYPEID_N5RECEPTA</typeid>
    <optional/>
  </ref>
  <ref>
    <name>prop_pProdukt</name>
    <humanname>Produkt</humanname>
    <typeid>TYPEID_N5PRODUKT</typeid>
    <optional/>
  </ref>
  <ref>
    <name>prop_pOpak</name>
    <humanname>Opakowanie produktu</humanname>
    <typeid>TYPEID_N5OPAKOWANIE_PRODUKTU</typeid>
    <optional/>
  </ref>
  <embedded>
    <name>prop_curIloscDoWyk</name>
    <sqltype>SQLqty</sqltype>
    <humanname>Ilość do wykonania</humanname>
    <default>1.0</default>
  </embedded>
  <embedded>
    <name>prop_curIloscWykon</name>
    <sqltype>SQLqty</sqltype>
    <humanname>Ilość wykonana</humanname>
    <default>0.0</default>
  </embedded>
  <embedded>
    <name>prop_curIloscGotow</name>
    <sqltype>SQLqty</sqltype>
    <humanname>Ilość gotowa do wykonania</humanname>
    <default>0.0</default>
  </embedded>
  <!-- dokumenty rozliczające -->
  <ref>
    <name>prop_pDokMag</name>
    <humanname>Dokument magazynowy</humanname>
    <typeid>TYPEID_N5DOKMAG</typeid>
    <optional/>
  </ref>
  <ref>
    <name>prop_pRealProd</name>
    <humanname>Rozliczenie produkcji</humanname>
    <typeid>TYPEID_N5REALPROD</typeid>
    <optional/>
  </ref>
  <embedded>
    <name>prop_strUwagi</name>
    <sqltype>SQLvc512</sqltype>
    <humanname>Uwagi</humanname>
  </embedded>
  <cursors />
  <script>
    <![CDATA[
function n5prop_as_text()
  n5prop_as_text = ""
end function
]]>
  </script>
</class>
