#include "h1000.h"

<?xml version="1.0" encoding="windows-1250"?>
<class>
	<identifier>TYPEID_SEARCHTYPEITEM</identifier>
	<table>SearchTypeItem</table>
	<humanname>Element sposobu wyszukiwania</humanname>
	<child/>
	<hidden/>
	<idobj/>
	<embedded>
		<name>ComposedPath</name>
		<sqltype>SQLvc256</sqltype>
		<humanname>Composed path</humanname>
		<nonempty/>
	</embedded>
	<embedded>
		<name>selectiontype</name>	<!-- typ okienka do selekcji -->
		<sqltype>SQLlong</sqltype>
		<virtual/>
		<default>0</default>
	</embedded>
	<embedded>
		<name>cGroup</name>
		<sqltype>SQLc1</sqltype>
		<humanname>'1'-dane maja byc grupowane, '0'-nie maja byc grupowane</humanname>
		<default>0</default>
		<nonempty/>
	</embedded>
	<embedded>
		<name>cDesc</name>
		<sqltype>SQLc1</sqltype>
		<humanname>'1'-dane maja byc sortowane malejaco, '0'-nie maja byc sortowane rosnaco</humanname>
		<default>0</default>
		<nonempty/>
	</embedded>
	<embedded>
		<name>cLink</name>
		<sqltype>SQLc1</sqltype>
		<humanname>'1'-kolumna jest laczem do wskazywanego obiektu</humanname>
		<default>0</default>
		<nonempty/>
	</embedded>
<script>

<![CDATA[
function SearchTypeItem_ComposedPath_change(oldval)
	this_.selectiontype = clng(0)	'reset
	SearchTypeItem_ComposedPath_change = true
end function

'--------------------------------------------------------------------------
'
' getType 
'
' pobiera typ i humanname ze sciezki
'
'--------------------------------------------------------------------------
function subGetType(byVal path,ByRef strListaPol):subGetType=Clng(0)
	dim sSplitter
	dim arrY:
	if getSplitterForWildReference(path, sSplitter) then
		dim i,tmpType
		arrY=Split(path,sSplitter)
		for i=LBound(arrY)+2 to UBound(arrY)-1
			tmpType=subGetType(arrY(i),strListaPol)
			if tmpType>0 then subGetType=tmpType
		next 
	else
		arrY=Split(path,";")
		dim pt:pt=UBound(arrY)
		dim flddef
		dim FldName
		if pt>0 then

			if (mid(arrY(pt), 1, 3)="#LP") then
				subGetType = CLng( 1 )
				strListaPol = "Pozycja"
			else
		
				if arrY(pt)<>"" then 
					dim obj:set obj=stdobjdef_.getobjdef(arrY(pt-1))
					set flddef=obj.field(obj.getfieldindex(arrY(pt)))
					if strListaPol<>"" then strListaPol=strListaPol+","
					strListaPol=strListaPol + flddef.Humanname
					FldName = flddef.name
					if (FldName="IdObj") then
							subGetType = CLng(arrY(pt-1))
					else 
							if flddef.type = RELT_ENUM then
								subGetType = clng(4)
							else
								select case flddef.sqltype
								case SQLlong	
									subGetType = clng(6)
								case SQLtime
									subGetType = clng(5)
								case SQLcurrency
									subGetType = clng(3)
								case SQLdate
									subGetType = clng(2)
								case else
									subGetType = clng(1)
								end select
							end if
					end if
				end if

			end if '#LP

		end if			
	end if

end function 




'--------------------------------------------------------------------------
'
' SearchTypeItem_getselectiontype()
'
'--------------------------------------------------------------------------

function SearchTypeItem_getselectiontype()
	if this_.selectiontype =  0 then
		dim strListaPol:strListaPol=""
		this_.selectiontype=CLng(subGetType (this_.ComposedPath,strListaPol))
	end if
	SearchTypeItem_getselectiontype = this_.selectiontype
end function




function SearchTypeItem_compose_name()
	dim strAll:strAll=makeNames(this_.ComposedPath,"")
	dim arrY:arrY=Split(strAll,"|")
	dim str:str=""
	dim f
	if (uBound(arrY)>lBound(arrY)) then
		for f=lBound(arrY) to uBound(arrY)-1
			str = str + arrY(f) 
			if f<(uBound(arrY)-1) then str = str + ") lub "
		next 
	else
		str=strAll
	end if

	SearchTypeItem_compose_name= str + CStr(")")
end function

'
' Funkcja tworzy krótką nazwę (zawiera tylko ostatni człon z pola ComposedPath)
'
function SearchTypeItem_compose_short_name()
'SearchTypeItem_compose_short_name="TODO:SearchTypeItem_compose_short_name"
	dim sSplitter
	dim str:str=""
	dim path:path=this_.ComposedPath
	
	if getSplitterForWildReference(path, sSplitter) then
		str=Split(path,sSplitter)(1)
		SearchTypeItem_compose_short_name=str
	end if

	if str="" then
		dim strListaPol:strListaPol=""
		this_.selectiontype=subGetType (path,strListaPol)
		SearchTypeItem_compose_short_name = strListaPol
	end if
end function


'--------------------------------------------------------------------------
'
'	getSplitterForWildReference
'
'	pobiera znak dzielnika stringu dzikiej referencji np: (1) lub (2)
'
'--------------------------------------------------------------------------
function getSplitterForWildReference(byVal sAll,byRef sSplitter)
	dim sElem
	dim sChar
	dim n1
	dim arrY: arrY=Split(sAll,";")
	dim arrYElem

	sSplitter=""
	getSplitterForWildReference=false

	if (ubound(arrY)>0) then
		sElem=arrY(ubound(arrY))
		sChar=Right(sElem,1)
		if sChar=")" then 
			n1=InStrRev(sElem,"(",-1,1)
			sSplitter="("+mid(sElem,n1+1,Len(sElem)-n1-1)+")"
			getSplitterForWildReference=true
		end if
	end if

end function





'--------------------------------------------------------------------------
'
'	getPrecedingPathName
'
'	tworzy sciezke nazw z poprzedzajacych obiektow :np " w Obiekt001 w Obiekt002"
'
'--------------------------------------------------------------------------

function getPrecedingPathName(byVal ComposedPath):getPrecedingPathName=""
	'dim stdobjdef_:set stdobjdef_=doc_.stdobjdef
	dim str:str=""
	dim PathArray : PathArray = split(ComposedPath,";")
	if (ubound(PathArray )<0) then exit function

	dim iter
	dim TypeId : TypeId = PathArray(ubound(PathArray)-1)
	dim FldName : FldName = PathArray(ubound(PathArray))

	dim tmpID: tmpID=CLng(0)
	dim firstChar: firstChar=" "


	dim NazwaPola: NazwaPola=""
	for iter = ubound(PathArray)-2 to 0 step -2
		
		TypeId = PathArray(iter-1)
		FldName = PathArray(iter)
		
		firstChar = mid(FldName,1,1)
		if (firstChar = "-" ) then
			tmpID = PathArray(iter+1)
			FldName=mid(FldName,2)
			NazwaPola = stdobjdef_.getobjdef(tmpID).field(stdobjdef_.getobjdef(tmpID).getfieldindex(FldName)).HumanName
			str = str + " przez " + stdobjdef_.getobjdef(tmpID).HumanName + ".[" + NazwaPola + "]"
			str = str + " do " + stdobjdef_.getobjdef(TypeId).HumanName
		else
			str = str + " w " + stdobjdef_.getobjdef(TypeId).HumanName	 
		end if
	next
	getPrecedingPathName = str
end function


'--------------------------------------------------------------------------
'
'	getBeginName
'
'	tworzy nazwe poczatkowa np: "Pole Jakietakie (z ObiektJakiTaki"
'
'--------------------------------------------------------------------------
function getBeginName(byVal ComposedPath):getBeginName=""
	'dim stdobjdef_:set stdobjdef_=doc_.stdobjdef
	dim str:str=""
	dim PathArray : PathArray = split(ComposedPath,";")

	if (ubound(PathArray )<0) then exit function

	dim TypeId : TypeId = PathArray(ubound(PathArray)-1)
	dim FldName : FldName = PathArray(ubound(PathArray))

	with stdobjdef_.getobjdef(TypeId)
		if FldName="IdObj" then
			str = "Cały obiekt (z " + .HumanName
		elseif (Mid(FldName, 1, 3)="#LP") then
			str = "Pozycja na liście (z " + .HumanName 
		else
			if FldName<>"" then
				str = .field(.getfieldindex(FldName)).HumanName	+ " (z " + .HumanName
			else
				str = "Dowolny (z " + .HumanName
			end if
		end if
	end with

	getBeginName=str
end function






'--------------------------------------------------------------------------
'
'	makeNames
'
'	tworzy opis wg sciezki
'
'--------------------------------------------------------------------------
function makeNames(byVal sAll, byVal sSplitter)
	
	dim newSplitter:newSplitter=CStr("")

	if sSplitter=""then
		if getSplitterForWildReference(sAll,newSplitter) then
			makeNames=makeNames(sAll,newSplitter)
		else
			makeNames= getBeginName(sAll) + getPrecedingPathName(sAll) 
		end if
	else
		dim arrY: arrY=Split(sAll,sSplitter)
		dim f
		dim g
		dim strNames:strNames=""
		dim strWildTableName:strWildTableName=""
		dim strPrecedingPathName :strPrecedingPathName =""
		dim NazwaPola
		dim tmpID:tmpID=0
		dim tmpPole:tmpPole=""

		if uBound(arrY)>0 then
			
			'obrabiamy poczatek
			dim strPrev: strPrev=arrY(lBound(arrY))
			strPrev = Left(strPrev ,len(strPrev )-1)'obcinamy ostatni ";"
			
			strPrecedingPathName = getPrecedingPathName(strPrev)
			
			dim arrZ:arrZ=Split(strPrev,";")
			tmpID=CLng(arrZ(uBound(arrZ)-1))
			tmpPole=CStr(arrZ(uBound(arrZ)))
			strWildTableName=stdobjdef_.getobjdef(CLng(tmpID)).Humanname
			NazwaPola = stdobjdef_.getobjdef(tmpID).field(stdobjdef_.getobjdef(tmpID).getfieldindex(tmpPole)).HumanName


			dim disassArrY
			dim strTmpNames:strTmpNames=""
			for f=lBound(arrY)+2 to uBound(arrY)-1
				strTmpNames= makeNames(arrY(f),"")
				disassArrY=Split(strTmpNames,"|")
				strTmpNames=""
				for g=lBound(disassArrY) to uBound(disassArrY)
					if disassArrY(g)<>"" then
						strTmpNames = strTmpNames + disassArrY(g) + " w "+ strWildTableName + ".["+NazwaPola +"]" + strPrecedingPathName + "|"
					end if
				next
				strNames = strNames + strTmpNames
			next
		end if
		makeNames = strNames
	end if
end function


]]>
</script>
</class>
