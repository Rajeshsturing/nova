<class>
	<identifier>TYPEID_N5GRUPAKLIENT</identifier>
	<table>n5grupaklient</table>
	<humanname>Grupa klientów</humanname>
	<idobj/>
	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc64</sqltype>
		<humanname>Nazwa</humanname>
		<unique/>
	</embedded>
	<ref>
		<name>pGrupaNadrzedna</name>
		<humanname>Grupa nadrzędna</humanname>
		<typeid>TYPEID_N5GRUPAKLIENT</typeid>
		<optional/>
	</ref>
	<embedded>
		<name>curLimitKred</name>
		<sqltype>SQLcurrency</sqltype>
		<humanname>Limit kredytowy</humanname>
	</embedded>
	<ref>
		<name>pWalutaLimitu</name>
		<humanname>Waluta limitu</humanname>
		<typeid>TYPEID_N5JEDNOSTKA</typeid>
		<optional/>
	</ref>



	<enum>
		<name>gkli_eZestawCenowy</name>
		<humanname>Zestaw cenowy</humanname>
		<default>1</default>
		<item>1</item>
		<item>2</item>
		<item>3</item>
		<item>4</item>
		<item>5</item>
		<item>6</item>
		<item>aktualny</item>
	</enum>

<cursors>
	DEFAULT_CURSOR(wg nazwy,strNazwa)
</cursors>

<script>
<![CDATA[
'programmer's script
'getCurrentFirma
#include "50203"

function n5grupaklient_initnew()
	'REV:KB:TODO: firma może nie istnieć podczas wczytywania preloadu
	'ale to powinno być rozróżniane przez APPVAR_IMPORT

	dim pFirma : set pFirma = getCurrentFirma()
	if not pFirma is nothing then
		set this_.pWalutaLimitu = pFirma.pWaluta
	end if
	n5grupaklient_initnew=true
end function

function n5grupaklient_as_text()
	n5grupaklient_as_text=this_.strNazwa
end function

]]>
</script>
	
	
	
	
</class>
