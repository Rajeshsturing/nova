<class>
	<identifier>TYPEID_N5PLSUBKONTO</identifier>
	<table>n5plsubkonto</table>
	<humanname>Subkonto płacowe</humanname>
	<idobj/>
	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc64</sqltype>
		<humanname>Nazwa</humanname>
		<unique/>
	</embedded>
	<embedded>
		<name>strKod</name>
		<sqltype>SQLc8</sqltype>
		<humanname>Kod subkonta</humanname>
		<unique/>
	</embedded>
	<embedded>
		<name>strOpis</name>
		<sqltype>SQLvc1024</sqltype>
		<humanname>Opis</humanname>
	</embedded>
	<enum>
		<name>eAktywne</name>
		<humanname>Aktywne</humanname>
		<default>N5PL_SUBKONTO_AKTYWNE</default>
		<item>Aktywne</item>
		<item>Nieaktywne</item>
	</enum>
	<ref>
		<name>pJednostka</name>
		<humanname>Jednostka</humanname>
		<typeid>TYPEID_N5JEDNOSTKA</typeid>
	</ref>
	<enum>
		<name>eZakres</name>
		<humanname>Zakres</humanname>
		<default>N5PL_SUBKONTO_ZAKRES_PRACOWNIK</default>
		<item>Pracownik</item>
		<item>Umowa</item>
		<item>Naliczenie</item>
	</enum>

	<!-- BD5 -->

	<embedded>
		<name>plsk_nInternalID</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Pochodzenie danych</humanname>
	</embedded>

<cursors>
	DEFAULT_CURSOR(wg kodu,strKod)
</cursors>

<script>
<![CDATA[
function n5plsubkonto_as_text()
	   n5plsubkonto_as_text = this_.strNazwa + "(" + this_.strKod + ")"
end function

function n5plsubkonto_befdel()
	'wolno usuwac tylko niesystemowe
	if (this_.plsk_nInternalID = 0) then
		trans_.message 1201,0,"To subkonto jest wymagane przez system naliczeń"
		n5plsubkonto_befdel = false
	else
		n5plsubkonto_befdel = true
	end if
end function
]]>
</script>
</class>
