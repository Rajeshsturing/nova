<class>
	<identifier>TYPEID_N5BWINFO_PRODUKT</identifier>
	<table>n5bwinfo_produkt</table>
	<hidden/>
	<humanname>Produkt lub grupa</humanname>
	<child/>
	<idobj/>

	<wildref>
		<name>wpProdGrupa</name>
		<humanname>Produkt lub grupa produktów</humanname>
		<typeid>TYPEID_N5PRODUKT</typeid>
		<typeid>TYPEID_N5GRUPAPRODUKTOW</typeid>
	</wildref>

	<ref>
		<name>pOpak</name>
		<humanname>Opakowanie produktu</humanname>
		<typeid>TYPEID_N5OPAKOWANIE_PRODUKTU</typeid>
		<optional/>
	</ref>

	


<cursors>
	<cursor>									
		<identifier>CRSR_DEFAULT</identifier>
		<humanname>po tytule</humanname>
		<join></join>					
		<where></where>							
		<orderby>wpProdGrupa</orderby>				
	</cursor>									
</cursors>


<script>
<![CDATA[

function n5bwinfo_produkt_as_text()
	if not this_.wpProdGrupa is nothing then
		n5bwinfo_produkt_as_text= this_.wpProdGrupa.text
	else
		n5bwinfo_produkt_as_text= "<brak grupy/produktu>"
	end if
end function



]]>
</script>
</class>
