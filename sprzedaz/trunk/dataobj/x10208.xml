<class>
	<identifier>TYPEID_N5BUDZET</identifier>
	<table>n5budzet</table>
	<humanname>Budżet</humanname>
	<idobj/>
	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc128</sqltype>
		<humanname>Nazwa</humanname>
		<nonempty/>
	</embedded>
		<embedded>
		<name>dDataOd</name>
		<sqltype>SQLdate</sqltype>
		<humanname>Data początkowa</humanname>
		<nonempty/>
	</embedded>
	<embedded>
		<name>dDataDo</name>
		<sqltype>SQLdate</sqltype>
		<humanname>Data końcowa</humanname>
		<nonempty/>
	</embedded>


<cursors>
	<cursor>
		<identifier>CRSR_DEFAULT</identifier>
		<humanname>wg nazwy</humanname>
		<join></join>
		<where></where>
		<orderby>strNazwa</orderby>
	</cursor>
</cursors>

<script>
<![CDATA[

function n5budzet_as_text()
    n5budzet_as_text = this_.strNazwa + _
		" (okres od " + trans_.afc.display.fulldate(this_.dDataOd) + _
		" do " + trans_.afc.display.fulldate(this_.dDataDo) + _
		")"
end function

]]>
</script>
	
	
	
	
</class>
