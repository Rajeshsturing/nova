<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h" 
#include "h1200.h" 
#include "h1231.h" 
-->
<class>
	<identifier>TYPEID_N5PTOP</identifier>
	<table>n5ptop</table>
	<dontcacheonserver/>
	<dontcacheonclient/>
	<alwayscandel/>
	<humanname>Operacja na płatności</humanname>
	<idobj/>
	<enum>
		<name>gmo_eTypOp</name>
		<humanname>Typ operacji</humanname>
		<item>WPLATA</item>				<!-- wpłata -->
		<item>WYPLATA</item>				<!-- wypłata -->
	</enum>
	<embedded>
		<name>gmo_nNumOp</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Numer operacji płatności</humanname>
		<nonempty/>
	</embedded>
	<embedded>
		<name>gmo_nLP</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Pozycja operacji</humanname>
		<nonempty/>
		<!-- 
			pozycja w operacji na płatności
		-->
	</embedded>
	<embedded>
		<name>gmo_curIlosc</name>
		<sqltype>SQLqty</sqltype>
		<humanname>Kwota w walucie</humanname>
		<nonempty/>
	</embedded>
	<embedded>
		<name>gmo_curCena</name>
		<sqltype>SQLprice</sqltype>
		<humanname>Kurs waluty</humanname>
	</embedded>
	<embedded>
		<name>gmo_curWartosc</name>
		<sqltype>SQLcurrency</sqltype>
		<humanname>Kwota w PLN</humanname>
	</embedded>
	<ref>
		<name>gmo_pProd</name>
		<humanname>Produkt (zawsze 0)</humanname>
		<typeid>TYPEID_N5PRODUKT</typeid>
    <default>0</default>
	</ref>
	<ref>
		<name>gmo_pOpak</name>
		<humanname>Opakowanie (zawsze 0)</humanname>
		<typeid>TYPEID_N5OPAKOWANIE_PRODUKTU</typeid>
    <default>0</default>
	</ref>
	<ref>
		<name>gmo_pMag</name>
		<humanname>Rejestr dokumentów</humanname>
		<typeid>TYPEID_N5REJESTRDOK</typeid>
	</ref>
	<embedded>
		<name>gmo_idDost</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Identyfikator dostawy</humanname>
		<nonempty/>		
	</embedded>
	<embedded>
		<name>gmo_idDostLP</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Subidentyfikator dostawy</humanname>
		<nonempty/>
		<!-- 
			j.w. tylko uszczegolawia
		-->
	</embedded>
	<embedded>
		<name>gmo_dDataWazn</name>
		<sqltype>SQLdate</sqltype>
		<humanname>Data ważności</humanname>
		<default>null</default>
	</embedded>
	<embedded>
		<name>gmo_nNumOpRel</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Numer operacji powiązanej</humanname>
    <default>0</default>
	</embedded>
	<embedded>
		<name>gmo_nLPRel</name>
		<sqltype>SQLlong</sqltype>
		<humanname>LP powiązanej</humanname>
    <default>0</default>
	</embedded>
	<embedded>
		<name>gmo_curPrzel</name>
		<sqltype>SQLcurrency</sqltype>
		<humanname>Przelicznik</humanname>
		<default>1.0</default>
	</embedded>
<cursors />

<script>
<![CDATA[
function n5ptop_gmo_curCena_change(oldval)
	this_.gmo_curWartosc = trans_.afc.convert.round2(this_.gmo_curIlosc * this_.gmo_curCena)

	n5ptop_gmo_curCena_change = true
end function

function n5ptop_gmo_curIlosc_change(oldval)
	this_.gmo_curWartosc = trans_.afc.convert.round2(this_.gmo_curIlosc * this_.gmo_curCena)

	n5ptop_gmo_curIlosc_change = true
end function

function n5ptop_as_text()
	n5ptop_as_text = ""
end function

]]>
</script>
	
	
	
	
</class>
