<!--
REV:KB:20030123

#include "h1000.h" 
#include "h1200.h" 
#include "h1231.h"
-->
<class>
	<identifier>TYPEID_N5TYPDZIALANIA</identifier>
	<table>n5typdzialania</table>
	<humanname>Typ dzialania</humanname>
	<idobj/>
	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc64</sqltype>
		<humanname>Nazwa typu dzialania</humanname>
		<unique/>
	</embedded>
	<embedded>
		<name>nInternalID</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Pochodzenie danych</humanname>
	</embedded>
	<!--
		0 dla danych wprowadzanych przez uzytkownika
		inna wartosc dla danych preloadowanych
	-->
	<ref>
		<name>pTypNadrzedny</name>
		<humanname>Typ nadrzedny</humanname>
		<typeid>TYPEID_N5TYPDZIALANIA</typeid>
		<optional/>
	</ref>
	<embedded>
		<name>strOpis</name>
		<sqltype>SQLvc256</sqltype>
		<humanname>Opis typu dzialania</humanname>
	</embedded>
	<embedded>
		<name>tpdz_strVBCheckReady</name>
		<sqltype>SQLvc7900</sqltype>
		<humanname>Sprawdzanie gotowości</humanname>
	</embedded>
	<embedded>
		<name>tpdz_strVBCheckDone</name>
		<sqltype>SQLvc7900</sqltype>
		<humanname>Sprawdzanie zakończenia</humanname>
	</embedded>
	<enum>
		<name>tpdz_eAktywny</name>
		<humanname>Status</humanname>
		<default>N5TYPDZIALANIA_AKTYWNY</default>
		<item>Aktywny</item>
		<item>Nieaktywny</item>
	</enum>
<cursors>
	<cursor>
		<identifier>CRSR_N5TYPDZIALANIA_WEDLUG_NAZWY</identifier>
		<humanname>wedlug nazwy</humanname>
		<join></join>
		<where></where>
		<orderby>strNazwa</orderby>
	</cursor>

	<cursor>
		<identifier>CRSR_N5TYPDZIALANIA_NOTATKI_NAZWY</identifier>
		<humanname>notatki</humanname>
		<join></join>
		<where>(nInternalID LIKE '3%')</where>
		<orderby>strNazwa</orderby>
	</cursor>

	<cursor>
		<identifier>CRSR_N5TYPDZIALANIA_KONTAKTY_NAZWY</identifier>
		<humanname>kontakty</humanname>
		<join></join>
		<where>(nInternalID LIKE '1%')</where>
		<orderby>strNazwa</orderby>
	</cursor>

	<cursor>
		<identifier>CRSR_N5TYPDZIALANIA_WIADOMOSCI_NAZWY</identifier>
		<humanname>wiadomosci</humanname>
		<join></join>
		<where>(nInternalID LIKE '4%')</where>
		<orderby>strNazwa</orderby>
	</cursor>

	<cursor>
		<identifier>CRSR_N5TYPDZIALANIA_KORESPONDENCJA_NAZWY</identifier>
		<humanname>korespondencja</humanname>
		<join></join>
		<where>(nInternalID LIKE '11%')</where>
		<orderby>strNazwa</orderby>
	</cursor>


	<cursor>
		<identifier>CRSR_ZLECENIASERWISOWE</identifier>
		<humanname>zlecenia serwisowe</humanname>
		<join></join>
		<where>(nInternalID LIKE 'N5TYPDZIALANIA_IID_ZLECENIASERWIS' or nInternalID LIKE 'N5TYPDZIALANIA_IID_KONSERWACJA')</where>
		<orderby>strNazwa</orderby>
	</cursor>


</cursors>

<script>
<![CDATA[
function n5typdzialania_as_text()
	n5typdzialania_as_text=this_.strNazwa
end function
]]>
</script>
	
	
	
	
</class>
