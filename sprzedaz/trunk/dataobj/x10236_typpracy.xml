<class>
	<identifier>TYPEID_N5PLTYPPRACY</identifier>
	<table>n5pltyppracy</table>
	<humanname>Typ pracy</humanname>
	<idobj/>

	<embedded>
		<name>tpr_strNazwa</name>
		<sqltype>SQLvc256</sqltype>
		<humanname>Nazwa pełna</humanname>
		<nonempty/>
	</embedded>

	<embedded>
		<name>tpr_strKod</name>
		<sqltype>SQLvc32</sqltype>
		<humanname>Kod</humanname>
		<unique/>
	</embedded>

	<embedded>
		<name>tpr_curWynagrodzenie</name>
		<sqltype>SQLprice</sqltype>
		<humanname>Wynagrodzenie</humanname>
	</embedded>

	<ref>
		<name>tpr_pUsluga</name>
		<humanname>Usługa</humanname>
		<typeid>TYPEID_N5PRODUKT</typeid>
		<optional/>
	</ref>
	<ref>
		<name>tpr_pOpak</name>
		<humanname>Opakowanie</humanname>
		<typeid>TYPEID_N5OPAKOWANIE_PRODUKTU</typeid>
		<optional/>
	</ref>
	
<cursors>
	<cursor>
		<identifier>CRSR_DEFAULT</identifier>
		<humanname>wg nazwy</humanname>
		<join></join>
		<where></where>
		<orderby>tpr_strNazwa</orderby>
	</cursor>
</cursors>

<script>
<![CDATA[
function n5pltyppracy_tpr_pUsluga_change(oldval)
	set this_.tpr_pOpak =this_.tpr_pUsluga.listOpakowania.get(1)	'domyślne opakowanie
	n5pltyppracy_tpr_pUsluga_change = true
end function

]]>
</script>
</class>
