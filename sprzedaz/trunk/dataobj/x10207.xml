<class>
	<identifier>TYPEID_N5KWALIFIKATOR</identifier>
	<table>n5kwalifikator</table>
	<humanname>Kwalifikator</humanname>
	<idobj/>

	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc64</sqltype>
		<humanname>Nazwa</humanname>
		<unique/>
	</embedded>
	<enum>
		<name>eAktywny</name>
		<humanname>Status</humanname>
		<default>N5KWALIFITATOR_AKTYWNY</default>
		<item>Aktywny</item>
		<item>Nieaktywny</item>
	</enum>

<cursors>
	<cursor>
		<identifier>CRSR_DEFAULT</identifier>
		<humanname>wg nazwy</humanname>
		<join></join>
		<orderby>strNazwa</orderby>
	</cursor>

	<cursor>
		<identifier>CRSR_N5KWALIFIKATOR_WG_NAZWY</identifier>
		<humanname>wg nazwy</humanname>
		<join></join>
		<where>eAktywny=N5KWALIFITATOR_AKTYWNY</where>
		<orderby>strNazwa</orderby>
	</cursor>
</cursors>


<script>
<![CDATA[

function n5kwalifikator_as_text(): n5kwalifikator_as_text=""
    n5kwalifikator_as_text=this_.strNazwa
end function


]]>
</script>
	
</class>
