<class>
	<identifier>TYPEID_N5EVENTLOG</identifier>
	<table>n5eventlog</table>
	<humanname>Zdarzenie systemowe</humanname>
	<idobj/>

	<enum>
		<name>eTyp</name>
		<humanname>Rodzaj zdarzenia</humanname>
		<item>Zalogowanie się użytkownika</item>
		<item>Wylogowanie się użytkownika</item>
		<item>Zmiana kursu waluty</item>
		<item>Zmiana ceny</item>
		<item>Zarządanie gospodarką magazynową</item>

		<item>Ustawienie blokady sprzedaży klientowi</item>
		<item>Zdjęcie blokady sprzedaży klientowi</item>
		<item>Wystawienie dokumentu klientowi z blokadą</item>

		<item>Archiwizacja bazy danych</item>
		<item>Modyfikacja dokumentu</item>
		<!-- DB9 -->
		<item>Nadanie uprawnienia</item>
		<item>Odebranie uprawnienia</item>
		<item>Usunięcie dokumentu</item>
    <!-- DB11 -->
    <item>Zmiana statusu</item>
  </enum>

	<embedded>
		<name>dDataZdarz</name>
		<sqltype>SQLdate</sqltype>
		<humanname>Data</humanname>
	</embedded>
	<embedded>
		<name>tCzasZdarz</name>
		<sqltype>SQLtime</sqltype>
		<humanname>Czas</humanname>
	</embedded>
	<ref>
		<name>pUser</name>
		<humanname>Użytkownik</humanname>
		<typeid>TYPEID_N5UZYTKOWNIK</typeid>
	</ref>

	<embedded>
		<name>strOpis</name>
		<sqltype>SQLvc7900</sqltype>
		<humanname>Opis</humanname>
	</embedded>

<cursors>
	<cursor>
		<identifier>CRSR_DEFAULT</identifier>
		<humanname>chronologicznie</humanname>
		<join></join>
		<where></where>
		<orderby>dDataZdarz,tCzasZdarz</orderby>
	</cursor>
</cursors>

<script>
<![CDATA[
]]>
</script>

</class>
