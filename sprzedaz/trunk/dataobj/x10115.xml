<class>
	<identifier>TYPEID_N5TYPDOKUMENTU</identifier>
	<table>n5typdokumentu</table>
	<humanname>Typ dokumentu</humanname>
	<idobj/>
	<embedded>
		<name>strNazwa</name>
		<sqltype>SQLvc64</sqltype>
		<humanname>Nazwa typu dokumentu</humanname>
		<unique/>
	</embedded>
	<ref>
		<name>pTypNadrzedny</name>
		<humanname>Nadrzędny typ dokumentu</humanname>
		<typeid>TYPEID_N5TYPDOKUMENTU</typeid>
		<optional/>
	</ref>
	<enum>
		<name>eRodzaj</name>
		<humanname>Rodzaj dokumentu</humanname>
		<default>N5TYPDOKUMENTU_PRZYCHADZACY</default>
		<item>przychodzący</item>
		<item>wychodzący</item>
		<item>wewnętrzny</item>
	</enum>
	<!--
	Przychodzący (1), Wychodzący (2), Wewnętrzny (3)
	-->
	<embedded>
		<name>nInternalID</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Pochodzenie danych</humanname>
	</embedded>
	<!--
	0 dla danych wprowadzanych przez uzytkownika
		inna wartosc dla danych preloadowanych
	-->

<cursors>
	DEFAULT_CURSOR(wg nazwy,strNazwa)
</cursors>

<script>
<![CDATA[
function n5typdokumentu_as_text()
    n5typdokumentu_as_text = this_.strNazwa
end function

]]>
</script>
	
	
	
	
</class>
