   	this_.prmg_curCenaBrutto##_nr_ceny_ = netto2brutto(this_.prmg_curCenaNetto##_nr_ceny_,this_.prmg_pProdukt.eVAT)  \
  end if  \
	n5produkt_magazyn_prmg_curCenaNetto##_nr_ceny_##_change = true	\
end function

CENA_NETTO_CHANGE(1)
CENA_NETTO_CHANGE(2)
