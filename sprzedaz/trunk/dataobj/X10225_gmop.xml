<?xml version="1.0" encoding="windows-1250" ?>
<!--
#include "h1000.h" 
#include "h1200.h" 
#include "h1231.h" 
-->
<class>
	<identifier>TYPEID_N5GMOP</identifier>
	<table>n5gmop</table>
	<dontcacheonserver/>
	<dontcacheonclient/>
	<alwayscandel/>
	<humanname>Operacja magazynowa</humanname>
	<idobj/>
	<enum>
		<name>gmo_eTypOp</name>
		<!--
		kodowanie
		typ:
		P - przychód
		R - rozchód
		K - korekta

		cena:
		CZ - cena zadana
		CA - cena auto
		CP - cena procentowa auto

		ilośc:
		IZ - ilość zadana
		IA - ilośc automatyczna


		dostawa:
		DS - dostawa 'self'
		DF - dostawa fifo
		DZ - dostawa zadana (numop)
		DX - nie dotyczy
		DI - dostawa zadana (iddost)
		-->
		<humanname>Typ operacji</humanname>
		<item>P_CZ_IZ_DS</item>				<!-- PZ, PW -->
		<item>R_CA_IZ_DF</item>				<!-- WZ, RW, zużycie surowca -->
		<item>R_CA_IZ_DZ</item>				<!-- WZ, RW, z wskazaniem dostawy -->
		<item>P_CA_IA_DS</item>				<!-- MM+ -->
		<item>R_CZ_IZ_DX</item>				<!-- robocizna / usługi -->
		<item>P_CP_IZ_DS</item>				<!-- wyroby -->	
		<item>K_CA_IA_DI</item>				<!-- korekta wartościowa -->
		<item>R_CA_IZ_DI</item>				<!-- zwrot do dostawcy -->
    #ifdef ENABLE_DB13
    <item>STORNO</item>				  <!--  -->
    <item>BO_ARCHIWUM</item>		<!--  -->
    #endif
  </enum>
	<embedded>
		<name>gmo_nNumOp</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Numer operacji</humanname>
		<nonempty/>
		<!-- 
			numer operacji magazynowej = numer operacji w n5dokmag/n5realprod
			sluzy do identyfikacji operacji i okreslania kolejnosci FIFO
		-->
	</embedded>
	<embedded>
		<name>gmo_nLP</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Pozycja operacji</humanname>
		<nonempty/>
		<!-- 
			pozycja w operacji magazynowej
		-->
	</embedded>
	<embedded>
		<name>gmo_curIlosc</name>
		<sqltype>SQLqty</sqltype>
		<humanname>Ilość opakowań</humanname>
		<nonempty/>
	</embedded>
	<embedded>
		<name>gmo_curCena</name>
		<sqltype>SQLprice</sqltype>
		<humanname>Cena jednostkowa</humanname>
	</embedded>
	<embedded>
		<name>gmo_curWartosc</name>
		<sqltype>SQLcurrency</sqltype>
		<humanname>Wartość</humanname>
	</embedded>
	<ref>
		<name>gmo_pProd</name>
		<humanname>Produkt</humanname>
		<typeid>TYPEID_N5PRODUKT</typeid>
	</ref>
	<ref>
		<name>gmo_pOpak</name>
		<humanname>Opakowanie</humanname>
		<typeid>TYPEID_N5OPAKOWANIE_PRODUKTU</typeid>
	</ref>
	<ref>
		<name>gmo_pMag</name>
		<humanname>Magazyn</humanname>
		<typeid>TYPEID_N5MAGAZYN</typeid>
	</ref>
	<embedded>
		<name>gmo_idDost</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Identyfikator dostawy</humanname>
		<nonempty/>
		<!-- 
			identyfikator dostawy - sluzy do kojarzenia co jest ta sama dostawa (fizyczna)
			a co nie.
			mozliwe sa sytuacje, gdy wiecej niz jeden dokument wprowadza towar z tej samej 
			dostawy np. MM wracajaca na pierwotny magazyn jest inna operacja,
			ale przesuwany towar jest z tej samej dostawy
			
			PZ +10 nroper=10,iddost = 10
			MM -10 nroper=20,iddost = 10
			MM +10 nroper=30,iddost = 10 = stad wiemy ze to ten sam towar co na PZ
			
			w ogolnosci idDost moze byc nadawany z osobnego slownika dostaw
			w chwili obecnej jest to numoper orygnalnej dostawy (PZ,PW,real prod.)
		-->
		
	</embedded>
	<embedded>
		<name>gmo_idDostLP</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Subidentyfikator dostawy</humanname>
		<nonempty/>
		<!-- 
			j.w. tylko uszczegolawia
		-->
	</embedded>
	<embedded>
		<name>gmo_dDataWazn</name>
		<sqltype>SQLdate</sqltype>
		<humanname>Data ważności</humanname>
		<default>null</default>
	</embedded>
	<embedded>
		<name>gmo_nNumOpRel</name>
		<sqltype>SQLlong</sqltype>
		<humanname>Numer operacji powiązanej</humanname>
		<!--
			numer operacji z ktorej korzysta dana operacja
			dla przychodow = numer operacji (self reference)
			dla rozchodow fifo = ustalane dynamicznie
			dla rozchodow ze wskazaniem dostawy = wartosc wskazana na n5pozdokmag
			
			mozliwy jest alternatywny sposob wypelniania tego pola:
			0 dla FIFO
			<>0 dla wskazanych dostaw
		-->
	</embedded>
	<embedded>
		<name>gmo_nLPRel</name>
		<sqltype>SQLlong</sqltype>
		<humanname>LP powiązanej</humanname>
	</embedded>
	<embedded>
		<name>gmo_curPrzel</name>
		<sqltype>SQLcurrency</sqltype>
		<humanname>Przelicznik</humanname>
		<!--
			dla real.prod = przelicznik do wyliczenia wartości wyrobu (% wartości)
			dla MM walutowej = kurs waluty
			dla MM ubruttowiającej = ubruttowienie
		-->
		<default>1.0</default>
	</embedded>
<cursors />

<script>
<![CDATA[
function n5gmop_gmo_curCena_change(oldval)
	this_.gmo_curWartosc = trans_.afc.convert.round2(this_.gmo_curIlosc * this_.gmo_curCena)

	n5gmop_gmo_curCena_change = true
end function

function n5gmop_gmo_curIlosc_change(oldval)
	this_.gmo_curWartosc = trans_.afc.convert.round2(this_.gmo_curIlosc * this_.gmo_curCena)

	n5gmop_gmo_curIlosc_change = true
end function

function n5gmop_as_text()
	n5gmop_as_text = ""
end function

]]>
</script>
	
	
	
	
</class>
