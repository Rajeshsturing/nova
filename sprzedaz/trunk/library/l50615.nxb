	ExportManager_SaveStream = pExpMan.container().import( pStream )
end function



'.........................
' PLATNOSC
'.........................
function Kasa_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5PLATNOSC

	pStream.fields("dDataOper") = pRecord.fields("DataOd").value
	'Do numeru dokumentu jest dodawany IdObj poniewa┐
	'w NavoFirma numery dokument¾w moga siĻ powtarzaµ
	pStream.fields("strNrDok") = CStr(pRecord.fields("NrDok").value) + " (" + CStr(pRecord.fields("IdRapKas").value) + ")"

	dim nNewTyp: nNewTyp = CLng(0)
	select case trim(pRecord.fields("Typ").value)
		case "B" 'Wpis bankowy
			nNewTyp = N5REJESTRDOK_BANKOWY

		case "K" 'Wpis kasowy
			nNewTyp = N5REJESTRDOK_KASOWY
	end select

	pStream.extra("TypRejestru") = nNewTyp

	export_Rejestr pExpMan, "Rejestr.IdRej=" + CStr(pRecord.fields("IdRej").value)
	pStream.virtualfieldref("pRejestrDok", TYPEID_N5REJESTRDOK) = pRecord.fields("RejestrUniqueID").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	'Ustawiamy kwote recznie bo zmiany pozycji ich nie usytawiaj╣
	pStream.fields("curKwotaPodm") = CCur(pRecord.fields("SumaPrzych").value) - CCur(pRecord.fields("SumaRozch").value)

	Kasa_Convert2Stream = true
end function

function Kasa_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	Kasa_SaveStream = pExpMan.container().import( pStream )

	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, PozKasa.* from PozKasa where PozKasa.IdRapKas=" + CStr(pRecord.fields("IdRapKas").value), "PozKasa"
	pExpMan.stop_waiting
end function

'.........................
' POZYCJA PLATNOSCI
'.........................
function PozKasa_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZPLATNOSC
	pStream.as_child "listPozycje"

	'Ustawiamy przychod lub rozchod
	if (CCur(pRecord.fields("Przychod").value)>0) then
		pStream.fields("curPozKwotaPodm") = pRecord.fields("Przychod").value
	else
		pStream.fields("curPozKwotaPodm") = CCur(pRecord.fields("Rozchod").value) * CCur(-1)
	end if

	'W tym miejscu nie eksportujemy Sprzedazy i Zakupu. Ustawiamy
	'tylko informacje jakie maja id dla p│atno£ci. Obiekty te by│y
	'zapisane (wyeksportowane) wcze£niej patrz funkcja export_Platnosc
	'Potrzebujemy je by skojarzyc dokument z transkacj╣. Jednak obiekty
	'te tworz╣ transkacje dopiero w befins dlatego wymagane bylo ich
	'zapisanie
	select case CStr(pRecord.fields("TypTrans").value)
		case "S"	'Sprzedaz
			pStream.extra("idsprzedaz") = CLng(pRecord.fields("IdTrans").value)
			
		case "Z"	'Zakup
			pStream.extra("idzakup") = pRecord.fields("IdTrans").value

	end select
	
	'pTransakcja bĻdzie ustawiona w AftImport na podstawie zaimportowanego
	'zakupu lub zaimportowanej sprzedazy

	PozKasa_Convert2Stream = true
end function

function PozKasa_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozKasa_SaveStream = pExpMan.container().import( pStream )
end function

'.........................
' REJESTR
'.........................
function Rejestr_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): Rejestr_Convert2Stream = false
	pStream.begin_object TYPEID_N5REJESTRDOK

	pStream.fields("strFormatNumeracji") = strFormat
	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value

	dim nTyp
	select case UCase(Trim(pRecord.fields("TypRej").value))
		case "SPRV"
			nTyp = N5REJESTRDOK_FAKT_SP

		case "ZAKV"
			nTyp = N5REJESTRDOK_FAKT_ZAK

'		case "AUTO"
'			nTyp = N5REJESTRDOK_AUTOM_PRZREK
'
'		case "DOKM"
'			nTyp = N5REJESTRDOK_DOK_MAG

		case "NOTA"
			nTyp = N5REJESTRDOK_NOTA_ODSETKOWA

		case "POJA"
			nTyp = N5REJESTRDOK_KARTA_POJAZDU

		case "SRTW"
			nTyp = N5REJESTRDOK_SRODKI_TRWALE

		case "PL99"
			nTyp = N5REJESTRDOK_WYNAGR

		case "BNP"
			nTyp = N5REJESTRDOK_BANKOWY
			pStream.fields("strNazwa") = pStream.fields("strNazwa") + "/P"

		case "BNR"
			nTyp = N5REJESTRDOK_BANKOWY
			pStream.fields("strNazwa") = pStream.fields("strNazwa") + "/R"

		case "KP"
			nTyp = N5REJESTRDOK_KASOWY
			pStream.fields("strNazwa") = pStream.fields("strNazwa") + "/P"

		case "KW"
			nTyp = N5REJESTRDOK_KASOWY
			pStream.fields("strNazwa") = pStream.fields("strNazwa") + "/R"

'		case "ZAL"
'			nTyp = N5REJESTRDOK_REJ_ZAL

		case "ZP"
			nTyp = N5REJESTRDOK_REJ_ZALICZEK

		case "ZR"
			nTyp = N5REJESTRDOK_REJ_ZALICZEK

'		case "POLE"
'			nTyp = N5REJESTRDOK_POLEC_KSIEG

		case "KASA"
			nTyp = N5REJESTRDOK_KASOWY
		
		case "BANK"
			nTyp = N5REJESTRDOK_BANKOWY

		case else
			view_message1 6252, 0, pRecord.fields("TypRej").value
			exit function

	end select

	pStream.fields("eTyp") = nTyp


	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim strFormat: strFormat = Trim( pRecord.fields("FormatInx").value )
	if (strFormat="") then
		strFormat = "%n"
	end if

	pStream.fields("nLicznik") = 1
	pStream.fields("eAktywny") = N5REJESTRDOK_AKTYWNY

	Rejestr_Convert2Stream = true
end function

function Rejestr_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Rejestr_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' KRAJ
'.........................
function Kraj_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5JEDNOSTKA

	pStream.fields("strSkrot") = pRecord.fields("Skrot").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	if (pRecord.fields("NWaluty").value <> "") then
		pStream.fields("strNazwa") = pRecord.fields("NWaluty").value
	else
		pStream.fields("strNazwa") = pRecord.fields("SNWaluty").value
	end if

	'PL jest dla nas rownoznaczne z PLN
	if (UCase(pStream.fields("strNazwa"))="PL") then
		pStream.fields("strNazwa") = "PLN"
	end if

	pStream.fields("nDokladnosc") = 3
	pStream.fields("eTyp") = N5JEDNOSTKA_WALUTA

	Kraj_Convert2Stream = true
end function

function Kraj_SaveStream(byref pExpMan, byref pStream, byref pRecord)
