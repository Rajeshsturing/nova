end function

function GMA_RW_PW_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting

	'Eksportuj tylko pozycje z ilo£ci╣ > 0
	GMA_RW_PW_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, GMA_PozRW_PW.*, '" + pRecord.fields("Typ").value + "' as Typ from PozRW_PW as GMA_PozRW_PW join Artykul on Artykul.IdArt = GMA_PozRW_PW.IdArt where GMA_PozRW_PW.Ilosc>0 and GMA_PozRW_PW.IdTrans=" + CStr(pRecord.fields("IdTrans").value) + " and upper(rtrim(ltrim(Artykul.TowarUsl))) = 'T' order by GMA_PozRW_PW.LP asc", "GMA_PozRW_PW"

	pExpMan.stop_waiting
	pExpMan.save_data
end function

function GMA_PozRW_PW_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZDOKMAG
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(pRecord.fields("IdMag").value)

	if (pRecord.fields("Typ").value="P") then
		pStream.fields("nTypDok") = N5REJESTRDOK__PW
		pStream.fields("pMagDocel") = pRecord.fields("IdMag").value
	else
		pStream.fields("nTypDok") = N5REJESTRDOK__RW
		pStream.fields("pMagZrod") = pRecord.fields("IdMag").value
	end if
	
	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
	pStream.fields("curIloscEwid") = pRecord.fields("Ilosc").value

	pStream.fields("curCenaMag") = pRecord.fields("Cena").value
	pStream.fields("curCenaEwid") = pStream.fields("curCenaMag")

	pStream.fields("curWartMag") = pStream.fields("curCenaMag") * pStream.fields("curIloscEwid")
	pStream.fields("curWartEwid") = pStream.fields("curCenaEwid") * pStream.fields("curIloscEwid")

	GMA_PozRW_PW_Convert2Stream = true
end function

function GMA_PozRW_PW_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	GMA_PozRW_PW_SaveStream = pExpMan.container().import( pStream )
end function

'.............................
' GMA SPRZEDAZ
'.............................
'todo:spiko Uzwglednic korekte, dla korekt zezwolic na ilosc 0
function GMA_Sprzedaz_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5DOKMAG

	pStream.fields("strNrDok") = pRecord.fields("NrDok").value

	if (pRecord.fields("Typ").value="S") then
		pStream.extra("TypRejestru") = N5REJESTRDOK__WZ
	else
		pStream.extra("TypRejestru") = N5REJESTRDOK__ZZ
	end if

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim nRejestrTyp: nRejestrTyp = -1
	dim nIdRejestrDok: nIdRejestrDok = -1

	'W przypadku istnienia dokumenty powiazanego robimy 
	'kopie zmiennych bo eksport tego dokumentu przestawi
	'nam te zmienne
	nRejestrTyp = trans_.var(APPVAR_REJESTR_TYP)
	nIdRejestrDok = trans_.var(APPVAR_REJESTR_DOKUMENTOW)

	'Nie przeliczaj warto£ci automatycznie
	'Pola sum zostan╣ wype│nione przy imporcie dzieci
	pStream.fields("cAutoCalc") = "0"
	pStream.fields("curSumaMag") = 0	'Suma w walucie magazynu
	pStream.fields("curSumaEwid") = 0	'Suma w walucie ewidencji

	'Wype│niamy reszte pol
	pStream.fields("dDataWyst") = pRecord.fields("DataWyst").value
	pStream.fields("listPozycje") = 0
	pStream.fields("nNumOper") = 0

	export_Sprzedaz pExpMan, "Sprzedaz.IdTrans=" + CStr(pRecord.fields("IdTrans").value)
	pStream.virtualfieldref("wrefDokHandl", TYPEID_N5SPRZEDAZ) = pRecord.fields("IdTrans").value

	'todo:spiko Dokument oryginalny (korekta, korekty). Obecnie pokazuje
	'na korekte ale tak siĻ nie zapisze. Jak ma pokazywaµ ? ? ?
	'Jak to jest dla sprzeda┐y?
	if (export_GMA_Sprzedaz(pExpMan, "GMA_Sprzedaz.IdTrans=" + CStr(pRecord.fields("IdTransOrgi").value))) then
		pStream.fields("pDokMag") = pRecord.fields("IdTransOrgi").value
	else
		if (CLng(pRecord.fields("IdTransOrgi").value)>0) then
			view_message2 6254, 0, "GMA_Sprzedaz", pRecord.fields("IdTransOrgi").value
			page_.activate
		end if
	end if

	'Odtwarzamy zmienne bo zostaly one przestawione
	'przez eksport dokumentu powi╣zanego
	trans_.var(APPVAR_REJESTR_TYP) = nRejestrTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = nIdRejestrDok

	if (export_Kontrahent(pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("IdKontra").value))) then
		pStream.virtualfieldref("pKlient", TYPEID_N5KLIENT) = pRecord.fields("IdKontra").value
	end if

	GMA_Sprzedaz_Convert2Stream = true
end function

#define Ilosc_Korekta_Sprzedaz "((select isNull(sum(Ilosc), 0) from PozSprzedaz as PozSprzedaz2 " + _ \
		"join Sprzedaz as Sprzedaz2 on Sprzedaz2.IdTRans = PozSprzedaz2.IdTrans " + _ \
		"where Sprzedaz2.IdTrans = Sprzedaz.IdTransOrgi and PozSprzedaz2.Lp = GMA_PozSprzedaz.LP) - GMA_PozSprzedaz.Ilosc)"

'Interesuja nas tylko pozycje sprzedazy z iloscia wieksza od zera
'lub w przypadku korekty z iloscia uwgledniajaca poprzednie dokumenty
'rowniez wieksza od zera. W przypadku dokument¾w magazynowych interesuja
'nas tylko zmiany ilosci a nie np. ceny
function GMA_Sprzedaz_Pozycje_SQL(byval strIdTrans)
	GMA_Sprzedaz_Pozycje_SQL = _
	"from PozSprzedaz as GMA_PozSprzedaz " + _
	"" + _
	"join Artykul on Artykul.IdArt = GMA_PozSprzedaz.IdArt " + _ 
	"join Sprzedaz on Sprzedaz.IdTrans = GMA_PozSprzedaz.IdTrans " + _
	"" + _
	"where ((GMA_PozSprzedaz.Ilosc>0 and Sprzedaz.Typ!='K') or (Sprzedaz.Typ='K' and " + Ilosc_Korekta_Sprzedaz + ">0)) and " + _
	"GMA_PozSprzedaz.IdTrans=" + CStr(strIdTrans) + _
	" and upper(rtrim(ltrim(Artykul.TowarUsl))) = 'T' "
end function

function GMA_Sprzedaz_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting

	'Eksportuj tylko pozycje z ilo£ci╣ > 0 lub w przypadku korekty
	'z iloscia uzglĻdniaj╣c╣ poprzednie dokumenty te┐ > 0
	GMA_Sprzedaz_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, GMA_PozSprzedaz.*, '" + _
		CStr(pRecord.fields("Brutto").value) + "' as Brutto, '" + _
		pRecord.fields("Typ").value + "' as Typ, " + _
		" " + _
		Ilosc_Korekta_Sprzedaz + " as IloscKorekta " + _
		" " + GMA_Sprzedaz_Pozycje_SQL(pRecord.fields("IdTrans").value) + _
		" " + _
		"order by GMA_PozSprzedaz.LP asc", "GMA_PozSprzedaz"
		
	pExpMan.stop_waiting
	pExpMan.save_data
end function

function GMA_PozSprzedaz_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): GMA_PozSprzedaz_Convert2Stream = false
	pStream.begin_object TYPEID_N5POZDOKMAG
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(pRecord.fields("IdMag").value)

	dim bKorekta: bKorekta = false
	if (pRecord.fields("Typ").value="S") then
		pStream.fields("nTypDok") = N5REJESTRDOK__WZ
		pStream.fields("pMagZrod") = pRecord.fields("IdMag").value
	else
		bKorekta = true
		pStream.fields("nTypDok") = N5REJESTRDOK__ZZ
		pStream.fields("pMagDocel") = pRecord.fields("IdMag").value
	end if
	
	if (not bKorekta) then
		pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
		pStream.fields("curIloscEwid") = pRecord.fields("Ilosc").value
	else
		'todo:spiko Sprawdzenie IloscKorekta Jezeli < 0 to jaki komunikat
		'czy cos?? Gdy IloscKorekta < 0 to mamy korekte, kt¾re powinna byµ
		'dokumentem typu WZ a nie ZZ.
		pStream.fields("curIloscOpak") = pRecord.fields("IloscKorekta").value
		pStream.fields("curIloscEwid") = pRecord.fields("IloscKorekta").value
	end if

#ifdef _DEBUG
	if (CCur(pStream.fields("curIloscOpak"))=0) then
		debug_now
	end if
#endif

	'! Nie ustalamy cen i wartosci. Cena i wartosc sprzedazy nie
	'! interesuja nas w przypadku dokumentow magazynowych. Interesuja
	'! nas tylko ceny zakupu
'	if (pRecord.fields("Brutto").value="T") then
'		dim curStawkaVAT
'		curStawkaVAT = CCur(CCur(CLng(pRecord.fields("VAT").value)) / 100)
'		pStream.fields("curCenaMag") = CCur(pRecord.fields("CenaKraj").value) / CCur((1 + curStawkaVAT))
'	else
'		pStream.fields("curCenaMag") = pRecord.fields("CenaKraj").value
'	end if

'	pStream.fields("curCenaEwid") = pStream.fields("curCenaMag")
'	pStream.fields("curWartMag") = pStream.fields("curCenaMag") * pStream.fields("curIloscEwid")
'	pStream.fields("curWartEwid") = pStream.fields("curCenaEwid") * pStream.fields("curIloscEwid")

	GMA_PozSprzedaz_Convert2Stream = true
end function

function GMA_PozSprzedaz_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	GMA_PozSprzedaz_SaveStream = pExpMan.container().import( pStream )
end function


'.............................
' GMA ZAKUP
'.............................
'todo:spiko Korekta zakupu z uwzglĻdnieniem odpowidnim ilo£ci i typ¾w
'dokument¾w
function GMA_Zakup_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5DOKMAG

	pStream.fields("strNrDok") = pRecord.fields("NrDok").value

	dim nDokType
	if (pRecord.fields("Typ").value="K") then
		nDokType = N5REJESTRDOK__ZZ
	else
		nDokType = N5REJESTRDOK__PZ
	end if

	pStream.extra("TypRejestru") = nDokType
	pStream.fields("nTypDok") = nDokType
			
	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim nRejestrTyp: nRejestrTyp = -1
	dim nIdRejestrDok: nIdRejestrDok = -1

	'W przypadku istnienia dokumenty powiazanego robimy 
	'kopie zmiennych bo eksport tego dokumentu przestawi
	'nam te zmienne
	nRejestrTyp = trans_.var(APPVAR_REJESTR_TYP)
	nIdRejestrDok = trans_.var(APPVAR_REJESTR_DOKUMENTOW)

	'Nie przeliczaj warto£ci automatycznie
	'Pola sum zostan╣ wype│nione przy imporcie dzieci
	pStream.fields("cAutoCalc") = "0"
	pStream.fields("curSumaMag") = 0	'Suma w walucie magazynu
	pStream.fields("curSumaEwid") = 0	'Suma w walucie ewidencji

	'Wype│niamy reszte pol
	pStream.fields("dDataWyst") = pRecord.fields("DataWyst").value
	pStream.fields("listPozycje") = 0
	pStream.fields("nNumOper") = 0

	export_Zakup pExpMan, "Zakup.IdTrans=" + CStr(pRecord.fields("IdTrans").value)
	pStream.virtualfieldref("wrefDokHandl", TYPEID_N5ZAKUP) = pRecord.fields("IdTrans").value

	if (export_GMA_Zakup(pExpMan, "GMA_Zakup.IdTrans=" + CStr(pRecord.fields("IdTransOrgi").value))) then
		pStream.fields("pDokMag") = pRecord.fields("IdTransOrgi").value
	else
		if (CLng(pRecord.fields("IdTransOrgi").value)>0) then
			view_message2 6254, 0, "GMA_Zakup", pRecord.fields("IdTransOrgi").value
			page_.activate
		end if
	end if

	if (export_Kontrahent(pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("IdKontra").value))) then
		pStream.virtualfieldref("pKlient", TYPEID_N5KLIENT) = pRecord.fields("IdKontra").value
	end if

	'Odtwarzamy zmienne bo zostaly one przestawione
	'przez eksport dokumentu powi╣zanego
	trans_.var(APPVAR_REJESTR_TYP) = nRejestrTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = nIdRejestrDok
	
	GMA_Zakup_Convert2Stream = true
end function

#define Ilosc_Korekta_Zakup	"((" + _ \
	"select isNull(sum(Ilosc), 0) from PozZakup as pz " + _ \
	"join zakup as z2 on z2.idtrans = pz.idtrans " + _ \
	"where z2.idtrans = Zakup.idtransorgi and pz.LP = GMA_PozZakup.LP " + _ \
	") - GMA_PozZakup.Ilosc)"

'Interesuja nas tylko pozycje sprzedazy z iloscia wieksza od zera
'lub w przypadku korekty z iloscia uwgledniajaca poprzednie dokumenty
'rowniez wieksza od zera. W przypadku dokument¾w magazynowych interesuja
'nas tylko zmiany ilosci a nie np. ceny
function GMA_Zakup_Pozycje_SQL(byval strIdTrans)
	GMA_Zakup_Pozycje_SQL = _
	"from PozZakup as GMA_PozZakup " + _
	"" + _
	"join Artykul on Artykul.IdArt = GMA_PozZakup.IdArt " + _
	"join Zakup on Zakup.IdTrans = GMA_PozZakup.IdTrans " + _
	"" + _
	"where ((GMA_PozZakup.Ilosc>0 and Zakup.Typ!='K') or (Zakup.Typ='K' and " + Ilosc_Korekta_Zakup + ">0)) and GMA_PozZakup.IdTrans=" + CStr(strIdTrans) + " and upper(rtrim(ltrim(Artykul.TowarUsl))) = 'T' "
end function

function GMA_Zakup_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting

	'Eksportuj tylko pozycje z ilo£ci╣ > 0 lub w przypadku korekty
	'z iloscia uzglĻdniaj╣c╣ poprzednie dokumenty te┐ > 0
	GMA_Zakup_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, GMA_PozZakup.*, '" + CStr(pRecord.fields("Brutto").value) + "' as Brutto, '" + pRecord.fields("Typ").value + "' as Typ, " + Ilosc_Korekta_Zakup + " as IloscKorekta, " + _
		"Zakup.Typ as TypDok " + _
		GMA_Zakup_Pozycje_SQL(pRecord.fields("IdTrans").value) + _
		" " + _
		"order by GMA_PozZakup.LP asc", "GMA_PozZakup"

	pExpMan.stop_waiting
	pExpMan.save_data
end function

function GMA_PozZakup_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZDOKMAG
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(pRecord.fields("IdMag").value)

	pStream.fields("pMagDocel") = pRecord.fields("IdMag").value

	dim bKorekta: bKorekta = false
	if (pRecord.fields("TypDok").value="K") then
		bKorekta = true
		pStream.fields("nTypDok") = N5REJESTRDOK__ZZ
	else
		pStream.fields("nTypDok") = N5REJESTRDOK__PZ
	end if

	'todo:spiko Sprawdzenie IloscKorekta Jezeli < 0 to jaki komunikat
	'czy cos?? Gdy IloscKorekta < 0 to mamy korekte, kt¾re powinna byµ
	'dokumentem typu PZ a nie ZZ.
	if (bKorekta) then
		pStream.fields("curIloscOpak") = pRecord.fields("IloscKorekta").value
		pStream.fields("curIloscEwid") = pRecord.fields("IloscKorekta").value
	else
		pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
		pStream.fields("curIloscEwid") = pRecord.fields("Ilosc").value
	end if

	'Wartosci na magazyn trafiaja zawsze jako netto
	if (pRecord.fields("Brutto").value="T") then
		dim curStawkaVAT
		curStawkaVAT = CCur(CCur(CLng(pRecord.fields("VAT").value)) / 100)

		pStream.fields("curCenaMag") = CCur(pRecord.fields("CenaKrajZak").value) / CCur((1 + curStawkaVAT))
		pStream.fields("curCenaEwid") = CCur(pRecord.fields("CenaZagr").value) / CCur((1 + curStawkaVAT))
	else
		pStream.fields("curCenaMag") = pRecord.fields("CenaKrajZak").value
		pStream.fields("curCenaEwid") = pRecord.fields("CenaZagr").value
	end if

	pStream.fields("curWartMag") = pStream.fields("curCenaMag") * pStream.fields("curIloscEwid")
	pStream.fields("curCenaEwid") = pStream.fields("curCenaMag")
	pStream.fields("curWartEwid") = pStream.fields("curCenaEwid") * pStream.fields("curIloscEwid")

	GMA_PozZakup_Convert2Stream = true
end function

function GMA_PozZakup_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	GMA_PozZakup_SaveStream = pExpMan.container().import( pStream )
end function

'.............................
' RECEPTA
'.............................
function Recepta_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5RECEPTA

	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("strNorma") = pRecord.fields("Norma").value
	pStream.fields("strOpis") = pRecord.fields("Opis").value
	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pWyrob", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	Recepta_Convert2Stream = true
end function

function Recepta_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	
	Recepta_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, PozRecepta.* from PozRecepta join Artykul on Artykul.IdArt = PozRecepta.IdTowRec where PozRecepta.IdRecepta=" + CStr(pRecord.fields("IdRecepta").value) + " and Status='A'", "PozRecepta"
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, PozRecepta2.* from PozRecepta as PozRecepta2 join Artykul on Artykul.IdArt = PozRecepta2.IdTowRec where PozRecepta2.IdRecepta=" + CStr(pRecord.fields("IdRecepta").value) + " and Status <> 'A'", "PozRecepta2"

	pExpMan.stop_waiting
end function

function PozRecepta_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZRECEPTA
	pStream.as_child "listSurowce"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdTowRec").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value
	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
	
	PozRecepta_Convert2Stream = true
end function

function PozRecepta_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozRecepta_SaveStream = pExpMan.container().import( pStream )
end function

function PozRecepta2_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZRECEPTA
	pStream.as_child "listCzynnosci"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdTowRec").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value
	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
	
	PozRecepta2_Convert2Stream = true
end function

function PozRecepta2_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozRecepta2_SaveStream = pExpMan.container().import( pStream )
end function


