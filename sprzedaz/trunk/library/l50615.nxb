		exit function
	end if

	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strNumSer") = pRecord.fields("Nr_ser").value
	pStream.fields("strKRST") = pRecord.fields("SymbolKRST").value

	pStream.fields("strNumDokZak") = pRecord.fields("Nr_fkt").value
	pStream.fields("eRodzaj") = CLng(pRecord.fields("TypSrodek").value) + CLng(1)
	
	stobj_Convert2Stream = true
end function

function stobj_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	stobj_SaveStream = pExpMan.container().import( pStream )
end function

'.............................
' ZAKUP
'.............................
function Zakup_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5ZAKUP

	pStream.fields("strNrDok") = pRecord.fields("NrDok").value

	if (pRecord.fields("Typ").value="K") then
		pStream.extra("KOREKTA") = "T"
	end if

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim nRejestrTyp: nRejestrTyp = -1
	dim nIdRejestrDok: nIdRejestrDok = -1

	'W przypadku istnienia dokumenty powiazanego robimy 
	'kopie zmiennych bo eksport tego dokumentu przestawi
	'nam te zmienne
	nRejestrTyp = trans_.var(APPVAR_REJESTR_TYP)
	nIdRejestrDok = trans_.var(APPVAR_REJESTR_DOKUMENTOW)

	'reczne liczenie
	pStream.fields("cAutoCalc") = "0"

	pStream.fields("strNrDokObcy") = pRecord.fields("NrDokObcy").value
	pStream.fields("dDataWyst") = pRecord.fields("DataWyst").value
	pStream.fields("dDataOtrzym") = pRecord.fields("DataOtrz").value
	pStream.fields("dDataZakupu") = pStream.fields("dDataWyst")
	pStream.fields("dDataPlat") = pStream.fields("DataPlat")
	
	dim strPlatnoscNazwa
	strPlatnoscNazwa = pRecord.fields("PLATNOSC_NAZWA").value

	if (trim(strPlatnoscNazwa)<>"") then
		dim nLiczbaDni: nLiczbaDni = CLng(0)
		dim i, strLiczba: strLiczba = ""
		dim bOnLiczba: bOnLiczba = false

		for i=1 to len(strPlatnoscNazwa)
			dim strChar
			strChar = mid(strPlatnoscNazwa, i, 1)

			if (strChar = "1" or _
				strChar = "2" or _
				strChar = "3" or _
				strChar = "4" or _
				strChar = "5" or _
				strChar = "6" or _
				strChar = "7" or _
				strChar = "8" or _
				strChar = "9" or _
				strChar = "0") then
				
				strLiczba = strLiczba + strChar
				bOnLiczba = true
					
			else
				if (bOnLiczba) then
					exit for
				end if
			end if
		next

		if (isNumeric( strLiczba )) then
			nLiczbaDni = CLng( strLiczba )
		end if

		pStream.extra("PLATNOSC_LICZBA_DNI") = nLiczbaDni

		if (Trim(strPlatnoscNazwa)<>"") then
			pExpMan.fromVirtualObject "Platnosc", Trim(strPlatnoscNazwa), pRecord, pStream
			pStream.virtualfieldref("pSposobPlatnosci", TYPEID_N5SPOSPLAT) = trim(strPlatnoscNazwa)
		end if

	end if 'strPlatnoscNazwa<>""

	export_Kontrahent pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("IdKontra").value)
	pStream.fields("pDostawca") = pRecord.fields("IdKontra").value

	pStream.fields("listPozycje") = 0

	if (export_Zakup(pExpMan, "Zakup.IdTrans=" + CStr(pRecord.fields("IdTransOrgi").value))) then
		pStream.fields("pPopZAkup") = pRecord.fields("IdTransOrgi").value
	else
		if (CLng(pRecord.fields("IdTransOrgi").value)>0) then
			view_message2 6254, 0, "Zakup", pRecord.fields("IdTransOrgi").value
			page_.activate
		end if
	end if

	'Sumy zostana wyliczone podczas importu pozycji
	pStream.fields("curSumaNetto")	= 0
	pStream.fields("curSumaVAT")	= 0
	pStream.fields("curSumaBrutto") = 0
	pStream.fields("curSumaWal")	= 0

	'Ustaw walute zakupu dla dokumentu zagranicznego
	if (CLng(pRecord.fields("IdZagr").value)<>CLng(pRecord.fields("IdKraj").value)) then
		pExpMan.fromObject "Kraj", "IdKraj", pRecord.fields("IdZagr").value
		pStream.fields("pWaluta") = pRecord.fields("IdZagr").value
	end if

	'Odtwarzamy zmienne bo zostaly one przestawione
	'przez eksport dokumentu powi╣zanego
	trans_.var(APPVAR_REJESTR_TYP) = nRejestrTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = nIdRejestrDok

	Zakup_Convert2Stream = true
end function

function Zakup_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	Zakup_SaveStream = pExpMan.container().import( pStream )

	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, " + CStr(pRecord.fields("IdKraj").value) + " as IdKraj, " + CStr(pRecord.fields("IdZagr").value) + " as IdZagr, PozZakup.*, '" + CStr(pRecord.fields("Brutto").value) + "' as Brutto, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex from PozZakup join Artykul on Artykul.IdArt = PozZakup.IdArt where PozZakup.IdTrans=" + CStr(pRecord.fields("IdTrans").value), "PozZakup"

	pExpMan.stop_waiting
end function


'.............................
' POZYCJA ZAKUPU
'.............................
function PozZakup_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZZAKUP
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value

	dim idKraj, idZagr
	idKraj = pRecord.fields("idKraj").value
	idZagr = pRecord.fields("idZagr").value

	dim curStawkaVAT
	curStawkaVAT = CCur(CCur(CLng(pRecord.fields("VAT").value)) / 100)

	if (pRecord.fields("Brutto").value="T") then
		pStream.fields("curCenaBrutto") = pRecord.fields("CenaKrajNab").value
		pStream.fields("curCenaNetto") = pStream.fields("curCenaBrutto") - doc_.afc.convert.round2(pStream.fields("curCenaBrutto") * curStawkaVAT / (1 + curStawkaVAT))
		pStream.fields("curVAT") = doc_.afc.convert.round2(pStream.fields("curCenaNetto") * curStawkaVAT)
	else
		pStream.fields("curCenaNetto") = pRecord.fields("CenaKrajNab").value
		pStream.fields("curVAT") = doc_.afc.convert.round2(curStawkaVAT * pStream.fields("curCenaNetto"))
		pStream.fields("curCenaBrutto") = pStream.fields("curCenaNetto") + pStream.fields("curVAT")
	end if
	
	pStream.fields("curVAT") = pStream.fields("curIloscOpak") * pStream.fields("curVAT")
	pStream.fields("curWartNetto") = pStream.fields("curIloscOpak") * pStream.fields("curCenaNetto")
	pStream.fields("curWartBrutto") = pStream.fields("curIloscOpak") * pStream.fields("curCenaBrutto")

	if (idKraj<>idZagr) then
		'Zakup zagraniczny
		pStream.fields("curCenaNettoWal") = pRecord.fields("CenaZagr").value
	end if

	PozZakup_Convert2Stream = true
end function

function PozZakup_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozZakup_SaveStream = pExpMan.container().import( pStream )
end function


'.................................................................
' GMA MM
'
' Jeden dokument magazynowy MM jest rozbijany na dwa dokumenty
' typu MP i MR, gdzie MP ma powiazenie na MR
'.................................................................
function GMA_MM_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5DOKMAG

	pStream.fields("strNrDok") = pRecord.fields("record_id").value
	pStream.extra("TypRejestru") = N5REJESTRDOK__MM
	
	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim nRejestrTyp: nRejestrTyp = -1
	dim nIdRejestrDok: nIdRejestrDok = -1

	'W przypadku istnienia dokumenty powiazanego robimy 
	'kopie zmiennych bo eksport tego dokumentu przestawi
	'nam te zmienne
	nRejestrTyp = trans_.var(APPVAR_REJESTR_TYP)
	nIdRejestrDok = trans_.var(APPVAR_REJESTR_DOKUMENTOW)

	'Nie przeliczaj warto£ci automatycznie
	'Pola sum zostan╣ wype│nione przy imporcie dzieci
	pStream.fields("cAutoCalc")		="0"
	pStream.fields("curSumaMag")	= 0	'Suma w walucie magazynu
	pStream.fields("curSumaEwid")	= 0	'Suma w walucie ewidencji

	'Wype│niamy reszte pol
	pStream.fields("dDataWyst") = pRecord.fields("DataOp").value
	pStream.fields("listPozycje") = 0
	pStream.fields("nNumOper") = 0

	'Odtwarzamy zmienne bo zostaly one przestawione
	'przez eksport dokumentu powi╣zanego
	trans_.var(APPVAR_REJESTR_TYP) = nRejestrTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = nIdRejestrDok

	GMA_MM_Convert2Stream = true
end function

function GMA_MM_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	
	'Eksportuj tylko pozycje z ilo£ci╣ > 0
	GMA_MM_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, " + CStr(pRecord.fields("IdMagFrom").value) + " as IdMagFrom, " + CStr(pRecord.fields("IdMagTo").value) + " as IdMagTo, GMA_POZMM.* from pozmm as GMA_POZMM join Artykul on Artykul.IdArt = GMA_POZMM.IdArt where GMA_POZMM.Ilosc>0 and GMA_POZMM.IdTrans = " + CStr(CStr(pRecord.fields("IdTrans").value)) + " and upper(rtrim(ltrim(Artykul.TowarUsl))) = 'T' order by GMA_POZMM.LP asc", "GMA_POZMM"

	pExpMan.stop_waiting
	pExpMan.save_data
end function

function GMA_POZMM_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	
	pStream.begin_object TYPEID_N5POZDOKMAG
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	pStream.fields("nTypDok") = N5REJESTRDOK__MM
	
	dim idMagazyn

	idMagazyn = pRecord.fields("IdMagFrom").value
	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(idMagazyn)
	pStream.fields("pMagZrod") = idMagazyn

	idMagazyn = pRecord.fields("IdMagTo").value
	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(idMagazyn)
	pStream.fields("pMagDocel") = idMagazyn

	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
	pStream.fields("curIloscEwid") = pRecord.fields("Ilosc").value

	pStream.fields("curCenaMag") = pRecord.fields("Cena").value
	pStream.fields("curCenaEwid") = pStream.fields("curCenaMag")

	pStream.fields("curWartMag") = pStream.fields("curCenaMag") * pStream.fields("curIloscEwid")
	pStream.fields("curWartEwid") = pStream.fields("curCenaEwid") * pStream.fields("curIloscEwid")

	GMA_POZMM_Convert2Stream = true
end function

function GMA_POZMM_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	GMA_POZMM_SaveStream = pExpMan.container().import( pStream )
end function

