'.........................
' DOWOD KSIEGOWY
'.........................
function Polecenie_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5DOWODKSIEG

	if (trim(pRecord.fields("NrDok").value)<>"") then
		pStream.fields("strNrDok") = pRecord.fields("NrDok").value
	else
		pStream.fields("strNrDok") = pRecord.fields("IdPolec").value
	end if

	pStream.extra("TypRejestru") = N5REJESTRDOK_DZIENNIK_NORM

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("dDataRej") = pRecord.fields("DataWyst").value
	pStream.fields("dDataKsieg") = pRecord.fields("DataKsieg").value
	
	pStream.fields("eTyp") = 2
	pStream.fields("eStatus") = 1

	if (trim(pRecord.fields("Uwagi").value)<>"") then
		pStream.fields("strOpis") = pRecord.fields("Uwagi").value
	else
		if (trim(pRecord.fields("NrDok").value)<>"") then
			pStream.fields("strOpis") = pRecord.fields("NrDok").value
		else
			pStream.fields("strOpis") = "<brak opisu>"
		end if
	end if

	pExpMan.fromObject "NAVOUser", "IdUser", pRecord.fields("IdUser").value
	pStream.fields("pUzytRej") = pRecord.fields("IdUser").value

	Polecenie_Convert2Stream = true
end function

function Polecenie_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	Polecenie_SaveStream = pExpMan.container().import( pStream )

	export_Dekret pExpMan, "IdPolec=" + CStr(pRecord.fields("IdPolec").value)
	pExpMan.stop_waiting
end function


'.........................
' ZAMOWIENIE
'.........................
function Zamowienie_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5ZAMOWIENIE

	pStream.fields("strNrDok") = pRecord.fields("NrDok").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if
	
	pStream.fields("dDataWyst") = pRecord.fields("DataWyst").value

	dim strPlatnoscNazwa
	strPlatnoscNazwa = pRecord.fields("PLATNOSC_NAZWA").value

	dim nLiczbaDni: nLiczbaDni = CLng(0)
	dim i, strLiczba: strLiczba = ""
	dim bOnLiczba: bOnLiczba = false
	for i=1 to len(strPlatnoscNazwa)
		dim strChar
		strChar = mid(strPlatnoscNazwa, i, 1)

		if (strChar = "1" or _
			strChar = "2" or _
			strChar = "3" or _
			strChar = "4" or _
			strChar = "5" or _
			strChar = "6" or _
			strChar = "7" or _
			strChar = "8" or _
			strChar = "9" or _
			strChar = "0") then
			
			strLiczba = strLiczba + strChar
			bOnLiczba = true
				
		else
			if (bOnLiczba) then
				exit for
			end if
		end if
	next

	if (isNumeric( strLiczba )) then
		nLiczbaDni = CLng( strLiczba )
	end if

	pStream.extra("PLATNOSC_LICZBA_DNI") = nLiczbaDni

	if (Trim(strPlatnoscNazwa)<>"") then
		pExpMan.fromVirtualObject "Platnosc", Trim(strPlatnoscNazwa), pRecord, pStream
		pStream.virtualfieldref("pSposobPlatnosci", TYPEID_N5SPOSPLAT) = Trim(strPlatnoscNazwa)
	end if

	pStream.fields("dDataPlat") = DateSerial(Year(pStream.fields("dDataReal")), Month(pStream.fields("dDataReal")), Day(pStream.fields("dDataReal")) + nLiczbaDni)
	pStream.fields("dDataReal") = pRecord.fields("DataAkt").value

	export_Kontrahent pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("IdKontra").value)
	pStream.fields("pKlient") = pRecord.fields("IdKontra").value
	
	'Zerujemy pozycje listy
	pStream.fields("listPozycje") = 0

	'Sumy wyliczane podczas importu
	pStream.fields("curSumaNetto")	= 0
	pStream.fields("curSumaVAT")	= 0
	pStream.fields("curSumaBrutto") = 0

	'todo:spiko Ustawienie waluty gdy pojawi sie pole waluty
	'w obiekcie n5zamowienie

	'todo:spiko Czy zamowienie obce czy w│asne itd. Jezeli pojawi
	'sie typ zamowienia w obiekcie n5zamowienie

	export_NAVOUser pExpMan, "NavoUser.IdUser=" + CStr(pRecord.fields("IdUser").value)
	pStream.fields("pUzytRej") = pRecord.fields("IdUser").value
		
	Zamowienie_Convert2Stream = true
end function

function Zamowienie_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	
	Zamowienie_SaveStream = pExpMan.container().import( pStream )
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex, Artykul.Nazwa as ArtNazwa, " + CStr(pRecord.fields("IdKraj").value) + " as IdKraj, " + CStr(pRecord.fields("IdZagr").value) + " as IdZagr, pozzamow.*, '" + CStr(pRecord.fields("Brutto").value) + "' as Brutto from pozzamow join Artykul on Artykul.IdArt = PozZamow.IdArt where pozzamow.IdTrans=" + CStr(pRecord.fields("IdTrans").value), "PozZamow"

	pExpMan.stop_waiting
end function


'.........................
' POZYCJA ZMOWIENIA
'.........................
function PozZamow_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZZAMOWIENIE
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value

	pStream.fields("curIloscEwid") = pRecord.fields("Ilosc").value
	pStream.fields("curIloscOpak") = pRecord.fields("Ilosc").value
	
	pStream.fields("curIloscEwidPoz") = CCur(pRecord.fields("Ilosc").value) - CCur(pRecord.fields("IloscZreal").value)
	pStream.fields("curIloscOpakPoz") = pStream.fields("curIloscEwidPoz")
	
	dim curStawkaVAT
	curStawkaVAT = CCur(CCur(CLng(pRecord.fields("VAT").value)) / 100)

	dim curVAT

	if (trim(pRecord.fields("Brutto").value)="T") then
		pStream.fields("curCenaBrutto") = pRecord.fields("CenaKraj").value
		pStream.fields("curCenaNetto") = pStream.fields("curCenaBrutto") - doc_.afc.convert.round2(pStream.fields("curCenaBrutto") * curStawkaVAT / (1 + curStawkaVAT))
		curVAT = doc_.afc.convert.round2(pStream.fields("curCenaNetto") * curStawkaVAT)
	else
		pStream.fields("curCenaNetto") = pRecord.fields("CenaKraj").value
		curVAT = doc_.afc.convert.round2(pStream.fields("curCenaNetto") * curStawkaVAT)
		pStream.fields("curCenaBrutto") = pStream.fields("curCenaNetto") + curVAT
	end if

	'Obecnie ceny bazowe sa rowne naszym cena
	pStream.fields("curCenaBazNetto") = pStream.fields("curCenaNetto")
	pStream.fields("curCenaBazBrutto") = pStream.fields("curCenaBrutto")

	pStream.fields("curWartNetto") = pStream.fields("curIloscEwid") * pStream.fields("curCenaNetto")
	pStream.fields("curWartBrutto") = pStream.fields("curIloscEwid") * pStream.fields("curCenaBrutto")
	pStream.fields("curVAT") = curVAT * pStream.fields("curIloscEwid")

	'Ustaw pole eVAT na podstawie stawki VAT
	set_eVAT "VAT", trim(pRecord.fields("ArtNazwa").value), pRecord, pStream, pExpMan

	'Eksport magazynu docelowego
	export_Magazyn pExpMan, "Magazyn.IdMagazyn=" + CStr(pRecord.fields("IdMag").value)
	pStream.fields("pMagazyn") = pRecord.fields("IdMag").value

	dim idKraj
	dim idZagr

	idKraj = pRecord.fields("idKraj").value
	idZagr = pRecord.fields("idZagr").value

	if (idKraj<>idZagr) then
		pStream.fields("curCenaNettoWal") = pRecord.fields("CenaZagr").value
		pStream.fields("curWartWal") = pStream.fields("curCenaNettoWal") * pStream.fields("curIloscEwid")
	end if
	
	PozZamow_Convert2Stream = true
end function

function PozZamow_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozZamow_SaveStream = pExpMan.container().import( pStream )
end function


'.............................
' KARTOTEKA SRODKOW TRWALYCH
'.............................
function stobj_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5SRTRW

