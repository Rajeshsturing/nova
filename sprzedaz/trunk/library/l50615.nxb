		"where GMA_RW_PW.IdTrans in (select PozRW_PW.IdTrans from PozRW_PW where PozRW_PW.Ilosc>0)" + strDestWhere, "GMA_RW_PW")
end function

function export_Recepta(byref pExpMan, byval strWhere)
