		strWhere = " where " + strWhere + ""
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	pExpMan.RecordsetCount "artykul", strDestWhere
	
	export_Artykul = pExpMan.fromRecordset("select ltrim(rtrim(artykul.NaszInx)), artykul.*, isNull((select sum(Ilosc) from kontrolaSM where IdArt = Artykul.IdArt Group By IdArt ),0.000) as SM from artykul" + strDestWhere, "Artykul")
end function

function export_GrupaArt(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " AND (" + strWhere + ")"
	end if

	dim strDestWhere
	strDestWhere = " WHERE (p.Nazwa <> 'Wszystko')" + strWhere
	
	pExpMan.RecordsetCount "GrupaArt p JOIN GrupaArt g ON g.IdGrArt = p.IdParent ", strDestWhere
	
	export_GrupaArt = pExpMan.fromRecordset("select p.IdGrArt as G_IdGrArt, p.Nazwa as G_Nazwa, p.IdParent as G_IdParent, g.Nazwa as P_Nazwa FROM GrupaArt p JOIN GrupaArt g ON g.IdGrArt = p.IdParent " + strDestWhere + " order by g.Hierarchia", "GrupaArt")
end function

function export_Konto(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " where " + strWhere
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	pExpMan.RecordsetCount "Konto " + _
		" LEFT OUTER JOIN kontrakonto kk ON Konto.IdKonto= kk.IdKonto" + _
		" LEFT OUTER JOIN pracownikkonto pk ON Konto.IdKonto= pk.IdKonto" + _
		" LEFT OUTER JOIN konto as kparent on Konto.IdParent=kparent.IdKonto ", _
		strDestWhere

	export_Konto = pExpMan.fromRecordset("select Konto.Symbol as unique_id, Konto.*, isnull(IdPrac,0) as PracID, isnull(IdKontra,0) as KontraID, isNull(kparent.IdKonto, 0) as KontoParentID, isNull(kparent.Symbol, '') as ParentSymbol from Konto" + _
		" LEFT OUTER JOIN kontrakonto kk ON Konto.IdKonto= kk.IdKonto" + _
		" LEFT OUTER JOIN pracownikkonto pk ON Konto.IdKonto= pk.IdKonto" + _
		" LEFT OUTER JOIN konto as kparent on Konto.IdParent=kparent.IdKonto" + strDestWhere, "Konto")
end function

function export_Pracownik(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " where " + strWhere
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	pExpMan.RecordsetCount "Pracownik", strDestWhere
	
	export_Pracownik = pExpMan.fromRecordset("select *, Bank as BANK_NAZWA, KontoBank AS BANK_RACHUNEK, Miejsc AS MIESCOWOSC_NAZWA, Wojew As WOJEWODZTWO_NAZWA, Kod as KOD_POCZTOWY from Pracownik" + strDestWhere, "Pracownik")
end function

function export_Kontrahent(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " where " + strWhere
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	pExpMan.RecordsetCount "Kontrahent " + _
		" left outer JOIN KontraSprz KSP ON Kontrahent.IdKontra = KSP.IdKontra" + _
		" left outer  JOIN GrupaKontra GK ON KSP.IdGrKontra = GK.IdGrKontra ", _
		strDestWhere

	export_Kontrahent = pExpMan.fromRecordset("select Kontrahent.*, isNull(KSP.Opis, '') as Opis, GK.IdGrKontra as GRUPA_KONTRAHENTA, " + _
	"Miejsc AS MIESCOWOSC_NAZWA, Kod as KOD_POCZTOWY from Kontrahent" + _
		" left outer JOIN KontraSprz KSP ON Kontrahent.IdKontra = KSP.IdKontra" + _
		" left outer  JOIN GrupaKontra GK ON KSP.IdGrKontra = GK.IdGrKontra" + _
		strDestWhere, "Kontrahent")

end function


