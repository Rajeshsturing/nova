function export_Platnosc(byref pExpMan, byval strWhere)

	dim strSprzedZak
	strSprzedZak = ""

	if (strWhere<>"") then
		strSprzedZak = " and " + strWhere
	end if

	if (strWhere<>"") then
		strWhere = " where (" + strWhere + ") "
	end if

	'Przed eksportem p│atno£ci musimy wyeksportowaµ
	'dokumenty sprzedazy powi╣zane z tymi p│atno£ciami
	'i zakupu. Robimy to po to by zosta│y utworzone 
	'transakcje dla tych dokument¾w. Nie robimy tego
	'przy eksporcie pozycji platnosci bo dokumenty
	'te tworza transakcje w befinsert->musza byc 
	'wczesniej zapisane
	export_Sprzedaz pExpMan, "Sprzedaz.IdTrans in (" + _
		"select IdTrans from Kasa " + _
		"join Rejestr on Rejestr.IdRej = Kasa.IdRej " + _
		"join PozKasa on PozKasa.IdRapKas = Kasa.IdRapKas " + _
		"where (TypTrans='S' and IdTrans>0 " + strSprzedZak + ")" + _
		")"

	export_Zakup pExpMan, "Zakup.IdTrans in (" + _
		"select IdTrans from Kasa " + _
		"join Rejestr on Rejestr.IdRej = Kasa.IdRej " + _
		"join PozKasa on PozKasa.IdRapKas = Kasa.IdRapKas " + _
		"where (TypTrans='Z' and IdTrans>0 " + strSprzedZak + ")" + _
		")"

	'Wyslij rzadanie zapisania danych natychmiast
	pExpMan.save_data

	'Rozpocznij teraz eksportowanie samych p│atno£ci
	dim strDestWhere
	strDestWhere = strWhere

	pExpMan.RecordsetCount "Kasa", strDestWhere

	export_Platnosc = pExpMan.fromRecordset("select Kasa.NrDok + ' (' + cast(Kasa.IdRapKas as varchar(64)) + ')' as unique_id, " + _
		"Kasa.*, Rejestr.nazwa as RejestrUniqueID from Kasa " + _
		"join Rejestr on Rejestr.IdRej = Kasa.IdRej " + _
		strDestWhere + _
		"order by Kasa.DataOd, Kasa.DataDo, Kasa.IdRapKas", "Kasa")

end function

