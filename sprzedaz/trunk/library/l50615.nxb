		pStream.fields("strLogin") = pRecord.fields("Name").value

		if (pExpMan.container().bMiniFirma) then
			if (trim(pRecord.fields("Name").value)="nikt") then
				pStream.fields("strNazwa") = ADMIN_LOGIN
				pStream.fields("strLogin") = ADMIN_LOGIN
			end if
		end if

	end if

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("strHaslo") = pRecord.fields("Password").value
	pStream.fields("strMail") = pRecord.fields("Contact").value
	pStream.fields("eAktywny") = 1

	NAVOUser_Convert2Stream = true
end function

function NAVOUser_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	NAVOUser_SaveStream = pExpMan.container().import( pStream )
end function



'.........................
' SPRZEDAZ
'.........................
function Sprzedaz_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): Sprzedaz_Convert2Stream = false
	pStream.begin_object TYPEID_N5SPRZEDAZ

	if (pRecord.fields("NrDok").value<>"") then
		pStream.fields("strNrDok") = pRecord.fields("NrDok").value
	else
		pStream.fields("strNrDok") = "Brak " + CStr(Year(Now)) + CStr(Month(Now)) + CStr(Day(Now)) + CStr(Hour(Now)) + CStr(Minute(Now)) + CStr(Second(Now))
	end if

	'Czy mamy dokument zagraniczny
	dim bZagranica: bZagranica = false
	if (CLng(pRecord.fields("IdZagr").value)<>CLng(pRecord.fields("IdKraj").value)) then
		bZagranica = true
	end if

	dim nNewTyp
	if (not bZagranica) then
		select case trim(pRecord.fields("FVATRach").value)
			case "F" 'Faktura
				if trim(pRecord.fields("Typ").value) = "S" then
					nNewTyp = N5REJESTRDOK_FAKT_SP
				else 'Korekta
					nNewTyp = N5REJESTRDOK_KOR_FAKT_SP
				end if

			case "R", "W" 'Rachunek
				if trim(pRecord.fields("Typ").value) = "S" then
					nNewTyp = N5REJESTRDOK_RACH
				else
					nNewTyp = N5REJESTRDOK_KOR_RACH
				end if

			case else
				
				view_message1 6316, 0, pRecord.fields("FVATRach").value

				#ifdef _DEBUG
				exit function
				#endif

				if trim(pRecord.fields("Typ").value) = "S" then
					nNewTyp = N5REJESTRDOK_FAKT_SP
				else 'Korekta
					nNewTyp = N5REJESTRDOK_KOR_FAKT_SP
				end if

		end select
	else 
		if trim(pRecord.fields("Typ").value) = "S" then
				nNewTyp = N5REJESTRDOK_FAKT_EXP
			else 'Korekta
				nNewTyp = N5REJESTRDOK_KOR_FAKT_EXP
		end if
	end if 

	pStream.extra("TypRejestru") = nNewTyp

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim nRejestrTyp: nRejestrTyp = -1
	dim nIdRejestrDok: nIdRejestrDok = -1
	
	'W przypadku korekty robimy kopie zmiennych
	'bo eksport dokumentu org. przestawi
	'nam te zmienne
	nRejestrTyp = trans_.var(APPVAR_REJESTR_TYP)
	nIdRejestrDok = trans_.var(APPVAR_REJESTR_DOKUMENTOW)
	
	export_Kontrahent pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("IdKontra").value)

	pStream.fields("pKlient") = pRecord.fields("IdKontra").value
	
	pStream.fields("dDataWyst") = pRecord.fields("DataWyst").value
	pStream.fields("dDataSprzed") = pRecord.fields("DataSprz").value
	pStream.fields("dDataPlat") = pRecord.fields("DataPlat").value

	if (Trim(pRecord.fields("PLATNOSC_NAZWA").value)<>"") then
		pExpMan.fromVirtualObject "Platnosc", Trim(pRecord.fields("PLATNOSC_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pSposobPlatnosci", TYPEID_N5SPOSPLAT) = Trim(pRecord.fields("PLATNOSC_NAZWA").value)
	end if

	pExpMan.fromObject "NAVOUser", "IdUser", pRecord.fields("IdUser").value
	pStream.fields("pUzytRej") = pRecord.fields("IdUser").value

	pStream.fields("strUwagi") = pRecord.fields("Opis").value
	pStream.fields("cAutoCalc") = 1

	if (pRecord.fields("Brutto").value = "T") then
		pStream.fields("eNettoBrutto") = N5SPRZEDAZ_BRUTTO
	else
		pStream.fields("eNettoBrutto") = N5SPRZEDAZ_NETTO
	end if

	'Sumy na zero bo wyliczane podczas importu
	pStream.fields("curSumaNetto") = 0
	pStream.fields("curSumaVAT") = 0
	pStream.fields("curSumaBrutto") = 0

	if (pRecord.fields("Drukowano").value="0") then
		pStream.fields("eSposVAT") = 1
	else
		pStream.fields("eSposVAT") = 2
	end if

	if (pRecord.fields("TYP").value="K") then
		if (export_Sprzedaz(pExpMan, "IdTrans=" + CStr(pRecord.fields("IdTransOrgi").value))) then
			pStream.fields("pPopSprzed") = pRecord.fields("IdTransOrgi").value
		else
			if (CLng(pRecord.fields("IdTransOrgi").value)>0) then
				view_message2 6254, 0, "Sprzedaz", pRecord.fields("IdTransOrgi").value
				page_.activate
			end if
		end if

	end if

	'Ustaw walute sprzedazy dla dokumentu zagranicznego
	if (bZagranica) then
		pExpMan.fromObject "Kraj", "IdKraj", pRecord.fields("IdZagr").value
		pStream.fields("pWaluta") = pRecord.fields("IdZagr").value
	end if

	'Odtwarzamy zmienne bo zostaly one przestawione
	'przez eksport dokumentu org.
	trans_.var(APPVAR_REJESTR_TYP) = nRejestrTyp
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = nIdRejestrDok
	
	Sprzedaz_Convert2Stream = true
end function

function Sprzedaz_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	pExpMan.start_waiting
	Sprzedaz_SaveStream = pExpMan.container().import( pStream )

	'pozycje sprzedazy - po obiekcie glownym
	pExpMan.fromRecordset "select '" + LIST_ELEMENT_IDENTITY + "' as list_id, PozSprzedaz.*, S.Brutto as Brutto, S.IdKraj as SIdKraj, S.IdZagr As SIdZagr, ltrim(rtrim(Artykul.NaszInx)) as ArtykulIndex from PozSprzedaz JOIN Sprzedaz S ON S.IdTrans = PozSprzedaz.IdTrans join Artykul on Artykul.IdArt = PozSprzedaz.IdArt where PozSprzedaz.IdTrans=" + CStr(pRecord.fields("IdTrans").value), "PozSprzedaz"
	pExpMan.stop_waiting
end function


'.........................
' POZYCJA SPRZEDAZY
'.........................
function PozSprzedaz_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5POZSPRZEDAZ
	pStream.as_child "listPozycje"

	export_Artykul pExpMan, "IdArt=" + CStr(pRecord.fields("IdArt").value)
	pStream.virtualfieldref("pProdukt", TYPEID_N5PRODUKT) = pRecord.fields("ArtykulIndex").value
	
	pStream.fields("curIloscOpak") = pRecord.fields("ilosc").value

	dim bBrutto: bBrutto = true
	if (pRecord.fields("Brutto").value="N") then
		bBrutto = false
	end if

	dim idKraj
	idKraj = CLng(pRecord.fields("SIdKraj").value)
	
	dim idZagr
	idZagr = CLng(pRecord.fields("SIdZagr").value)

	dim curStawkaVAT
	curStawkaVAT = CCur(CCur(CLng(pRecord.fields("VAT").value)) / 100)

	pStream.fields("curRabat") = pRecord.fields("rabat").value

	'Ustalenie ceny brutto i netto
	dim curCenaBazowaNetto
	dim curCenaBazowaBrutto

	if (pStream.fields("curRabat")>0 and bBrutto) then
		curCenaBazowaBrutto = CCur(pRecord.fields("CenaKraj").value)
		curCenaBazowaBrutto = CCur(CCur(curCenaBazowaBrutto * 100) / CCur(100 - pStream.fields("curRabat")))
		curCenaBazowaNetto = curCenaBazowaBrutto - doc_.afc.convert.round2(curCenaBazowaBrutto * curStawkaVAT / (1 + curStawkaVAT))
	else
		curCenaBazowaNetto = CCur(pRecord.fields("CenaZagr").value)

		'UwzglĻdniamy rabat gdy┐ w przypadku pojawienie siĻ go
		'cena netto jest ju┐ o niego pomniejszona
		if (pStream.fields("curRabat")>0) then
			curCenaBazowaNetto = CCur(CCur(curCenaBazowaNetto * 100) / CCur(100 - pStream.fields("curRabat")))
		end if

		if (bBrutto) then
			curCenaBazowaBrutto = CCur(pRecord.fields("CenaKraj").value)
		else
			curCenaBazowaBrutto = CCur(curCenaBazowaNetto) + CCur(doc_.afc.convert.round2(curStawkaVAT * pStream.fields("curCenaNetto")))
		end if
	end if

	if (bBrutto) then
		'mamy cene bazow╣ brutto
		pStream.fields("curCenaBazBrutto") = curCenaBazowaBrutto
	else
		'mamy cene bazow╣ netto
		pStream.fields("curCenaBazNetto") = curCenaBazowaNetto
	end if

	if (idKraj<>idZagr) then
		'Cena zagraniczna zawsze w netto
		'bazowa rowna sie w walucie bo w Firmie
		'mamy juz tylko cene po danym kursie
		'u nas wylaczone jest auto przeliczanie
		'kursu
		pStream.fields("curCenaBazowaNettoWal") = curCenaBazowaNetto
		pStream.fields("curCenaNettoWal") = curCenaBazowaNetto
		pStream.fields("curWartWal") = pStream.fields("curIloscEwid") * pStream.fields("curCenaBazowaNettoWal")
	end if

	PozSprzedaz_Convert2Stream = true
end function

function PozSprzedaz_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	PozSprzedaz_SaveStream = pExpMan.container().import( pStream )
end function


