'.........................
' PRACOWNIK
'.........................
function Pracownik_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5PRACOWNIK

	pStream.fields("strNazwisko") = pRecord.fields("Nazwisko").value
	pStream.fields("strImie") = pRecord.fields("Imie1").value

	if trim(pRecord.fields("PESEL").value)<>"" then
		pStream.fields("strPESEL") = pRecord.fields("PESEL").value
	else
		pStream.fields("strPESEL") = "BRAK" + CStr(pRecord.fields("IdPrac").value)
	end if

	pStream.fields("strNIP") = pRecord.fields("NIP").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("strImie2") = pRecord.fields("Imie2").value
	pStream.fields("dDataUr") = pRecord.fields("DataUr").value
	pStream.fields("strMiejsceUr") = pRecord.fields("MiejscUr").value

	pStream.fields("ePlec") = doc_.afc.business.imie2plec(trim(pRecord.fields("Imie1").value))
	pStream.fields("strUlica") = pRecord.fields("Ulica").value
	pStream.fields("strNrDomu") = pRecord.fields("NrDomu").value
	pStream.fields("strNrLokalu") = pRecord.fields("NrLokalu").value
	pStream.fields("strKod") = pRecord.fields("Kod").value
	pStream.fields("strTel1") = pRecord.fields("Tel1").value
	pStream.fields("strTel2") = pRecord.fields("Tel2").value
	pStream.fields("strFax") = pRecord.fields("Fax").value
	pStream.fields("eTypDT") = 1

	if (CDate(pRecord.fields("DataZwol").value) < CDate(Now)) then
		pStream.fields("eAktywny") = N5PRACOWNIK_AKTYWNY_NIEAKTYWNY
	else
		pStream.fields("eAktywny") = N5PRACOWNIK_AKTYWNY_AKTYWNY
	end if

	'bark jakiejs nazwy to przy imporcie ustawienie na <brak>
	if (trim(pRecord.fields("BANK_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Bank", trim(pRecord.fields("BANK_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pBank1", TYPEID_N5BANK) = trim(pRecord.fields("BANK_NAZWA").value)
	end if

	dim strWojewodztwo
	strWojewodztwo = doc_.afc.business.zip2area_pl( trim(pRecord.fields("KOD_POCZTOWY").value) )

	if (strWojewodztwo <> "") then
		pExpMan.fromVirtualObject "Wojewodztwo", strWojewodztwo, pRecord, nothing
	end if

	if (trim(pRecord.fields("MIESCOWOSC_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Miejscowosc", trim(pRecord.fields("MIESCOWOSC_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pMiejscowosc", TYPEID_N5MIEJSCOWOSC) = trim(pRecord.fields("MIESCOWOSC_NAZWA").value)
	end if

	Pracownik_Convert2Stream = true
end function

function Pracownik_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Pracownik_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' BANK
'.........................
function Bank_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5BANK

	pStream.fields("strSkrot") = pRecord.fields("BANK_NAZWA").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("strNazwa") = pRecord.fields("BANK_NAZWA").value
	pStream.fields("strOddzial") = "oddzia│"

	dim strRachunek
	strRachunek = pRecord.fields("BANK_RACHUNEK").value
	
	dim strKodRachunku
	strKodRachunku = ""

	if (strRachunek <> "" and len(strRachunek)=19 and mid(strRachunek, 9, 1) = "-") then
		strKodRachunku = left(strRachunek, 9)
	end if

	if (strKodRachunku = "") then
		strKodRachunku = "KOD ?" + CStr(Year(Now)) + CStr(Month(Now)) + CStr(Day(Now)) + CStr(Hour(Now)) + CStr(Minute(Now)) + CStr(Second(Now)) + "?"
	end if

	pStream.fields("strKodRach") = 	strKodRachunku

	Bank_Convert2Stream = true
end function

function Bank_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Bank_SaveStream = pExpMan.container().import( pStream )
end function


