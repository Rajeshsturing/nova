#include "50613"

dim pPrerforming
set pPrerforming = nothing
dim strOldText

function Export_CreatePerforming(byref pExpMan, byval strText)

	if (pExpMan is nothing) and (not pPrerforming is nothing) then
		exit function
	end if

	if (strText<>"Pracownik" and _
		strText<>"Urzad" and _
		strText <> "connectSQL" and _
		strText <> "connectSQL_TEST" and _
		strText <> "Jednostka" and _
		strText <> "Kontrahent" and _
		strText <> "Konto" and _
		strText <> "Artykul" and _
		strText <> "Ko±cowy zapis danych" and _
		strText <> "NAVOUser" and _
		strText <> "Sprzedaz" and _
		strText <> "Dekret" and _
		strText <> "Polecenie" and _
		strText <> "Analiza danych" and _
		strText <> "Zamowienie" and _
		strText <> "stobj" and _
		strText <> "Zakup" and _
		strText <> "Recepta" and _
		strText <> "open_file" and _
		left(strText, 3) <> "GMA") then
		exit function
	end if

	select case strText
		case "NAVOUser"
			strText = "U┐ytkownik"

		case "Sprzedaz"
			strText = "Sprzeda┐"

		case "Artykul"
			strText = "Artyku│"

		case "Polecenie"
			strText = "Dow¾d ksiĻgowy"

		case "Zamowienie"
			strText = "Zam¾wienie"

		case "stobj"
			strText = "Kartoteka £rodk¾w trwa│ych"

		case "Urzad"
			strText = "Urz╣d"

		case else
			if (left(strText, 3) = "GMA") then
				strText = "Dokumenty magazynowe"
			end if

	end select

	dim strToDisplay
	if (strText = "connectSQL") then
		strToDisplay = "Ż╣czenie z baz╣ danych . . ."
	elseif (strText = "open_file") then
		strToDisplay = "Otwieranie pliku . . ."
	elseif (strText = "connectSQL_TEST") then
		strToDisplay = "Analiza dostĻpnych baz danych . . ."
	else
		
		if (not pExpMan is nothing) then
			dim curLevelPercent: curLevelPercent = CCur(-1)
			if (pExpMan.m_nRecords>-1) then
						
				if (pExpMan.m_nRecords>0) then
					curLevelPercent = CCur(pExpMan.m_nCurrentRecord * 100) / CCur(pExpMan.m_nRecords)
				end if
			end if

			if (curLevelPercent>-1) then
				if (curLevelPercent>100) then
					curLevelPercent = 100
				end if
				
				strToDisplay = "Importowanie danych " + CStr(CLng(curLevelPercent)) + "%"
			else
				strToDisplay = "Importowanie danych . . . (" + strText + ")"
			end if
		else
			strToDisplay = "Importowanie danych . . . (" + strText + ")"
		end if

	end if
	
	if (strOldText=strToDisplay) then
		exit function
	end if

	if (pPrerforming is nothing) then
		page_.updateview
		set pPrerforming = doc_.performing( strToDisplay )
		strOldText=strToDisplay
		exit function
	end if

	pPrerforming.text = strToDisplay
	strOldText=strToDisplay
end function

function Export_DestroyPerforming(byref pExpMan)
	set pPrerforming = nothing
	strOldText = ""
end function

function Import_DestroyPerforming(byref pImpMan)
	Export_DestroyPerforming nothing
end function

function Import_CreatePerforming(byref pExpMan, byval strText)
	Export_CreatePerforming nothing, "Analiza danych"
end function

class CImportContainer
	public pImport
	public pExport
	public bMiniFirma
	public idFirmy
	public bSybase

	private sub class_initialize()
		set pImport = new CImportManager
		bMiniFirma = false
		bSybase = false
		idFirmy = 0
	end sub

	public function import(byref pImportStream)
		import = pImport.import( pImportStream )
	end function

	public function end_import()

		if (pImport.isCanceled()) then
			exit function
		end if

		if (pExport.isCanceled()) then
			exit function
		end if

		pExport.m_nCurrentRecord = pExport.m_nRecords
		pExport.performing_restore()

		end_import = pImport.end_import()
	end function

	public function getImportManager()
		set getImportManager = pImport
	end function

	public function CheckIfMiniFirma(byref pExpMan)
		bMiniFirma = false
		
		dim pRecordset
		set pRecordset = pExpMan.getConnection().execute("SELECT ModName FROM navolicence")

		while (not pRecordset.EOF)
			if (pRecordset.fields("ModName").value = "STARTKIT") then
				bMiniFirma = true
				exit function
			end if
			pRecordset.MoveNext
		wend
	end function

	public function choiceFirma(byref pExpMan): choiceFirma = false
		
		dim pNewHli
		set pNewHli=doc_.createhlistr("varCmd=CMD_OPEN_STATIC_PAGE varDestPage=PAGE_FORM_CHOICE_FIRMA_IMP")

		dim pUserPage
		set pUserPage=doc_.getpagehli(pNewHli)

		if (pUserPage is nothing) then
			exit function
		end if

		dim nRes
		nRes = pUserPage.read_firmy(pExpMan.getConnection())

		select case nRes
			case -100 'Wiecej firm
				pExpMan.performing_destroy
				idFirmy = pUserPage.domodalauto()
				pExpMan.performing_show "Analiza danych"

			case -200 'Rezygnacja
				exit function

			case else
				idFirmy = CLng(nRes)

		end select

		choiceFirma = (idFirmy > 0)
	end function

	public function database_logon(byval strLogin, byval strPwd, byval strServerName, byval bSQL, byref pExportManager): database_logon = false
		if (bSQL) then

			bSybase = false
			
			dim bSQLTryAutoLogon: bSQLTryAutoLogon = true

			if (strLogin<>"") then
				if (pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_FIRMA", strLogin, strPwd)) then
					bSQLTryAutoLogon = false
				end if
			end if

			if (bSQLTryAutoLogon) then
				if (not pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_FIRMA", "dba", "y1410grun")) then
					if (not pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_FIRMA", "sa", "")) then
						view_message 6241, 0
						exit function
					end if
				end if
			end if

		else 'SQL

			bSybase = true

			dim bSybTryAutoLogon: bSybTryAutoLogon = true

			if (strLogin<>"") then
				if (not pExportManager.connectDSN("NAVO_FIRMA", strLogin, strPwd)) then
					if (pExportManager.connectDSN("NAVO_FIRMA37", strLogin, strPwd)) then
						bSybTryAutoLogon = false
					end if
				else
					bSybTryAutoLogon = false
				end if
			end if

			if (bSybTryAutoLogon) then
				
				if (pExportManager.connectDSN("NAVO_FIRMA", "", "")) then
					database_logon = true
					exit function
				end if

				if (pExportManager.connectDSN("NAVO_FIRMA", "dba", "y1410grun")) then
					database_logon = true
					exit function
				end if

				if (pExportManager.connectDSN("NAVO_FIRMA", "dba", "mendelejew")) then
					database_logon = true
					exit function
				end if
				
				if (pExportManager.connectDSN("NAVO_FIRMA37", "", "")) then
					database_logon = true
					exit function
				end if
				
				if (pExportManager.connectDSN("NAVO_FIRMA37", "dba", "y1410grun")) then
					database_logon = true
					exit function
				end if
				
				if (pExportManager.connectDSN("NAVO_FIRMA37", "dba", "mendelejew")) then
					database_logon = true
					exit function
				end if
				
				view_message 6241, 0
				exit function

			end if

		end if 'SQL

		database_logon = true

	end function


	public function database_logon_kadry(byval strLogin, byval strPwd, byval strServerName, byref pExportManager): database_logon_kadry = false

		bSybase = false
			
		dim bSQLTryAutoLogon: bSQLTryAutoLogon = true

		if (strLogin<>"") then
			if (pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_KADRY", strLogin, strPwd)) then
				bSQLTryAutoLogon = false
			end if
		end if

		if (bSQLTryAutoLogon) then
			if (not pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_KADRY", "dba", "y1410grun")) then
				if (not pExportManager.connectSQL(strServerName, "STD_DATABASE_NAME_KADRY", "sa", "")) then
					view_message 6241, 0
					exit function
				end if
			end if
		end if

		database_logon_kadry = true

	end function



	public function logon(byval strLogin, byval strPwd, byval strServerName, byval bSQL, byref pExportManager): logon = false
		pExportManager.setContainer me
		
		'import z bazy do bazy - bezposredni
		pExportManager.directImport getImportManager()

		if (not database_logon(strLogin, strPwd, strServerName, bSQL, pExportManager)) then
			pExportManager.performing_destroy
			exit function
		end if

		dim strChoiceFirma: strChoiceFirma = ""

		if (bSQL) then
			strChoiceFirma = "SQL=" + strServerName + "="
		else
			strChoiceFirma="SYBASE="
		end if 'SQL

		'Sprawdzamy czy mamy doczynienia z mini firma i jezeli
		'tak to to zaznaczamy
		CheckIfMiniFirma pExportManager

		'Dokonujemy wyboru firmy
		if (not choiceFirma(pExportManager)) then
			pExportManager.performing_destroy
			exit function
		end if

		'Sprawdzamy czy firma jest inna od tej z poprzedniego importu
		strChoiceFirma = strChoiceFirma + CStr(idFirmy)

		dim strLastFirmaChoice
		strLastFirmaChoice = getglobprofile(GLOBPROF_LAST_IMPORTED_FIRMA)

		if (strLastFirmaChoice<>"") then
			if (strLastFirmaChoice<>strChoiceFirma) then
		
				pExportManager.performing_destroy
				if MessageBox("Wybrana baza danych lub firma r¾┐ni siĻ od wybranej przy poprzednim imporcie. Czy mimo to kontynuowaµ? ", "Inna baza", vbYesNo, vbQuestion ) <> vbYes then
					exit function
				end if 
				pExportManager.performing_restore

			end if
		end if

		'ustaw profil z firma jaka imporujemy i zapisz
		setglobprofile GLOBPROF_LAST_IMPORTED_FIRMA, strChoiceFirma
		trans_.saveobjects

		logon = true
	end function

end class

