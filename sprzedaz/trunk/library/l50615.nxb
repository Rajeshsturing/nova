'.........................
' Firma
'.........................
function Firma_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5FIRMA

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim strWojewodztwo
	strWojewodztwo = doc_.afc.business.zip2area_pl( trim(pRecord.fields("KOD_POCZTOWY").value) )

	if (strWojewodztwo <> "") then
		pExpMan.fromVirtualObject "Wojewodztwo", strWojewodztwo, pRecord, nothing
	end if

	if (trim(pRecord.fields("MIESCOWOSC_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Miejscowosc", trim(pRecord.fields("MIESCOWOSC_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pMiejscowosc", TYPEID_N5MIEJSCOWOSC) = trim(pRecord.fields("MIESCOWOSC_NAZWA").value)
	end if

	if (trim(pRecord.fields("BANK_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Bank", trim(pRecord.fields("BANK_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pBank1", TYPEID_N5BANK) = trim(pRecord.fields("BANK_NAZWA").value)
		pStream.fields("strRachunek1") = pRecord.fields("BANK_RACHUNEK").value
	end if

	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strSkrot") = pRecord.fields("Nazwa").value
	pStream.fields("strUlica") = pRecord.fields("Ulica").value
	pStream.fields("strKod") = pRecord.fields("Kod").value
	pStream.fields("strTel1") = pRecord.fields("Tel1").value
	pStream.fields("strTel2") = pRecord.fields("Tel2").value
	pStream.fields("strTel3") = pRecord.fields("Tel3").value
	pStream.fields("strFax") = pRecord.fields("Fax").value
	pStream.fields("eForma") = 1
	pStream.fields("strNIP") = pRecord.fields("NIP").value
	pStream.fields("strREGON") = pRecord.fields("Regon").value

	Firma_Convert2Stream = true
end function

function Firma_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Firma_SaveStream = pExpMan.container().import( pStream )
	pExpMan.save_data
end function


