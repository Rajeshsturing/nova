	pStream.fields("eWielkosc") = 7
	pStream.virtualfieldref("pWojewodztwo", TYPEID_N5WOJEWODZTWO) = doc_.afc.business.zip2area_pl(trim(pRecord.fields("KOD_POCZTOWY").value))

