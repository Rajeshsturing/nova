function export_Rejestr(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " and (" + strWhere + ")"
	end if

	dim strDestWhere
	strDestWhere = " where Rejestr.Nazwa <> '' and Rejestr.TypRej!='AUTO' and Rejestr.TypRej!='DOKM' and Rejestr.TypRej!='ZAL' and Rejestr.TypRej!='POLE'" + strWhere
	
	pExpMan.RecordsetCount "Rejestr", strDestWhere

	export_Rejestr = pExpMan.fromRecordset("select Rejestr.nazwa as unique_id, Rejestr.* from Rejestr" + strDestWhere, "Rejestr")
end function

function export_GMA_MM(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " and (" + strWhere + ")"
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	export_GMA_MM = pExpMan.fromRecordset("select GMA_MM.NrDok as record_id, GMA_MM.* from przesmm as GMA_MM " + _
		"where GMA_MM.IdTrans in (select GMA_POZMM.IdTrans from pozmm as GMA_POZMM where GMA_POZMM.Ilosc>0)" + strDestWhere, "GMA_MM")
end function

