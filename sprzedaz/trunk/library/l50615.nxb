	export_Urzad = pExpMan.fromRecordset("select *, Bank as BANK_NAZWA, KontoBank AS BANK_RACHUNEK, Miejsc AS MIESCOWOSC_NAZWA, Kod as KOD_POCZTOWY from Urzad" + strDestWhere, "Urzad")
end function

function export_Dekret(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " and (" + strWhere + ")"
	end if

	dim strDestWhere
	strDestWhere = " where (Dekret.KwotaWn <> 0 or Dekret.KwotaMa <> 0)" + strWhere
	
	pExpMan.RecordsetCount "Dekret join Konto on Dekret.IdKonto = Konto.IdKonto ", strDestWhere
	
	export_Dekret = pExpMan.fromRecordset("select '" + LIST_ELEMENT_IDENTITY + "' as list_id, Dekret.*, Konto.Symbol as Symbol from Dekret join Konto on Dekret.IdKonto = Konto.IdKonto " + strDestWhere, "Dekret")
end function

function export_Sprzedaz(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " where (" + strWhere + ")"
	end if

	dim strDestWhere
	strDestWhere = strWhere
	
	pExpMan.RecordsetCount "Sprzedaz join Kontrahent k on Sprzedaz.IdKontra=k.IdKontra", strDestWhere
	
	export_Sprzedaz = pExpMan.fromRecordset("select Sprzedaz.*, k.Nazwa as KONTRAHENT_NAZWA," + _
	" Sprzedaz.Kod as KOD_POCZTOWY, Sprzedaz.Miejsc As MIESCOWOSC_NAZWA," + _
	" Cast(DataPlat - DataSprz as int) as PLATNOSC_LICZBA_DNI, SposobPlat as PLATNOSC_NAZWA" + _
	" from Sprzedaz" + _
	" join Kontrahent k on Sprzedaz.IdKontra=k.IdKontra" + _
	" " + strDestWhere, "Sprzedaz")
end function

function export_Artykul(byref pExpMan, byval strWhere)
