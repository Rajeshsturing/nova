'.........................
' INSTYTUCJE
'.........................
function Urzad_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5INSTYTUCJA

	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strUlica") = pRecord.fields("Ulica").value

	dim strWojewodztwo
	strWojewodztwo = doc_.afc.business.zip2area_pl( trim(pRecord.fields("KOD_POCZTOWY").value) )

	if (strWojewodztwo <> "") then
		pExpMan.fromVirtualObject "Wojewodztwo", strWojewodztwo, pRecord, nothing
	end if

	if (trim(pRecord.fields("MIESCOWOSC_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Miejscowosc", trim(pRecord.fields("MIESCOWOSC_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pMiejscowosc", TYPEID_N5MIEJSCOWOSC) = trim(pRecord.fields("MIESCOWOSC_NAZWA").value)
	end if

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("strSkrot") = pRecord.fields("Nazwa").value
	pStream.fields("strNrDomu") = pRecord.fields("NrDomu").value
	pStream.fields("strNrLokalu") = pRecord.fields("NrLokalu").value
	pStream.fields("strKod") = pRecord.fields("Kod").value

	if (trim(pRecord.fields("BANK_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Bank", trim(pRecord.fields("BANK_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pBank1", TYPEID_N5BANK) = trim(pRecord.fields("BANK_NAZWA").value)
		pStream.fields("strRachunek1") = pRecord.fields("KontoBank").value
	end if

	Urzad_Convert2Stream = true
end function

function Urzad_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Urzad_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' JEDNOSTKA
'.........................
function Jednostka_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5JEDNOSTKA

	pStream.fields("strSkrot") = pRecord.fields("Nazwa").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if
	
	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("nDokladnosc") = clng(pRecord.fields("Zaokr").value) + 1
	pStream.fields("eTyp") = N5JEDNOSTKA_MIARY

	Jednostka_Convert2Stream = true
end function

function Jednostka_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Jednostka_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' KLIENCI
'.........................
function Kontrahent_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5KLIENT

	pStream.fields("strIndeks") = pRecord.fields("Indeks").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	'referencje:
	dim idGrupaKontra
	idGrupaKontra = pRecord.fields("GRUPA_KONTRAHENTA").value

	if (isNull(idGrupaKontra)) then
		idGrupaKontra = 0
	else
		pExpMan.fromObject "GrupaKontra", "IdGrKontra", idGrupaKontra
	end if

	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strSkrot") = pRecord.fields("Nazwa").value
	pStream.fields("strUlica") = pRecord.fields("Ulica").value
	pStream.fields("strKod") = pRecord.fields("Kod").value
	pStream.fields("strTel1") = pRecord.fields("Tel1").value
	pStream.fields("strTel2") = pRecord.fields("Tel2").value
	pStream.fields("strTel3") = pRecord.fields("Tel3").value
	pStream.fields("strFax") = pRecord.fields("Fax").value
	pStream.fields("strEmail") = pRecord.fields("email").value

	dim strNIP
	strNIP = pRecord.fields("NIP").value

	if (trim(strNIP)<>"") then
		pStream.fields("strNIP") = strNIP
	else
		pStream.fields("strNIP") = "Brak"
	end if

	dim strRegon
	strRegon = ""

	pStream.fields("strREGON") = strRegon
	pStream.fields("eAktywny") = N5KLIENT_AKTYWNY
	pStream.fields("eKlasaKlienta") = N5KLIENT_SREDNI
	pStream.fields("dDataUr") = doc_.afc.globals.nulldate()
	pStream.fields("strUwagi") = pRecord.fields("Opis").value
	pStream.fields("ePrywat") = N5KLIENT_FIRMA
	pStream.fields("pGrupaKlient") = idGrupaKontra

	dim strWojewodztwo
	strWojewodztwo = doc_.afc.business.zip2area_pl( trim(pRecord.fields("KOD_POCZTOWY").value) )

	if (strWojewodztwo <> "") then
		pExpMan.fromVirtualObject "Wojewodztwo", strWojewodztwo, pRecord, nothing
	end if

	if (trim(pRecord.fields("MIESCOWOSC_NAZWA").value) <> "") then
		pExpMan.fromVirtualObject "Miejscowosc", trim(pRecord.fields("MIESCOWOSC_NAZWA").value), pRecord, nothing
		pStream.virtualfieldref("pMiejscowosc", TYPEID_N5MIEJSCOWOSC) = trim(pRecord.fields("MIESCOWOSC_NAZWA").value)
	end if

	Kontrahent_Convert2Stream = true
end function

function Kontrahent_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Kontrahent_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' KONTA
'.........................
function Konto_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5KONTO

	pStream.fields("strSymbol") = pRecord.fields("Symbol").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	export_Konto pExpMan, "Konto.IdKonto=" + CStr(pRecord.fields("KontoParentID").value)
	
	pStream.virtualfieldref("pKontoNadrz", TYPEID_N5KONTO) = pRecord.fields("ParentSymbol").value
	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strOpis") = pRecord.fields("Komentarz").value
	
	if (export_Pracownik(pExpMan, "Pracownik.IdPrac=" + CStr(pRecord.fields("PracID").value))) then
		pStream.virtualfieldref("wrefPodmiotRozrach", TYPEID_N5PRACOWNIK) = pRecord.fields("PracID").value
	end if
	
	if (export_Kontrahent(pExpMan, "Kontrahent.IdKontra=" + CStr(pRecord.fields("KontraID").value))) then
		pStream.virtualfieldref("wrefPodmiotRozrach", TYPEID_N5KLIENT) = pRecord.fields("KontraID").value
	end if
	
	if (pRecord.fields("Syntet").value="S") then
		pStream.fields("eAnalit") = N5KONTO_SYNTETYCZNE
	else
		pStream.fields("eAnalit") = N5KONTO_ANALITYCZNE
	end if

	if (pRecord.fields("Bilans").value="B") then
		pStream.fields("eBilans") = N5KONTO_BILANSOWE
	else
		pStream.fields("eBilans") = N5KONTO_POZABILANSOWE
	end if

	pStream.fields("eAktywne") = N5KONTO_AKTYWNE

	Konto_Convert2Stream = true
end function

function Konto_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Konto_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' Artykul
'.........................
function Artykul_Convert2Stream(byref pExpMan, byref pRecord, byref pStream)
	pStream.begin_object TYPEID_N5PRODUKT
	
	pStream.fields("strIndeks") = pRecord.fields("NaszInx").value

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pExpMan.start_waiting

	export_GrupaArt pExpMan, "p.IdGrArt=" + CStr(pRecord.fields("IdGrArt").value)
	pExpMan.fromObject "Jednostka", "IdJedn", pRecord.fields("IdJedn").value
	
	pStream.fields("strNazwa") = pRecord.fields("Nazwa").value
	pStream.fields("strNazwaMiedzynarodowa") = pRecord.fields("NazwaM").value
	pStream.fields("strKodPKWiU") = pRecord.fields("SWW").value
	pStream.fields("strOpis") = pRecord.fields("Opis").value

	pStream.fields("eAktywny") = N5PRODUKT_AKTYWNY

	if (trim(pRecord.fields("TowarUsl").value)<>"T") then  
		pStream.fields("eRodzaj") = N5PRODUKT_USLUGA
	end if

	'Ustaw pole eVAT na podstawie stawki VAT
	set_eVAT "VAT", trim(pRecord.fields("Nazwa").value), pRecord, pStream, pExpMan

	pStream.fields("pGrupaProd") = pRecord.fields("IdGrArt").value
	pStream.fields("pJednostkaEwid") = pRecord.fields("IdJedn").value

	'wymuszamy usuniecie wszyskiego z listy - jezeli cos bylo
	pStream.fields("listOpakowania") = 0

	Artykul_Convert2Stream = true
end function

function Artykul_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	Artykul_SaveStream = pExpMan.container().import( pStream )

	'eksportujemy listĻ
	pExpMan.fromVirtualObject "Opakowanie", LIST_ELEMENT_IDENTITY, pRecord, nothing
	pExpMan.stop_waiting
end function


