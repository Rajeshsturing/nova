'funkcja na kartach
function popraw_dane()

	dim idRoot: idRoot=page_.root.idobj
	dim rootTypeId:rootTypeId = page_.root.type
	dim pSubTrans:set pSubTrans = trans_.createsubtran()
		doc_.getmodule(60129).form_domodal rootTypeId,idRoot,USAGE_EDIT
	set pSubTrans=nothing
	rebuild_contents

end function

