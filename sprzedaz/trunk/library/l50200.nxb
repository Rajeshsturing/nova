'funkcja otwiera domyślny formularz dla obiektu pMainObject w polu <ref> strRefFldName
private function std_openform_field(byref pMainObject,byref strRefFldName)
	dim pRefObject : set pRefObject = pMainObject.field(strRefFldName)
	if pRefObject is nothing then
		exit function
	else
		doc_.postcommand doc_.afc.convert.formatter(" OPEN_FORM_PROXY_HLI_USAGE(%1,%2,USAGE_VIEW) ") _
			.add(cstr(pRefObject.type)).add(cstr(pRefObject.idobj)).done()
	end if
end function

'domyslny formularz dla obiektu o idobj = hli.prop(2) i typeid = hli.prop(1)
function std_openform_object_hli(hli)
	dim nTypeId:nTypeId = hli.prop(1)
	dim nIdObj:nIdObj = hli.prop(2)
	doc_.postcommand doc_.afc.convert.formatter(" OPEN_FORM_PROXY_HLI_USAGE(%1,%2,USAGE_VIEW) ") _
		.add(cstr(nTypeId)).add(cstr(nIdObj)).done()
end function


'funkcja otwiera domyślny formularz dla obiektu root w polu <ref> strRefFldName
'do użycia z hyperlinka
'prop 1 = strRefFldName
function std_openform_field_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)
	std_openform_field page_.root, strRefFldName
end function

#comment 'funkcja otwiera domyślny formularz dla obiektu root w polu listy strListRef, w 
#comment 'elemencie nRow, w jego polu <ref> strRefFldName
#comment 'do użycia z hyperlinka
#comment 'prop 1 - nazwa pola listy strListFldName
#comment 'prop 2 - nazwa pola referencji strRefFldName
#comment 'propc_row - nr wiersza (dostarczany przez silnik)

function std_open_form_list_hli(byref pHLI)
	dim strListFldName : strListFldName = pHLI.prop(1)
	dim strRefFldName : strRefFldName = pHLI.prop(2)
	dim nRow : nRow = CLng(pHLI.prop(PROPC_ROW))
	dim pList : set pList = page_.root.field(page_.root.getobjdef.getfieldindex(strListFldName))

	if pList.exists(nRow) then
		std_openform_field pList.get(nRow), strRefFldName
	end if
end function

