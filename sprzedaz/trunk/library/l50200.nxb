'std_choice_list_s
'funkcja pokazuje listę obiektów, z której można wybrać jeden
'wynik wstawiamy do pObject.strRefFldName
'parametry podawane recznie
function std_choice_list_s(byref pObject,byval strRefFldName,byval strTitle,byval strMatchField,byval strWhere,byval strOrderBy,byval strJoin) : std_choice_list_s = 0
	if pObject is nothing then
		exit function
	end if

	dim pStdObjDef : set pStdObjDef = pObject.getobjdef()
	dim nFieldNr : nFieldNr = pStdObjDef.getfieldindex(strRefFldName)
	dim nRefTypeId : nRefTypeId = pStdObjDef.field(nFieldNr).reftypeid
	dim idChoice : idChoice = fire_choice_list(nRefTypeId,strTitle,strMatchField,strWhere,strOrderBy,strJoin)

	if idChoice <> 0 then
		set pObject.field(nFieldNr) = trans_.getobj(nRefTypeId, idChoice)
	end if
	std_choice_list_s = idChoice
end function




'Funkcja do wyboru i wstawienia do pola (referencja) elementu w gridzie
'prop 1 = nazwa listy (np. listZalaczniki)
'prop 2 = nazwa pola referowanego w liscie (np pDokument)
'prop 3 = where
' do wykorzystania w XML
'np xg_ref_cell(PICTURE_CHOICE_N5DOKUMENT,20,pDokument,strTematDokum,1,,std_choose_element_list,listDokumenty)										
' TODO:AM - funkcja do rozbicia na mniejsze w razie potrzeby
function std_choose_element_list_hli(pHli)


	dim strTitle':strTitle = "Wybierz dokument do załączenia"
	dim strListName : strListName = pHLI.prop(1)
	dim strRefName : strRefName = pHLI.prop(2)
	dim strWhere : strWhere = pHLI.prop(3)	
dim strWybor
if pHLI.exists(4) then		' zmienna prop(4) mówiąca o tym po jakim polu sortujemy (dowod ksiegowy wybor po symbolu lub nazwie
	strWybor = pHLI.prop(4)
else
	strWybor = ""
end if

	'definicja pola listy
	dim pFieldDef:set pFieldDef = page_.root.getobjdef.field(page_.root.getobjdef.getfieldindex(strListName))
	'definicja dziecka listy
	dim pStdObjDef:set pStdObjDef = doc_.stdobjdef.getobjdef( pFieldDef.reftypeid )
	'indeks pola strRefName w obiekcie dziecka listy
	dim nFldNr:nFldNr = pStdObjDef.getfieldindex(strRefName)
	'typid pola strRefName - co by liste wyboru mozna wyswietlic
	dim nTypeId : nTypeId = pStdObjDef.field(nFldNr).reftypeid
	'obiekt listy
	dim pList : set pList = page_.root.field(page_.root.getobjdef.getfieldindex(strListName))


	dim nRow : nRow = CLng(pHLI.prop(PROPC_ROW))
	dim choice

	dim pM43009 : set pM43009 = doc_.getmodule(43009)
	pM43009.prepare_multi_selection nTypeId,strTitle, strWhere,strWybor 'zmienna strWybor przyjmuje nazwe pola dla wyboru konta wg nazwy w dowod ksiegowy, standardowo jest ""
	dim oNXArray : set oNXArray = pM43009.run_multi_browser()
	if not oNXArray is nothing then
		dim idChoosenItem
		for each idChoosenItem in oNXArray
			dim pChoosenObj:set pChoosenObj=trans_.getobj(nTypeId, idChoosenItem)
			dim pListItemObject
			if pList.exists(nRow) then
				set pListItemObject = pList.get(nRow)
			else
				set pListItemObject = pList.addnew()
			end if
			set pListItemObject.field(nFldNr) = pChoosenObj
			nRow = nRow + 1
		next
	end if
end function


'REV:KB:TODO: zrobić uniwersalne
'hli ma zawierać typeid, idobj, fieldname
'zmienic pPM.createmail pObj
function createmail_for_root(hli)

	dim nTypeId
	if hli.exists(1) then
		nTypeId = clng(hli.prop(1))
	end if

	dim nIdObj
	if hli.exists(2) then
		nIdObj = clng(hli.prop(2))
	end if

	dim strFldName:strFldName=""
	if hli.exists(PROPC_EMAIL) then
		strFldName = cstr(hli.prop(PROPC_EMAIL))
	end if


	dim pObj
	if nTypeId = 0 then
		set pObj = page_.root
	else
		set pObj = trans_.getobj(nTypeId , nIdObj)
	end if

	if pObj is nothing then
		exit function
	end if

	dim pHli
	set pHli=doc_.createhlistr("varCmd=CMD_OPEN_RECORD_PAGE varDestPage=PAGE_FORM_EMAIL")

	dim pPM: set pPM=doc_.getpagehli(pHli)
	if pPM is nothing then
		exit function
	end if
	pPM.createmail pObj , strFldName

end function

'REV:KB:TODO: zrobić uniwersalne
'hli ma zawierać typeid, idobj, fieldname
function navigate(hli)
	if page_.root is nothing then
		exit function
	end if
	dim strWWW : strWWW = page_.root.field(cstr(hli.prop(PROPC_EMAIL)))
	doc_.getmodule(PAGE_FORM_WEB).navigate strWWW
end function





' wybiera i wstawia element - dziką referencje do dziecka listy
'hli.prop(1) - nazwa listy
'hli.prop(2) - pole w obiekcie dziecka
'hli.prop(3) - ordery dla list wyboru
function choose_wref_grid_elem(hli)
	dim strListName : strListName = hli.prop(1)
	dim strRefName : strRefName = hli.prop(2)

	'definicja pola listy
	dim pFieldDef:set pFieldDef = page_.root.getobjdef.field(page_.root.getobjdef.getfieldindex(strListName))
	'definicja dziecka listy
	dim pStdObjDef:set pStdObjDef = doc_.stdobjdef.getobjdef( pFieldDef.reftypeid )
	'obiekt listy
	dim pList : set pList = page_.root.field(page_.root.getobjdef.getfieldindex(strListName))


	'dim pChild
	'dim pList:set pList = page_.root.field(cstr(hli.prop(1)))
	dim nRow : nRow = CLng(hli.prop(PROPC_ROW))

	dim pPageSuggest
	set pPageSuggest=doc_.getmodule(43002)

	dim nObjectId
	nObjectId = pPageSuggest.wildref_choose(pStdObjDef, strRefName, cstr(hli.prop(3)), "")

	if (nObjectId>0) then
		dim pObj
		set pObj=trans_.getobj(pPageSuggest.getTypeID(), nObjectId)

		dim pChild
		if pList.exists(nRow) then
			set pChild=pList.get(nRow)
		else
			set pChild=pList.addnew()
		end if

		set pChild.field(strRefName) = pObj
	end if

end function


'prop 1 = nazwa pola referencji np. pKlient
function std_remove_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)	

	dim strMatchField: strMatchField = ""
	if (pHLI.exists(4)) then
		strMatchField = pHLI.prop(4)
	end if

	dim pStdObjDef:set pStdObjDef = doc_.stdobjdef.getobjdef(page_.root.type)

	dim nFldNr:nFldNr = pStdObjDef.getfieldindex(strRefFldName)

	set page_.root.field(nFldNr) = nothing
	
end function


function UnderConstruction
	doc_.getmodule(MODULE_MSGBOX).message_box "under construction", "", vbOkOnly, vbInformation
end function


#comment Taki link umiescic aby posortowac liste po polu pProdukt według strNazwa
#comment href='varFunctionHLI="sort_list_by_objfld" vs1="pProdukt" vs2="strNazwa" vs3="listPozycje"'

function sort_list_by_objfld (byref hli)
	if not hli.exists(4) then
		hli.prop(4)	= 0
	else
		if hli.prop(4)	= 0 then
			hli.prop(4)	= 1
		else
			hli.prop(4)	= 0			
		end if
	end if
	doc_.getmodule(60242).sort_list_by_objfld page_.root.field(hli.prop(3)) , hli.prop(1) , hli.prop(2)	, (hli.prop(4)=0)
end function


function show_hide_blokada(byval ctrl)							
	if not page_.root.pKlient is nothing then	
		if page_.root.pKlient.kli_cBlokadaSprz then	
			page_.ctrl(ctrl).hide = false						
		else	
			page_.ctrl(ctrl).hide = true					
		end if	
	else	
		page_.ctrl(ctrl).hide = true					
	end if	
end function

function show_hide_rejestracja(byval ctrl)
	if page_.root.strExtra1 = "1" then
		page_.ctrl(ctrl).hide = false						
	else	
		page_.ctrl(ctrl).hide = true					
	end if	

end function


#comment ===========================================
#comment Załącznik do dokumenu
#comment ===========================================

function newDokZal(oRow) : set newDokZal = nothing
	dim pDokument : set pDokument = nothing
  
	'podepnij plik z dysku
	dim strPath : strPath = SelectFile("c:\", "", "")
	if (Len(strPath) > 0) then  
		set pDokument = trans_.newobj(TYPEID_N5DOKUMENT)
		pDokument.nForma = CLng(N5DOKUMENT_FORMA_ELEKTRON)
		
		on error resume next		
		
		err.Clear	
		pDokument.fPlik.Attach strPath
		
		if (err.Number>0) then
			trans_.message 0,0,"Brak możliwości podłączenia pliku " + strPath +". Prawdopodobnie brak uprawnień. Szczegóły: " +_
				err.Description
			pDokument.ignore = true
			exit function
		end if
		
		on error goto 0

		pDokument.fPlik.ext = doc_.getmodule(60144).get_filename_extension(strPath)
		pDokument.strFileName = AddComputerName(strPath)
		
		dim pFD, bOK
		set pFD = CFileDrive(bOK)
		if (bOK) then
			pDokument.strTematDokum = "zalacznik_" + CStr(oRow) + "_" + pFD.GetFileName(strPath)
			pDokument.dok_strOpis = pFD.GetFileName(strPath)
		end if
		set newDokZal = pDokument
	end if  
end function

function open_save_wref_grid_elem(hli)
	dim pChild
	dim pList: set pList = page_.root.field(cstr(hli.prop(1)))
	dim nRow: nRow = CLng(hli.prop(PROPC_ROW))

	if pList.exists(nRow) then
		set pChild=pList.get(nRow)
	else
		exit function
	end if

	dim elem: set elem = pChild.field(cstr(hli.prop(2)))

	if elem is nothing then
		exit function
	end if
  
	if trans_.findobjid(elem.type,"IdObj = " + cstr(elem.idobj)) = clng(0) then
		trans_.message 7000, 0, "Dokument musi być zapisany"
		exit function
	end if

	dim new_hli:set new_hli = doc_.createhlistr("vs1='" + cstr(elem.type) + "' vs2='" + cstr(elem.idobj) + "'")
	std_openform_object_hli(new_hli)
end function

function view_dok(hli)
	dim pChild
	dim pList: set pList = page_.root.field(cstr(hli.prop(1)))
	dim nRow: nRow = CLng(hli.prop(PROPC_ROW))

	if pList.exists(nRow) then
		set pChild=pList.get(nRow)
	else
		exit function
	end if

	dim elem: set elem = pChild.field(cstr(hli.prop(2)))
	if elem is nothing then
		exit function
	end if
  
	if trans_.findobjid(elem.type,"IdObj = " + cstr(elem.idobj)) = clng(0) then
		trans_.message 7000, 0, "Dokument musi być zapisany"
		exit function
	end if
  
	View trans_.getobj(elem.type,elem.idobj)

end function

