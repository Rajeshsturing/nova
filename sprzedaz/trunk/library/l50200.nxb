#macro VB_GRID_WREF_TRANSFER(_list_,_field_,_ctrl_)						\
function c##_ctrl_##_ongetdata(ctrl,row)								\
	if page_.root._list_.exists(row) then								\
		dim oElem														\
		set oElem = page_.root._list_.get(row)							\
		if not oElem is nothing then									\
			if not oElem.field("_field_") is nothing then				\
				ctrl.text = oElem.field("_field_").text					\
				set ctrl.hli = doc_.createhlistr("varFunctionHLI='open_wref_grid_elem' vs1='_list_' vs2='_field_'")	\
				exit function						\
			end if									\
		end if										\
	end if											\
	set ctrl.hli = nothing							\
	ctrl.text = "<brak>"							\
end function

#comment ------------------------------------------------------
#comment nx_fire_choice_list

#include "50560"

#comment 'fire_choice_list - uruchamianie listy podpowiedzi 
#comment ' typeid - typ obiektów jakie wyświetlamy - WYMAGANY
#comment ' title - tytuł okna - AUTOSUPPLIED
#comment ' fldname - pole "szukania" (wzorca), po którym następuje selekcja w zbiorze - AUTOSUPPLIED
#comment ' strWhere - predefiniowany przez nas where (ogranicznik zbioru po którym szukamy) - OPTIONAL
#comment ' strOrderBy - order by - przy braku robiony jest wg fldname - AUTOSUPPLIED
#comment ' strJoin - dodatkowy join wymagany przez strWhere lub/i strOrderBy- OPTIONAL

function fire_choice_list(byval nTypeId,byref strTitle,byref strMatchField,byref strWhere,byref strOrderBy,byref strJoin)
	fire_choice_list = nx_fire_choice_list(nTypeId,strTitle,strWhere,strMatchField)
end function

function fire_choice_list_is_new(byval nTypeId,byref strTitle,byref strMatchField,byref strWhere,byref strOrderBy,byref strJoin , byref bNew)	
	fire_choice_list_is_new = doc_.getmodule(43001).do_choice_list_isnew(nTypeId,strTitle,strMatchField,strWhere,strOrderBy,strJoin, nothing , bNew)
end function


function fire_choice_list_disable_add(byval nTypeId,byref strTitle,byref strMatchField,byref strWhere,byref strOrderBy,byref strJoin)
	fire_choice_list_disable_add = nx_fire_choice_list_disable_addnew(nTypeId,strTitle,strWhere)
end function


function fire_choice_list_custom(byval nTypeId,byref strTitle,byref strMatchField,byref strWhere,byref strOrderBy,byref strJoin,byval pFun,byval bDisableAdd)

	dim choicelist:set choicelist = doc_.getmodule(43001)
	choicelist.prepare_choice_list nTypeId,strTitle,strMatchField,strWhere,strOrderBy,strJoin, pFun
	if bDisableAdd then
		choicelist.hide_buttons(true)
	end if
	fire_choice_list_custom = choicelist.domodalauto()

end function



function fire_multiple_choice_list_custom(byval nTypeId,byref strTitle,byref strMatchField,byref strWhere,byref strOrderBy,byref strJoin,byval pFun,byval bDisableAdd)

	dim choicelist:set choicelist = doc_.getmodule(43001)
	choicelist.prepare_choice_list nTypeId,strTitle,strMatchField,strWhere,strOrderBy,strJoin, pFun
	if bDisableAdd then
		choicelist.hide_buttons(true)
	end if
	choicelist.multiple
	fire_multiple_choice_list_custom = choicelist.domodalauto()

end function


function get_choicelist()
	set get_choicelist = doc_.getmodule(43001)
end function



#comment wyświetl drzewko typu nTreeType = EXPLORER_*, korzeniem drzewka jest
#comment obiekt (nStartingTypeId:nStartingIdObj) - podaj nStartingIdObj = 0 dla 'wszystkich'
#comment zwraca w rezultacie idObj wybranego obiektu, a w nChoosenTypeId typeid
function fire_choice_tree(byval nTreeType,byval nStartingTypeId,byval nStartingIdObj,byref nChoosenTypeId)
	dim pPageSuggest : set pPageSuggest = doc_.getpagehli("varCmd=CMD_OPEN_STATIC_PAGE varDestPage=43007 varFormUsage=USAGE_DO_CHOICE")
	dim idChoosenIdObj : idChoosenIdObj = 0
	pPageSuggest.prepare_and_show nTreeType,nStartingTypeId,nStartingIdObj,true,nChoosenTypeId,idChoosenIdObj
	fire_choice_tree = idChoosenIdObj 
end function

#comment 'std_choice_field_crsr
#comment 'funkcja pokazuje listę obiektów, z której można wybrać jeden
#comment 'wynik wstawiamy do pObject.strRefFldName
#comment 'parametry podawane z kursora
#comment 'hli jest opcjonalne

function std_choice_field_crsr(byref pObject,byval strRefFldName,byval strTitle,byval strMatchField,byval idCursor,byval idRefTypeId, byval hli) : std_choice_field_crsr = 0
	if pObject is nothing then
		exit function
	end if

	dim pStdObjDef : set pStdObjDef = pObject.getobjdef()
	dim nFieldNr : nFieldNr = pStdObjDef.getfieldindex(strRefFldName)
	dim nRefTypeId 
	if idRefTypeId = 0 then	'znajdź jeśli nie podano (zazwyczaj)
		nRefTypeId = pStdObjDef.field(nFieldNr).reftypeid
	else
		nRefTypeId = idRefTypeId
	end if
	dim pCursDef : set pCursDef = doc_.stdobjdef.getobjdef(nRefTypeId).cursor(idCursor)

	dim strWhere : strWhere = trans_.applyvars(pCursDef.where)
	dim strOrder : strOrder = trans_.applyvars(pCursDef.orderby)
	dim strJoin : strJoin = trans_.applyvars(pCursDef.join)

#ifdef ENABLE_DB11
	if trans_.isvar(APPVAR_REJESTR_TYP) then
		if nRefTypeId = TYPEID_N5ZAMOWIENIE and trans_.var(APPVAR_REJESTR_TYP) = N5REJESTRDOK__ZAM_WLASNE then
			trans_.var(GVAR_CURRENT_REJESTR_TYP) = "N5REJESTRDOK__ZAM_OBCE"
		end if
		if nRefTypeId = TYPEID_N5ZADANIE then
			trans_.var(GVAR_CURRENT_REJESTR_TYP) = "N5REJESTRDOK_ZADANIA"
		end if
	end if
#endif
	
	dim idChoice
	'jesli to jest puste to nie konfigurujemy listy w zaden sposób
	if hli is nothing then
		idChoice = fire_choice_list(nRefTypeId,strTitle,strMatchField,strWhere,strOrder,strJoin)
	else
		'a jesli nie to musimy cos z nia zrobić
		'wersja dla nowej szkoły
		'jesli hli.prop(4) = strIndeks to lista z kolumami indeks/nazwa
		'jesli hli.prop(4) = strNazwa to na odwrót
		if hli.exists(4) then
			dim strFld:strFld = hli.prop(4)
			if UCASE(strFld) = UCASE("strIndeks") then
				idChoice = fire_choice_list_custom(nRefTypeId,strTitle,strMatchField,strWhere,strOrder,strJoin,getref("BulidCustomerRow_INDEX") , false)			
			else
				idChoice = fire_choice_list_custom(nRefTypeId,strTitle,strMatchField,strWhere,strOrder,strJoin,getref("BulidCustomerRow_NAME") , false)			
			end if
		end if				
	end if

	if idChoice <> 0 then
		set pObject.field(nFieldNr) = trans_.getobj(nRefTypeId, idChoice)
	end if
	std_choice_field_crsr = idChoice
end function

#comment 'std_choice_field_cq
#comment 'funkcja pokazuje listę obiektów, z której można wybrać jeden
#comment 'wynik wstawiamy do pObject.strRefFldName
#comment 'parametry podawane poprzez wywołanie funkcji cNNN_onsuggquery

function std_choice_field_cq(byref pObject,byval strRefFldName,byval strTitle,byval strMatchField,byval idEditCtrl,byval strWrefTypeId,byval strFillFunctionName) : std_choice_field_cq = 0
	if pObject is nothing then
		exit function
	end if

	dim pStdObjDef : set pStdObjDef = pObject.getobjdef()
	dim nFieldNr : nFieldNr = pStdObjDef.getfieldindex(strRefFldName)

	dim nRefTypeId
	if isNumeric(strWrefTypeId) then
		nRefTypeId = clng(strWrefTypeId)
	else
		nRefTypeId = pStdObjDef.field(nFieldNr).reftypeid
	end if

	dim strQueryFunction : strQueryFunction = "c" + cstr(idEditCtrl) +  "_onsuggquery"
	dim pQueryFunction : set pQueryFunction = GetRef(strQueryFunction)
	dim pEditCtrl : set pEditCtrl = page_.ctrl(idEditCtrl)
	
	dim strWhere : strWhere = ""
	if pObject.type = TYPEID_N5PLNALICZENIE and strRefFldName = "pPracownik" then
		strWhere = "n5pracownik.eAktywny <> N5PRACOWNIK_AKTYWNY_NIEAKTYWNY"
	end if

	dim strOrder : strOrder = ""
	dim strJoin : strJoin = ""
	pQueryFunction pEditCtrl,pEditCtrl.value,strWhere,strOrder,strJoin

	dim idChoice : idChoice = fire_choice_list(nRefTypeId,strTitle,strMatchField,strWhere,strOrder,strJoin)

	if idChoice <> 0 then
		set pObject.field(nFieldNr) = trans_.getobj(nRefTypeId, idChoice)
	end if
	std_choice_field_cq = idChoice
end function

#comment 'std_choice_field_crsr_hli
#comment 'wersja std_choice_field_crsr do wywoływania z hyperlinkiem
#comment 'prop 1 = nazwa pola referencji np. pKlient - wymagane
#comment 'prop 2 = pole po którym szukamy - opcjonalne
#comment 'prop 3 = wskazany wariant referencji (dla dzikich) - opcjonalne
#comment 'varCursor - id kursora - wymagane

function std_choice_field_crsr_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)
	dim strMatchField: strMatchField = ""

	if (pHLI.exists(2)) then
		strMatchField = pHLI.prop(2)
	end if
	dim idRefTypeId : idRefTypeId = 0
	if (pHLI.exists(3)) then
		idRefTypeId = clng(pHLI.prop(3))
	end if

	if (pHLI.exists(APPVAR_REJESTR_TYP)) then
		trans_.var(APPVAR_REJESTR_TYP) = pHLI.prop(APPVAR_REJESTR_TYP)
	end if

#ifdef APPCONFIG_OGRANICZONY_WYBOR_KLIENTA

	if trans_.isvar(GVAR_PRACOWNIK_DEDYK) and (page_.root.type = TYPEID_N5ZAMOWIENIE or page_.root.type = TYPEID_N5ZADANIE or page_.root.type = TYPEID_N5KLIENT_PRACOWNIK) and strRefFldName = "pKlient" then
		if trans_.var(GVAR_PRACOWNIK_DEDYK) > clng(-1) then
			if pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_INX) then
				pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_INX_TYLKO_WYBRANY_KLIENT)
			end if
			if pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU) or pHLI.prop(GVAR_CURSOR) = clng(CRSR_DEFAULT) then
				pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU_TYLKO_WYBRANY_KLIENT)
			end if
		end if
	end if

	'ograniczony dostęp do wyboru dostawcy (Alma Trend)
	if trans_.isvar(GVAR_DOSTAWCA_OGRANICZONY_DOSTEP) and page_.root.type = TYPEID_N5ZAMOWIENIE and strRefFldName = "pKlient" then
		if not page_.root.pRejestrDok is nothing and trans_.var(GVAR_DOSTAWCA_OGRANICZONY_DOSTEP) = clng(1) then
			if page_.root.pRejestrDok.eTyp = N5REJESTRDOK__ZAM_WLASNE or page_.root.pRejestrDok.eTyp = N5REJESTRDOK_ZAP_OFERTOWE_WLASNE or page_.root.pRejestrDok.eTyp = N5REJESTRDOK_OFERTY_OBCE then
				if pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU) or pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_INX) then
					pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU_WYBRANY_DOSTAWCA)
				end if
			end if
		end if
	end if
	if trans_.isvar(GVAR_DOSTAWCA_OGRANICZONY_DOSTEP) and page_.root.type = TYPEID_N5ZAKUP and strRefFldName = "pDostawca" then
		if trans_.var(GVAR_DOSTAWCA_OGRANICZONY_DOSTEP) = clng(1) then
			if pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU) or pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_INX) then
				pHLI.prop(GVAR_CURSOR) = clng(CRSR_N5KLIENT_WG_NAZWY_SKROTU_WYBRANY_DOSTAWCA)
			end if
		end if
	end if
#endif

	if (pHLI.exists(4)) then
		DEBUG_MESSAGE("std_choice_field_crsr_hli: vn4 exists")
		std_choice_field_crsr_hli = std_choice_field_crsr(page_.root,strRefFldName,"",strMatchField,pHLI.prop(GVAR_CURSOR),idRefTypeId, pHLI )
	else
		std_choice_field_crsr_hli = std_choice_field_crsr(page_.root,strRefFldName,"",strMatchField,pHLI.prop(GVAR_CURSOR),idRefTypeId, nothing )
	end if

end function

'std_choice_field_cq_hli 
'standardowa lista, ale z custom query
#comment 'prop 1 = nazwa pola referencji np. pKlient - wymagane
#comment 'prop 2 = pole po którym szukamy - opcjonalne
#comment 'prop 3 = idEditCtrl - wymagany
#comment 'prop 4 = typeid dla dziekiej referencji jesli korzystamy z tej funkcji w tym przypadku
#comment 'prop 5 = nazwa funkcji wypełniającej choicelist
function std_choice_field_cq_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)
	dim strMatchField: strMatchField = ""
	if (pHLI.exists(2)) then
		strMatchField = pHLI.prop(2)
	end if
	
	dim strFillFun
	if (pHLI.exists(5)) then	
		strFillFun = cstr(pHLI.prop(5))
	else
		strFillFun = ""
	end if
		
	std_choice_field_cq_hli = std_choice_field_cq(page_.root,strRefFldName,"",strMatchField,pHLI.prop(3),pHLI.prop(4),strFillFun)
end function

#comment 'std_choice_lst_crsr
#comment 'funkcja pokazuje listę obiektów, z której można wybrać jeden
#comment 'wynik wstawiamy do pObject.list.get(nRow).strRefFldName
#comment 'parametry podawane z kursora

function std_choice_lst_crsr(byref pObject,byval strLstFldName,byval nRow,byval strRefFldName,byval strTitle,byval strMatchField,byval idCursor,byval idRefTypeId) : std_choice_lst_crsr = 0
	if pObject is nothing then
		exit function
	end if

	'definicja ojca
	dim pStdObjDef : set pStdObjDef = pObject.getobjdef()
	
	'definicja pola listy
	dim pListFieldDef : set pListFieldDef = pStdObjDef.field(pStdObjDef.getfieldindex(strLstFldName))
	
	'definicja dziecka listy
	dim pChildDef : set pChildDef = doc_.stdobjdef.getobjdef( pListFieldDef.reftypeid )

	dim nFieldNr : nFieldNr = pChildDef.getfieldindex(strRefFldName)
	dim nRefTypeId 
	if idRefTypeId = 0 then	'znajdź jeśli nie podano (zazwyczaj)
		nRefTypeId = pChildDef.field(nFieldNr).reftypeid
	else
		nRefTypeId = idRefTypeId
	end if
	dim pCursDef : set pCursDef = doc_.stdobjdef.getobjdef(nRefTypeId).cursor(idCursor)

	dim strWhere : strWhere = trans_.applyvars(pCursDef.where)
	dim strOrder : strOrder = trans_.applyvars(pCursDef.orderby)
	dim strJoin : strJoin = trans_.applyvars(pCursDef.join)

	dim idChoice : idChoice = fire_choice_list(nRefTypeId,strTitle,strMatchField,strWhere,strOrder,strJoin)

	if idChoice <> 0 then
		dim pList : set pList = pObject.field(strLstFldName)
		dim pChildObject
		if pList.exists(nRow) then
			set pChildObject = pList.get(nRow)
		else
			set pChildObject = pList.addnew()
		end if
		set pChildObject.field(nFieldNr) = trans_.getobj(nRefTypeId, idChoice)
	end if
	std_choice_lst_crsr = idChoice
end function

#comment 'std_choice_lst_crsr_hli
#comment 'wersja std_choice_lst_crsr_hli do wywoływania z hyperlinkiem
#comment 'prop 1 = nazwa pola referencji np. pKlient - wymagane
#comment 'prop 2 = pole po którym szukamy - opcjonalne
#comment 'prop 3 = wskazany wariant referencji (dla dzikich) - opcjonalne
#comment 'prop 4 = nazwa pola listy - wymagane
#comment 'varCursor - id kursora - wymagane

function std_choice_lst_crsr_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)
	dim strMatchField: strMatchField = ""

	if (pHLI.exists(2)) then
		strMatchField = pHLI.prop(2)
	end if
	dim idRefTypeId : idRefTypeId = 0
	if (pHLI.exists(3)) then
		idRefTypeId = clng(pHLI.prop(3))
	end if
	dim strLstFldName : strLstFldName =  pHLI.prop(4)

	std_choice_lst_crsr_hli = _
		std_choice_lst_crsr(page_.root,strLstFldName,clng(pHLI.prop(PROPC_ROW)),strRefFldName,"",strMatchField,pHLI.prop(GVAR_CURSOR),idRefTypeId)
end function

#comment 'std_choice_lst_cq
#comment 'funkcja pokazuje listę obiektów, z której można wybrać jeden
#comment 'wynik wstawiamy do pObject.list.get(nRow).strRefFldName
#comment 'parametry podawane poprzez wywołanie funkcji cNNN_onsuggquery

function std_choice_lst_cq(byref pObject,byval strLstFldName,byval nRow,byval strRefFldName,byval strTitle,byval strMatchField,byval idEditCtrl,byref pRealEditCtrl , byval strFillFun) : std_choice_lst_cq = 0
	if pObject is nothing then
		exit function
	end if

	'definicja ojca
	dim pStdObjDef : set pStdObjDef = pObject.getobjdef()
	
	'definicja pola listy
	dim pListFieldDef : set pListFieldDef = pStdObjDef.field(pStdObjDef.getfieldindex(strLstFldName))
	
	'definicja dziecka listy
	dim pChildDef : set pChildDef = doc_.stdobjdef.getobjdef( pListFieldDef.reftypeid )

	dim nFieldNr : nFieldNr = pChildDef.getfieldindex(strRefFldName)
	dim nRefTypeId : nRefTypeId = pChildDef.field(nFieldNr).reftypeid

	dim strQueryFunction : strQueryFunction = "c" + cstr(idEditCtrl) +  "_onsuggquery"
	dim pQueryFunction : set pQueryFunction = GetRef(strQueryFunction)
	
	dim strWhere : strWhere = ""
	dim strOrder : strOrder = ""
	dim strJoin : strJoin = ""

#ifdef _ALMA_TREND
	if pObject.type = TYPEID_N5PLATNOSC and strRefFldName = "pTransakcja" then
		if not pObject.wrefPodmiot is nothing then 
			if pObject.wrefPodmiot.type <> TYPEID_N5KLIENT then 
				if not doc_.getmodule(60106).FullRightTrans() then
					'nie pokazuj transakcji
					strWhere = "1=0"                
				end if
			end if
		end if
	end if
#endif
	
	pQueryFunction pRealEditCtrl,nRow,pRealEditCtrl.value,strWhere,strOrder,strJoin
	
#ifdef _TORAL
	'brak rozróżniania typu transakcji na należność lub zobiwiązanie
	if pObject.type = TYPEID_N5PLATNOSC and strRefFldName = "pTransakcja" then
		strWhere = replace(strWhere,"eTyp= 2","1=1")
		strWhere = replace(strWhere,"eTyp= 1","1=1")
	end if
#endif

#ifdef ENABLE_DB12
	'pomijaj dostawy przy wyborze transakcji na płatności
	if pObject.type = TYPEID_N5PLATNOSC and strRefFldName = "pTransakcja" then
		if Len(strWhere) > 0 then
			strWhere = strWhere + " and "
		end if
		strWhere = strWhere + "IdObj not in (select pTransakcja from n5sprzedaz where pRejestrDok in (select idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)))"
	end if
#endif	
#ifdef _FRAM
	'pomijaj dostawy przy wyborze transakcji na dowodzie księgowym
	if pObject.type = TYPEID_N5DOWODKSIEG and strRefFldName = "pTransakcja" then
		if Len(strWhere) > 0 then
			strWhere = strWhere + " and "
		end if
		strWhere = strWhere + "IdObj not in (select pTransakcja from n5sprzedaz where pRejestrDok in (select idobj from n5rejestrdok where eTyp in (N5REJESTRDOK_DOSTAWA, N5REJESTRDOK_KOR_DOSTAWA)))"
	end if
#endif	

	dim pM43009 : set pM43009 = doc_.getmodule(43009)
	pM43009.prepare_multi_selection nRefTypeId,strTitle, strWhere,""
	dim oNXArray : set oNXArray = pM43009.run_multi_browser()
	if not oNXArray is nothing then
		dim idChoosenItem
		dim pList : set pList = pObject.field(strLstFldName)
		for each idChoosenItem in oNXArray
			dim pChoosenObj:set pChoosenObj=trans_.getobj(nRefTypeId, idChoosenItem)
			dim pListItemObject
			if pList.exists(nRow) then
				set pListItemObject = pList.get(nRow)
			else
				set pListItemObject = pList.addnew()
			end if
			set pListItemObject.field(nFieldNr) = pChoosenObj
			nRow = nRow + 1
		next
	else
#ifdef _ALMA_TREND
	if pObject.type = TYPEID_N5PLATNOSC and strRefFldName = "pTransakcja" then
		if trans_.isvar(GVAR_ID_TRANS_AT) then
			if trans_.var(GVAR_ID_TRANS_AT) > 0 then
				dim idChooseItem: idChooseItem = trans_.var(GVAR_ID_TRANS_AT)
				dim pChooseObj:set pChooseObj = trans_.getobj(nRefTypeId, idChooseItem)
				dim pLst : set pLst = pObject.field(strLstFldName)
				dim pListItemObj: set pListItemObj = pLst.addnew()
				set pListItemObj.field(nFieldNr) = pChooseObj
				trans_.var(GVAR_ID_TRANS_AT) = -1
			end if
		end if
	end if
#endif
	end if
end function

'std_choice_lst_cq_hli 
'standardowa lista, ale z custom query
#comment 'prop 1 = nazwa pola referencji np. pKlient - wymagane
#comment 'prop 2 = pole po którym szukamy - opcjonalne
#comment 'prop 3 = idEditCtrl - wymagany
#comment 'prop 4 = nazwa pola listy - wymagane
#comment 'prop 5 = nazwa funkcji wypełniającej - opcjonalnie
function std_choice_lst_cq_hli(byref pHLI)
	dim strRefFldName : strRefFldName = pHLI.prop(1)
	dim strMatchField : strMatchField = ""
	if (pHLI.exists(2)) then
		strMatchField = pHLI.prop(2)
	end if
	dim strLstFldName : strLstFldName =  pHLI.prop(4)
	'firing jest picture, następny musi być edit z którego
	'bieżemy pod uwagę wprowadzoną wartość
	dim idFiringCtrl : idFiringCtrl = pHLI.prop(PROPC_CONTROL)
	dim pRealEditCtrl : set pRealEditCtrl = page_.ctrl(idFiringCtrl).nextelement


	dim strFillFun
	if (pHLI.exists(5)) then	
		strFillFun = cstr(pHLI.prop(5))
	else
		strFillFun = ""
	end if


	std_choice_lst_cq page_.root,strLstFldName,clng(pHLI.prop(PROPC_ROW)),strRefFldName,"",strMatchField,pHLI.prop(3),pRealEditCtrl , strFillFun 
end function

#comment 'prop 1 = nazwa pola dzikiej referencji - wymagane
#comment 'prop 2 = ordery dla kazdej z list wyboru (order;order;order)
#comment 'prop 3 = opcjonalne whery (where;where;where)

function std_choice_wildref_hli(hli)
	dim strFldName : strFldName =cstr(hli.prop(1))
	dim strOrders : strOrders =cstr(hli.prop(2))
	dim strWheres : strWheres =cstr(hli.prop(3))

	dim pPageSuggest
	set pPageSuggest=doc_.getmodule(43002)

	dim nObjectId
	nObjectId = pPageSuggest.wildref_choose(page_.root, strFldName, strOrders, strWheres)

	if (nObjectId > 0) then
		set page_.root.field(strFldName) = trans_.getobj(pPageSuggest.getTypeID(), nObjectId)
	end if
end function


#comment Wybór statusu dokumentu na podstawie typu rejestru
#comment 'prop 1 = nazwa pola referencji: pDokStatus
#comment 'prop 2 = pole po którym szukamy: dcs_strNazwa
#comment 'prop 3 = typ rejestru dokumentów
function std_choice_field_status(byref pHLI)
	dim strRefFldName: strRefFldName = pHLI.prop(1)
  
	dim strMatchField: strMatchField = ""
	if (pHLI.exists(2)) then
		strMatchField = pHLI.prop(2)
	end if
  
	dim nTypDok : nTypDok = 0
	if (pHLI.exists(3)) then
		nTypDok = clng(pHLI.prop(3))
	end if
  
	if page_.root is nothing then
		exit function
	end if

	dim pStdObjDef : set pStdObjDef = page_.root.getobjdef()
	dim nFieldNr : nFieldNr = pStdObjDef.getfieldindex(strRefFldName)
	dim nRefTypeId:	nRefTypeId = pStdObjDef.field(nFieldNr).reftypeid

	dim strWhere : strWhere = getWhereStatus(nTypDok)
	
	dim idChoice: idChoice = fire_choice_list(nRefTypeId,"",strMatchField,strWhere,"","")
	
	'gdy podczas wyboru statusu dodamy nowy dla innego typu dok
	if idChoice > 0 then
		dim oRS: set oRS = trans_.createadors("select * from n5dokstatus where " + strWhere + " and idobj = " + CStr(idChoice))
		if oRS.recordCount = 0 then
			idChoice = clng(0)
		end if
	end if
  
	if idChoice > 0 then
		set page_.root.field(nFieldNr) = trans_.getobj(nRefTypeId, idChoice)
	end if
	std_choice_field_status = idChoice  

end function

'----------------------------------------------------------------
'Ustala where dla statusu dokumentu w zależności od typu rejestru
'----------------------------------------------------------------
function getWhereStatus(nTypDok) : getWhereStatus = ""
  if nTypDok > clng(0) then
    dim idPos : idPos = 0
    select case nTypDok
      case N5REJESTRDOK_FAKT_SP,N5REJESTRDOK_RACH,N5REJESTRDOK_PARAGON,N5REJESTRDOK_WDT,N5REJESTRDOK_FAKT_EXP,N5REJESTRDOK_FAKTURA_ZALICZKOWA,N5REJESTRDOK_DOSTAWA  'sprzedaż
        idPos = 1
      case N5REJESTRDOK_KOR_FAKT_SP,N5REJESTRDOK_KOR_RACH,N5REJESTRDOK_KOR_PARAGON,N5REJESTRDOK_KOREKTA_WDT,N5REJESTRDOK_KOR_FAKT_EXP,N5REJESTRDOK_FAKTURA_ZALICZKOWA_KOR,N5REJESTRDOK_KOR_DOSTAWA  'korekta sprzedaży
        idPos = 2
      case N5REJESTRDOK_FAKT_ZAK,N5REJESTRDOK_FAKT_ZAK_RR,N5REJESTRDOK_WNT,N5REJESTRDOK_FAKT_IMP  'zakup
        idPos = 3
      case N5REJESTRDOK_KOR_FAKT_ZAK,N5REJESTRDOK_KOR_FAKT_ZAK_RR,N5REJESTRDOK_KOREKTA_WNT,N5REJESTRDOK_KOR_FAKT_IMP  'korekta zakupu
        idPos = 4
      case N5REJESTRDOK_ZAP_OFERTOWE_OBCE  'zapytanie ofertowe obce
        idPos = 5
      case N5REJESTRDOK_ZAP_OFERTOWE_WLASNE  'zapytanie ofertowe własne
        idPos = 6
      case N5REJESTRDOK_OFERTY_OBCE  'oferta obca
        idPos = 7
      case N5REJESTRDOK_OFERTY_WLASNE  'oferta własna
        idPos = 8
      case N5REJESTRDOK__ZAM_OBCE  'zamowienie obce
        idPos = 9
      case N5REJESTRDOK__ZAM_WLASNE 'zamowienie własne   
        idPos = 10
      case N5REJESTRDOK__PZ
        idPos = 11
      case N5REJESTRDOK__WZ
        idPos = 12
      case N5REJESTRDOK__MM
        idPos = 13
      case N5REJESTRDOK__MR  'MM-
        idPos = 14
      case N5REJESTRDOK__MP  'MM+
        idPos = 15
      case N5REJESTRDOK__RW
        idPos = 16
      case N5REJESTRDOK__PW
        idPos = 17
      case N5REJESTRDOK__IR
        idPos = 18
      case N5REJESTRDOK__IP
        idPos = 19
      case N5REJESTRDOK__RP
        idPos = 20
      case N5REJESTRDOK__PP
        idPos = 21
      case N5REJESTRDOK__REALPROD  'realizacja produkcji
        idPos = 22
      case N5REJESTRDOK_KASOWY,N5REJESTRDOK_BANKOWY  'wpłata/wypłata
        idPos = 23
		getWhereStatus = "substring(dcs_strTypDok," + CStr(idPos) + ",1) = '1' or substring(dcs_strTypDok," + CStr(idPos+1) + ",1) = '1'"
        exit function
      case N5REJESTRDOK_ZADANIA  'zadanie
        idPos = 25        
    end select
    getWhereStatus = "substring(dcs_strTypDok," + CStr(idPos) + ",1) = '1'"
  end if
end function

