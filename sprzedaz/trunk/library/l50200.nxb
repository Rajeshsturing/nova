#macro QVE_REF_OPEN_FORM(_ctrl_,_field_)	\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true \
	with page_.ctrl(_ctrl_)												\
		if page_.root.field("_field_") is nothing then					\
			set .hli = nothing											\
			.tip=""														\ 
		else															\
			set .hli = doc_.createhlistr("varFunctionHLI='std_openform_field_hli' vs1='_field_'")	\
			.tip="Pokaż szczegóły"										\ 
		end if	\
	end with	\
end function

#macro QVE_RTEXT_MONEY(_ctrl_,_fld_)	\
function c##_ctrl_##_ongetdata(byref pCtrl) : c##_ctrl_##_ongetdata = true	\
	pCtrl.text = doc_.afc.display.money(page_.root._fld_,"")				\
end function							\

#macro QVE_NRDOK_FROM_REJESTR(_ctrl_,_pRej_field_,_strNrDok_field_)		\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true \
	with page_.ctrl(_ctrl_)												\
		dim strFN : strFN = page_.root._pRej_field_.strFormatNumeracji	\
		if strFN = "" or left(strFN,1) = "|" then						\
			.disable = false											\
			.value = page_.root._strNrDok_field_						\
			.tip = "Wprowadź numer dokumentu"							\
		else															\
			.disable = true												\
			if page_.root._strNrDok_field_ = "" then					\
				.value = AUTONO_NAME									\
				.tip = "Numer zostanie nadany automatycznie"			\
			else														\
				.value = page_.root._strNrDok_field_					\
				.tip = ""												\
			end if														\
		end if															\
	end with															\
end function															\
function c##_ctrl_##_ondataentered(ctrl, value)							\
	c##_ctrl_##_ondataentered=true										\
	page_.root._strNrDok_field_ = CStr(value)							\
end function



#macro QVE_CURRENCY_CUSTOM_PRICE(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
	QVE_CURRENCY_CUSTOM_PRICE_GETDATA(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
	QVE_CURRENCY_CUSTOM_PRICE_DATAENTER(_ctrl_,_pObjectField_,_factor_)


#macro QVE_CURRENCY_CUSTOM_PRICE_DISABLE(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
	QVE_CURRENCY_CUSTOM_PRICE_GETDATA_DISABLE(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
	QVE_CURRENCY_CUSTOM_PRICE_DATAENTER(_ctrl_,_pObjectField_,_factor_)	




#macro QVE_CURRENCY_CUSTOM_PRICE_GETDATA(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true \
	pCtrl.value = (_factor_) * _pObjectField_							\
	if not _pWalutaField2_ is nothing then								\
		pCtrl.unit = _pWalutaField2_.strSkrot							\
	else																\
		pCtrl.unit = ""													\
	end if																\
end function

#macro QVE_CURRENCY_CUSTOM_PRICE_GETDATA_DISABLE(_ctrl_,_pObjectField_,_pWalutaField2_,_factor_)		\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true \
	pCtrl.value = (_factor_) * _pObjectField_							\
	if not _pWalutaField2_ is nothing then								\
		pCtrl.unit = _pWalutaField2_.strSkrot							\
	else																\
		pCtrl.unit = ""													\
	end if																\
	pCtrl.disable = true												\
end function


#macro QVE_CURRENCY_CUSTOM_PRICE_GETDATA_AUTOCALC_MODE_DISABLE(_ctrl_,_pObjectField_,_cAutoCalcField_,_pWalutaField2_,_factor_,_nvb_,_vatmode_)		\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true \
	'aaaa \
	dim bAutoCalc:bAutoCalc = _cAutoCalcField_ = "1"					\
	dim bNetto:bNetto = _nvb_ = 1										\
	dim bBrutto:bBrutto = _nvb_ = 2										\
	dim bVat:bVat = _nvb_ = 3											\	
	if not bAutoCalc then	\
		pCtrl.disable = false	\
	else	\
		pCtrl.disable = (bVat) or (bNetto and (_vatmode_ = N5SPRZEDAZ_BRUTTO) or (bBrutto and (_vatmode_ = N5SPRZEDAZ_NETTO)))								\
	end if	\
	pCtrl.value = (_factor_) * _pObjectField_							\
	if not _pWalutaField2_ is nothing then								\
		pCtrl.unit = _pWalutaField2_.strSkrot							\
	else																\
		pCtrl.unit = ""													\
	end if																\
end function


#macro QVE_CURRENCY_CUSTOM_PRICE_DATAENTER(_ctrl_,_pObjectField_,_factor_)		\
function c##_ctrl_##_ondataentered(byref pCtrl, varValue) :	c##_ctrl_##_ondataentered=true	\
	_pObjectField_ = (_factor_) * varValue							\
end function															




#macro SVE_CURRENCY_CUSTOM_PRICE(_ctrl_,_pListField_,_pObjectField_,_pWalutaField2_,_factor_,_prec_)	\
	SVE_CURRENCY_CUSTOM_PRICE_GETDATA(_ctrl_,_pListField_,_pObjectField_,_pWalutaField2_,_factor_,_prec_)	\
	SVE_CURRENCY_CUSTOM_PRICE_DATAENTER(_ctrl_,_pListField_,_pObjectField_,_factor_)


#macro SVE_CURRENCY_CUSTOM_PRICE_GETDATA(_ctrl_,_pListField_,_pObjectField_,_pWalutaField2_,_factor_,_prec_)	\
function c##_ctrl_##_ongetdata(byref pCtrl,nRow): c##_ctrl_##_ongetdata=true				\
	pCtrl.precision = clng(_prec_) 															\
	if _pListField_.exists(nRow) then														\
		pCtrl.value = (_factor_) * _pListField_.get(nRow)._pObjectField_					\
	else																					\
		pCtrl.value = ccur(0.0)	\
		exit function																\
	end if																					\
	if not _pWalutaField2_ is nothing then													\
		pCtrl.unit = _pWalutaField2_.strSkrot												\
	else																					\
		pCtrl.unit = ""																		\		
	end if																					\
											\
end function


#macro SVE_CURRENCY_CUSTOM_PRICE_GETDATA_AUTOCALC_DISABLE(_ctrl_,_pListField_,_pObjectField_,_cAutoCalcField_,_pWalutaField2_)	\
function c##_ctrl_##_ongetdata(pCtrl,row): c##_ctrl_##_ongetdata = true															\	
	pCtrl.precision = clng(2)'#*gvar_price_prec																							\
	pCtrl.disable = _cAutoCalcField_ = "1"																						\
	if _pListField_.exists(row) then																							\	
		dim pElement:set pElement = _pListField_.get(row)																		\	
		if not pElement is nothing then																							\
			pCtrl.value = ccur(pElement._pObjectField_)																			\
			exit function																										\
		end if																													\
	end if																														\
	if not 	_pWalutaField2_ is nothing then																						\
		pCtrl.unit = _pWalutaField2_.strSkrot 																					\				
	else																														\
		pCtrl.unit = ""																											\
	end if																														\		
	pCtrl.value = CCur(0.0)																										\
end function



#macro SVE_CURRENCY_CUSTOM_PRICE_DATAENTER(_ctrl_,_pListField_,_pObjectField_,_factor_)	\
function c##_ctrl_##_ondataentered(byref pCtrl,nRow,varValue) :	c##_ctrl_##_ondataentered=true	\
	dim pPozObject																			\
	if _pListField_.exists(nRow) then														\
		set pPozObject = _pListField_.get(nRow)												\
	else																					\
		set pPozObject = _pListField_.addnew()												\
	end if																					\
	pPozObject._pObjectField_ = ccur((_factor_) * varValue)									\
end function











#macro SVE_CENY_NETTO_BRUTTO_TRANSFER(_ctrlid_,_fldnetto_,_fldbrutto_,_prec_,_pWaluta_)	\
function c##_ctrlid_##_ongetdata(pCtrl,row): c##_ctrlid_##_ongetdata = true		\
	pCtrl.precision = clng(_prec_)												\
	if not _pWaluta_ is nothing then	\
		pCtrl.unit = (_pWaluta_).strSkrot \
	else								\
	pCtrl.unit = ""																\
	end if	\
	if page_.root.listPozycje.exists(row) then									\															
		dim pElement:set pElement = page_.root.listPozycje.get(row)				\															
		if not pElement is nothing then											\
			if page_.root.eNettoBrutto = N5SPRZEDAZ_NETTO then					\																	
				pCtrl.value = ccur(pElement._fldnetto_)							\
			else																\
				pCtrl.value = ccur(pElement._fldbrutto_)						\
			end if																\
			exit function														\												
		end if																	\												
	end if																		\												
	pCtrl.value = CCur(0.0)														\												
end function																	\
function c##_ctrlid_##_ondataentered(byref pCtrl,nRow,varValue) :	c##_ctrlid_##_ondataentered=true	\
	dim pPozObject																\
	dim strFldName																\														
	if page_.root.eNettoBrutto = N5SPRZEDAZ_NETTO then							\
		strFldName = "_fldnetto_"												\
	else																		\
		strFldName = "_fldbrutto_"												\
	end if																		\
																				\
	if page_.root.listPozycje.exists(nRow) then									\					
		set pPozObject = page_.root.listPozycje.get(nRow)						\						
	else																		\			
		set pPozObject = page_.root.listPozycje.addnew()						\						
	end if																		\			
	pPozObject.field(strFldName) = varValue										\	
end function









#macro QVE_CURRENCY_CUSTOM_QUANTITY(_ctrl_,_pObjectField_,_pObjectJedn_,_pJednField_,_factor_)	\
function c##_ctrl_##_ongetdata(byref pCtrl): c##_ctrl_##_ongetdata=true		\
	pCtrl.value = _pObjectField_											\
	if not _pObjectJedn_ is nothing then									\
		if not _pObjectJedn_._pJednField_ is nothing then					\
			pCtrl.precision = _pObjectJedn_._pJednField_.nDokladnosc - 1	\
			pCtrl.unit = _pObjectJedn_._pJednField_.strSkrot				\
			exit function													\
		end if																\	
	end if																	\	
	pCtrl.precision = 0														\
	pCtrl.unit = ""															\
end function																\
function c##_ctrl_##_ondataentered(byref pCtrl, byval newValue)				\
	_pObjectField_ = newValue												\
	c##_ctrl_##_ondataentered=true											\
end function




#macro QVX_SUGGQUERY_TRANSAKCJA(_ctrl_,_pFullPodmiotField_)					\
function c##_ctrl_##_onsuggquery(byref pEditCtrl,byval strEnteredVal,byref strWhere,byref strOrder,byref strJoin)	\
	if not _pFullPodmiotField_ is nothing then																		\
		if strWhere <> "" then																						\
			strWhere = strWhere + " and "																			\
		end if																										\
		strWhere = strWhere + doc_.afc.convert.formatter("(wrefPodmiot_wrt=%1) and (wrefPodmiot=%2)") _				\
			.add(cstr(_pFullPodmiotField_.type)).add(cstr(_pFullPodmiotField_.idobj)).done()						\
	end if																											\
end function




#macro QVX_SUGGQUERY_DUMMY(_ctrl_) \
function c##_ctrl_##_onsuggquery(byref pEditCtrl,byval strEnteredVal,byref strWhere,byref strOrder,byref strJoin)	\
end function

#ifdef ENABLE_DB11
#macro QVX_SUGGQUERY_DOKHANDL(_ctrl_,_pFullKlientField_,_rejtype_,_klientfld_,_strExtraWhere_,_elsewhere_)						\
function c##_ctrl_##_onsuggquery(byref pEditCtrl,byval strEnteredVal,byref strWhere,byref strOrder,byref strJoin)	\
	if not _pFullKlientField_ is nothing then																		\
		if strWhere <> "" then																						\
			strWhere = strWhere + " and "																			\
		end if																										\
		trans_.var(GVAR_CURRENT_REJESTR_TYP) = cstr(_rejtype_)														\
		strWhere = strWhere + doc_.afc.convert.formatter("( _klientfld_ =%1) and (pRejestrDok in (select idobj from n5rejestrdok where eTyp in (%2))) ") _				\
			.add(cstr(_pFullKlientField_.idobj)).add(cstr(_rejtype_)).done()						\
		if _strExtraWhere_ <> "" then	\
			strWhere = strWhere + " and " + _strExtraWhere_	\
		end if	\
	else				\
		strWhere = _elsewhere_	\	
	end if					\
	DEBUG_MESSAGE("c##_ctrl_##_onsuggquery: " + strWhere)															\
end function
#else
#macro QVX_SUGGQUERY_DOKHANDL(_ctrl_,_pFullKlientField_,_rejtype_,_klientfld_,_strExtraWhere_,_elsewhere_)						\
function c##_ctrl_##_onsuggquery(byref pEditCtrl,byval strEnteredVal,byref strWhere,byref strOrder,byref strJoin)	\
	if not _pFullKlientField_ is nothing then																		\
		if strWhere <> "" then																						\
			strWhere = strWhere + " and "																			\
		end if																										\
		strWhere = strWhere + doc_.afc.convert.formatter("( _klientfld_ =%1) and (pRejestrDok in (select idobj from n5rejestrdok where eTyp in (%2))) ") _				\
			.add(cstr(_pFullKlientField_.idobj)).add(cstr(_rejtype_)).done()						\
		if _strExtraWhere_ <> "" then	\
			strWhere = strWhere + " and " + _strExtraWhere_	\
		end if	\
	else				\
		strWhere = _elsewhere_	\	
	end if					\
	DEBUG_MESSAGE("c##_ctrl_##_onsuggquery: " + strWhere)															\
end function
#endif


