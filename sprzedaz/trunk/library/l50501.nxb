<HTML>

<HEAD>
	<META HTTP-EQUIV="Content-type" CONTENT="text/html; charset=windows-1250">
	<TITLE>Wizytówka</TITLE>
</HEAD>

<STYLE>
<!--

.body	{
			font-family: Verdana, Tahoma, Arial, sans-serif;
			font-size: medium;
		}

.odstep	{
			background: #CFCFCF;
			height: 2px;
		}

.naglowek	{
				font-size: medium;
				text-align: center;
				border: 1px outset;
				background: #CFCFCF;
			}

.naglowekmaly	{
				font-size: small;
				text-align: center;
				font-style: italic;
				}

A	{
		text-decoration: none;
	}
TH	{
		font-family: Verdana, Tahoma, Arial, sans-serif;
		text-align: left;
		font-size: x-small;
	}

TD	{
		font-family: Verdana, Tahoma, Arial, sans-serif;
		font-size: x-small;
		text-align: right;
	}

TABLE	{
			border: 2px outset;
			background: #F7F7F7;
		}

-->
</STYLE>

<BODY CLASS="body">

<SCRIPT language=JavaScript event=onload for=window>
      start();      
	var x=12;
</SCRIPT>

<SCRIPT ID=clientEventHandlersVBS LANGUAGE=vbscript>
Sub button1_onclick

	dim str,fileName,command,error
	
	str = document.all("neipckg").innerHTML
	'dim doc
	dim application
	on error resume next
	set application = createobject("navo2002.client")
	select case Err.Number
		case 0:
			on error resume next
			fileName = application.document.system.createtempfilename("x","xml")
			select case err.Number
				case 0:
					dim pSXML
					on error resume next
					set pSXML = application.document.createstreamobj()
					select case err.number'todo - rozpoznawanie bledow
						case 0:
							pSXML.write "<?xml version=""1.0"" encoding=""windows-1250""?>"
							pSXML.write str
							pSXML.save fileName
							on error resume next
							application.document.postcommand("vn1001=1030 vn1002=70004 vs3034='" + fileName + "' vs8003='NAVO Kontakt 2002'")
							select case err.number
								case 0:
									set application = nothing
								case else									
									msgbox "Aplikacja jest zainstalowana niepoprawnie - Opis bledu: " + err.description
									err.clear
									exit sub
							end select
						case else
							msgbox "Aplikacja jest zainstalowana niepoprawnie  - Opis bledu: " + err.description
							err.clear
							exit sub
					end select
				case else					
					msgbox "Aplikacja jest zainstalowana niepoprawnie - Opis bledu: " + err.description
					err.clear
					exit sub
			end select			
		case else
			msgbox "Na Twoim komputerze nie ma zainstalowanego programu ""NAVO Kontakt 2002"" ... A to taka fajowa aplikacja :-) NAPRAWDĘ!!!  - Opis bledu: " + err.description
			err.clear
			exit sub
	end select

End Sub
</SCRIPT>

<SCRIPT language=JavaScript>
      function start()
        {				
			var bInTable=false;
			var strInnerPrac="";
			var strInnerFirma="";
			
			strInnerFirma += "<table CELLPADDING=4 CELLSPACING=0 ALIGN=CENTER><tbody>"+
				"<TR>"+
				"<TH ROWSPAN=27 WIDTH=4></TH>"+
				"<TH COLSPAN=2 CLASS=naglowek>WIZYTÓWKA FIRMY</TH>"+
				"<TH ROWSPAN=27 WIDTH=4></TH>"+
				"</TR>";

			var strWoj,strMiejsc,strWaluta,strFirmData
			var strBank1,strBank2,strBank3,id1,id2,id3,bIsB1,bIsB2,bIsB3
			bIsB1=false;//ktore banki sa wypelnione
			bIsB2=false;
			bIsB3=false;
			strBank1=""
			strBank2=""
			strBank3=""
			var rootElem = neipckg.documentElement;
			var childNode = rootElem.firstChild;
			var count1 = childNode.childNodes.length;			
			for (cl=0; cl<count1; cl++)
			{
				currNode = childNode.childNodes.item(cl)
				currNodeChild = currNode.childNodes.item(0)
				
				if (currNodeChild.text=="10100")	strWoj = currNode.childNodes.item(2).text;
				if (currNodeChild.text=="10111")	strMiejsc = currNode.childNodes.item(4).text;
				if (currNodeChild.text=="10102")	strWaluta = currNode.childNodes.item(5).text;
				if (currNodeChild.text=="10104")	
				{	if (strBank1=="")
					{	strBank1 = currNode.childNodes.item(14).text;
						id1 = currNode.childNodes.item(1).text;
						bIsB1=true;
					}
					else if (strBank2=="")
					{	strBank2 = currNode.childNodes.item(14).text
						id2 = currNode.childNodes.item(1).text
						bIsB2=true;
					}
					else
					{	strBank3 = currNode.childNodes.item(14).text
						id3 = currNode.childNodes.item(1).text
						bIsB3=true;
					}	
				}
				
				if (currNodeChild.text=="10108")
				{
					//kod HTML odstęp
					var strOdstep = "<TR CLASS=odstep><TD COLSPAN=2></TD></TR>"
					
					//kod HTML adresu
					var strAdr = "ul." + currNode.selectSingleNode("fstrulica").text + " " +currNode.selectSingleNode("fstrnrdomu").text;
					if (currNode.selectSingleNode("fstrnrlokalu").text!= "")
					{	strAdr = strAdr + "/" + currNode.selectSingleNode("fstrnrlokalu").text + ", " + currNode.selectSingleNode("fstrkod").text + " " + strMiejsc;
					}
					else
					{	strAdr = strAdr + ", " + currNode.selectSingleNode("fstrkod").text + " " + strMiejsc
					}
					
					strInnerFirma += "<tr><th>Nazwa</th><td><i>"+currNode.selectSingleNode("fstrnazwa").text+"</i></td></tr>";
					strInnerFirma += "<tr><th>Skrót nazwy</th><td><i>"+currNode.selectSingleNode("fstrindeks").text+"</i></td></tr>";
					strInnerFirma += "<tr><th>Adres</th><td><i>"+strAdr+"</i></td></tr>";
					strInnerFirma += strOdstep
					strInnerFirma += "<tr><th>Numer telefonu 1</th><td><i>"+currNode.selectSingleNode("fstrtel1").text+"</i></td></tr>";
					strInnerFirma += "<tr><th>Numer telefonu 2</th><td><i>"+currNode.selectSingleNode("fstrtel2").text+"</i></td></tr>";
					strInnerFirma += "<tr><th>Numer telefonu 3</th><td><i>"+currNode.selectSingleNode("fstrtel3").text+"</i></td></tr>";
					strInnerFirma += strOdstep
					strInnerFirma += "<tr><th>Adres e-mail</th><td><i><a href=mailto:" + currNode.selectSingleNode("fstremail").text + ">" + currNode.selectSingleNode("fstremail").text + "</a></i></td></tr>";
					strInnerFirma += "<tr><th>Strona WWW</th><td><i><a href=&quot;" + currNode.selectSingleNode("fstrwww").text + "&quot;>" + currNode.selectSingleNode("fstrwww").text +"</a></i></td></tr>";
					strInnerFirma += strOdstep
					strInnerFirma += "<tr><th>NIP</th><td><i>"+currNode.selectSingleNode("fstrnip").text+"</i></td></tr>";
					strInnerFirma += strOdstep
					strInnerFirma += "<tr><th>Nazwa waluty</th><td><i>"+strWaluta+"</i></td></tr>";
					strInnerFirma += strOdstep
					if (currNode.selectSingleNode("fpbank1").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank1").text)
						{	case id1:
							{	strInnerFirma += "<tr><th>Bank 1</th><td><i>"+strBank1+"</i></td></tr>";								
								break;
							}
							case id2:
							{	strInnerFirma += "<tr><th>Bank 1</th><td><i>"+strBank2+"</i></td></tr>";								
								break;
							}
							case id3:
							{	strInnerFirma += "<tr><th>Bank 1</th><td><i>"+strBank3+"</i></td></tr>";								
								break;
							}
						}
						strInnerFirma += "<tr><th>Numer rachunku bankowego 1</th><td><i>"+currNode.selectSingleNode("fstrrachunek1").text+"</i></td></tr>";
						strInnerFirma += "<tr><th>Przeznaczenie rachunku 1</th><td><i>"+currNode.selectSingleNode("fstrprzeznaczenie1").text+"</i></td></tr>";
						strInnerFirma += strOdstep
						
					}
					if (currNode.selectSingleNode("fpbank2").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank2").text)
						{	case id1:
							{	strInnerFirma += "<tr><th>Bank 2</th><td><i>"+strBank1+"</i></td></tr>";								
								break;
							}
							case id2:
							{	strInnerFirma += "<tr><th>Bank 2</th><td><i>"+strBank2+"</i></td></tr>";								
								break;
							}
							case id3:
							{	strInnerFirma += "<tr><th>Bank 2</th><td><i>"+strBank3+"</i></td></tr>";								
								break;
							}
						}
						strInnerFirma += "<tr><th>Numer rachunku bankowego 2</th><td><i>"+currNode.selectSingleNode("fstrrachunek2").text+"</i></td></tr>";
						strInnerFirma += "<tr><th>Przeznaczenie rachunku 2</th><td><i>"+currNode.selectSingleNode("fstrprzeznaczenie2").text+"</i></td></tr>";
						strInnerFirma += strOdstep
						
					}
					if (currNode.selectSingleNode("fpbank3").text!="0") //wypelnione pole bank 1
					{	
						switch(currNode.selectSingleNode("fpbank3").text)
						{	case id1:
							{	strInnerFirma += "<tr><th>Bank 3</th><td><i>"+strBank1+"</i></td></tr>";								
								break;
							}
							case id2:
							{	strInnerFirma += "<tr><th>Bank 3</th><td><i>"+strBank2+"</i></td></tr>";								
								break;
							}
							case id3:
							{	strInnerFirma += "<tr><th>Bank 3</th><td><i>"+strBank3+"</i></td></tr>";								
								break;
							}
						}
						strInnerFirma += "<tr><th>Numer rachunku bankowego 3</th><td><i>"+currNode.selectSingleNode("fstrrachunek3").text+"</i></td></tr>";
						strInnerFirma += "<tr><th>Przeznaczenie rachunku 3</th><td><i>"+currNode.selectSingleNode("fstrprzeznaczenie3").text+"</i></td></tr>";
						
					}									
				}

				if (currNodeChild.text=="10112")
				{	

					if (!bInTable)
					{
						strInnerPrac +=	"<table CELLPADDING=4 CELLSPACING=0 ALIGN=CENTER>" +
						"<TR>" +
							"<TH COLSPAN=2 CLASS=naglowek>PRACOWNICY</TH>" +
						"</TR>";

						bInTable=true;
					}

					strInnerPrac +=	
					"<TR>"+
						"<TD COLSPAN=2 CLASS=naglowekmaly>" +
					currNode.selectSingleNode("fstrnazwisko").text + " " + currNode.selectSingleNode("fstrimie").text +
					"</TD>"+
					"</TR>" +
	
					"<TR>" +
						"<TH>Stanowisko</TH>" +
						"<TD>" + currNode.selectSingleNode("fstrstanowisko").text + "</TD>" +
					"</TR>" +

					"<TR>" +
						"<TH>Numer faksu</TH>" +
						"<TD>" + currNode.selectSingleNode("fstrfax").text + "</TD>" +
					"</TR>" +

					"<TR>" +
						"<TH>Telefon slużbowy</TH>" +
						"<TD>" + currNode.selectSingleNode("fstrtel1").text + "</TD>" +
					"</TR>" +

					"<TR>" +
						"<TH>Telefon slużbowy komórkowy</TH>" +
						"<TD>" + currNode.selectSingleNode("fstrtel2").text + "</TD>" +
					"</TR>" +

					"<TR>" +
						"<TH>Adres e-mail</TH>" +
						"<TD><a href=mailto:" + currNode.selectSingleNode("fstremail").text + ">" + currNode.selectSingleNode("fstremail").text + "</a></TD>" +
					"</TR>" +

					"<TR>" +
						"<TH>Strona WWW</TH>" +
						"<TD><a href=&quot;" + currNode.selectSingleNode("fstrwww").text + ">" + currNode.selectSingleNode("fstrwww").text + "</a></TD>" +
					"</TR>" +

					"<TR CLASS=odstep><TD COLSPAN=2></TD></TR>";
					

				}	
				
			}

			if (bInTable)
			{
				strInnerPrac+="</table>";
			}
			
			strInnerFirma += "</tbody></table>";
			strFirma.innerHTML = strInnerFirma;
			strPracownicy.innerHTML=strInnerPrac;
			
		}
</SCRIPT>





<XML id="neipckg" version="1.0" encoding="windows-1250">
%%XMLFROMNE%%
</XML>


<p id="strFirma">
</p>

<P></P>

<p id="strPracownicy">
</p>

<INPUT  id=BTN2 type=button value="Importuj dane" title="Wcisnij jesli chcesz importowac dane znajdujace sie na wizytowce">

</BODY>
</HTML>