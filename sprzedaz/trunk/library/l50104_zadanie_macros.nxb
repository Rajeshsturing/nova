#ifndef LIBRARY_50104
#define LIBRARY_50104

#comment -- klocki do formularzy zadań

'EventStatus
#include "50608"

#macro QVX_ZADANIE_ZLECAJACY(_ctrl_)	QVE_REF_OPEN_FORM(_ctrl_,pZlecajacy)
#macro QVX_ZADANIE_WYKONAWCA(_ctrl_)	QVE_REF_OPEN_FORM(_ctrl_,pWykonawca)
#macro QVX_ZADANIE_KLIENT(_ctrl_)		QVE_REF_OPEN_FORM(_ctrl_,pKlient)
#macro QVX_ZADANIE_KLIENT_PRAC(_ctrl_)	QVE_REF_OPEN_FORM(_ctrl_,pKlientPracownik)

#macro QVX_ZADANIE_POPNAD_ZADANIE(_pop_ctrl_,_nad_ctrl_)														\
	dim g_pPlugTaskTreeFactory : set g_pPlugTaskTreeFactory = nothing											\
	sub show_hide_popnad_zadanie_row																			\
		set g_pPlugTaskTreeFactory = doc_.getmodule(60161)														\
		g_pPlugTaskTreeFactory.plug_dzialania_powiazane_tree g_pTSRS,page_.ctrl(_pop_ctrl_),page_.root.idobj	\
	end sub


#macro QVX_ZADANIE_INFO_PIC(_pic_ctrl_)												\
function c##_pic_ctrl_##_ongetdata(byref oCtrl): c##_pic_ctrl_##_ongetdata=true		\
	oCtrl.image = EventStatus2PicNum(page_.root.nStatus)							\
end function

#macro QVX_ZADANIE_INFO_TEXT(_txt_ctrl_)											\
function c##_txt_ctrl_##_ongetdata(byref oCtrl): c##_txt_ctrl_##_ongetdata=true		\
	dim strText																		\
	if page_.root.pTypDzialania is nothing then										\
		strText = ""																\
	else																			\
		strText = "   Typ: "+ page_.root.pTypDzialania.strNazwa + "      "			\
	end if																			\
	strText = strText + "Priorytet: " + page_.root.n5zadanie_getPriorityName()		\
	oCtrl.text = strText															\
end function


#macro QVX_ZADANIE_SECURITY(_ctrl_)													\
dim g_lastidobj##_ctrl_ : g_lastidobj##_ctrl_ = 0									\
function c##_ctrl_##_ongetdata(byref oCtrl): c##_ctrl_##_ongetdata=true				\
	if page_.root.idobj <> g_lastidobj##_ctrl_ then									\
		on_root_changed																\
		g_lastidobj##_ctrl_ = page_.root.idobj										\
	end if																			\
	oCtrl.value=cstr(page_.root.nIsSecurity)										\
	update_controls																	\
end function																		\
function c##_ctrl_##_ondataentered(byref oCtrl, byval newValue): c##_ctrl_##_ondataentered=true	\
	page_.root.nIsSecurity = clng(newValue)											\
end function

#macro QVX_ZADANIE_POWIADOM(_ctrl_)													\
dim g_cNotify##_ctrl_ : g_cNotify##_ctrl_ = "1"										\
function c##_ctrl_##_ongetdata(byref oCtrl) : c##_ctrl_##_ongetdata = true			\
	oCtrl.value = g_cNotify##_ctrl_													\
end function																		\
function c##_ctrl_##_ondataentered(byref oCtrl, byval newValue): c##_ctrl_##_ondataentered=true		\
	g_cNotify##_ctrl_ = newValue													\
end function

#define QVX_ZADANIE_KONTYNUACJA														\
function zadanie_kontynuacja														\
	dim idCustomer : idCustomer = 0													\
	if not page_.root.pKlient is nothing then										\
		idCustomer = page_.root.pKlient.idobj										\
	end if																			\
	doc_.postcommand "OPEN_FORM_PROXY_HLI(TYPEID_N5ZADANIE,0) " +_					\
		"appvar_zadanie_powiazanie=AV_ZAD_POW_KONTYN appvar_zadanie_powiazanie_idobj=" + cstr(page_.root.idobj)	+_ \
		" gvar_current_customer=" + cstr(idCustomer)								\
end function

#define QVX_ZADANIE_PODZADANIE														\
function zadanie_podzadanie														\
	dim idCustomer : idCustomer = 0													\
	if not page_.root.pKlient is nothing then										\
		idCustomer = page_.root.pKlient.idobj										\
	end if																			\
	doc_.postcommand "OPEN_FORM_PROXY_HLI(TYPEID_N5ZADANIE,0) " +_					\
		"appvar_zadanie_powiazanie=AV_ZAD_POW_PODZAD appvar_zadanie_powiazanie_idobj=" + cstr(page_.root.idobj)	+_ \
		" gvar_current_customer=" + cstr(idCustomer)								\
end function

#define QVX_ZADANIE_COMMON_ACTION													\	
function zadanie_common(byval nNewStatus,byval strNotifyText,byref pNotifyWho)		\
	page_.root.nStatus=clng(nNewStatus)												\
	page_.root.n5zadanie_auto_change_status()										\
	if not std_fsave() then																\
		exit function																\
	end if																			\
	if g_cNotify##CTRLID_POWIADOM = "1" then										\
		dim pModule : set pModule = doc_.getmodule(60158)							\
		pModule.notify_wykonawca_about_zadanie strNotifyText,pNotifyWho,page_.root	\
	end if	\
	section_fsave THIS_FILE																			\
	page_.goback																	\
end function


