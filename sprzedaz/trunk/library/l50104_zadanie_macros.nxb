#macro QXX_ZADANIE_ZALACZNIKI(_sec_ctrl_,_pic_ctrl_)			\
	QXS_BEGIN_FLAT(_sec_ctrl_,Załączniki,FORM_SPAN)				\
		<tr>													\
			<td colspan='FORM_SPAN'>							\
				<grid style='STYLE_TABLE'>						\
					<transfer mode='grid_list'>					\
						<field>listZalaczniki</field>			\
					</transfer>									\
					<thead>										\
						<tr style='STYLE_DESC_ROW'>				\
							<td width='max'>					\
								QXE_LABEL(Załączniki)			\
							</td>								\
						</tr>									\
					</thead>									\
					<tbody>										\
						<tr style='STYLE_TABLE_BODY'>			\
							XG_WREF_CELL(PICTURE_CHOICE_N5ZADANIEZAL,_pic_ctrl_,40,listZalaczniki,wrefZal,strTematDokum;strTemat,false)	\
						</tr>									\
					</tbody>									\
				</grid>											\
			</td>												\
		</tr>													\
	QXS_END_FLAT(FORM_SPAN)										\

#macro QXX_ZADANIE_ROLE(_sec_ctrl_)			\
