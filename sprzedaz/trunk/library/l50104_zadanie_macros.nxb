					<transfer mode='grid_list'>					\
						<field>zad_listRole</field>			\
					</transfer>									\
					<thead>										\
						<tr style='STYLE_DESC_ROW'>				\
							<td width='max'>					\
								QXE_LABEL(Rola)			\
							</td>								\
							<td width='max'>					\
								QXE_LABEL(Priorytet)			\
							</td>								\
						</tr>									\
					</thead>									\
					<tbody>										\
						<tr style='STYLE_TABLE_BODY'>			\
							SXC_EDIT_REF(-1,40,PICTURE_CHOICE_N5DOKUMENT,zad_listRole,zadr_pRola,rola_strNazwa,CRSR_DEFAULT) \
							SXC_EDIT_REF(-1,10,PICTURE_CHOICE_N5DOKUMENT,zad_listRole,zadr_pRolaPrior,rolap_strNazwa,CRSR_DEFAULT) \
						</tr>									\
					</tbody>									\
				</grid>											\
			</td>												\
		</tr>													\
	QXS_END_OPT(FORM_SPAN)										\

