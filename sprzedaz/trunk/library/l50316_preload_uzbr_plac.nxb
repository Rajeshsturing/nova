			<fnpriorytet vt='3'>120</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[.section 8
.level 0
.subtitle 0,"Urlop " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
dim nMinUW : nMinUW = .calendar.min_rob_plan(.document.ddataod,.document.ddatado)
.var("$hrurw") = clng(-Int(-nMinUW/60))
.edit_var 2,"Godziny urlopu", "$hrurw", "h", 2
.store_entry "HRURW", .var("$hrurw"), "Urlop od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.store_entry "HPON", - .var("$hrurw"), "Urlop od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.var("HPON") = .var("HPON") - .var("$hrurw")

.var("$drurw") = .calendar.dni_rob_plan(.document.ddataod,.document.ddatado)
.edit_var 4,"Dni urlopu","$drurw","d",0
.store_entry "DRURW", .var("$drurw"), "Urlop od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.store_entry "DPON", - .var("$drurw"), "Urlop od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.var("DPON") = .var("DPON") - .var("$drurw")]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
