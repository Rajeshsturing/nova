			<fstrvbcode vt='8'><![CDATA[
.section 22
.level 2
.subtitle 0,"Wyniki"
'wyniki
.var("UBFIRMA") = .var("UBEMF") + .var("UBREF") + .var("UBWYP")
.edit_var 2, "Ubezpieczenie społeczne - firma", "UBFIRMA", "PLN", 2
.store_entry "UBFIRMA", .var("UBFIRMA"), .payroll.text

.var("RZUS") = .var("UBPRAC") + .var("UBFIRMA")
.edit_var 4, "Ubezpieczenie społeczne - razem", "RZUS", "PLN", 2
.store_entry "RZUS", .var("RZUS"), .payroll.text
.info_cur 5,"Łączny koszt wynagrodzenia",.var("BRUTTO") + .var("UBFIRMA") + .var ("FP") + .var ("FGSP"),"PLN",2
'netto
.var("NETTO") = .var("BRUTTO") - .var("ZALPDZM") - .var("UBPRAC") - .var("UBZDR")
.edit_var 6, "Netto", "NETTO", "PLN", 2
.store_entry "NETTO", .var("NETTO"), .payroll.text
'potrącenia i dodatki
.edit_var 22, "Razem potrącenia", "RPOTR", "PLN", 2
.store_entry "RPOTR", .var("RPOTR"), .payroll.text
.edit_var 24, "Razem dodatki", "RDODATKI", "PLN", 2
.store_entry "RDODATKI", .var("RDODATKI"), .payroll.text
.edit_var 26, "Razem zasiłki nieopodatkowane", "ZNPDZUS", "PLN", 2
.store_entry "ZNPDZUS", .var("ZNPDZUS"), .payroll.text
'wyplata
.var("WYPLATA") = .var("NETTO") - .var("RPOTR") + .var("RDODATKI") + .var("ZNPDZUS") 
.edit_var 28, "Do wypłaty", "WYPLATA", "PLN", 2
.store_entry "WYPLATA", .var("WYPLATA"),.payroll.text]]></fstrvbcode>
