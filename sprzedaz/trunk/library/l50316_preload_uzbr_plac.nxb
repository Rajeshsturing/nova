			<fstrvbcode vt='8'><![CDATA[dim iter : iter = 0
dim curSuma : curSuma = ccur(0.0)
dim nRok : nRok = year(.monthstart())
dim nMc : nMc = month(.monthstart())
if not .was_entry("SRURL",.monthstart(),.monthend()) then
    for iter=1 to 12 
        nRok = year(DateAdd("m",-iter,.monthstart()))        
        nMc = month(DateAdd("m",-iter,.monthstart()))
        curSuma = curSuma + .monthsum("PSRURL",nRok,nMc)        
    next
else
    .var("SRURL") = .monthsum("SRURL",nRok,nMc)
end if

.var("$ekwiwalent") = .round(.var("$ekwiwalent") + .var("PURLOP") + curSuma,2)
.var("$ekwiwalent") = .round(.var("$ekwiwalent") / 21,2)
.var("$ekwiwalent") = .round(.var("$ekwiwalent") / 8,2)
.var("$ekwiwalent") = .round(.var("$ekwiwalent")  * .param1(),2)
.var("EURLOP") = ccur(.var("$ekwiwalent"))
.edit_var 2,"Ekwiwalent za urlop","$ekwiwalent","PLN",2
.var("PPDWYN") = .var("PPDWYN") + .var("$ekwiwalent")
.var("PZUS") = .var("PZUS") + .var("$ekwiwalent")
.var("PSRZUS") = .var("PSRZUS") + .var("$ekwiwalent")]]></fstrvbcode>
