			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3'>12</fpjednostkaparam1>
			<fstropis vt='8' />
