			<fstrvbcode vt='8'><![CDATA[.section 8
.level 0
dim curStawkaGodz
if .var("HRON") = 0 then
curStawkaGodz = ccur(0.0)
else
curStawkaGodz = (.var("PURLOP") + .var("SRURL")) / .var("HRON")
end if
.var("$wynurl") = .round(.var("$hrurw") * curStawkaGodz,2)
.edit_var 2,"Wynagrodzenie urlopowe","$wynurl","PLN",2
.var("PPDWYN") = .var("PPDWYN") + .var("$wynurl")
.var("PZUS") = .var("PZUS") + .var("$wynurl")
.var("PSRZUS") = .var("PSRZUS") + .var("$wynurl")]]></fstrvbcode>
