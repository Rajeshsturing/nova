			<idobj>30</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8' />
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>10</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[.section 1
.level 0
.subtitle 1,"Podstawa zasiłku chorobowego z poprzednich m-cy"
dim nMonths : nMonths = clng(12)
dim dStartDate
dStartDate = dateadd("m",-nMonths,.startdate)
dStartDate = dateserial(year(dStartDate),month(dStartDate),1)
dim iter
for iter = 1 to nMonths
.var("$ym" + cstr(iter)) = ccur(dStartDate)
.var("$srzus" + cstr(iter)) = ccur(0.0)
.edit_year_month iter+iter,"Miesiąc " + cstr(iter - nMonths - 1),"$ym" + cstr(iter)
.edit_var iter+iter+1,"Wartość","$srzus" + cstr(iter),"PLN",2
.store_entry "PSRZUS", .var("$srzus" + cstr(iter)),"Miesiąc " + cstr(iter - nMonths - 1),cdate(.var("$ym" + cstr(iter)))
.store_entry "DPON", 1,"Miesiąc " + cstr(iter - nMonths - 1),cdate(.var("$ym" + cstr(iter)))
.store_entry "DRON", 1,"Miesiąc " + cstr(iter - nMonths - 1),cdate(.var("$ym" + cstr(iter)))
dStartDate = dateadd("m",1,dStartDate)
next
.section 2
.subtitle 2,"Średnia urlopowa składników zmiennych"
nMonths = clng(3)
dStartDate = dateadd("m",-nMonths,.startdate)
dStartDate = dateserial(year(dStartDate),month(dStartDate),1)
for iter = 1 to nMonths
.var("$ym1" + cstr(iter)) = ccur(dStartDate)
.var("$srurl" + cstr(iter)) = ccur(0.0)
.edit_year_month iter+iter,"Miesiąc " + cstr(iter - nMonths - 1),"$ym1" + cstr(iter)
.edit_var iter+iter+1,"Wartość","$srurl" + cstr(iter),"PLN",2
.store_entry "PSRURL", .var("$srurl" + cstr(iter)),"Miesiąc " + cstr(iter - nMonths - 1),cdate(.var("$ym1" + cstr(iter)))
dStartDate = dateadd("m",1,dStartDate)
next]]></fstrvbcode>
