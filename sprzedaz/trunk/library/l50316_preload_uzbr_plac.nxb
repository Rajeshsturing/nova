			<fstropis vt='8'><![CDATA[Naliczenie zaliczki na podatek dochodowy w przypadku wspolnego opodatkowania wspolmalzonkow - zaliczka obliczana jest zawsze wg podstawowej stawki podatku]]></fstropis>
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>912</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[.section 21
.level 2
.subtitle 0,"Podatek dochodowy"
'brutto
.var("BRUTTO") = .var("PPDWYN") + .var("PPDZAS")
.edit_var 10,"Brutto", "BRUTTO","PLN",2
.store_entry "BRUTTO", .var("BRUTTO") , .payroll.text
'ub.prac.
.var("UBPRAC") = .var("UBEMP") + .var("UBREP") + .var("UBCHOR")
.section 22
.level 0
.edit_var 3, "Ubezpieczenia spoleczne - pracownik", "UBPRAC", "PLN", 2
'PPD
.section 21
.store_entry "UBPRAC", .var("UBPRAC"), .payroll.text
.var("PPDWYN") = .var("PPDWYN") - .var("UBPRAC")
'KUP
.level 1
.info_cur 18, "Koszty uzyskania przychodu", .var("KUP"), "PLN", 2
if .var("KUP") > .var("PPDWYN") then
.var("KUP") = .var("PPDWYN") 
end if
.store_entry "KUP",.var("KUP"), .payroll.text
.var("PPDWYN") = .var("PPDWYN") - .var("KUP")
'podatek 
.level 0
.edit_var 22, "Podstawa pod. doch. od wynagrodzen", "PPDWYN", "PLN", 2
.store_entry "PPDWYN",.var("PPDWYN"), .payroll.text
.edit_var 24, "Podstawa pod. doch. od zasilków", "PPDZAS", "PLN", 2
.store_entry "PPDZAS",.var("PPDZAS"), .payroll.text
.var ("PPD") = .round(.var("PPDWYN") + .var("PPDZAS"),0)
.edit_var 26, "Podstawa podatku dochodowego", "PPD", "PLN",2
.store_entry "PPD",.var("PPD"), .payroll.text
'PPD narastajaco od poczatku roku bez biezacego miesiaca
.var("PPDPOP") = .sum("PPD",.yearstart(),.monthstart()-1)
.edit_var 28, "Podstawa podatku dochodowego narast z pop. m-cy", "PPDPOP", "PLN",2
'stawka PD
.var("STPD") = .rate("STPD1")
.edit_var 30, "Stawka podatku dochodowego", "STPD", "%", 2
.store_entry "STPD", .var("STPD"), .payroll.text
'zaliczka
.var("ZALPD") = .var("STPD") * .round(.var("PPD"),0) / 100.0
.edit_var 32, "Naliczenie podatku", "ZALPD", "PLN", 2
.store_entry "ZALPD", .var("ZALPD"), .payroll.text
'ulga
'.var("ULGPOD") = .sum("ULGPOD",.monthstart(),.monthend()) + .var("ULGPOD")
.edit_var 20, "Miesieczna ulga podatkowa", "ULGPOD", "PLN", 2
'ub zdrowotne
if .agreement.cUbZdr = "1" then
.var ("PUBZDR") = .round(.var("PZUS") - .var("UBEMP") - .var("UBREP") - .var("UBCHOR") + .var("PUBZDRX"),2)
.edit_var 12, "Podstawa ubezpieczenia zdrowotnego", "PUBZDR", "PLN", 2
.store_entry "PUBZDR", .var ("PUBZDR") , .payroll.text
.var("UBZDR") = .round(.var("PUBZDR") * .rate("UBZDR") / 100.0,2)
.var("UBZDRPD") = .round(.var("PUBZDR") * .rate("UBZDRPD") / 100.0,2)
.edit_var 14, "Ubezpieczenie zdrowotne", "UBZDR", "PLN", 2
.edit_var 16, "Ubezpieczenie zdrowotne odliczone", "UBZDRPD", "PLN", 2
end if
'zmniejszenie zal. p.d.
if .var("ZALPD") < .var("ULGPOD") then
.var("ZALPDZM") = ccur(0.0)
else
.var("ZALPDZM") = .var("ZALPD") - .var("ULGPOD")
end if
'korekta ub.zdr.
if .var("ZALPDZM") < .var("UBZDR") then
.var("UBZDR") = .var("ZALPDZM")
if .var("ZALPDZM") < .var("UBZDRPD") then
.var("UBZDRPD") = .var("ZALPDZM")
.var("ZALPDZM") = 0.0
else
.var("ZALPDZM") = .var("ZALPDZM") - .var("UBZDRPD")
end if
else
.var("ZALPDZM") = .var("ZALPDZM") - .var("UBZDRPD")
end if
.var("ZALPDZM") = .round(.var("ZALPDZM"),1)
.store_entry "UBZDR", .var("UBZDR"), .payroll.text
.store_entry "UBZDRPD", .var("UBZDRPD"), .payroll.text
.level 2
.edit_var 40, "Zaliczka na podatek", "ZALPDZM", "PLN", 2
.store_entry "ZALPDZM", .var("ZALPDZM"), .payroll.text]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
