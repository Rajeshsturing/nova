			<fstropis vt='8'><![CDATA[Wynagrodzenie w kwocie stałej brutto, z tytułu umowy o dzieło, zlecenia, lub jednorazowe wynagrodzenie stałe - nie tworzy podstawy zasiłku chorobowego ani średniej urlopowej]]></fstropis>
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>500</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[.var("PZUS") = .var("PZUS") + .param1()
.var("PPDWYN") = .var("PPDWYN") + .param1()]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[1]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
			<fcconfparam2 vt='8'><![CDATA[0]]></fcconfparam2>
			<fpgrupaschemnal vt='3'>2</fpgrupaschemnal>
