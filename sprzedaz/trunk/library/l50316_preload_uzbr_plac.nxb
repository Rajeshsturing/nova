.var("$kwota") = ccur(0.0)
if .param1() <= 2 then
    .var("$kwota") = ccur(.rate("ZASRODZ1") * .param1())
else
    if .param1() <= 3 then
        .var("$kwota") = ccur(.rate("ZASRODZ1") * 2 + .rate("ZASRODZ3"))
    else
        .var("$kwota") = ccur(.rate("ZASRODZ1") * 2 + .rate("ZASRODZ3") + .rate("ZASRODZ4") * (.param1() - 3))
    end if
end if
