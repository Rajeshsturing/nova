		<neio>
			<typeid>10190</typeid>
			<idobj>1</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8'><![CDATA[Nominalny czas pracy]]></fstropis>
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>100</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[if .var("DKMK") = 0 then
    .var("DRMK") = .calendar.dni_rob_plan(.monthstart(),.monthend())
    dim nMinRMK : nMinRMK = .calendar.min_rob_plan(.monthstart(),.monthend())
    .var("HRMK") = clng(-Int(-nMinRMK/60))
    .var("DKMK") = .calendar.dni_kal(.monthstart(),.monthend())
    .var("DRON") = .calendar.dni_rob_plan(.startdate(),.enddate())
    dim nMinRON : nMinRON = .calendar.min_rob_plan(.startdate(),.enddate())
    .var("HRON") = clng(-Int(-nMinRON/60))
    .var("HPON") = .var("HRON")
    .var("DPON") = .var("DRON")
    .var("DKON") = .calendar.dni_kal(.startdate(),.enddate())
    .level 0
    .section 2
    .subtitle 0, "Czas pracy"
    .edit_var 2, "Dni robocze w miesiącu kalendarzowym","DRMK","d",0
    .edit_var 4, "Dni robocze w okresie naliczenia","DRON","d",0
    .edit_var 6, "Dni kalendarzowe w miesiącu kalendarzowym","DKMK","d",0
    .edit_var 8, "Dni kalendarzowe w okresie naliczenia","DKON","d",0
    .edit_var 10, "Dni przepracowane w okresie naliczenia","DPON","d",0
    .store_entry "DPON", .var("DPON"), "(czas nominalny)" + .payroll.text
    .store_entry "DRON", .var("DRON"), .payroll.text
    .store_entry "HPON", .var("HPON"), "(czas nominalny)" + .payroll.text 
end if]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
			<fcconfparam2 vt='8'><![CDATA[0]]></fcconfparam2>
			<fpgrupaschemnal vt='3'>1</fpgrupaschemnal>
			<f_versionid vt='3'>1</f_versionid>
			<ferodzaj vt='3'>1</ferodzaj>
			<fstrnazwa vt='8'><![CDATA[Nominalny czas pracy]]></fstrnazwa>
			<f_begin_unit vt='3' />
			<fcurparam1 vt='6' />
			<fstrkod vt='8'><![CDATA[CPNOM]]></fstrkod>
		</neio>
		<neio>
			<typeid>1</typeid>
			<idobj>107</idobj>
			<f_end_unit vt='3' />
		</neio>
		<neio>
			<typeid>10190</typeid>
			<idobj>2</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8' />
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>110</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[
.section 6
.level 0
.subtitle 0,"Choroba od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
dim nDniRobChor : nDniRobChor = .calendar.dni_rob_plan(.document.ddataod,.document.ddatado)
dim nMinRobChor : nMinRobChor = .calendar.min_rob_plan(.document.ddataod,.document.ddatado)
dim nHRobChor : nHRobChor = clng(-Int(-nMinRobChor/60))
dim nDniKalChor : nDniKalChor = .calendar.dni_kal(.document.ddataod,.document.ddatado)
.store_entry "DKCHOR", nDniKalChor, "Choroba od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.store_entry "DRCHOR", nDniRobChor, "Choroba od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.store_entry "DPON", - nDniRobChor, "Choroba od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.store_entry "HPON", - nHRobChor, "Choroba od " + cstr(.document.ddataod) + " do " + cstr(.document.ddatado)
.var("DRCHOR") = .var("DRCHOR") + nDniRobChor
.var("DKCHOR") = .var("DKCHOR") + nDniKalChor
.var("DPON") = .var("DPON") - nDniRobChor
.var("HPON") = .var("HPON") - nHRobChor
.info_cur 2,"Dni choroby",nDniKalChor,"d",0]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
			<fcconfparam2 vt='8'><![CDATA[0]]></fcconfparam2>
			<fpgrupaschemnal vt='3'>1</fpgrupaschemnal>
			<f_versionid vt='3'>1</f_versionid>
			<ferodzaj vt='3'>1</ferodzaj>
			<fstrnazwa vt='8'><![CDATA[Choroba - rozliczenie czasu pracy]]></fstrnazwa>
			<f_begin_unit vt='3' />
			<fcurparam1 vt='6' />
			<fstrkod vt='8'><![CDATA[CPCHOR]]></fstrkod>
		</neio>
		<neio>
			<typeid>1</typeid>
			<idobj>108</idobj>
			<f_end_unit vt='3' />
		</neio>
		<neio>
			<typeid>10190</typeid>
			<idobj>3</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8' />
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>120</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[dim dDataProg : dDataProg = dateserial(2009,2,1)
dim curUnettowienie
if .startdate >= dateserial(2007,7,1) then
    curUnettowienie = ccur(1.0) - .rate("UBEMER") / 2 / 100.0 - .rate("UBRENTP") / 100.0 - .rate("UBCHOR") / 100.0
else
    curUnettowienie = ccur(1.0) - .rate("UBEMER") / 2 / 100.0 - .rate("UBRENT") / 2 / 100.0 - .rate("UBCHOR") / 100.0
end if
'data zawarcia umowy
dim oPracownik : set oPracownik = .employee
dim idUmowa : idUmowa = 0
idUmowa = trans_.findobjid(10199,"pPracownik = " + cstr(oPracownik.idobj) + " and eTypUmowy = 2 and (dDataDo = {d '1899-12-31'} or dDataDo >= " + trans_.afc.convert.date2SQL(.monthstart()) + ")")
if idUmowa > 0 then
  dim oUmowa : set oUmowa = trans_.getobj(10199,idUmowa)
  dim dPoczUmowy : dPoczUmowy = oUmowa.dDataOd
  'bRozpMies - zmienna bool czy brac pod uwage dany miesiac do sredniej (domyslnie tak)
  dim bRozpMies : bRozpMies = true
  dim nDRON, nDPON, nDRURW
  
    if .var("SRZUS") = 0 then
        dim nRok : nRok = year(.monthstart())
        dim nMc : nMc = month(.monthstart())
        if not .was_entry("SRZUS",.monthstart(),.monthend()) then
            dim curSuma : curSuma = ccur(0.0)
            dim lnMcy : lnMcy = 0
            dim iter
            'gdy pracownik zachorowal w miesiacu zatrudnienia => podstawa tylko z tego miesiaca
            dim bMiesZatr : bMiesZatr = false
            if nRok = Year(dPoczUmowy) then
              if nMc = Month(dPoczUmowy) then
                nDRON = .var("DRON")
                if nDRON > 0 then
                    nDPON = .var("DPON")
                    nDRURW = .var("DRURW")
                    if (nDPON + nDRURW >= nDRON / 2) then
                       if dPoczUmowy < dDataProg then
                         curSuma = curSuma + .var("PSRZUS") * curUnettowienie
                       else
                         curSuma = curSuma + .var("PSRZUS")
                       end if    
                        bMiesZatr = true
                    end if
                end if
              end if    
            end if
            if not bMiesZatr then
                'gdy na 90 dni wstecz byla choroba => pobierz SRZUS ostatniej choroby
                dim i
                dim bChor : bChor = false
                dim isChoroba : isChoroba = false
                dim dDataWstecz : dDataWstecz = DateAdd("d",-90,.monthstart())
                dim iLiczMies : iLiczMies = DateDiff("m",dDataWstecz,.monthstart())
                for i = 1 to iLiczMies
                  'sprawd  czy na 3 miesišce wstecz była choroba
                  dDataWstecz = DateAdd("m",-i,.monthstart())
                  dim oChoroba : set oChoroba = trans_.createadors("select 'idChor'=idobj from n5plchoroba where pPracownik = " + cstr(oPracownik.idobj) + " and " +_
                    " ((year(dDataOd) = " + cstr(year(dDataWstecz)) + " and month(dDataOd) = " + cstr(month(dDataWstecz)) + ") or " +_
                    " (year(dDataDo) = " + cstr(year(dDataWstecz)) + " and month(dDataDo) = " + cstr(month(dDataWstecz)) + "))")
                  if oChoroba.RecordCount <> 0 then 
                    isChoroba = true
                  end if
                  if isChoroba then
                    exit for
                  end if  
                next
                if isChoroba then
                  'pobierz max datę zapisu na subkonto SRZUS dla danego pracownika
                  dim oRS : set oRS = trans_.createadors("select 'data'=max(dDataNal) from n5pldekret where pPracownik = " + cstr(oPracownik.idobj) +_
                                                         " and pSubKonto = (select idobj from n5plsubkonto where strKod = 'SRZUS')")
                  if oRS.RecordCount <> 0 then
                    dDataWstecz = oRS("data")
                    dim oRKw : set oRKw = trans_.createadors("select 'kwotaSRZUS'=curKwota from n5pldekret where pPracownik = " + cstr(oPracownik.idobj) +_
                                                             " and pSubKonto = (select idobj from n5plsubkonto where strKod = 'SRZUS') and dDataNal = " +_
                                                             trans_.afc.convert.date2SQL(dDataWstecz))
                    dim kwotaSRZUS
                    if oRKw.RecordCount <> 0 then
                      kwotaSRZUS = ccur(oRKW("kwotaSRZUS"))
                    end if                                         
                  end if
                  if dDataWstecz < dDataProg then
                    .var("SRZUS") = kwotaSRZUS * curUnettowienie
                  else
                    .var("SRZUS") = kwotaSRZUS
                  end if  
                  bChor = true
                end if
                if not bChor then               
                    for iter = 1 to 12
                        nMc = nMc - 1
                        'gdy pracownik pracuje mniej niz 12 miesiecy
                        if Year(DateAdd("m",-iter,.monthstart())) = Year(dPoczUmowy) then
                          if Month(DateAdd("m",-iter,.monthstart())) = Month(dPoczUmowy) then
                            'gdy umowa nie rozpoczyna sie od 1 dnia miesiaca => pomin miesiac
                            if Day(dPoczUmowy) <> 1 then
                              bRozpMies = false
                            end if
                          end if      
                        end if
                        if bRozpMies then
                            nDRON = .monthsum("DRON",nRok,nMc)
                            if nDRON > 0 then
                                nDPON = .monthsum("DPON",nRok,nMc)
                                nDRURW = .monthsum("DRURW",nRok,nMc)
                                if (nDPON + nDRURW >= nDRON / 2) then
                                                      dim curPodstawa : curPodstawa = .monthsum("PSRZUS",nRok,nMc) - .monthsum("UBEMP",nRok,nMc) - .monthsum("UBREP",nRok,nMc) - .monthsum("UBCHOR",nRok,nMc)
                                    curSuma = curSuma + curPodstawa
                                    if curPodstawa > 0 then
                                      lnMcy = lnMcy + 1
                                    end if
                                end if
                            end if
                        end if
                        bRozpMies = true        
                    next
                    if lnMCy = 0 then
                        .var("SRZUS") = ccur(0.0) 
                    else
                        .var("SRZUS") = ccur(curSuma / lnMcy)
                    end if
                end if
            end if                              
            .store_entry "SRZUS", .var("SRZUS"), .payroll.text
        else
          if .monthstart() < dDataProg then 
            .var("SRZUS") = .monthsum("SRZUS",nRok,nMc) * curUnettowienie
          else
            .var("SRZUS") = .monthsum("SRZUS",nRok,nMc)
          end if    
        end if
    end if
end if]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
			<fcconfparam2 vt='8'><![CDATA[0]]></fcconfparam2>
			<fpgrupaschemnal vt='3'>1</fpgrupaschemnal>
			<f_versionid vt='3'>19</f_versionid>
			<ferodzaj vt='3'>1</ferodzaj>
			<fstrnazwa vt='8'><![CDATA[Średnia ZUS]]></fstrnazwa>
			<f_begin_unit vt='3' />
			<fcurparam1 vt='6' />
			<fstrkod vt='8'><![CDATA[SRZUS]]></fstrkod>
		</neio>
		<neio>
			<typeid>1</typeid>
			<idobj>109</idobj>
			<f_end_unit vt='3' />
		</neio>
		<neio>
			<typeid>10190</typeid>
			<idobj>4</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8' />
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>900</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[
.section 20
.level 1
.subtitle 0,"Ubezpieczenia społeczne"
'PZUS narastająco od początku roku bez bieżącego miesiąca
.var("$pzuspop") = .sum("PZUS",.yearstart(),.monthstart()-1)
.level 0
.edit_var 2, "Podstawa ZUS narastająco (bez bieżącego miesiąca)", "$pzuspop", "PLN", 2
'todo: co jesli jest to 2-gie naliczenie w m-cu !!
'podstawa-ub. em. i rent.-kwota graniczna
.store_entry "PZUS", .var("PZUS"), .payroll.text
if .var("PZUS") + .var("$pzuspop") > .rate("GRUBEMRE") then
    .var("PUBEMRE") = .max(0.0,.rate("GRUBEMRE") - .var("$pzuspop"))
else
    .var("PUBEMRE") = .var("PZUS")
end if
.edit_var 4, "Podstawa ub. emerytalnego i rentowego", "PUBEMRE", "PLN", 2
.store_entry "PUBEMRE", .var("PUBEMRE"), .payroll.text

.var("PUBCHWYP") = .var("PZUS")
.edit_var 6, "Podstawa ub. chorobowego i wypadkowego", "PUBCHWYP", "PLN", 2
.store_entry "PUBCHWYP", .var("PUBCHWYP"), .payroll.text
.level 1
'ub. emerytalne
if .agreement.cUbEm = "1" then
    .var("UBEMP") = .round( .var("PUBEMRE") * .rate("UBEMER") / 2 / 100.0,2)
    .var("UBEMF") = .var("UBEMP")
    .edit_var 8, "Ubezpiecznie emerytalne - pracownik", "UBEMP", "PLN", 2
    .store_entry "UBEMP",.var("UBEMP"), .payroll.text
    .edit_var 10, "Ubezpiecznie emerytalne - firma", "UBEMF", "PLN", 2
    .store_entry "UBEMF", .var("UBEMF"), .payroll.text
'    .var("UBEMER") = .var("UBEMF") + .var("UBEMP")
end if
'ub. rentowe
if .agreement.cUbRe = "1" then
	if .startdate >= dateserial(2007,7,1) then
		.var("UBREP") = .round( .var("PUBEMRE") * .rate("UBRENTP") / 100.0,2)
		.var("UBREF") = .round( .var("PUBEMRE") * .rate("UBRENTF") / 100.0,2)
	else
		.var("UBREP") = .round( .var("PUBEMRE") * .rate("UBRENT") / 2 / 100.0,2)
		.var("UBREF") = .var("UBREP")
	end if
    .edit_var 12, "Ubezpieczenie rentowe - pracownik", "UBREP", "PLN", 2
    .store_entry "UBREP", .var("UBREP"), .payroll.text
    .edit_var 14, "Ubezpieczenie rentowe - firma", "UBREF", "PLN", 2
    .store_entry "UBREF", .var("UBREF"), .payroll.text
'    .var("UBRENT") = .var("UBREF") + .var("UBREP")
end if
'ub chorobowe
if .agreement.cUbCh = "1" then
     .var("UBCHOR") = .round(.var("PZUS") * .rate("UBCHOR") / 100.0,2)
     .edit_var 16, "Ubezpieczenie chorobowe", "UBCHOR", "PLN", 2
     .store_entry "UBCHOR", .var("UBCHOR"), .payroll.text
end if
'ub wypadkowe
if .agreement.cUbWyp = "1" then
    .var ("UBWYP") = .round(.var("PZUS") * .rate("UBWYP") / 100.0,2)
    .edit_var 18, "Ubezpieczenie wypadkowe", "UBWYP", "PLN", 2
    .store_entry "UBWYP", .var ("UBWYP") , .payroll.text
end if
'FP i FGSP
if .agreement.cFP = "1" then
    .var ("FP") = .round(.var("PZUS") * .rate("FP") / 100.0,2)
    .edit_var 20, "Fundusz Pracy", "FP", "PLN", 2
    .store_entry "FP", .var ("FP") , .payroll.text
end if
if .agreement.cFGSP = "1" then
    .var ("FGSP") = .round(.var("PZUS") * .rate("FGSP") / 100.0,2)
    .edit_var 22, "FGŚP", "FGSP", "PLN", 2
    .store_entry "FGSP", .var ("FGSP"), .payroll.text
end if

.edit_var 40, "Suma do podstawy zasiłku chorobowego", "PSRZUS", "PLN", 2
.store_entry "PSRZUS", .var ("PSRZUS"), .payroll.text]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
			<fcconfparam2 vt='8'><![CDATA[0]]></fcconfparam2>
