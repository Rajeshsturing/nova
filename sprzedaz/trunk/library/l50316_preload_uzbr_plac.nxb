			<f_versionid vt='3'>1</f_versionid>
			<ferodzaj vt='3'>1</ferodzaj>
			<fstrnazwa vt='8'><![CDATA[Urlop - rozliczenie czasu pracy]]></fstrnazwa>
			<f_begin_unit vt='3' />
			<fcurparam1 vt='6' />
			<fstrkod vt='8'><![CDATA[CPURL]]></fstrkod>
		</neio>
		<neio>
			<typeid>1</typeid>
			<idobj>112</idobj>
			<f_end_unit vt='3' />
		</neio>
		<neio>
			<typeid>10190</typeid>
			<idobj>7</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3' />
			<fstropis vt='8' />
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>120</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[if .var("SRURL") = 0 then
   dim nRok : nRok = year(.monthstart())
   dim nMc : nMc = month(.monthstart())        
     if not .was_entry("SRURL",.monthstart(),.monthend()) then    
     dim curSuma : curSuma = ccur(0.0)    
     'sprawdz czy była choroba w poprzednim misiącu
     dim iter : iter = 1
     dim iLiczMies : iLiczMies = 0
     do while true
        nMc = nMc - 1
            if not .was_entry("RSA",DateAdd("m",-iter,.monthstart()),DateAdd("m",-iter,.monthend())) then
               curSuma = curSuma + .monthsum("PSRURL",nRok,nMc)
           iLiczMies = iLiczMies + 1
           if iLiczMies = 3 then
          exit do
           end if                   
            end if
            iter = iter + 1
         loop              
         if iLiczMies > 0 then
            .var("SRURL") = ccur(curSuma / iLiczMies)
         end if    
         .store_entry "SRURL", .var("SRURL"), .payroll.text    
      else    
         .var("SRURL") = .monthsum("SRURL",nRok,nMc)
      end if
end if]]></fstrvbcode>
			<fcconfparam1 vt='8'><![CDATA[0]]></fcconfparam1>
			<fpterminnal vt='3'>1</fpterminnal>
