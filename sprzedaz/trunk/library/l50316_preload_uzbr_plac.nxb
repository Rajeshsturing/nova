			<fstrnazwa vt='8'><![CDATA[Wynagrodzenie za pracę]]></fstrnazwa>
		</neio>
		<neio>
			<typeid>10190</typeid>
			<idobj>9</idobj>
			<fcurparam2 vt='6' />
			<fplsn_cvisibility vt='8'><![CDATA[11111111111111111111]]></fplsn_cvisibility>
			<fpjednostkaparam1 vt='3'>4</fpjednostkaparam1>
			<fstropis vt='8'><![CDATA[Stałe wynagrodzenie miesięczne z umowy o pracę]]></fstropis>
			<fpjednostkaparam2 vt='3' />
			<fnpriorytet vt='3'>500</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA[dim curPensjaN: curPensjaN= .round(.param1() * .var("DRON") / .var("DRMK"),2)
'dni nieob. innych
dim iDniNBI : iDniNBI = .var("DRMK") - .var("DPON") - .var("DRCHOR")
'.info_cur 1,"iDniNBI",iDniNBI,"d",0
'.info_cur 2,"DRCHOR",.var("DKCHOR"),"d",0
'.info_cur 3,"pomn.nieob",.round(.param1() * iDniNBI / .var("DRMK"),2),"zl",2
'.info_cur 4,"pomn.chor",.round(.param1() * .var("DKCHOR") / 30,2),"zl",2

dim curPensja
'curPensja = .param1() - .round(.param1() * iDniNBI / .var("DRMK"),2) - .round(.param1() * .var("DKCHOR") / 30,2)
curPensja = .param1() - .round(.param1() * .var("DKCHOR") / 30,2)
if curPensja < 0 then
curPensja = ccur(0)
end if


.var("WYNZAS") = .var("WYNZAS") + curPensjaN
.var("PZUS") = .var("PZUS") + curPensja
.var("PPDWYN") = .var("PPDWYN") + curPensja
.var("PSRZUS") = .var("PSRZUS") + curPensja
.var("PURLOP") = .var("PURLOP") + curPensjaN]]></fstrvbcode>
