			<fnpriorytet vt='3'>800</fnpriorytet>
			<fstrvbcode vt='8'><![CDATA['zlicz ilosc dni choroby od poczatku roku
dim iter, nRok, nMc, iMiesNal
dim iDniChor : iDniChor = 0
iMiesNal = month(.monthstart())
nRok = year(.monthstart())
for iter = 1 to iMiesNal - 1
nMc = month(DateAdd("m",-iter,.monthstart())) 
iDniChor = iDniChor + .monthsum("DKCHOR",nRok,nMc)
next

.var("$wynchor") = .round(.var("SRZUS") * .calendar.dni_kal(.document.ddataod,.document.ddatado) / 30 * .param1() / 100.00,2)

if (iDniChor + .var("DKCHOR")) <= 33 then
'wynagrodzenie chorobowe 80%
.section 6
.level 0
.edit_var 6,"Wynagrodzenie chorobowe","$wynchor","PLN",2
.store_entry0 "RSA",.var("$wynchor"),.payroll.text
.var("PPDWYN") = .var("PPDWYN") + .var("$wynchor")
.var("PUBZDRX") = .var("PUBZDRX") + .var("$wynchor")
else
dim iDniWynChor, iDniZasChor
.var("$curWynChor") = ccur(0)
.var("$curZasChor") = ccur(0) 
if iDniChor < 33 then
iDniWynChor = 33 - iDniChor
iDniZasChor = .var("DKCHOR") - iDniWynChor
.var("$curWynChor") = .round(.var("SRZUS") * iDniWynChor / 30 * .param1() / 100.00,2)
.section 6
.level 0
.info_cur 6,"Dni choroby (wyn. chorobowe)",iDniWynChor,"d",0
.info_cur 8,"Dni choroby (zas. chorobowy)",iDniZasChor,"d",0
.edit_var 10,"Wynagrodzenie chorobowe","$curWynChor","PLN",2
.edit_var 12,"Zasilek chorobowy","$curZasChor","PLN",2
.store_entry0 "RSA",.var("$curWynChor"),.payroll.text
'tylko za dni do 33
.var("PPDWYN") = .var("PPDWYN") + .var("$curWynChor")
else
'zasilek chorobowy
.var("$wynchor") = ccur(0)
.section 6
.level 0
.edit_var 6,"Zasilek chorobowy","$wynchor","PLN",2
.store_entry0 "RSA",.var("$wynchor"),.payroll.text
.var("PPDZAS") = .var("PPDZAS") + .var("$wynchor")
end if 
end if]]></fstrvbcode>
