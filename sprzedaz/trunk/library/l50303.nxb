#include "h1203.h"

'SelectFile
#include "50123"

dim g_nPreloadType
g_nPreloadType = CLng(0)

'-----------------------------------------------------------------------------
' Funkcja rozpoczyna preload danych z pliku o podanym numerze
' lub z podanego strumienia danych
'-----------------------------------------------------------------------------
private function imPreload(byval varInputData): imPreload = false

	'Strumień danych do zaimportowania
	dim pImportStream
	set pImportStream = nothing
	
	if (isObject(varInputData)) then
		'Dodstalismy juz gotowy stream
		set pImportStream = varInputData
	else
		'Mamy numer pliku wiec zamieniamy
		'go na stream danych
		g_nPreloadType = CLng(varInputData)
		set pImportStream = doc_.getappfile( CLng(varInputData) )
	end if

	dim pImportHelper : set pImportHelper =  doc_.getmodule(60211) 
	imPreload = (pImportHelper.import_nxd_stream_2_EB( pImportStream ) = 0)

end function

function PreloadUprZmDatySp()
	g_nPreloadType = T_IOW_UPR_ZMIANY_DATY_SP
	PreloadUprZmDatySp = imPreload( T_IOW_UPR_ZMIANY_DATY_SP )
end function

