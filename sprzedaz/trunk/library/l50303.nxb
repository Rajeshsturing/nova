'-----------------------------------------------------------------------------
' Import danych demo (preload)
'-----------------------------------------------------------------------------
function PreloadDemo(): PreloadDemo = false

	g_nPreloadType = T_DEMO

	'Jezeli preload danych demo to musimy
	'pobrac sciezke do danych demo na podstawie
	'wpisu w registry
	dim pSystem
	set pSystem=doc_.system

	dim strMediaSource
	strMediaSource = pSystem.registry(hKey_LocalMachine, "SOFTWARE\NAVO\NAVO2002\Setup", "MediaSource")

	dim strFilePath
	strFilePath="preload\NAVO Kontakt 2002 dane demo.nxd"

	'sprawdzanie czy istnieje plik
	dim pFD, bOK
	set pFD=CFileDrive(bOK)

	if (not bOK) then
		view_message 6186, 0
		exit function
	end if

	dim strFullFilePath
	strFullFilePath = strMediaSource + strFilePath
		
	'Szukanie pliku w określonej lokalizacji
	if (not pFD.isFile( strFullFilePath )) then
		
		'Nie instnieje plik w określonej lokalizacji
		'Czy użytkownik chce wybrać z innej lokalizacji

		if (MessageBox ("Nie istnieje plik importowy " + strFullFilePath + " Czy chcesz wybrać inną lokalizację?"  , "Brak pliku", vbYesNo, vbInformation) = vbYes) then

			dim bSelecetedFile
			bSelecetedFile = false
		
			do
				'Wybór ścieżki przez uzytkownika
				strFullFilePath = SelectFile("c:\", "*.nxd", "")

				if (strFullFilePath="") then
					'Nic nie chciano wybierać
					exit function
				end if

				bSelecetedFile = true
			
			loop until ( bSelecetedFile )
		
		else
			'Brak pliku i użytkownik go nie wybietał
			exit function
		end if
		
	end if

	if (not pFD.isFile(strFullFilePath)) then
		'W miedzy czasie plik został usunięty
		exit function
	end if

	'Robimy stream na podstawie pliku
	dim pFileStream
	set pFileStream = doc_.createstreamobj()

	on error resume next
#ifdef _DEBUG
	'DEBUG:
	pFileStream.attach strFullFilePath
	'END_DEBUG
#else
	pFileStream.attachcoded strFullFilePath
#endif
	
	if (err.number <> 0) then
		view_message1 6267, 0, strFullFilePath
		exit function
	end if

	on error goto 0

	PreloadDemo = imPreload( pFileStream )
	set pFileStream = nothing
end function

#endif
