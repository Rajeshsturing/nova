set strSQL=trans_.createadors("select 'c_ilosc_opak'=isnull(sum(t_0.gms_curIlosc),0) "+_
 "from n5gmstan as t_0  inner join n5magazyn as t_1 on t_0.gms_pMag = t_1.IdObj  "+_
 "inner join n5produkt as t_2 on t_0.gms_pProd = t_2.IdObj  "+_
 "inner join n5opakowanie_produktu as t_3 on t_0.gms_pOpak = t_3.IdObj  "+_
 "where t_1.eTyp <> 2 and  (t_1.idobj ="+_
 "(select m.idobj from n5magazyn as m inner join n5rejestrdok as r on m.idobj=r.wrefParam2 "+_
 "where r.etyp=33 )) and  (t_2.idobj = "+cstr(poz_dok.pProdukt.idobj)+") ")

if bCena then
	oAR.add_pozycja bLeft,poz_dok.pProdukt.idobj,0,0,poz_dok.curCenaNetto,curFactor*poz_dok.curIloscOpak,strSQL.fields("c_ilosc_opak"),curFactor*poz_dok.curIloscOpak,true
