end function

#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu zamowien wraz z dokumentami powiazanymi (dokumenty magazaynowe)
#comment '---------------------------------------------------------------------------------------------

public function ar_zamowienie_dm(byref oAR,byref oZamow,byref bLeft, byref curFactor, byval bCena)
'bCena - czy porownujemy tez z cenami.

	ar_dodaj_zamow oAR,oZamow,true,1,bCena

	dim cursor : set cursor = trans_.createrawcursor(TYPEID_N5DOKMAG , "wrefDokHandl="+cStr(oZamow.idobj)+" and wrefdokhandl_wrt=TYPEID_N5ZAMOWIENIE" , "" , "")	

	dim oPz 
	

	for each oPz in cursor
	
		ar_dodaj_dm oAR,oPz,false,1,bCena

		dim cursor_p : set cursor_p =  trans_.createrawcursor(TYPEID_N5DOKMAG , "pDokMag="+cStr(oPZ.idobj),"","")
		dim oZD 
		
		for each oZD in cursor_p
			ar_dodaj_dm oAR,oZD,false, 1,bCena
		next
		
	next
	
end function


#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu sprzedazy wraz z dokumentami powiazanymi (dokumenty magazaynowe)
#comment '---------------------------------------------------------------------------------------------

public function ar_sprzedaz_dm(byref oAR,byref oSprzed,byref bLeft, byref curFactor, byval bCena)


	ar_dodaj_sprzed oAR,oSprzed,true,1,bCena
	dim oKorekSprzed
	dim cursor : set cursor = trans_.createrawcursor(TYPEID_N5SPRZEDAZ, "pPopSprzed="+cStr(oSprzed.idobj),"","")
	
	for each oKorekSprzed in cursor
		ar_dodaj_sprzed oAR,okorekSprzed,false,1,bCena
	next
	
	set cursor = trans_.createrawcursor(TYPEID_N5DOKMAG , "wrefDokHandl="+cStr(oSprzed.idobj)+" and wrefdokhandl_wrt=TYPEID_N5SPRZEDAZ" , "" , "")	
	dim oWz 

	for each oWz in cursor
	
		ar_dodaj_dm oAR,oWz,false, 1,bCena
		
				dim cursor_p : set cursor_p = trans_.createrawcursor(TYPEID_N5DOKMAG , "pDokMag="+cStr(oWz.idobj), "" , "")
				dim oZZ 
				
				for each oZZ in cursor_p		
				
					ar_dodaj_dm oAR,oZZ,false, -1,bCena
				next
	next
	
end function

#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu zakupu wraz z dokumentami powiazanymi (dokumenty magazaynowe)
#comment '---------------------------------------------------------------------------------------------

public function ar_zakup_dm(byref oAR,byref oZakup,byref bLeft, byref curFactor, byval bCena)

	ar_dodaj_zakup oAR,oZakup,true,1,bCena
	
	dim cursor : set cursor = trans_.createrawcursor(TYPEID_N5ZAKUP , "pPopZakup="+cStr(oZakup.idobj),"","")
	dim oKorekZakup
	
	for each oKorekZakup in cursor
		ar_dodaj_zakup oAR,oKorekZakup,false,1,bCena	
	next
	
	set cursor = trans_.createrawcursor(TYPEID_N5DOKMAG , "wrefDokHandl="+cStr(oZakup.idobj)+" and wrefdokhandl_wrt=TYPEID_N5ZAKUP" , "" , "")	
	
	dim oPz 
	
	dim pcursor

	for each oPZ in cursor
		ar_dodaj_dm oAR,oPZ,false, 1,bCena
		
		dim cursor_p:set cursor_p = trans_.createrawcursor(TYPEID_N5DOKMAG , "pDokMag="+cStr(oPZ.idobj),"" , "")	

		dim oZD 
						
		for each oZD in cursor_p
			ar_dodaj_dm oAR,oZD,false, -1,bCena
		next
		
	next

end function


#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu zamowien wraz z dokumentami sprzedazy
#comment '---------------------------------------------------------------------------------------------

public function ar_zamow_sprzed(byref oAR,byref oZamow,byref bLeft, byref curFactor, byval bCena)


		ar_dodaj_zamow oAR,oZamow,true,1,bCena
		
		dim cursor : set cursor = trans_.createrawcursor(TYPEID_N5SPRZEDAZ,"pZamowienie="+cStr(oZamow.idobj),"","")
		dim oSprzed
		dim oKorekSprzed

		for each oSprzed in cursor
			ar_dodaj_sprzed oAR,oSprzed,false,1,bCena
			
			dim cursor_p : set cursor_p = trans_.createrawcursor(TYPEID_N5SPRZEDAZ,"pPopSprzed="+cStr(oSprzed.idobj),"","")
	
			for each oKorekSprzed in cursor_p
				ar_dodaj_sprzed oAR,okorekSprzed,false,-1,bCena
			next
		next
		
end function


#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu zamowienia wraz z dokumentem zakupu 
#comment '---------------------------------------------------------------------------------------------

public function ar_zamow_zakup(byref oAR,byref oZamow,byref bLeft, byref curFactor,byval bCena)


	ar_dodaj_zamow oAR,oZamow,true,1,bCena
		
		dim cursor : set cursor = trans_.createrawcursor(TYPEID_N5ZAKUP,"pZamowienie="+cStr(oZamow.idobj),"","")
		dim oZakup
		dim oKorekZakup

		for each oZakup in cursor
			ar_dodaj_zakup oAR,oZakup,false,1,bCena
			
			dim cursor_p : set cursor_p = trans_.createrawcursor(TYPEID_N5ZAKUP,"pPopZakup="+cStr(oZakup.idobj),"","")
	
			for each oKorekZakup in cursor_p
				ar_dodaj_zakup oAR,oKorekZakup,false,-1,bCena
			next
		next
end function