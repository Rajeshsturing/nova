#include "h1201.h"
#include "h1240.h"
#include "h1250.h"

dim strSQL

public function fill_left_mag(cPorownaj,byref pDok , byref pPage) : fill_left_mag = true


dim ostr : set ostr = doc_.createstreamobj()

dim oPB : set oPB=nx_.slot0.new_dhm_diff()
dim poz_dok
dim poz_dok_dok_handl
for each poz_dok in pDok.listPozycje
oPB.add_pozycja true,poz_dok.pProdukt.idobj,0,0,poz_dok.curCenaMag,poz_dok.curIloscOpak
next

dim ilosc:ilosc=opb.ilosc()
dim i
for i=0 to ilosc-1
if (opb.get_pozycja(i).strona) then
ostr.write " strona: Lewa"
else
ostr.write " strona: Prawa"
end if
ostr.write " id produktu: "+cstr(opb.get_pozycja(i).id_produkt)
ostr.write " id magazynu: "+cstr(opb.get_pozycja(i).id_magazyn)
ostr.write " id dostawcy: "+cstr(opb.get_pozycja(i).id_dostawcy)
ostr.write " cena : "+cstr(opb.get_pozycja(i).cena)
ostr.write " ilosc: "+cstr(opb.get_pozycja(i).ilosc)
ostr.save "C:\Documents and Settings\Administrator\Pulpit\ela.txt"
next

end function

#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu magazynowego
#comment '---------------------------------------------------------------------------------------------

public function ar_dodaj_dm(byref oAR,byref oDok,byref bLeft, byref curFactor,byval bCena)

if oAR is nothing then
	set oAR=nx_.slot0.new_dhm_diff()
end if
dim poz_dok
for each  poz_dok in oDok.listPozycje

set strSQL=trans_.createadors("select 'c_ilosc_opak'=isnull(sum(t_0.gms_curIlosc),0) "+_
 "from n5gmstan as t_0  inner join n5magazyn as t_1 on t_0.gms_pMag = t_1.IdObj  "+_
 "inner join n5produkt as t_2 on t_0.gms_pProd = t_2.IdObj  "+_
 "inner join n5opakowanie_produktu as t_3 on t_0.gms_pOpak = t_3.IdObj  "+_
 "where t_1.eTyp <> 2 and  (t_1.idobj ="+_
 "(select m.idobj from n5magazyn as m inner join n5rejestrdok as r on m.idobj=r.wrefParam2 "+_
 "where r.etyp=33 )) and  (t_2.idobj = "+cstr(poz_dok.pProdukt.idobj)+") ")


if bCena then
	oAR.add_pozycja bLeft,poz_dok.pProdukt.idobj,0,0,poz_dok.curCenaMag,curFactor*poz_dok.curIloscOpak,strSQL.fields("c_ilosc_opak"),curFactor*poz_dok.curIloscOpak,true
else
	oAR.add_pozycja bLeft,poz_dok.pProdukt.idobj,0,0,0,curFactor*poz_dok.curIloscOpak,strSQL.fields("c_ilosc_opak"),curFactor*poz_dok.curIloscOpak,true
end if
next

end function


#comment '---------------------------------------------------------------------------------------------
'wypelnianie akrusza pozycjami dokumentu sprzedazy
#comment '---------------------------------------------------------------------------------------------

public function ar_dodaj_sprzed(byref oAR,byref oDok,byref bLeft, byref curFactor,byval bCena)

if oAR is nothing then
	set oAR=nx_.slot0.new_dhm_diff()
end if

dim poz_dok
for each  poz_dok in oDok.listPozycje

set strSQL=trans_.createadors("select 'c_ilosc_opak'=isnull(sum(t_0.gms_curIlosc),0) "+_
 "from n5gmstan as t_0  inner join n5magazyn as t_1 on t_0.gms_pMag = t_1.IdObj  "+_
 "inner join n5produkt as t_2 on t_0.gms_pProd = t_2.IdObj  "+_
 "inner join n5opakowanie_produktu as t_3 on t_0.gms_pOpak = t_3.IdObj  "+_
 "where t_1.eTyp <> 2 and  (t_1.idobj ="+_
 "(select m.idobj from n5magazyn as m inner join n5rejestrdok as r on m.idobj=r.wrefParam2 "+_
 "where r.etyp=33 )) and  (t_2.idobj = "+cstr(poz_dok.pProdukt.idobj)+") ")


	if bCena then
		oAR.add_pozycja bLeft,poz_dok.pProdukt.idobj,0,0,poz_dok.curCenaNetto,curFactor*poz_dok.curIloscOpak,strSQL.fields("c_ilosc_opak"),curFactor*poz_dok.curIloscOpak,true
	else
		oAR.add_pozycja bLeft,poz_dok.pProdukt.idobj,0,0,0,curFactor*poz_dok.curIloscOpak,strSQL.fields("c_ilosc_opak"),curFactor*poz_dok.curIloscOpak,true
	end if

next

end function

