#define UNKNOWN_NAME	"brak"
#define INSTYTUCJA_TYP "Urząd"
#define SPOSOB_PLATNOSCI_EMPTY "nieokreślony"

dim pRejestrDokChoice
set pRejestrDokChoice = nothing

function getEmptySposobPlatnosci(): set getEmptySposobPlatnosci = nothing
	dim pSubTrans
	set pSubTrans = trans_.createsubtran()

	dim idFounded
	idFounded = trans_.findobjid(TYPEID_N5SPOSPLAT, "strNazwa='" + SPOSOB_PLATNOSCI_EMPTY + "'")

	if (idFounded=0) then

		dim pObject
		set pObject = trans_.newobj(TYPEID_N5SPOSPLAT)

		pObject.strNazwa = SPOSOB_PLATNOSCI_EMPTY

		idFounded = pObject.idobj

		if (not trans_.SaveObjects()) then
			set pObject = nothing
			set pSubTrans = nothing
			exit function
		end if
	end if

	set pObject = nothing
	set pSubTrans = nothing
	set getEmptySposobPlatnosci = trans_.getobj(TYPEID_N5SPOSPLAT, idFounded)
end function

function setRejestrVariableFld(byref pStream, byref pImpMan, byval strFieldName, byval nTypRej): setRejestrVariableFld = false
	dim nIdRejestrDok
	nIdRejestrDok = pStream.fields( strFieldName )

	if (isEmpty(nIdRejestrDok)) then
		dim pRejestrDok
		set pRejestrDok = getRejestDok(nTypRej, pImpMan)

		if (not pRejestrDok is nothing) then
			nIdRejestrDok = pRejestrDok.IdObj
			trans_.var(APPVAR_REJESTR_TYP) = pRejestrDok.eTyp
		end if

		set pRejestrDok = nothing
	else
		nIdRejestrDok = pImpMan.idFromMap(TYPEID_N5REJESTRDOK, CLng(nIdRejestrDok) )
		set pRejestrDok = trans_.getobj(TYPEID_N5REJESTRDOK, nIdRejestrDok)
		
		trans_.var(APPVAR_REJESTR_TYP) = pRejestrDok.eTyp

		set pRejestrDok = nothing
	end if

	if (isNumeric(nIdRejestrDok)) then
		trans_.var(APPVAR_REJESTR_DOKUMENTOW) = CLng(nIdRejestrDok)
		setRejestrVariableFld = true
	end if

	if (not setRejestrVariableFld) then
		view_message 6303, 0
	end if
	
end function

function setRejestrVariable(byref pStream, byref pImpMan, byval nTypRej)
	setRejestrVariable = setRejestrVariableFld(pStream, pImpMan, "pRejestrDok", nTypRej)
end function

function getRejestDok(byval nTyp, byref pImpMan): set getRejestDok = nothing

	if (nTyp<0) then
		exit function
	end if

	dim IdRejestr
	IdRejestr = trans_.findobjid(TYPEID_N5REJESTRDOK, "eTyp = " + cstr(nTyp))

	if (IdRejestr <= 0) then

		if (pRejestrDokChoice is nothing) then
			set pRejestrDokChoice = CreateObject("Scripting.Dictionary")
		end if

		if (pRejestrDokChoice.exists(CStr(nTyp))) then
			IdRejestr = pRejestrDokChoice.item(CStr(nTyp))
		else

			pImpMan.performing_destroy
				
			dim strTyp: strTyp = eTypRejestru2Str(nTyp)
			
			trans_.var(APPVAR_REJESTR_TYP)=CLng(nTyp)
						
			dim choice : choice = clng(0)

			while (choice = clng(0))
				choice = fire_choice_list (TYPEID_N5REJESTRDOK, "Wybierz domyślny rejestr typu:" + strTyp, "strNazwa", "eTyp = " + CStr(nTyp), "", "")
				
				if choice > clng(0) then

					'Sprawdzenie potrzebne w przypadku dodania nowego rejestru (jeżeli ktoś dodał rejestr innego typu)
					choice = trans_.findobjid(TYPEID_N5REJESTRDOK, "eTyp = " + CStr(nTyp) + " AND IdObj = " + CStr(choice))

					if choice > clng(0) then
						IdRejestr = choice
						pRejestrDokChoice.add CStr(nTyp), IdRejestr
					else
						MessageBox "Musisz wybrać lub utworzyć rejstr typu: " + cstr(strTyp) , "Błędny typ rejestru", vbOKOnly, vbInformation
					end if
				else
					if (MessageBox("Musisz wybrać domyślny rejestr. Kontynuować?" , "Brak wyboru", vbYesNo, vbInformation))<>vbYes then
						pImpMan.cancelImport
						exit function
					end if
				end if
			wend

		end if 'exists key

	end if

	page_.activate
	pImpMan.performing_restore
	set getRejestDok = trans_.getobj(TYPEID_N5REJESTRDOK, IdRejestr)

end function

function getDefaultWaluta(): set getDefaultWaluta = nothing
	dim pSubTrans
	set pSubTrans = trans_.createsubtran()

	dim idFounded
	idFounded = trans_.findobjid(TYPEID_N5JEDNOSTKA, "strSkrot='PLN'")

	if (idFounded=0) then

		trans_.var(APPVAR_JEDNOSTKA_TYPE)=CLng(N5JEDNOSTKA_WALUTA)

		dim pObject
		set pObject = trans_.newobj(TYPEID_N5JEDNOSTKA)

		pObject.strNazwa = "Polski złoty"
		pObject.strSkrot = "PLN"
		pObject.nDokladnosc = CLng(3)

		idFounded = pObject.idobj

		if (not trans_.SaveObjects()) then
			set pObject = nothing
			set pSubTrans = nothing
			exit function
		end if
	end if

	set pObject = nothing
	set pSubTrans = nothing
	set getDefaultWaluta = trans_.getobj(TYPEID_N5JEDNOSTKA, idFounded)
end function

