end function

function n5firma_AftImport(byref pImpMan, byref pStream, byref pObject)
	if (pObject.pWaluta is nothing) then
		set pObject.pWaluta = getDefaultWaluta()
	end if

	if (pObject.pMiejscowosc is nothing) then
		set pObject.pMiejscowosc = getEmptyMiejscowosc()
	end if

	if (not trans_.isvar(GVAR_FIRMA)) then
		trans_.var(GVAR_FIRMA) = pObject.IdObj
	end if

	n5firma_AftImport = true
end function

