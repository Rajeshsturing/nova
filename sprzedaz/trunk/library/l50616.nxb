		trans_.afc.convert.DoubleApostrophe( pStream.fields("strNazwa") ) + "' or " + _
		"strLogin='" + trans_.afc.convert.DoubleApostrophe( pStream.fields("strLogin") ) + "'")

	if (n5uzytkownik_BefImport>0) then
		n5uzytkownik_BefImport = n5uzytkownik_BefImport * (-1)
	end if
end function

function n5uzytkownik_AftImport(byref pImpMan, byref pStream, byref pObject)
	n5uzytkownik_AftImport = true

	'nadawanie uprawnien uzytkownikowi
	'z szablonu pobranego z preload'u
	dim idTemplate
	idTemplate = trans_.findobjid(TYPEID_N5UZYTKOWNIK, "strNazwa = 'Importowani'" )

	if (idTemplate <= 0) then
		exit function
	end if

	'usun poprzednie uprawnienia jezeli były
	dim cursor, pSO
	set cursor = trans_.createrawcursor(TYPEID_N5SECURITYOBJ, "pUser=" + CStr(pObject.IdObj), "", "")

	dim element
	for each element in cursor
		element.markdel = true
	next

	if (pObject.strLogin<>ADMIN_LOGIN) then
		set cursor = trans_.createrawcursor(TYPEID_N5SECURITYOBJ, "pUser=" + CStr(idTemplate), "", "")

		for each element in cursor
			set pSO = trans_.newobj(TYPEID_N5SECURITYOBJ)
			set pSO.pUser = pObject
			set pSO.pSOD = element.pSOD
		next

	else

		'mamy doczynienia z administratorem - nadajemy wszystkie
		'uprawnienia
		dim pCursor
		set pCursor = trans_.createrawcursor(TYPEID_N5SOD, "",  "", "")

		dim pSOD
		for each pSOD in pCursor
			if not pSOD is nothing then
				set pSO = trans_.newobj(TYPEID_N5SECURITYOBJ)
				set pSO.pSOD  = pSOD
				set pSO.pUser = pObject
			end if
		next

	end if

end function

function n5firma_BefImport(byref pImpMan, byref pStream)
	'w bazie moze byc tylko jedna firma
	n5firma_BefImport = pImpMan.getUniqueID("IdObj<>0")

	if (n5firma_BefImport>0) then
		n5firma_BefImport = n5firma_BefImport * (-1)
