function n5pozzamowienie_AftImport(byref pImpMan, byref pStream, byref pObject)

	dim pParent
	set pParent = pObject.parent

	pParent.curSumaNetto = pParent.curSumaNetto + pObject.curWartNetto
	pParent.curSumaVAT = pParent.curSumaVAT + pObject.curVAT
	pParent.curSumaBrutto = pParent.curSumaNetto + pParent.curSumaVAT

	n5pozzamowienie_AftImport = true
end function

