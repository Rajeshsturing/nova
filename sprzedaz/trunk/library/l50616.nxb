end function

function n5sprzedaz_BefImport(byref pImpMan, byref pStream)

	dim nTypRej: nTypRej = -1

	if (pStream.extraExists("TypRejestru")) then
		nTypRej = CLng( pStream.extra("TypRejestru") )
	end if

	if (nTypRej <> N5REJESTRDOK_KOR_FAKT_SP) then
		n5sprzedaz_BefImport = pImpMan.getUniqueID("strNrDok='" + _
			trans_.afc.convert.DoubleApostrophe( pStream.fields("strNrDok") ) + "'")
	else
		dim pCheckCursor
		set pCheckCursor = trans_.createrawcursor(TYPEID_N5SPRZEDAZ, "n5sprzedaz.strNrDok = '" + pStream.fields("strNrDok") + "' and n5rejestrdok.eTyp=N5REJESTRDOK_KOR_FAKT_SP", "", "n5rejestrdok on n5rejestrdok.idobj = n5sprzedaz.pRejestrDok")

		if (pCheckCursor.exists(1)) then
			n5sprzedaz_BefImport = pCheckCursor.get(1).IdObj
		else
			n5sprzedaz_BefImport = 0
		end if
	end if

	if (n5sprzedaz_BefImport>0) then
		n5sprzedaz_BefImport = n5sprzedaz_BefImport * (-1)
	end if

	if (n5sprzedaz_BefImport>=0) then
		if (not setRejestrVariable(pStream, pImpMan, nTypRej)) then
			pImpMan.cancelImport
		end if
	end if

end function

#include "50203"
#include "50523"

function n5sprzedaz_AftImport(byref pImpMan, byref pStream, byref pObject)

	if (pObject.pWaluta is nothing) then
		set pObject.pWaluta = getDefaultWaluta()
	end if

	if (pObject.pSposobPlatnosci is nothing) then
		set pObject.pSposobPlatnosci = getEmptySposobPlatnosci()
	end if

	'Ustawienie rozliczenia vat
	if (pObject.pRozlVat is nothing) then
		'Poszukiwanie
		dim idRozliczenie
		idRozliczenie = vat_lookup_rozliczenie( pObject.dDataWyst )

		'Tworzenie
		if (idRozliczenie=0) then
			idRozliczenie = vat_create_rozliczenie( pObject.dDataWyst )
		end if

		'Podstawienie
		if (idRozliczenie > 0) then
			set pObject.pRozlVat = trans_.getobj(TYPEID_N5ROZLVAT, idRozliczenie)
		else
			view_message1 6304, 0, doc_.afc.display.fulldate(pObject.dDataWyst)
			pImpMan.cancelImport
		end if

	end if

	n5sprzedaz_AftImport = true
end function

