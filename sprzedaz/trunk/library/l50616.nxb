function n5dokument_AftImport(byref pImpMan, byref pStream, byref pObject)
	if (pObject.isnew) then
		set pObject.pUzytkWypoz = nothing
		pObject.strCheckoutFileName = ""
	end if

	n5dokument_AftImport = true
end function

