function n5zakup_BefImport(byref pImpMan, byref pStream)
	n5zakup_BefImport = pImpMan.getUniqueID("strNrDok='" + _
		trans_.afc.convert.DoubleApostrophe( pStream.fields("strNrDok") ) + "'")

	if (n5zakup_BefImport>0) then
		n5zakup_BefImport = n5zakup_BefImport * (-1)
	end if

	if (n5zakup_BefImport>=0) then

		dim nTypRej
		if (pStream.extraExists("KOREKTA")) then
			nTypRej = N5REJESTRDOK_KOR_FAKT_ZAK
		else
			nTypRej = N5REJESTRDOK_FAKT_ZAK
		end if

		if (not setRejestrVariable(pStream, pImpMan, nTypRej)) then
			pImpMan.cancelImport
		end if
	end if
end function

function n5zakup_AftImport(byref pImpMan, byref pStream, byref pObject)
	if (pObject.pSposobPlatnosci is nothing) then
		set pObject.pSposobPlatnosci = getEmptySposobPlatnosci()
	end if

	'Ustawienie rozliczenia vat
	if (pObject.pRozlVat is nothing) then
		'Poszukiwanie
		dim idRozliczenie
		idRozliczenie = vat_lookup_rozliczenie( pObject.dDataOtrzym )

		'Tworzenie
		if (idRozliczenie=0) then
			idRozliczenie = vat_create_rozliczenie( pObject.dDataOtrzym )
		end if

		'Podstawienie
		if (idRozliczenie > 0) then
			set pObject.pRozlVat = trans_.getobj(TYPEID_N5ROZLVAT, idRozliczenie)
		end if
	end if

	n5zakup_AftImport = true
end function

function n5pozzakup_BefImport(byref pImpMan, byref pStream)
	n5pozzakup_BefImport = 0
end function

function n5pozzakup_AftImport(byref pImpMan, byref pStream, byref pObject)

	'Uzupelniamy odpowiednie sumy w parencie
	select case pObject.eVAT
		case 1 '0%
			pObject.parent.curNetto0 = pObject.parent.curNetto0 + pObject.curWartNetto

		case 2 'zwolniony
			pObject.parent.curNettoZw = pObject.parent.curNettoZw + pObject.curWartNetto

		case 3 'nie podlega
			pObject.parent.curNettoNp = pObject.parent.curNettoNp + pObject.curWartNetto

		case 4 '2%
			pObject.parent.curNetto2 = pObject.parent.curNetto2 + pObject.curWartNetto
			pObject.parent.curVat2 = pObject.parent.curVat2 + pObject.curVAT

		case 5 '3%
			pObject.parent.curNetto3 = pObject.parent.curNetto3 + pObject.curWartNetto
			pObject.parent.curVat3 = pObject.parent.curVat3 + pObject.curVAT

		case 6 '4%
			pObject.parent.curNetto4 = pObject.parent.curNetto4 + pObject.curWartNetto
			pObject.parent.curVat4 = pObject.parent.curVat4 + pObject.curVAT

		case 7 '7%
			pObject.parent.curNetto7 = pObject.parent.curNetto7 + pObject.curWartNetto
			pObject.parent.curVat7 = pObject.parent.curVat7 + pObject.curVAT

		case 8 '12%
			pObject.parent.curNetto12 = pObject.parent.curNetto12 + pObject.curWartNetto
			pObject.parent.curVat12 = pObject.parent.curVat12 + pObject.curVAT

		case 9 '17%
			pObject.parent.curNetto17 = pObject.parent.curNetto17 + pObject.curWartNetto
			pObject.parent.curVat17 = pObject.parent.curVat17 + pObject.curVAT

		case 10 '22%
			pObject.parent.curNetto22 = pObject.parent.curNetto22 + pObject.curWartNetto
			pObject.parent.curVat22 = pObject.parent.curVat22 + pObject.curVAT

	end select

	pObject.parent.curSumaNetto = pObject.parent.curSumaNetto + pObject.curWartNetto
	pObject.parent.curSumaVAT = pObject.parent.curSumaVAT + pObject.curVAT
	pObject.parent.curSumaBrutto = pObject.parent.curSumaNetto + pObject.parent.curSumaVAT
	pObject.parent.curSumaWal = pObject.parent.curSumaWal + (pObject.curCenaNettoWal * pObject.curIloscOpak)

	n5pozzakup_AftImport = true
end function

