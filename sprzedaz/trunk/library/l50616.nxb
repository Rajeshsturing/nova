function n5_klient_jedn_org_BefImport(byref pImpMan, byref pStream)
	dim strKlientIndex : strKlientIndex = pStream.fields("pKlient")
	dim idKlient : idKlient = trans_.findobjid(TYPEID_N5KLIENT, "strIndeks='" + strKlientIndex + "'")
	
	pStream.fields("pKlient") = idKlient	
	pImpMan.add2map TYPEID_N5KLIENT, idKlient, idKlient, cstr(idKlient)

	n5_klient_jedn_org_BefImport = pImpMan.getUniqueID("strSkrot='" + _
		trans_.afc.convert.DoubleApostrophe( pStream.fields("strSkrot") ) + "' and " + _
		"pKlient=" + cstr(idKlient))

	if (n5_klient_jedn_org_BefImport>0) then
		n5_klient_jedn_org_BefImport = n5_klient_jedn_org_BefImport * (-1)
	end if

