function getEmptyWoj(): set getEmptyWoj = nothing

	dim pSubTrans
	set pSubTrans = trans_.createsubtran()

	dim idWoj
	idWoj = trans_.findobjid(TYPEID_N5WOJEWODZTWO, "strNazwa='" + UNKNOWN_NAME + "'")

	if (idWoj = 0) then
		dim pWoj
		set pWoj = trans_.newobj(TYPEID_N5WOJEWODZTWO)

		pWoj.strNazwa = UNKNOWN_NAME

		idWoj = pWoj.idobj

		if (not trans_.SaveObjects()) then
			set pWoj = nothing
			set pSubTrans = nothing
			exit function
		end if

	end if

	set pWoj = nothing
	set pSubTrans = nothing
	set getEmptyWoj = trans_.getobj(TYPEID_N5WOJEWODZTWO, idWoj)
end function

function getEmptyMiejscowosc(): set getEmptyMiejscowosc = nothing

	dim pSubTrans
	set pSubTrans = trans_.createsubtran()

	dim idMiejsc
	idMiejsc = trans_.findobjid(TYPEID_N5MIEJSCOWOSC, "strNazwa='" + UNKNOWN_NAME + "'")

	if (idMiejsc = 0) then
		dim pMiejscowosc
		set pMiejscowosc = trans_.newobj(TYPEID_N5MIEJSCOWOSC)

		pMiejscowosc.strNazwa = UNKNOWN_NAME
		set pMiejscowosc.pWojewodztwo = getEmptyWoj()

		idMiejsc = pMiejscowosc.idobj

		if (not trans_.SaveObjects()) then
			set pMiejscowosc = nothing
			set pSubTrans = nothing
			exit function
		end if

	end if

	set pMiejscowosc = nothing
	set pSubTrans = nothing
	set getEmptyMiejscowosc = trans_.getobj(TYPEID_N5MIEJSCOWOSC, idMiejsc)
end function

