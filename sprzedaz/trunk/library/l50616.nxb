function n5instytucja_BefImport(byref pImpMan, byref pStream)

	dim nSourceMiejscowosc
	nSourceMiejscowosc = pStream.fields("pMiejscowosc")

	dim strMiejscowoscWhere: strMiejscowoscWhere = ""

	if (not isEmpty(nSourceMiejscowosc)) then
		dim nMiejscowoscIdObj: nMiejscowoscIdObj = CLng(0)
		nMiejscowoscIdObj = pImpMan.idFromMap(TYPEID_N5MIEJSCOWOSC, pStream.fields("pMiejscowosc"))

		if (not isEmpty(nMiejscowoscIdObj)) then
			strMiejscowoscWhere = " and pMiejscowosc = " + CStr(nMiejscowoscIdObj)
		end if

	end if

	n5instytucja_BefImport = pImpMan.getMultiID("strNazwa='" + _
	 trans_.afc.convert.DoubleApostrophe( pStream.fields("strNazwa") ) + "' and " + _
	 "strUlica='" + trans_.afc.convert.DoubleApostrophe( pStream.fields("strUlica") ) + "'" + strMiejscowoscWhere)

	if (n5instytucja_BefImport>0) then
		n5instytucja_BefImport = n5instytucja_BefImport * (-1)
	end if
end function

