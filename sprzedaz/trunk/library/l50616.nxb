#macro VB_BEFIMP_SINGLE_FIELD(_obj_name_,_field_name_)									\
function _obj_name_##_BefImport(byref pImpMan, byref pStream)							\
	_obj_name_##_BefImport = pImpMan.getUniqueID("_field_name_='" + _					\
		trans_.afc.convert.DoubleApostrophe( pStream.fields("_field_name_") ) + "'")	\
	if (_obj_name_##_BefImport>0) then													\
		_obj_name_##_BefImport = _obj_name_##_BefImport * (-1)							\
	end if																				\
end function

dim bIgnoreAllPlatnosc: bIgnoreAllPlatnosc = false

function n5rejestrdok_BefImport(byref pImpMan, byref pStream)
	n5rejestrdok_BefImport = pImpMan.getUniqueID("strNazwa='" + trans_.afc.convert.DoubleApostrophe( pStream.fields("strNazwa") ) + "'")

	if (n5rejestrdok_BefImport>0) then
		n5rejestrdok_BefImport = n5rejestrdok_BefImport * (-1)
	end if

	if (n5rejestrdok_BefImport>=0) then
		trans_.var(APPVAR_REJESTR_TYP) = pStream.fields("eTyp")
	end if
end function

