function n5dokmag_BefImport(byref pImpMan, byref pStream)
	n5dokmag_BefImport = pImpMan.getUniqueID("strNrDok='" + _
		trans_.afc.convert.DoubleApostrophe( pStream.fields("strNrDok") ) + "'")

	 if (n5dokmag_BefImport>0) then
		n5dokmag_BefImport = n5dokmag_BefImport * (-1)
	 end if

	if (n5dokmag_BefImport>=0) then

		dim nTypRej: nTypRej = -1
		if (pStream.extraExists("TypRejestru")) then
			nTypRej = pStream.extra("TypRejestru")
		end if

		if (not setRejestrVariable(pStream, pImpMan, nTypRej)) then
			pImpMan.cancelImport
		end if
	end if
end function

dim g_bIgnoreAllInType: g_bIgnoreAllInType = false

function n5dokmag_AftImport(byref pImpMan, byref pStream, byref pObject)
	
	if ((pObject.pDokMag is nothing) and (pObject.nTypDok = N5REJESTRDOK__MP or pObject.nTypDok = N5REJESTRDOK__PP or pObject.nTypDok = N5REJESTRDOK__ZD or pObject.nTypDok = N5REJESTRDOK__ZZ)) then

		if (not g_bIgnoreAllInType) then
			pImpMan.performing_destroy
			select case MessageBoxCustom("Dla dokumentu magazynowego " + _
				"" + " numer """ + pObject.strNrDok + """" + _
				" wymagane jest istnienie dokument powiązanego, który nie istnieje. Chcesz pominąć ten dokument i kontynuować import?", "Brak dokumentu", vbYesNoCancel, vbQuestion ,"Pomiń;Pomiń wszystkie;Przerwij import")
					
					case vbYes	'pomin
						page_.activate
						pObject.ignore = true
						pImpMan.performing_restore
					
					case vbNo	'pomin wszystkie
						page_.activate
						pObject.ignore = true
						g_bIgnoreAllInType = true
						pImpMan.performing_restore
					
					case vbCancel	'przerwij import
						page_.activate
						pImpMan.cancelImport
						pImpMan.performing_restore
						exit function
			end select
		else
			pObject.ignore = true
		end if

	end if

	n5dokmag_AftImport = true
end function

function n5pozdokmag_BefImport(byref pImpMan, byref pStream)
	n5pozdokmag_BefImport = 0
end function

function n5pozdokmag_AftImport(byref pImpMan, byref pStream, byref pObject)
	if (pObject.parent.pMagZrod is nothing) then
		set pObject.parent.pMagZrod = pObject.pMagZrod
	else
		if (pObject.parent.pMagZrod.idObj <> pObject.pMagZrod.IdObj) then
			view_message3 6242, 0, pObject.parent.strNrDok, pObject.parent.pMagZrod.strNazwa, pObject.pMagZrod.strNazwa
			page_.activate
			pObject.parent.ignore = true
		end if
	end if

	if (pObject.parent.pMagDocel is nothing) then
		set pObject.parent.pMagDocel = pObject.pMagDocel
	else
		if (pObject.parent.pMagDocel.idObj <> pObject.pMagDocel.IdObj) then
			view_message3 6242, 0, pObject.parent.strNrDok, pObject.parent.pMagDocel.strNazwa, pObject.pMagDocel.strNazwa
			page_.activate
			pObject.parent.ignore = true
		end if
	end if

	n5pozdokmag_AftImport = true
end function

function n5platnosc_BefImport(byref pImpMan, byref pStream)
	n5platnosc_BefImport = 0

	n5platnosc_BefImport = pImpMan.getUniqueID("strNrDok='" + _
		trans_.afc.convert.DoubleApostrophe( pStream.fields("strNrDok") ) + "'")
	
	if (n5platnosc_BefImport > 0) then
		n5platnosc_BefImport = n5platnosc_BefImport * (-1)
	end if

	if (n5platnosc_BefImport>=0) then

		dim varRejestrId
		varRejestrId = pImpMan.idFromMap(TYPEID_N5REJESTRDOK, pStream.fields("pRejestrDok"))

		if (not isEmpty(varRejestrId)) then
			trans_.var(APPVAR_REJESTR_DOKUMENTOW) = CLng(varRejestrId)
		else
			view_message 6334, 0
			pImpMan.cancelImport
			exit function
		end if

		trans_.var(APPVAR_REJESTR_TYP) = pStream.extra("TypRejestru")
	end if

end function

dim bShow: bShow = true
dim bSkip: bSkip = false

function n5platnosc_AftImport(byref pImpMan, byref pStream, byref pObject)

	if (pObject.pWalutaPodm is nothing) then
		set pObject.pWalutaPodm = getCurrentFirma().pWaluta
	end if

	if (pObject.pUzytRej is nothing) then
		set pObject.pUzytRej = getCurrentUser()
	end if

	n5platnosc_AftImport = true
end function

function n5pozplatnosc_BefImport(byref pImpMan, byref pStream)
	n5pozplatnosc_BefImport = 0
end function

function n5pozplatnosc_AftImport(byref pImpMan, byref pStream, byref pObject): n5pozplatnosc_AftImport = false

	'Określamy transakcje na podstawie wcześniej
	'zaimportowanych obietków sprzedaż/zakup
	if (pObject.pTransakcja is nothing) then
		if (pStream.extraExists("idsprzedaz")) then
			'Transakcja dla sprzedazy
			dim varSprzedaz
			varSprzedaz = pImpMan.idFromMap(TYPEID_N5SPRZEDAZ, pStream.extra("idsprzedaz"))

			if (not isEmpty(varSprzedaz)) then
				dim pSprzedaz
				set pSprzedaz = trans_.getobj(TYPEID_N5SPRZEDAZ, CLng(varSprzedaz))

				if (not pSprzedaz is nothing) then
					if (not pSprzedaz.pTransakcja is nothing) then
						set pObject.pTransakcja = pSprzedaz.pTransakcja
					else
						'todo:spiko Komunikat
					end if
				else
					'todo:spiko Komunikat
				end if

				set pSprzedaz = nothing
			else
				'todo:spiko Komunikat
			end if

		elseif (pStream.extraExists("idzakup")) then

			'Transakcja dla zakupu
			dim varZakup
			varZakup = pImpMan.idFromMap(TYPEID_N5ZAKUP, pStream.extra("idzakup"))

			if (not isEmpty(varZakup)) then
				dim pZakup
				set pZakup = trans_.getobj(TYPEID_N5ZAKUP, CLng(varZakup))

				if (not pZakup is nothing) then
					if (not pZakup.pTransakcja is nothing) then
						set pObject.pTransakcja = pZakup.pTransakcja
					else
						'todo:spiko Komunikat
					end if
				else
					'todo:spiko Komunikat
				end if

				set pZakup = nothing
			else
				'todo:spiko Komunikat
			end if

		end if

	end if

	n5pozplatnosc_AftImport = true
end function

function n5dowodksieg_BefImport(byref pImpMan, byref pStream)
	n5dowodksieg_BefImport = pImpMan.getUniqueID("strNrDok='" + _
		trans_.afc.convert.DoubleApostrophe( pStream.fields("strNrDok") ) + "'")

	 if (n5dowodksieg_BefImport>0) then
		n5dowodksieg_BefImport = n5dowodksieg_BefImport * (-1)
	 end if

	if (n5dowodksieg_BefImport>=0) then
		dim nTypRej: nTypRej = -1
		if (pStream.extraExists("TypRejestru")) then
			nTypRej = pStream.extra("TypRejestru")
		end if

		if (not setRejestrVariable(pStream, pImpMan, nTypRej)) then
			pImpMan.cancelImport
		end if

		trans_.var(APPVAR_DZIENNIK_DK) = trans_.var(APPVAR_REJESTR_DOKUMENTOW)
	end if

end function

function n5dowodksieg_AftImport(byref pImpMan, byref pStream, byref pObject)

	if (pObject.nNumDow=0) then
		pObject.nNumDow = pObject.IdObj
	end if

	if (pObject.pRejestrDok is nothing) then
		set pObject.pRejestrDok = getRejestDok(N5REJESTRDOK_DZIENNIK_NORM, pImpMan)
	end if

	n5dowodksieg_AftImport = true
end function

