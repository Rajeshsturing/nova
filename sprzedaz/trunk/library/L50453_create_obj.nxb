create procedure n5realprod_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10206
union
select TOP 5 'typeid'=cast(10119 as integer),idobj from n5zadanie where wrefSzczegoly=@idobj_par and wrefSzczegoly_wrt=10206
union
select TOP 5 'typeid'=cast(10274 as integer),idobj from n5prop where prop_pRealProd=@idobj_par
go

