create procedure n5opsrtrw_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10134 as integer),idobj from n5pkpir where pkpir_wrefDokZrodl=@idobj_par and pkpir_wrefDokZrodl_wrt=10216
union
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10216
union
select TOP 5 'typeid'=cast(10216 as integer),idobj from n5opsrtrw where wrefDokument=@idobj_par and wrefDokument_wrt=10216
go

