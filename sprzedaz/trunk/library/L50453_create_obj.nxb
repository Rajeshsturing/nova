create procedure n5sposdost_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10129 as integer),idobj from n5sprzedaz where sprzed_pSposobDostawy=@idobj_par
union
select TOP 5 'typeid'=cast(10162 as integer),idobj from n5dokmag where dm_pSposobDostawy=@idobj_par
union
select TOP 5 'typeid'=cast(10108 as integer),idobj from n5klient where kli_pSposobDostawy=@idobj_par
union
select TOP 5 'typeid'=cast(10176 as integer),idobj from n5zakup where zak_pSposobDostawy=@idobj_par
union
select TOP 5 'typeid'=cast(10172 as integer),idobj from n5zamowienie where zam_pSposobDostawy=@idobj_par
go

