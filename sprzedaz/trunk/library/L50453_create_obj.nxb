create procedure n5egzemplarz_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10168 as integer),idobj from n5pozdokmag_egz where pdmeg_pEgz=@idobj_par
union
select TOP 5 'typeid'=cast(10274 as integer),idobj from n5prop where prop_pEgzemplarz=@idobj_par
go

