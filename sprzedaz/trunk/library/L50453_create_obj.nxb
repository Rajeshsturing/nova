create procedure n5paleta_kolorow_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10131 as integer),idobj from n5produkt where prod_pPaletaKolorow=@idobj_par
union
select TOP 5 'typeid'=cast(10261 as integer),idobj from n5kolor where kol_pPaleta=@idobj_par
go

