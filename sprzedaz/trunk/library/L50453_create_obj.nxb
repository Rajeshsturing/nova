	drop view  view_doksp_sum_magic
go

create view view_doksp_sum_magic as 
select iddoksp,'magic'=sum(ilosc + cast (idprod as decimal(14,4)) * 1000000) from view_doksp_sum_by_prod
where ilosc <> 0.0
group by iddoksp

go

