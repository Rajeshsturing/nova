create procedure n5dokstatus_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10129 as integer),idobj from n5sprzedaz where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10162 as integer),idobj from n5dokmag where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10176 as integer),idobj from n5zakup where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10119 as integer),idobj from n5zadanie where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10150 as integer),idobj from n5platnosc where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10283 as integer),idobj from n5polecenie_wyjazdu where pws_pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10172 as integer),idobj from n5zamowienie where pDokStatus=@idobj_par
union
select TOP 5 'typeid'=cast(10206 as integer),idobj from n5realprod where pDokStatus=@idobj_par
go

