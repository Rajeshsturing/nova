create procedure n5rapkas_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10158
union
select TOP 5 'typeid'=cast(10150 as integer),idobj from n5platnosc where plat_pRapKas=@idobj_par
go

