	@curKol16_par decimal(12,2),
	@pkpir_wrefDokZrodl_par integer,
	@pkpir_wrefDokZrodl_wrt_par integer,
	@strExtra1_par varchar(32),
	@strExtra2_par varchar(128),
	@dExtra3_par datetime,
	@curExtra4_par decimal(12,2),
	@curExtra5_par decimal(12,2),
	@pKwalifikatorEx_par integer,
	@strExtra6_par varchar(128),
	@strExtra7_par varchar(128),
	@curExtra8_par decimal(12,2),
	@curExtra9_par decimal(12,2),
	@dExtra10_par datetime,
	@curKosztyBR_par decimal(12,2),
	@strOpisBR_par varchar(512)) with encryption as 
	update n5pkpir set VersionId=@versionid_par,
	nNumOper=@nNumOper_par,
	dDataOper=@dDataOper_par,
	pRejestrDok=@pRejestrDok_par,
	strNrDok=@strNrDok_par,
	pKlient=@pKlient_par,
	strOpis=@strOpis_par,
	strUwagi=@strUwagi_par,
	curWartSprzed=@curWartSprzed_par,
	curPozPrzych=@curPozPrzych_par,
	curZakTow=@curZakTow_par,
	curKosztZak=@curKosztZak_par,
	curKosztRekl=@curKosztRekl_par,
	curWynagrodz=@curWynagrodz_par,
	curPozWyd=@curPozWyd_par,
	curKol16=@curKol16_par,
	pkpir_wrefDokZrodl=@pkpir_wrefDokZrodl_par,
	pkpir_wrefDokZrodl_wrt=@pkpir_wrefDokZrodl_wrt_par,
	strExtra1=@strExtra1_par,
	strExtra2=@strExtra2_par,
	dExtra3=@dExtra3_par,
	curExtra4=@curExtra4_par,
	curExtra5=@curExtra5_par,
	pKwalifikatorEx=@pKwalifikatorEx_par,
	strExtra6=@strExtra6_par,
	strExtra7=@strExtra7_par,
	curExtra8=@curExtra8_par,
	curExtra9=@curExtra9_par,
	dExtra10=@dExtra10_par,
	curKosztyBR=@curKosztyBR_par,
	strOpisBR=@strOpisBR_par
	where idobj=@idobj_par
return @@rowcount
go

