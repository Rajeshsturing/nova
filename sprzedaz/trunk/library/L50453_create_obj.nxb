create procedure n5pit5l_delete(@idobj_par integer) with encryption as 
	delete from n5pit5l where idobj=@idobj_par
return @@rowcount
go

create procedure n5pit5l_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5pit5l
go

create procedure n5pit5l_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10137
go

-- table: n5transakcja
create procedure n5transakcja_select(@idobj_par integer,@versionid_par integer output,
	@strSymTrans_par varchar(64) output,
	@pWaluta_par integer output,
	@wrefPodmiot_par integer output,
	@wrefPodmiot_wrt_par integer output,
	@dDataRozp_par datetime output,
	@dDataWym_par datetime output,
	@dDataZamk_par datetime output,
	@curWn_par decimal(12,2) output,
	@curMa_par decimal(12,2) output,
	@eTyp_par integer output,
	@eStatus_par integer output,
	@curWnEwid_par decimal(12,2) output,
	@curMaEwid_par decimal(12,2) output,
	@eTypOdset_par integer output,
	@curOdsetkiUmowne_par decimal(12,2) output,
	@pNotaOds_par integer output,
	@trn_eRodzaj_par integer output,
	@trn_curKurs_par decimal(14,4) output,
	@trn_pHandlowiec_par integer output) with encryption as 
	select @versionid_par=VersionId,
	@strSymTrans_par=strSymTrans,
	@pWaluta_par=pWaluta,
	@wrefPodmiot_par=wrefPodmiot,
	@wrefPodmiot_wrt_par=wrefPodmiot_wrt,
	@dDataRozp_par=dDataRozp,
	@dDataWym_par=dDataWym,
	@dDataZamk_par=dDataZamk,
	@curWn_par=curWn,
	@curMa_par=curMa,
	@eTyp_par=eTyp,
	@eStatus_par=eStatus,
	@curWnEwid_par=curWnEwid,
	@curMaEwid_par=curMaEwid,
	@eTypOdset_par=eTypOdset,
	@curOdsetkiUmowne_par=curOdsetkiUmowne,
	@pNotaOds_par=pNotaOds,
	@trn_eRodzaj_par=trn_eRodzaj,
	@trn_curKurs_par=trn_curKurs,
	@trn_pHandlowiec_par=trn_pHandlowiec from n5transakcja where IdObj=@idobj_par
return @@rowcount
go

