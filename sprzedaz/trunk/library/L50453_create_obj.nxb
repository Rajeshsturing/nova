select TOP 5 'typeid'=cast(10275 as integer),idobj from n5pozrealprod_zasob where prpz_pTypZasobu=@idobj_par
union
select TOP 5 'typeid'=cast(10272 as integer),idobj from n5pozrecepta_zasob where prz_pTypZasobu=@idobj_par
union
select TOP 5 'typeid'=cast(10274 as integer),idobj from n5prop where prop_pTypZasobu=@idobj_par
go

-- table: n5maszyna_toral
create procedure n5maszyna_toral_select(@idobj_par integer,@versionid_par integer output,
	@masz_strNazwa_par varchar(128) output,
	@masz_strExtra1_par varchar(32) output,
	@masz_strExtra2_par varchar(128) output,
	@masz_dExtra3_par datetime output,
	@masz_curExtra4_par decimal(12,2) output,
	@masz_curExtra5_par decimal(12,2) output,
	@masz_pKwalifikatorEx_par integer output) with encryption as 
	select @versionid_par=VersionId,
	@masz_strNazwa_par=masz_strNazwa,
	@masz_strExtra1_par=masz_strExtra1,
	@masz_strExtra2_par=masz_strExtra2,
	@masz_dExtra3_par=masz_dExtra3,
	@masz_curExtra4_par=masz_curExtra4,
	@masz_curExtra5_par=masz_curExtra5,
	@masz_pKwalifikatorEx_par=masz_pKwalifikatorEx from n5maszyna_toral where IdObj=@idobj_par
return @@rowcount
go

create procedure n5maszyna_toral_insert(@idobj_par integer,@versionid_par integer,
	@masz_strNazwa_par varchar(128),
	@masz_strExtra1_par varchar(32),
	@masz_strExtra2_par varchar(128),
	@masz_dExtra3_par datetime,
	@masz_curExtra4_par decimal(12,2),
	@masz_curExtra5_par decimal(12,2),
	@masz_pKwalifikatorEx_par integer) with encryption as 
	insert into n5maszyna_toral values(@idobj_par,@versionid_par,
	@masz_strNazwa_par,
	@masz_strExtra1_par,
	@masz_strExtra2_par,
	@masz_dExtra3_par,
	@masz_curExtra4_par,
	@masz_curExtra5_par,
	@masz_pKwalifikatorEx_par)
return @@rowcount
go

create procedure n5maszyna_toral_update(@idobj_par integer,@versionid_par integer,
	@masz_strNazwa_par varchar(128),
	@masz_strExtra1_par varchar(32),
	@masz_strExtra2_par varchar(128),
	@masz_dExtra3_par datetime,
	@masz_curExtra4_par decimal(12,2),
	@masz_curExtra5_par decimal(12,2),
	@masz_pKwalifikatorEx_par integer) with encryption as 
	update n5maszyna_toral set VersionId=@versionid_par,
	masz_strNazwa=@masz_strNazwa_par,
	masz_strExtra1=@masz_strExtra1_par,
	masz_strExtra2=@masz_strExtra2_par,
	masz_dExtra3=@masz_dExtra3_par,
	masz_curExtra4=@masz_curExtra4_par,
	masz_curExtra5=@masz_curExtra5_par,
	masz_pKwalifikatorEx=@masz_pKwalifikatorEx_par
	where idobj=@idobj_par
return @@rowcount
go

create procedure n5maszyna_toral_delete(@idobj_par integer) with encryption as 
	delete from n5maszyna_toral where idobj=@idobj_par
return @@rowcount
go

create procedure n5maszyna_toral_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5maszyna_toral
go

create procedure n5maszyna_toral_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10287 as integer),idobj from n5pozankieta_toral where pank_pMaszyna=@idobj_par
go

