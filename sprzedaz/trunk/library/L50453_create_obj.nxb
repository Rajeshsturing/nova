	@strNazwa_par,
	@pKraj_par)
return @@rowcount
go

create procedure n5wojewodztwo_update(@idobj_par integer,@versionid_par integer,
	@strNazwa_par varchar(32),
	@pKraj_par integer) with encryption as 
	update n5wojewodztwo set VersionId=@versionid_par,
	strNazwa=@strNazwa_par,
	pKraj=@pKraj_par
