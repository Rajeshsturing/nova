create procedure n5pit5_delete(@idobj_par integer) with encryption as 
	delete from n5pit5 where idobj=@idobj_par
return @@rowcount
go

create procedure n5pit5_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5pit5
go

create procedure n5pit5_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10148 as integer),idobj from n5dowodksieg where wrefDokZrod=@idobj_par and wrefDokZrod_wrt=10136
go

-- table: n5typdzialania
create procedure n5typdzialania_select(@idobj_par integer,@versionid_par integer output,
	@strNazwa_par varchar(64) output,
	@nInternalID_par integer output,
	@pTypNadrzedny_par integer output,
	@strOpis_par varchar(255) output,
	@tpdz_strVBCheckReady_par varchar(7900) output,
	@tpdz_strVBCheckDone_par varchar(7900) output,
	@tpdz_eAktywny_par integer output) with encryption as 
	select @versionid_par=VersionId,
	@strNazwa_par=strNazwa,
	@nInternalID_par=nInternalID,
	@pTypNadrzedny_par=pTypNadrzedny,
	@strOpis_par=strOpis,
	@tpdz_strVBCheckReady_par=tpdz_strVBCheckReady,
	@tpdz_strVBCheckDone_par=tpdz_strVBCheckDone,
	@tpdz_eAktywny_par=tpdz_eAktywny from n5typdzialania where IdObj=@idobj_par
return @@rowcount
go

create procedure n5typdzialania_insert(@idobj_par integer,@versionid_par integer,
	@strNazwa_par varchar(64),
	@nInternalID_par integer,
	@pTypNadrzedny_par integer,
	@strOpis_par varchar(255),
	@tpdz_strVBCheckReady_par varchar(7900),
	@tpdz_strVBCheckDone_par varchar(7900),
	@tpdz_eAktywny_par integer) with encryption as 
	insert into n5typdzialania values(@idobj_par,@versionid_par,
	@strNazwa_par,
	@nInternalID_par,
	@pTypNadrzedny_par,
	@strOpis_par,
	@tpdz_strVBCheckReady_par,
	@tpdz_strVBCheckDone_par,
	@tpdz_eAktywny_par)
return @@rowcount
go

create procedure n5typdzialania_update(@idobj_par integer,@versionid_par integer,
	@strNazwa_par varchar(64),
	@nInternalID_par integer,
	@pTypNadrzedny_par integer,
	@strOpis_par varchar(255),
	@tpdz_strVBCheckReady_par varchar(7900),
	@tpdz_strVBCheckDone_par varchar(7900),
	@tpdz_eAktywny_par integer) with encryption as 
	update n5typdzialania set VersionId=@versionid_par,
	strNazwa=@strNazwa_par,
	nInternalID=@nInternalID_par,
	pTypNadrzedny=@pTypNadrzedny_par,
	strOpis=@strOpis_par,
	tpdz_strVBCheckReady=@tpdz_strVBCheckReady_par,
	tpdz_strVBCheckDone=@tpdz_strVBCheckDone_par,
	tpdz_eAktywny=@tpdz_eAktywny_par
	where idobj=@idobj_par
return @@rowcount
go

create procedure n5typdzialania_delete(@idobj_par integer) with encryption as 
	delete from n5typdzialania where idobj=@idobj_par
return @@rowcount
go

create procedure n5typdzialania_maxid(@maxid_par integer output) with encryption as 
	select @maxid_par=max(idobj) from n5typdzialania
go

create procedure n5typdzialania_candel(@idobj_par integer) with encryption as 
select TOP 5 'typeid'=cast(10119 as integer),idobj from n5zadanie where pTypDzialania=@idobj_par
union
select TOP 5 'typeid'=cast(10153 as integer),idobj from n5typdzialania where pTypNadrzedny=@idobj_par
union
select TOP 5 'typeid'=cast(10238 as integer),idobj from n5pozdokprod where pdp_pTypDzial=@idobj_par
go

