-- DB13
--------------------------------------------------------------
if exists (select * from sysobjects where name='nx_lex_order')
	drop function nx_lex_order
go

create function dbo.nx_lex_order(@symbol varchar(32), @znak varchar(1))
returns varchar(96)
with encryption
as
begin
    declare @iter int
    declare @start int
    declare @strresult varchar(96)

    set @iter = 1
    set @start = 1
    set @strresult = ''
	
    while @iter <= datalength(@symbol)
        begin
            if substring(@symbol,@iter,1) = @znak
                begin
                    if @start = 1
                        set @strresult = @strresult + substring(@symbol,1,@iter)
					else
                        set @strresult = @strresult + isnull(replicate('0',6-(@iter-@start)),'') + substring(@symbol,@start,@iter-@start+1)

                    set @start=@iter+1
                end
            set @iter = @iter + 1
        end

    if @start = 1
        set @strresult = @strresult + substring(@symbol,1,@iter)
	else
        set @strresult = @strresult + isnull(replicate('0',6-(@iter-@start)),'') + substring(@symbol,@start,@iter-@start)

    return isnull(@strresult,@symbol)
end