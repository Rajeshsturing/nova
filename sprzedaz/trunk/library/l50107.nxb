#ifndef LIBRARY_KSIEGOWOSC
#define LIBRARY_KSIEGOWOSC

private function count_salda(byref ma , byref wn)

	if isNull(ma) then
		ma = 0
	end if	
	if isNull(wn) then
		wn = 0
	end if

	ma = CCur(ma)
	wn = CCur(wn)

	if (wn-ma) >= 0 then
		wn = wn - ma
		ma = 0
	else
		ma = (-1) * (wn - ma)
		wn = 0 
	end if

end function


#endif