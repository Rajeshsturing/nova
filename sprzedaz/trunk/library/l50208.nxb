#ifndef LIBRARY_50208
#define LIBRARY_50208

#comment '--------------- "naprawa" GM -------------------------------
#comment '------------------------------------------------------------


function gm_ensure_accuracy_internal(byref varLog)

 if nxm_jse_mode() = NXM_JSE_MODE_NEW then
	'nxm-jse: fill here
	gm_ensure_accuracy_internal = false
 else
	gm_ensure_accuracy_internal = false
	dim pNAVOGMSrvr : set pNAVOGMSrvr = trans_.CreateServerExtension("navogm.n5gmsvr") 
	gm_ensure_accuracy_internal = pNAVOGMSrvr.validate(varLog)
end if

end function

function gm_check_operations(byref varLog)
	gm_check_operations = false
	dim pNAVOGMSrvr : set pNAVOGMSrvr = trans_.CreateServerExtension("navogm.n5gmsvr") 
	gm_check_operations = pNAVOGMSrvr.check(varLog)
end function

function gm_ensure_accuracy_automatic(nNumOperOfChange,nAccuracyLevel,byref varLog)

	if nAccuracyLevel = GM_ACCURACY_USE_CURRENT then
		nAccuracyLevel = trans_.var(GVAR_GM_ACCURACY_LEVEL)
	end if 
	
	select case nAccuracyLevel
	case GM_ACCURACY_NONE
		gm_ensure_accuracy_automatic = true
	case GM_ACCURACY_QUANTITY
		dim pTestRS
		'1. sprawdz czy nie bedzie minusa na koncu
		set pTestRS = trans_.createadors( _
			"select top 1 gms_pProd from n5gmstan group by gms_pProd,gms_pMag,gms_pOpak having sum(gms_curIlosc) < 0.0")
		gm_ensure_accuracy_automatic = (pTestRS.EOF)
		'2. sprawdz dokladniej
		if gm_ensure_accuracy_automatic then
			set pTestRS = trans_.createadors("select isnull((select max(gmo_nNumOp) from n5gmop),0) " )
			'jesli to nie jest ostatnia - sprawdzaj na serwerze
			if nNumOperOfChange < pTestRS(0).value then
				gm_ensure_accuracy_automatic = gm_check_operations(varLog)
			end if
		end if
		set pTestRS = nothing

	case GM_ACCURACY_PRICE
		gm_ensure_accuracy_automatic = gm_check_operations(varLog)
	case else
		gm_ensure_accuracy_automatic = false
	end select
#ifdef TRACE_GM
	if gm_ensure_accuracy_automatic then
		IMPTRACE("gm_ensure_accuracy_automatic PASSED")
	else
		IMPTRACE("gm_ensure_accuracy_automatic FAIL")
	end if
#endif
end function

'-------------------------------------------------
'-----  Zestaw funkcji dla n5ptop, n5ptstan  -----
'-------------------------------------------------
function pt_ensure_accuracy_automatic(nAccuracyLevel,byref varLog)
  select case nAccuracyLevel
	case GM_ACCURACY_NONE
		pt_ensure_accuracy_automatic = true
	case GM_ACCURACY_PRICE
		pt_ensure_accuracy_automatic = false
		dim pNAVOGMSrvr : set pNAVOGMSrvr = trans_.CreateServerExtension("navogm.n5gmsvr") 
		pt_ensure_accuracy_automatic = pNAVOGMSrvr.check_pt(varLog)
  end select
end function

function pt_ensure_accuracy_internal(byref varLog)
	pt_ensure_accuracy_internal = false
	dim pNAVOGMSrvr : set pNAVOGMSrvr = trans_.CreateServerExtension("navogm.n5gmsvr") 
	pt_ensure_accuracy_internal = pNAVOGMSrvr.validate_pt(varLog)
end function

function pt_check_operations(byref varLog)
	pt_check_operations = false
	dim pNAVOGMSrvr : set pNAVOGMSrvr = trans_.CreateServerExtension("navogm.n5gmsvr") 
	pt_check_operations = pNAVOGMSrvr.check_pt(varLog)
end function

