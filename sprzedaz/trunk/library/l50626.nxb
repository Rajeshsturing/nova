#comment ' insert_SecurityObjectCustom(byval pGroup , byval strGroupName, byval strSODDesc, byval nIdObj, byval nTypeId, byval strUserWhere, byval bRead, byval bUpdate, byval bDelete, byval bInsert)
#comment ' insert_SecurityObjectCustom_save(byval strGroupName, byval strSODDesc, byval nIdObj, byval nTypeId, byval strUserWhere, byval bRead, byval bUpdate, byval bDelete, byval bInsert)
