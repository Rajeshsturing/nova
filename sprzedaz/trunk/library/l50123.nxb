#ifndef SELECT_FILES_LIB
#define SELECT_FILES_LIB

#ifndef LIBRARY_50203
#include "50203"
#endif

'-----------------------------------------------------------------------
'WYBOR PLIKOW
'-----------------------------------------------------------------------


'-----------------------------------------------------------------------
'wybieranie pojedynczego pliku
'-----------------------------------------------------------------------
function SelectFile(byval strInitialDir,byval strMask,byval strNameMask)
	if has_nxm_feature("select_file") then
		SelectFile = nx_.nxm_features.select_file(strInitialDir, strMask)
	else
		dim pFilesPage: set pFilesPage=doc_.getmodule(MODULE_CHOICE_FILE)
		SelectFile=pFilesPage.select_file(strInitialDir, strMask, strNameMask)
	end if
end function

'-----------------------------------------------------------------------
'wybieranie wielu plikow
'-----------------------------------------------------------------------
function SelectFiles(byval strInitialDir,byval strMask,byval strNameMask, byval nMaxFiles)
	dim pFilesPage: set pFilesPage=doc_.getmodule(MODULE_CHOICE_FILE)
	SelectFiles=pFilesPage.select_files(strInitialDir, strMask, strNameMask, nMaxFiles)
end function


'-----------------------------------------------------------------------
'wybieranie pojedynczego katalogu
'-----------------------------------------------------------------------
function SelectFolder(byval strInitialDir)
	dim pFilesPage: set pFilesPage=doc_.getmodule(MODULE_CHOICE_FILE)
	SelectFolder=pFilesPage.select_folder(strInitialDir)
end function

'-----------------------------------------------------------------------
'wybieranie katalogu + nazwy pliku
'strFileName - poczatkowa nazwa pliku
'-----------------------------------------------------------------------
function SelectFolderNewFile(byval strInitialDir, byval strFileName)
	if has_nxm_feature("save_as_file") then
		SelectFolderNewFile = nx_.nxm_features.save_as_file(strInitialDir, strFileName)
	else
		dim pFilesPage: set pFilesPage=doc_.getmodule(MODULE_CHOICE_FILE)
		SelectFolderNewFile=pFilesPage.select_folder_newfile(strInitialDir, strFileName)
	end if
end function

#endif