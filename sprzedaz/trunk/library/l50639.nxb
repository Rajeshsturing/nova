				"		bError = false																" + vbCrLf + _
				"	end function																		" + vbCrLf + _
				" function c##CTRLID_DOKLADNIE##_ongetdata(byref oCtrl)							" + vbCrLf + _
				"		desc10(page_.ctrl(CTRLID_RADIO).value)									" + vbCrLf + _
				"		c##CTRLID_DOKLADNIE##_ongetdata=true														" + vbCrLf + _
				" end function " + vbCrLf
				
 	  m_strVBPart = m_strVBPart + vbCrLf + _
				"	function c##CTRLID_POCZATEK##_ondataentered(oCtrl, newValue)			" + vbCrLf + _
				"		bError = false																" + vbCrLf + _
				"	end function																		" + vbCrLf + _
				" function c##CTRLID_POCZATEK##_ongetdata(byref oCtrl)							" + vbCrLf + _
				"		desc10(page_.ctrl(CTRLID_RADIO).value)									" + vbCrLf + _
				"		c##CTRLID_POCZATEK##_ongetdata=true														" + vbCrLf + _
				" end function " + vbCrLf
				
 	  m_strVBPart = m_strVBPart + vbCrLf + _
				"	function c##CTRLID_ZAWIERA##_ondataentered(oCtrl, newValue)			" + vbCrLf + _
				"		bError = false																" + vbCrLf + _
				"	end function																		" + vbCrLf + _
				" function c##CTRLID_ZAWIERA##_ongetdata(byref oCtrl)							" + vbCrLf + _
