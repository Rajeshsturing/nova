'instrukcje inicjujące stany kontrolek - do fopen
public function get_vb_init_ctrls_part(ByVal nParamNr, ByRef pRPDB): get_vb_init_ctrls_part = ""
	Dim firstId: firstId = nParamNr * 10    
	m_strFopenPart = "init" + CStr(firstId) + "()" + vbCrLf
    get_vb_init_ctrls_part = m_strFopenPart
end function

private function przepiszBezPustych(byval pstrKontzpus,byref pstrKonta)
	dim iter
	for iter = 0 to pstrKontzpus.UpperIndex()
		if pstrKontzpus.value(iter) <>"" then
			pstrKonta.add pstrKontzpus.value(iter)
		end if
	next
end function

public function get_where_part(ByRef pTransaction) : get_where_part = ""
dim iMode, strValue1, strValue2
	if trans_.isvar(9829) then
		iMode = trans_.var(9829)
	else
		trans_.message 0,0,"Brak zmiennej przekazującej nr. zaznaczonej pozycji"
		exit function
	end if
	
	if trans_.isvar(9830) then
		strValue1 = trans_.var(9830)
		if trans_.isvar(9831) then
			strValue2 = trans_.var(9831)
		end if
	else
		trans_.message 0,0,"Brak zmiennej przekazującej wpisaną wartość"
		exit function
	end if
	
	dim pstrKonta,pstrKontaZPus
	dim iter,strConnect
  
	select case iMode
	  case 1
		  get_where_part = "(" + m_strBindExpr + " is not null)"
	  case 2
		  get_where_part = "(" + m_strBindExpr + " like '"+strValue1+"')"
	  case 3
		  get_where_part = "(" + m_strBindExpr + " like '"+strValue1+"%')"
	  case 4
		  get_where_part = "(" + m_strBindExpr + " like '%"+strValue1+"%')"
	  case 5
      get_where_part = "(" + m_strBindExpr + " between '"+strValue1+"' and '"+strValue2+"')"
	  case 6
      get_where_part = "(" + replace(replace(m_strBindExpr,"isnull(",""),",'')","") + " is null)"
  'bez typu zasobu
	end Select
		m_strWhereCustom = get_where_part
end function

public property let strWhereCustom(ByVal nMode)
end property

public property get strWhereCustom()
strWhereCustom = m_strWhereCustom
end property

'czy wyswietlac czy nie
public function is_complete():is_complete = false
end function

'czy prawidlowe wartości
public Function is_valid(ByRef strMessage ) 
	is_valid = true
end Function

public Function Add2CtrlTable(byval id)
	if isEmpty(ctrls_id) then
		set ctrls_id = trans_.afc.new_navoarray()
	end if

	ctrls_id.add clng(id)
end function

'transfer z kontrolek na obiekt filtru
public Function Update(ByVal nParamNr , ByVal page )
	if isEmpty(ctrls_obj) then
		set ctrls_obj = trans_.afc.new_navoarray()
	end if	

	dim iter
	for iter = 0 to ctrls_id.UpperIndex
		ctrls_obj.add page.ctrl(ctrls_id.value(iter))
	next
end Function

public Function get_desc_from_page(ByVal nParamNr , ByVal page ):get_desc_from_page = ""
    Dim firstId: firstId = nParamNr * 10
end Function

public Function paramtype()
    paramtype = -1
end Function

end class

function new_custom(byval strParamName)
	Set new_custom = New RapParamCustom
    new_custom.ParamName = strParamName
end function

