#define CTRLID_RADIO             500
#define CTRLID_DOKLADNIE         501
#define CTRLID_POCZATEK          502
#define CTRLID_ZAWIERA           503
#define CTRLID_ZAKRES_OD         504
#define CTRLID_ZAKRED_DO         505
#define CTRLID_FILTR_TEXT        506

class RapParamCustom
  private m_strXMLPart 
  private m_strVBPart 
  private m_strFopenPart 
  private m_strParamName 
  private m_strBindExpr 
  private m_strBindExprRight 
  private m_nMode
  private m_strWhereCustom
  private m_bAllowNone
  private m_strExtraXMLPart
  private m_strExtraInitPart

  public ctrls_id
  public ctrls_obj


public Sub initialize()
  m_nMode = 0
  m_strXMLPart = ""
  m_strVBPart = ""
  m_strBindExpr = ""
  m_strBindExprRight = ""
  m_strFopenPart = ""
  m_strExtraXMLPart = ""
  m_bAllowNone = False
end Sub

public function allow_none()
  m_bAllowNone = true
end function

public property let ParamName(ByVal vData )
  m_strParamName = vData
end property
public property get ParamName()     
  ParamName = m_strParamName
end property

public property let ExtraXML(ByVal strData )
  m_strExtraXMLPart = strData
end property

public property let ExtraINIT(ByVal strData )
  m_strExtraInitPart = strData
end property

public property let mode(ByVal nMode)
  trans_.var(9829) = nMode
end property

public property get mode()
	if trans_.isvar(9829) then
    mode = trans_.var(9829)
	else
		trans_.message 0,0,"Brak zdefiniowanej zmiennej 9829"
		mode = 0
	end if
end property

public function Bind(ByVal strTableName , ByVal strFieldName ) 
  m_strBindExpr = strTableName + "." + strFieldName
  Set Bind = Me
end function

public function BindExpr(ByVal strBindExpr ) 
  m_strBindExpr = strBindExpr
  Set BindExpr = Me
end function

public function BindExprRight(ByVal strBindExprRight ) 
  m_strBindExprRight = strBindExprRight
  Set BindExprRight = Me
end function

public function get_bindexpr() 
  get_bindexpr = m_strBindExpr
end function

public function get_xml_part(ByVal nParamNr, ByRef pRPDB)

  dim firstId : firstId = nParamNr * 10
    
  m_strXMLPart = vbCrLf + " <tabitem name='" + CStr(firstId) + "' title='" + ParamName + "' style='" + CStr(STYLE_TABLE_BODY) + "'>" + vbCrLf		
  m_strXMLPart = m_strXMLPart + vbCrLf + m_strExtraXMLPart
  m_strXMLPart = m_strXMLPart + vbCrLf + " </tabitem>" + vbCrLf

  get_xml_part = m_strXMLPart
end function


public function get_vb_part(ByVal nParamNr , ByRef pRPDB )

	dim firstId: firstId = nParamNr * 10
    	
  m_strVBPart = m_strVBPart + vbCrLf +_
    "function check" + CStr(nParamNr) + vbCrLf +_
		"	check" + CStr(nParamNr) + " = true" + vbCrLf +_
		"end function "

	m_strVBPart = m_strVBPart + vbCrLf + _
    " function init" + CStr(firstId) + vbCrLf

	m_strVBPart = m_strVBPart + m_strExtraInitPart + vbCrLf

	m_strVBPart = m_strVBPart + vbCrLf + _
	"   end function" + vbCrLf
  
  if firstId <> 10 then
	m_strVBPart = m_strVBPart + vbCrLf + _
     "   function desc" + CStr(firstId) + "(newValue)" + vbCrLf + _
		 " " + vbCrLf + _
     "   end function" + vbCrLf
end if

if firstId = 10 then
		m_strVBPart = m_strVBPart + vbCrLf + _
		"   function desc" + CStr(firstId) + "(newValue) " + vbCrLf + _
		"   if bError then exit function																											" + vbCrLf + _
    "   dim strDesc, strValue																																				" + vbCrLf + _
		"   trans_.var(9829) = newValue																												" + vbCrLf + _
		"		dim strDokladnie : strDokladnie = page_.ctrl(CTRLID_DOKLADNIE).value							" + vbCrLf + _
    "   dim strPoczatek : strPoczatek =  page_.ctrl(CTRLID_POCZATEK).value 								" + vbCrLf + _
    "   dim strZawiera : strZawiera =  page_.ctrl(CTRLID_ZAWIERA).value 									" + vbCrLf + _
		"   dim strOd : strOd = page_.ctrl(CTRLID_ZAKRES_OD).value 														" + vbCrLf + _
		"   dim strDo : strDo = page_.ctrl(CTRLID_ZAKRED_DO).value 														" + vbCrLf + _
		"   if clng(newValue) = 1 then																												" + vbCrLf + _
    "       strDesc=""Pole '" + ParamName + "' dowolne							""										" + vbCrLf + _
		"				trans_.var(9830) = "" (1=1) ""																								" + vbCrLf + _
    "   elseif clng(newValue)=2 then																											" + vbCrLf + _
    "       strDesc=""Pole '" + ParamName + "' równe '""+strDokladnie+	""'""							"	+ vbCrLf + _
		"				trans_.var(9830) = strDokladnie																								" + vbCrLf + _
		"		strValue = strDokladnie																												    " + vbCrLf + _
    "   elseif clng(newValue)=3 then																											" + vbCrLf + _
    "       strDesc=""Pole '" + ParamName + "' rozpoczyna się od '""+strPoczatek+	""'""		"	+ vbCrLf + _
		"				strValue = strPoczatek																											  " + vbCrLf + _
		"				trans_.var(9830) = strPoczatek																								" + vbCrLf + _
    "   elseif clng(newValue)=4 then																											" + vbCrLf + _
    "       strDesc=""Pole '" + ParamName + "' zawiera '""+strZawiera+	""'""							"	+ vbCrLf + _
		"				strValue = strZawiera																											    " + vbCrLf + _
		"				trans_.var(9830) = strZawiera																									" + vbCrLf + _
		"   elseif clng(newValue)=5 then																										  " + vbCrLf + _
		"       strDesc=""Pole '" + ParamName + "' zawiera się między '""+strOd+	""' i '""+strDo+	""'"""	+ vbCrLf + _
		"				strValue = strOd	+ strDo																								      " + vbCrLf + _
		"				trans_.var(9830) = strOd																							        " + vbCrLf + _
		"				trans_.var(9831) = strDo																								      " + vbCrLf + _
    "   elseif clng(newValue)=6 then																											" + vbCrLf + _
    "       strDesc=""Pole '" + ParamName + "' bez typu  							""									"	+ vbCrLf + _
    "  end if																																							" + vbCrLf + _
    "   page_.ctrl(CTRLID_FILTR_TEXT).text = strDesc 																			" + vbCrLf + _
    "   page_.ctrl(CTRLID_FILTR_TEXT).forecolor=rgb(0,0,0) 																" + vbCrLf + _
		"   end function																																			" + vbCrLf
		
		
    m_strVBPart = m_strVBPart + vbCrLf + _
				"	function c##CTRLID_RADIO##_ondataentered(oCtrl, byval newValue) " + vbCrLf + _
				"		bError = false																	" + vbCrLf + _
				"		c##CTRLID_RADIO##_ondataentered=true													" + vbCrLf + _
