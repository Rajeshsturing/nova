				"		elseif clng(newValue)=6 then												" + vbCrLf + _
				"			 bEnableBezTypu=true											" + vbCrLf + _
				"		else																								" + vbCrLf + _
				"		end if																							" + vbCrLf + _
				"		page_.ctrl(CTRLID_DOKLADNIE).disable=not bEnableDokladnie				" + vbCrLf + _
				"		page_.ctrl(CTRLID_POCZATEK).disable=not bEnablePoczatek					" + vbCrLf + _
				"		page_.ctrl(CTRLID_ZAWIERA).disable=not bEnableZawiera					" + vbCrLf + _
				"		page_.ctrl(CTRLID_ZAKRES_OD).disable=not bEnableOd				" + vbCrLf + _
				"		page_.ctrl(CTRLID_ZAKRED_DO).disable=not bEnableDo				" + vbCrLf + _
				"   end function" + vbCrLf

	  m_strVBPart = m_strVBPart + vbCrLf + _
				"	 function c##CTRLID_RADIO##_ongetdata(byref oCtrl) " + vbCrLf + _
