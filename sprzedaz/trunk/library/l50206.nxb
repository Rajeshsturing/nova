	id = trans_.findobjid(TYPEID_N5KLIENT_PRACOWNIK,strSQL)			
	if(id >0) then
		FindNadawca = id
		set pObjNadawca = trans_.getobj(TYPEID_N5KLIENT_PRACOWNIK,id) 
		count = count + clng(1)
	end if
	if(id = clng(-1) or count>1) then
		FindNadawca = clng(-1)
