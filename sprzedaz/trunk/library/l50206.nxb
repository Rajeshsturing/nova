	end if
	if(id = clng(-1) or count>1) then
		FindNadawca = clng(-1)
		set pObjNadawca = nothing
'		NadawcaDict.Add cstr(mail), cstr(-1)
		exit function
	end if
	
'	if id = clng(0) then
		'NadawcaDict.Add cstr(mail), clng(0)
'	else
'		NadawcaDict.Add cstr(mail), cstr(pObjNadawca.type)+ ";" + cstr(pObjNadawca.idobj)
'	end if

end function

'--------------------------------------------------------------------------------
'Wysyła dokument poczta elektroniczna
'--------------------------------------------------------------------------------
private function SendDokument(byref pObj,byval strFldName,byval strEmail, byref pDoks, byval strSubject, byval strText, byref pMAPIP, byref pAttachments):SendDokument=false

	dim pEmailModule
	set pEmailModule=doc_.getmodule(PAGE_FORM_EMAIL)

	dim strTo:strTo=""
	dim strMsg:strMsg=strText

	if strFldName="" then
		strFldName = "strEmail"
	end if

	if pObj is nothing then
		strTo = strEmail
	else
		strTo=pObj.field(strFldName)	
	end if

	if ( len(strTo)=0 ) then
		nx_.trace.error "EMA001","Brak adresu e-mail adresata"
		exit function
	end if

	dim arrZalaczniki
	set arrZalaczniki=trans_.afc.new_navoarray()

	if (not pDoks is nothing) then

		dim i
		for i=0 to pDoks.Count()-1
			dim pDok
			set pDok=pDoks.Value(i)
			
			if (not pDok.fPlik.isEmpty()) then
				dim pAttachment
				set pAttachment=new CMailAttachment

				dim pFD, bOK
				set pFD=CFileDrive(bOK)

				set pAttachment.pSO=pDok.fPlik

				if (bOk) then
					pAttachment.strName=pFD.GetFileName(RemoveComputerName(pDok.strFileName))
				else
					pAttachment.strName=RemoveComputerName(pDok.strFileName)
				end if

				arrZalaczniki.Add pAttachment
			end if

		next

	end if

	if (not pAttachments is nothing) then
		dim n
		for n=0 to pAttachments.Count()-1
			arrZalaczniki.Add pAttachments.Value(n)
		next
	end if
	
	if ( len(strTo)>0 ) then
		SendDokument=pEmailModule.send_email(pMAPIP, strTo, strSubject, strMsg, arrZalaczniki)
		exit function
	end if

end function

dim g_AutoSaveTask:g_AutoSaveTask=true
dim g_TaskID:g_TaskID=clng(0)

'--------------------------------------------------------------------------------
'Zapisuje wysyłke jako zadanie 
'pObj wref (klient, prac..) pDok - dokument
'--------------------------------------------------------------------------------
private function SaveDokumentZadanie(byref pObj, byref pDoks, byval strSubject, byval strText, byval pOptions):SaveDokumentZadanie=false
	dim pContext
	set pContext=new CMailContext

	set pContext.pZlecajacy=getCurrentWykonawca()
	set pContext.pNadawca=pObj		'OPT	wr -> pracownik_klientawr -> pracownikwr -> klient
	pContext.strSubiect=strSubject
	pContext.strBody=strText

	dim pTaskAttachment
	set pTaskAttachment=trans_.afc.new_navoarray()

	dim i
	for i=0 to pDoks.Count()-1
		if (not pDoks.Value(i).fPlik.isEmpty() ) then
			dim pNavoFile
			set pNavoFile=new CNavoFile

			set pNavoFile.so=pDoks.Value(i).fPlik
			pNavoFile.filename=pDoks.Value(i).strFileName
			set pNavoFile.pDokument=pDoks.Value(i)

			pTaskAttachment.Add pNavoFile
		end if
	next

	set pContext.arrAttachment=pTaskAttachment

	select case pObj.type
		case TYPEID_N5KLIENT
			set pContext.pKlient=pObj

		case TYPEID_N5KLIENT_PRACOWNIK
			set pContext.pKlient=pObj.pKlient

		case TYPEID_N5PRACOWNIK
			set pContext.pKlient=nothing

	end select

	'ustaw czas i datę
	pContext.dDate=CDate(trans_.var(GVAR_SYSDATE))
	pContext.tTime=trans_.var(GVAR_SYSTIME)
	if (not getCurrentWykonawca() is nothing) then
		set pContext.pNadawca=getCurrentWykonawca().wrefObiekt
	end if

	'ustaw status zadania
	pContext.nStatus=clng( N5ZADANIE_ZLECONE )

	'czy automatycznie zapisywać zadanie 
	pContext.bAutoSave=g_AutoSaveTask

	if not pOptions is nothing then
		pContext.bPrzyp = pOptions.m_bPrzyp
		pContext.dDataPrzyp = cdate(pOptions.m_dDataPrzyp)
		pContext.tCzasPrzyp = pOptions.m_tCzasPrzyp
	end if

	SaveDokumentZadanie=AddZadanie( pContext )
	g_TaskID=pContext.idZadanie
end function

#endif
