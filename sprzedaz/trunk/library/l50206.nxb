
#ifndef _L50206_
#define _L50206_

'---------------------------------------------------------
'
'	CMailContext
'	
'	obiekt "kontekstu" podczas importu z maila
'---------------------------------------------------------
#include "50517"

class CNavoFile
	public filename
	public so
	public pDokument		'wskaźnik na dokument
							'domyślnie nothing - jednak gdy bedzie
							'wskazywał na dokument to nie będziemy
							'przy dodawaniu zadania robić już
							'nowego dokumentu tylko damy wsk. na
							'dokument istniejacy

	private sub Class_Initialize()
		set pDokument=nothing
	end sub

end class

class CMailContext

	public pWykonawca	'Obiekt wykonawcy
	public pNadawca		'Obiekt nadawcy
	public pZlecajacy	'Obiekt N5WYKONAWCA skojarzony z nadawcą
	public pKlient		'Jeśli nadawca jest typu n5klient lub n5klient_pracownik to właściwy klient
	public strSubiect	'Temat wiadomości (subject zadania)
	public strBody		'Treść wiadomości (zadania)
	'public idProcedura  'pKrokProcedury	(Roboczo) pierwszy z brzegu obiekt (będzie pochodził z preloadu)
	public arrAttachment'tabela odnośników - wskaznikow na obiekt CNavoFile!
	public dDate		'data otrzymania maila (zadania)
	public tTime		'czas otrzymania	(czas zadania)
	public nStatus
	public pDokument	'wskaźnik na n5dokument gdy nie jest nothing
						'ignorowane jest arrAttachment default:nothing

	public bAutoSave	'auto zapisywanie przez AddZadanie - domyslnie
						'TAK
	public idZadanie	'id obiektu zadania

	public bPrzyp
	public dDataPrzyp
	public tCzasPrzyp

	private sub Class_Initialize()
		nStatus=clng(010) 'zlecone
		set pDokument=nothing
		set pKlient=nothing
		bAutoSave=true
		idZadanie=clng(0)
	end sub
	
    Private Sub Class_Terminate()   'OK
	end sub

end class


private function AddZadanie (byref context)
	AddZadanie = false
	
	'wybor rejestru
	dim idRejestr : idRejestr = choose_rejestr_dok("N5REJESTRDOK_ZADANIA", true, "Wybór rejestru zadań")
	if idRejestr <= 0 then
		exit function
	end if

	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = clng(idRejestr)

	Dim pObjZadanie:set pObjZadanie = trans_.newobj(TYPEID_N5ZADANIE)
	context.idZadanie=pObjZadanie.IdObj

	if context.bPrzyp="1" then
		pObjZadanie.dDataPrzyp = cdate(context.dDataPrzyp)
		pObjZadanie.tCZasPrzyp = context.tCZasPrzyp
	end if

	pObjZadanie.nStatus	= context.nStatus		'zlecone
	pObjZadanie.DDataZlec = context.dDate
	pObjZadanie.tCzasZlec = context.tTime

	set pObjZadanie.pZlecajacy = nothing	
	set pObjZadanie.pZlecajacy = context.pZlecajacy
	
	pObjZadanie.ePriorytet = clng(2)					'1-niski2-normalny3-wysoki4-krytyczny
	pObjZadanie.eTypTerminRozp = clng(5)				'1-najszybciej jak można (ASAP)2-nie wcześniej niż3-w momencie4-nie później niż5-obojętne
	pObjZadanie.eTypTerminZak = clng(5)					'Termin zakończenia (typ)	ENUM		1-najszybciej jak można (ASAP)2-nie wcześniej niż3-w momencie4-nie później niż5-obojętne 	010
	'set pObjZadanie.pKlient = context.pKlient			'Klient	*** Ustawia się atomatycznie **

	if pObjZadanie.pKlient is nothing then
		set pObjZadanie.pKlient = context.pKlient			'Klient	*** Ustawia się atomatycznie **
	end if

	pObjZadanie.strTemat = context.strSubiect			'Temat zadania
	pObjZadanie.strOpis = left(context.strBody, 1024)	'Opis zadania
	
	'set pObjZadanie.pProcedura = trans_.getobj(TYPEID_N5PROCEDURA,1) 				'todo: domyślna procedura
	'set pObjZadanie.pKrok = trans_.getobj(TYPEID_N5KROKPROC,1) 
	dim id:id = trans_.findobjid(TYPEID_N5TYPDZIALANIA,"strNazwa='Komunikacja z klientem'")
	if id=0 then		

		if MessageBox("Domyślnym typem działania jest ""Komunikacja z klientem""  - "+_
			"w Twojej bazie nie ma takiego. Naciśnij OK aby wybrać inne. "+_
			"Jeśli wybierzesz Anuluj nie uda się zapisać działania " + context.strSubiect +_ 
			". Okno nie będzie się więcej pokazywać jeśli stworzysz taki właśnie "+_
			"typ działania.", "Brak domyślnego typu działania", vbOKCancel, vbInformation) = vbOK then
			
			'REV:KB:TODO: Arek: lepiej użyć std_choice_list_s
			dim choice : choice = fire_choice_list( TYPEID_N5TYPDZIALANIA, "", "","","","")
			if choice <> 0 then
				set pObjZadanie.pTypDzialania = trans_.getobj(TYPEID_N5TYPDZIALANIA,choice)
			else
				set pObjZadanie.pTypDzialania = nothing	
			end if
		else
			set pObjZadanie.pTypDzialania = nothing
		end if
	else
		set pObjZadanie.pTypDzialania = trans_.getobj(TYPEID_N5TYPDZIALANIA,id)
	end if

'	set pObjZadanie.pTypDzialania = trans_.getobj(TYPEID_N5TYPDZIALANIA,1) 
	
	dim CurrUser:set CurrUser = GetCurrentUser() 'todo: sprawdzanie do którego wykonawcy
	set pObjZadanie.pWykonawca = getCurrentWykonawca()
	
	dim pZadanieZalObj

	if (context.pDokument is nothing) then
		if context.arrAttachment.Count() > 0 then
			dim pFD,bOK
			set pFD=CFileDrive(bOK)
				
			dim index
			'trans_.var(APPVAR_IS_IMPORT)=CLng(1)
			
			for index = clng(0) to context.arrAttachment.Count()-1
				
				if (index = clng(0)) and (context.arrAttachment.Value(0).so is nothing) then 
					index = clng(1)
				end if
							
				
				dim pAttachmentObj	
				set pAttachmentObj = nothing

				
				if (not context.arrAttachment.Value(index).pDokument is nothing) then
					set pAttachmentObj =context.arrAttachment.Value(index).pDokument
				else
					set pAttachmentObj = trans_.newobj(TYPEID_N5DOKUMENT)
					
					'Todo: zmienić sposób numerowania
					pAttachmentObj.strNumDok = "DOK " + cstr(pAttachmentObj.IdObj)

					dim pSO					
					set pSO = context.arrAttachment.Value(index).so
					pAttachmentObj.fPlik.attach pSO 

					
					dim strSubjectTemp
					dim nLen
					
					if index = clng(0) then
						nLen = clng( clng(256) - len("Treść wiadomości email ()") )
						
						if len(context.strSubiect) > nLen then 
							strSubjectTemp = left(context.strSubiect, nLen-clng(3))+ "..."
						else
							strSubjectTemp = context.strSubiect
						end if
						
						pAttachmentObj.strStreszczenie = "Treść wiadomości email (" + strSubjectTemp + ")"
					else
						nLen = clng( clng(256) - len("Załącznik do wiadomości email ()") )
						
						if len(context.strSubiect) > nLen then 
							strSubjectTemp = left(context.strSubiect, nLen-clng(3))+ "..."
						else
							strSubjectTemp = context.strSubiect
						end if
						
						pAttachmentObj.strStreszczenie = "Załącznik do wiadomości email (" + strSubjectTemp +")"

					end if

					pAttachmentObj.strFileName=AddComputerName(context.arrAttachment.Value(index).filename)

					pAttachmentObj.strTematDokum = pFD.GetFileName(context.arrAttachment.Value(index).filename)
					
					dim IdTyp:IdTyp= trans_.findobjid(TYPEID_N5TYPDOKUMENTU, "strNazwa= 'Odebrana korespondencja'")
					set pAttachmentObj.pTypDokumentu = trans_.getobj(TYPEID_N5TYPDOKUMENTU,IdTyp) 				'todo: musi być w preloadzie
					
					pAttachmentObj.dDataWeWy = context.dDate			'Data wpłynięcia/wysłania dokumentu	Data	NE	
					pAttachmentObj.dDataRejestracji	= context.dDate		'Data rejestracji dokumentu	Data	NE	Kiedy informacja o dokumencie trafiła do systemu

					set pAttachmentObj.wpNadawca  = context.pNadawca	'Nadawca dokumentu	Wref	OPT	wr -> pracownik_klientawr -> pracownikwr -> klient

					if not getCurrentWykonawca() is nothing then
						set pAttachmentObj.wpAdresat  = getCurrentWykonawca().wrefObiekt	'TODO: Adresat
					else
					end if
						'TODO: Adresat
					pAttachmentObj.nForma = clng(1)						'1-	tylko forma elektroniczna

				end if

				'dodaj na liste w zadaniu
				set pZadanieZalObj = pObjZadanie.listZalaczniki.AddNew()
				set pZadanieZalObj.wrefZal = pAttachmentObj
	
			next
			'trans_.var(APPVAR_IS_IMPORT)=CLng(0)
		end if

	else 'not pDokument is nothing

		set pZadanieZalObj = pObjZadanie.listZalaczniki.AddNew()
		set pZadanieZalObj.wrefZal=context.pDokument

	end if 'pDokument is nothing

	if (context.bAutoSave) then
		if not trans_.saveobjects then
			AddZadanie = false
		else
			AddZadanie = true
		end if
	else
		AddZadanie = true
	end if

end function

'Jeżeli nie znajdzie zwraca 0,
'Jeżeli znajdzie wiele zwraca -1
'Jeżeli znajdzie jednego zwraca idobj oraz pObjNadawca
private function FindNadawca(byref pObjNadawca, byval mail, byval NadawcaDict):FindNadawca=clng(0)
	dim id
	dim typeid

	'Sprawdzanie, czy mail był już znaleziony
'--------------------------------------
'Zakomentowane korzystanie z Dictionary
'--------------------------------------


'	dim DictItem
'	if NadawcaDict.Exists(mail) then
'		DictItem = NadawcaDict.item(mail) 
'		if(DictItem = cstr(0) or DictItem = cstr(-1)) then
'			set pObjNadawca = nothing
'			FindNadawca  = clng(DictItem)
'			exit function
'		else
'			dim nPos : nPos = instr(1,DictItem,";")
'			if nPos > 0 then
'				typeid = clng(left(DictItem,nPos-1))
'				id = clng(mid(DictItem,nPos+1))
'				set pObjNadawca = trans_.getobj(typeid,id) 
'				FindNadawca  = id
'				exit function
'			end if	
'		end if
'	end if


	dim count:count=clng(0)
	dim strSQL:strSQL = "strEMail = '" + trim(mail) + "'"

	id = trans_.findobjid(TYPEID_N5KLIENT,strSQL)			
