#ifndef _LIBRARY_50629_
#define _LIBRARY_50629_

'szuka strony o zadanym IID - służy do wyszukania innej kopii 'siebie'

function find_page_on_iid(byval nIID)
	set find_page_on_iid = nothing

	dim pPageStack
	for each pPageStack in doc_
		if (not pPageStack.gettoppage is nothing) then
			if pPageStack.gettoppage.iid = nIID then
				set find_page_on_iid = pPageStack.gettoppage
				exit function
			end if
		end if
	next

end function

#endif 