	public sub create_prod_info(byref oAppDoc,byval pProd , byval pHli , byref pTB)

#ifdef APPCONFIG_GRID_CHOOSE_PROD_MODE_2
		set pHli = oAppDoc.createhlistr("varFunctionHLI=custom_function")
		pHli.prop(1) = pProd.idobj
#endif
		pTB.cell.keepline=true
		if m_bByNazwa then
			pTB.addtexthli(pProd.strNazwa, pHli).element.bold = true
			pTB.newcell.addtext(pProd.strIndeks).element.bold = true
		else
			pTB.addtexthli(pProd.strIndeks ,  pHli).element.bold = true
			pTB.newcell.addtext(pProd.strNazwa).element.bold = true
		end if

#ifdef _IOW
		'pTB.addtexthli(pProd.strCecha1 ,  pHli).element.bold = true
		pTB.newcell.addtext(pProd.strCecha1).element.bold = true
#endif

		exit sub

		if m_bPrintOpak then

			pTB.newrow.newcell
			pTB.cell.colspan=clng(2)
			pTB.addctrl CTRL_TYPE_TABLE	, -1

			dim pTabOpak : set pTabOpak = m_pAFC.new_tb(page_).attach(pTB.element).removeall			

			dim elem,iter
			iter = 1
			for each elem in pProd.listOpakowania
				create_opak_info oAppDoc,pProd,elem,iter,pTabOpak				
				iter = iter + 1
			next

		end if

	end sub


	public sub create_header(byref pTB)

		if m_bByNazwa then
			pTB.addtext "Nazwa"
			pTB.newcell.addtext "Indeks"
		else
			pTB.addtext "Indeks"
			pTB.newcell.addtext "Nazwa"
		end if

#ifdef _IOW
		pTB.addtext "Oznaczenie producenta"
		pTB.newcell.addtext "Oznaczenie producenta"
#endif

'		if m_bPrintOpak then
'			pTB.newcell.addtext "Opakowania, ceny i dostępność"
'		end if

	end sub


	public sub create_group_row(byref pTB , byval strName , byval pHli)
		pTB.addtexthli strName , pHli
		dim nColspan:nColspan = 2
'		if m_bPrintOpak then
'			nColspan = nColspan + 1
'		end if
		pTB.cell.colspan = nColspan
	end sub

end class



function init_configurator()
	set g_pConfigurator = new CProdListConfigurator
	g_pConfigurator.init_stan_mag("")
	g_pConfigurator.init_ceny
end function



function init_configurator_ex(byval bPrintCeny , byval bPrintStanMag , byval bPrintOpak , byval bByNazwa)
	set g_pConfigurator = new CProdListConfigurator

'	g_pConfigurator.m_bByNazwa = bByNazwa
	g_pConfigurator.m_bPrintOpak = bPrintOpak

	if bPrintStanMag then
		g_pConfigurator.init_stan_mag("")
	end if

	if bPrintCeny then
		g_pConfigurator.init_ceny()
	end if

end function




function init_configurator_profile(byval bByNazwa)

	set g_pConfigurator = new CProdListConfigurator
'	g_pConfigurator.m_bByNazwa = bByNazwa

	g_pConfigurator.m_bPrintOpak = (getuserprofileObj(USERPROF_PRODCHOICELIST_SHOWOPAK).wartosc) = "1"
	if g_pConfigurator.m_bPrintOpak then
		g_pConfigurator.init_ceny_profile getuserprofileObj(USERPROF_PRODCHOICELIST_CENY).wartosc
		g_pConfigurator.init_stan_mag_profile getuserprofileObj(USERPROF_PRODCHOICELIST_MAGAZYNY).wartosc
	end if
	
		
end function


dim g_pConfigurator




function BulidProdRow_Adv(byref pTableBuilder, byref pHli, byref pObj, byval strName)

	if (pHli is nothing) then
		'Budowanie nagłówka		
		g_pConfigurator.create_header pTableBuilder
	else
		if (not pObj is nothing) then			
			'Budowanie elementu
			g_pConfigurator.create_prod_info doc_,pObj , pHli ,  pTableBuilder			
		else
			'budowanie grupy (szufladki)			
			g_pConfigurator.create_group_row pTableBuilder , strName , pHli
		end if
	end if
	BulidProdRow_Adv = true
end function


#endif









#ifdef INCLUDE_BULID_CHOICELIST_ROW_TRANS


function BulidTransRow(byref pTableBuilder, byref pHli, byref pObj, byval strName)

	if (pHli is nothing) then
		'Budowanie nagłówka		
		clear_choice()'dzieki temu wybor bedzie dotyczyl TYLKO tego co widoczne
		pTableBuilder.addtext "Symbol transakcji"
	else
		if (not pObj is nothing) then			
			'Budowanie elementu
			pTableBuilder.addctrl CTRL_TYPE_CHECKBOX, -1
			pTableBuilder.element.border = 0
			pTableBuilder.element.addnew(CTRL_TYPE_STATIC,-1).text = ""
			pTableBuilder.element.value = "1"
			
			'dodajemy do tabilcy odpoeidni obiekt
			dim pTrans:set pTrans = new CObjsCheckbox
			set pTrans.m_pCtrl = pTableBuilder.element
			pTrans.m_nIdObj = pObj.idobj
			pCtrls.add pTrans						
			pTableBuilder.addtexthli pObj.text, doc_.createhlistr( _
				doc_.afc.convert.formatter(" OPEN_FORM_PROXY_HLI_USAGE(%1,%2,%3) ").add(CStr(pObj.type)).add(CStr(pObj.idobj)).add(cstr(USAGE_VIEW)).done())
			pTableBuilder.element.tip = "Pokaż szczegóły"

		else			
			pTableBuilder.addtext strName' , pHli
		end if						
	end if
	BulidTransRow = true

end function


#endif






