#endif


'formatowanie liczby zwracanej przez choicelist w przypadku kliknięcia na opakowanie
function format_idprod_pl (byref idProdukt , byref lp)
	lp = (idProdukt mod 1000) * -1
	idProdukt = (idProdukt \ 1000) * -1
end function

'funkcja odrwrotna do powyzszej - z idprod i lp tworzy twór, który zostanie zwrocopny po kliknięciu na opakowanie
function compose_choice (byval idProdukt , byval lp)
	compose_choice = ((1000 * idProdukt) + lp)   * -1
end function


function OnCustomChoice_opakowanie(byval hli)
	page_.result = compose_choice(hli.prop(1) , hli.prop(2))
	page_.goback
end function





#ifdef INCLUDE_BULID_DOSTAWCA_CHOICELIST_ROW

function BulidDostawcaRow(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		pTableBuilder.addtext "Dostawca"
		pTableBuilder.newcell
		pTableBuilder.addtext "Data ostatniego zakupu"

		pTableBuilder.newcell.cell.align = ALIGN_RIGHT
		pTableBuilder.addtext "Brutto"
		pTableBuilder.newcell.cell.align = ALIGN_RIGHT
		pTableBuilder.addtext "Aktualna brutto"

	else
		if (not pObj is nothing) then						
			'Budowanie elementu			
			pTableBuilder.cell.keepline = true
			pTableBuilder.addtexthli pObj.text, pHli
			ostatnie_ceny_zakupu pObj , pTableBuilder
		else			
			'Budowanie grupy
			BulidDostawcaRow = false
			exit function
		end if
	end if
	BulidDostawcaRow = true
end function



dim g_choicelist_idprod
function ostatnie_ceny_zakupu(byval pdostawca , byref tb)
	dim rs:set rs = trans_.createadors(" select top 20 p_ddatazakupu as data , c_curcenabrutto as cb , n5jednostka.strSkrot as jedn from vlist_n5zakup_listpozycje join n5jednostka on vlist_n5zakup_listpozycje.p_pWaluta = n5jednostka.idobj where p_pdostawca="+cstr(pdostawca.idobj) + " and c_pprodukt="+ cstr(g_choicelist_idprod) + " order by p_ddatazakupu desc " )
	if not rs.eof then 
		tb.newcell.addtext doc_.afc.display.fulldate(cdate(rs("data")))
		tb.newcell.cell.align = ALIGN_RIGHT
		tb.addtext trans_.afc.display.price( ccur(rs("cb")) , "PLN" ,  trans_.var(GVAR_PRICE_PREC) )
	else
		tb.newcell.addtext "<brak>"
		tb.cell.colspan = clng(2)
	end if
	'a tutaj odamy aktualną cenę
	dim nNrZestawuCen:nNrZestawuCen = clng(pdostawca.kli_eZestawCenowy)
	dim curCenaWynik : curCenaWynik = get_n_cena(trans_.getobj(TYPEID_N5PRODUKT, g_choicelist_idprod).listOpakowania.get(1),nNrZestawuCen, _
		(false))

	dim bResult : bResult = computeprice_n(pdostawca, trans_.getobj(TYPEID_N5PRODUKT, g_choicelist_idprod), trans_.getobj(TYPEID_N5PRODUKT, g_choicelist_idprod).listOpakowania.get(1), trans_.var(GVAR_TODAY) , _
				getCurrentFirma.pWaluta, (false), _
					curCenaWynik, nNrZestawuCen)

	if bResult then
		tb.newcell.cell.align = ALIGN_RIGHT
		tb.addtext trans_.afc.display.price( curCenaWynik , "PLN" ,  trans_.var(GVAR_PRICE_PREC) )
	else
		tb.newcell.addtext "<brak>"
	end if

end function

#endif





function BulidCustomerRow_INDEX(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		pTableBuilder.addtext "Indeks"
		pTableBuilder.newcell.addtext "Nazwa"
	else
		if (not pObj is nothing) then						
			'Budowanie elementu
			pTableBuilder.addtexthli pObj.strIndeks , pHli
			pTableBuilder.newcell.addtext pObj.strNazwa
		else			
			'Budowanie grupy
			pTableBuilder.cell.colspan= 2
			BulidCustomerRow_INDEX = false
			exit function
		end if
	end if
	BulidCustomerRow_INDEX = true
end function


