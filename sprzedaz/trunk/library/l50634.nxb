#ifdef INCLUDE_BULID_CHOICELIST_ROW_WZ_MULTIPLE

function BulidWZRow_Klient(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		clear_choice()'dzieki temu wybor bedzie dotyczyl TYLKO tego co widoczne
		pTableBuilder.addtext "Numer dokumentu"
#ifdef _CDNOLAWA		
		pTableBuilder.newcell.addtext "Wystawił"
#else
        pTableBuilder.newcell.addtext "Data wystawienia"		
#endif		
	else
		if (not pObj is nothing) then
		
			'checkbox
			pTableBuilder.addctrl CTRL_TYPE_CHECKBOX, -1
			pTableBuilder.element.border = 0
			pTableBuilder.element.addnew(CTRL_TYPE_STATIC,-1).text = ""
#ifdef _AMPLUS
      g_bChecked = false
#endif			
			if g_bChecked then
				pTableBuilder.element.value = "1"			
			else
				pTableBuilder.element.value = "0"			
			end if

			'dodajemy do tabilcy odpoeidni obiekt
			dim pWZCtrl:set pWZCtrl = new CObjsCheckbox
			set pWZCtrl.m_pCtrl = pTableBuilder.element
			pWZCtrl.m_nIdObj = pObj.idobj
			pCtrls.add pWZCtrl						
			
			pTableBuilder.addtexthli pObj.strNrDok, doc_.createhlistr( _
				doc_.afc.convert.formatter(" OPEN_FORM_PROXY_HLI_USAGE(%1,%2,%3) ").add(CStr(pObj.type)).add(CStr(pObj.idobj)).add(cstr(USAGE_VIEW)).done())
			pTableBuilder.element.tip = "Pokaż szczegóły"
            
#ifdef _CDNOLAWA            
            pTableBuilder.newcell.addtext pObj.pUzytRej.strNazwa
#else
            pTableBuilder.newcell.addtext trans_.afc.display.fulldate(pObj.dDataWyst)            
#endif            
		else			
			'Budowanie grupy
			BulidWZRow_Klient = false
			exit function
		end if
	end if
	BulidWZRow_Klient = true
end function

#endif



'tablica z kontrolkami okreslajacymi, ktore obiekty wybieramy
dim pCtrls:set pCtrls = trans_.afc.new_navoarray()
dim g_bChecked:g_bChecked = true

'reprezentacja jednej kontrolki - kontrolka + id obiektu
class CObjsCheckbox
	public m_pCtrl
	public m_nIdObj

	public property get generate()
		generate = m_pCtrl.value = "1"
	end property

	public property get id()
		id = m_nIdObj
	end property
	
	public function select_item(byval bSelect)
		if bSelect then
			m_pCtrl.value = "1"
		else
			m_pCtrl.value = "0"
		end if
	end function
end class

'wystawiamy na zewnątrz tablicę tych kontrolek
function get_choice()
	set get_choice = pCtrls
end function


function checked(byval bChecked)
	g_bChecked = bChecked
end function

sub clear_choice()
	set pCtrls = trans_.afc.new_navoarray()	
end sub









#ifdef INCLUDE_BULID_CHOICELIST_SPRZEDAZ


#comment OBSOLETE - check calls and remove
function BulidDokMagRow(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		pTableBuilder.addtext "Numer dokumentu"
		pTableBuilder.newcell.addtext "Klient/Dostawca"
		pTableBuilder.newcell.addtext "Data wystawienia"
		pTableBuilder.newcell.addtext "Wartość"
	else
		if (not pObj is nothing) then			
			
			'Budowanie elementu
			dim strKlient:strKlient = ""
			if not pObj.pKlient is nothing then
				strKlient = pObj.pKlient.text
			end if
			pTableBuilder.addtexthli pObj.strNrDok, pHli
			pTableBuilder.newcell.addtext strKlient
			pTableBuilder.newcell.addtext doc_.afc.display.fulldate(pObj.dDataWyst)  
			dim strWartosc : strWartosc = ""
			if pObj.curSumaMag <> 0.0 then
				strWartosc = doc_.afc.display.money( pObj.curSumaMag,"")
			end if
			pTableBuilder.newcell.addtext strWartosc
			pTableBuilder.cell.align = 1
		else			
			'Budowanie grupy
			pTableBuilder.cell.colspan= 3
			BulidDokMagRow = false
			exit function
		end if
	end if
	BulidDokMagRow = true
end function

#endif



