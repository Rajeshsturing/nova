#ifdef INCLUDE_BULID_CHOICELIST_TRANSAKCJA

function Bulid_Choicelist_Transakcja_Row(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		'pTableBuilder.cell.colspan = clng(2)
		pTableBuilder.addtext "Symbol"

		pTableBuilder.newcell.addtext "Podmiot"
		pTableBuilder.newcell.addtext "Saldo"
	else
		if (not pObj is nothing) then			
			
			'Budowanie elementu
			dim strKlient:strKlient = ""			
			if not pObj.wrefPodmiot is nothing then
				strKlient = pObj.wrefPodmiot.text
			end if

			pTableBuilder.cell.keepline = true
			pTableBuilder.addtexthli pObj.strSymTrans, pHli
			pTableBuilder.newcell.addtext strKlient

			dim strSaldo:strSaldo = trans_.afc.display.money(pObj.curWn - pObj.curMa ,pObj.pWaluta.strSkrot)			
			pTableBuilder.newcell.addtext strSaldo
			pTableBuilder.cell.align = 1

		else			
			'Budowanie grupy
			pTableBuilder.cell.colspan= 2
			Bulid_Choicelist_Transakcja_Row = false
			exit function
		end if
	end if
	Bulid_Choicelist_Transakcja_Row = true
end function

#endif



