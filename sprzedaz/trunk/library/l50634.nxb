#ifdef INCLUDE_BULID_CHOICELIST_ROW_DOKUMENT_HANDLOWY
#comment OBSOLETE - check calls and remove

function BulidDokHandlRow_Klient(byref pTableBuilder, byref pHli, byref pObj, byval strName)
	if (pHli is nothing) then
		'Budowanie nagłówka
		pTableBuilder.addtext "Numer dokumentu   (Klient)"
	else
		if (not pObj is nothing) then			
			
			'Budowanie elementu
			dim strKlient:strKlient = pObj.pKlient.text
			pTableBuilder.addtexthli pObj.strNrDok + "   ("+strKlient+")", pHli
		else			
			'Budowanie grupy
			BulidDokHandlRow_Klient = false
			exit function
		end if
	end if
	BulidDokHandlRow_Klient = true
end function

#endif


#ifdef INCLUDE_BULID_CHOICELIST_ROW_PRODUKT_ADVANCED


'get_glob_
#include "50203"


class CProdListConfigurator


	public m_bByNazwa

	public m_pStanMagContainerDICT
	public m_pMagContainer
	public m_strCena1

	public m_strCena2

	public m_strCena3


	public m_strCena4
	

	public m_strCena5	

	public m_strCena6


	public m_pAFC

	public m_bPrintCeny
	public m_bPrintStanMag
	public m_bPrintOpak


	public m_nOpakHeaderColspan

	
	public sub class_initialize()		
		set m_pAFC = doc_.afc		
		set m_pStanMagContainerDICT = doc_.system.activex("scripting.dictionary")
		set m_pMagContainer = m_pAFC.new_navoarray()

		m_bPrintCeny = false
		m_bPrintStanMag = false

		m_bPrintOpak = true
		m_nOpakHeaderColspan = 1

#ifdef APPCONFIG_RAPORT_BY_PROD_INX
		m_bByNazwa = false
#else
		m_bByNazwa = true
#endif
	end sub


	public function init_ceny

		m_bPrintCeny = true
		m_bPrintOpak = true
		m_nOpakHeaderColspan = m_nOpakHeaderColspan + 1


		m_strCena1 = getglobprofile(GLOBPROF_CENA1_NAME)
		m_strCena2 = getglobprofile(GLOBPROF_CENA2_NAME)
		m_strCena3 = getglobprofile(GLOBPROF_CENA3_NAME)
		m_strCena4 = getglobprofile(GLOBPROF_CENA4_NAME)
		m_strCena5 = getglobprofile(GLOBPROF_CENA5_NAME)
		m_strCena6 = getglobprofile(GLOBPROF_CENA6_NAME)

	end function



	public function init_ceny_profile(byval strSettings)

		init_ceny

		dim bIsCenaVisible:bIsCenaVisible = false


		if mid(strSettings,1,1) = "0" then
			m_strCena1 = ""
		else
			bIsCenaVisible = true
		end if



		if mid(strSettings,2,1) = "0" then
			m_strCena2 = ""
		else
			bIsCenaVisible = true
		end if



		if mid(strSettings,3,1) = "0" then
			m_strCena3 = ""
		else
			bIsCenaVisible = true
		end if



		if mid(strSettings,4,1) = "0" then
			m_strCena4 = ""
		else
			bIsCenaVisible = true
		end if



		if mid(strSettings,5,1) = "0" then
			m_strCena5 = ""
		else
			bIsCenaVisible = true
		end if



		if mid(strSettings,6,1) = "0" then
			m_strCena6 = ""
		else
			bIsCenaVisible = true
		end if


		m_bPrintCeny = bIsCenaVisible


	end function


	public function init_stan_mag_profile(byval strSettings)

		dim arr:arr = split(strSettings , "**")
		dim iter,strWhere
		strWhere = " idobj in (0"
		for iter = 0 to ubound(arr)
			strWhere = strWhere + "," + cstr(arr(iter))
		next
		strWhere = strWhere + ")"		

		init_stan_mag strWhere

	end function



	public function init_stan_mag( byval strWhere)

		m_bPrintStanMag = false
		m_bPrintOpak = true
		m_nOpakHeaderColspan = m_nOpakHeaderColspan + 1


		dim cursor_mag:set cursor_mag = trans_.createrawcursor(TYPEID_N5MAGAZYN,strWhere,"","")
		dim magazyn
		for each magazyn in cursor_mag
			m_bPrintStanMag = true
			m_pMagContainer.add magazyn	
		next

		dim rs_stanmag:set rs_stanmag = trans_.createadors(doc_.getmodule(60300).bquery_stanmag_adors())
		while not rs_stanmag.eof

			dim key:key = make_key(cstr(rs_stanmag.fields("gms_pProd").value),cstr(rs_stanmag.fields("gms_pOpak").value),cstr(rs_stanmag.fields("gms_pMag").value))							
			dim value:value = ccur(rs_stanmag.fields("gms_Ilosc").value)

			m_pStanMagContainerDICT.add key , value
			
			rs_stanmag.movenext
		wend

	end function






	private function make_key(byval strProd , byval strOpak , byval strMag)
		make_key = strProd + "*" + strOpak + "*" + strMag
	end function



