'-----------------------------------------------------------------------
' Wybór stringa
'-----------------------------------------------------------------------
function Rules_ChoiceStringArray(byref pHli, byref pParamsArray)
	dim pUtilPage
	set pUtilPage=doc_.getmodule(60265)	

	if (not pUtilPage.Rules_GetString()) then
		exit function
	end if

	dim strChoice
	strChoice = pUtilPage.getChoice()

	dim nPosArr
	nPosArr = CLng(pHli.prop(FUNCTION_ARRAY_POS))

	dim pRulesParam
	if (not pHli.exists(FUNCTION_LIST_POS)) then
		set pRulesParam = pParamsArray.value(nPosArr)
	else
		set pRulesParam = pParamsArray.value(nPosArr).pListParams.value(CLng(pHli.prop(FUNCTION_LIST_POS)))
	end if

	dim bOnlyChanges
	bOnlyChanges = (not pRulesParam.bEmpty)

	pRulesParam.strDisplay = value2display(strChoice)
	pRulesParam.strSave = value2save(strChoice, var2string(strChoice))
	pRulesParam.bEmpty = false

	page_.ctrl(pHli.prop(FUNCTION_CTRL_ID)).forecolor = PARAM_COLOR_OPT
	page_.ctrl(pHli.prop(FUNCTION_CTRL_ID)).text = pRulesParam.strDisplay

	if (not bOnlyChanges) then
		'Dodajemy kontynuacje wyboru naszego elementu, je¿eli
		'wybór jest typu continue
		dim bEmptyID
		Rules_ContinueSelection pHli, pParamsArray, page_, -1, bEmptyID
	end if 'bOnlyChanges

end function

