			background: #CFCFCF;
			height: 2px;
		}

.naglowek	{
				
				text-align: center;
				border: 1px outset;
				background: #D1D1E9;
				font-weight: bold;
				font-size: large;
				padding-left: 1ex;
			}
			
.naglowek	{
			font-weight: bold;
			font-size: large;
			padding-left: 1ex;
			}

.naglowekmaly	{
				font-size: small;
				text-align: center;
				font-style: italic;
				}

A	{
		text-decoration: none;
	}
