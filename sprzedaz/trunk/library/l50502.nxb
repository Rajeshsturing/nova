			background: #EDEEF3
		}

-->
</STYLE>

<BODY CLASS="body">

<P>
<SCRIPT language=JavaScript event=onload for=window>
      start();      
</SCRIPT>

<SCRIPT language=JavaScript>

      void function start()
      {	

			var rootElem = raportdata.documentElement;
			var childNode = rootElem.firstChild
			var count1 = childNode.childNodes.length;

			//informacja o liczbie kolumn w raporcie
			var strColumnsNo=childNode.childNodes.item(0).text;
			var iRaportColumns=parseInt(strColumnsNo);

			//kod wynikowy tabelki
			var strInnerHTML="<table CELLPADDING=4 CELLSPACING=0 bordercolor=#003060 border=1>";

			for (cl=1; cl<count1; cl++)
			{

				var currNode = childNode.childNodes.item(cl)
				//typ wiersza
				var iTypeOfRow=parseInt(currNode.childNodes.item(0).text);

				switch (iTypeOfRow)
				{
					case 1:
						//wiersz rozpoczynajacy nowa grupe
						
						strInnerHTML+="<tr>";
						strInnerHTML+="<td align=center colspan=" + strColumnsNo + "><b>&nbsp;" + currNode.childNodes.item(1).text + "</b></td>";						
						strInnerHTML+="</tr>";

						break;
					case 2:
						//normalny wiersz z danymi
						strInnerHTML+="<tr>";

						for (var i=1; i<=iRaportColumns; i++)
						{
							strInnerHTML+="<td>&nbsp;" + currNode.childNodes.item(i).text + "&nbsp;</td>";
						}
						
						strInnerHTML+="</tr>";

						break;
					case 3:

						//wiersz nagłówka
						strInnerHTML+="<tr backcolor=#D1D1E9>";

						for (var i=1; i<=iRaportColumns; i++)
						{
							strInnerHTML+="<td align=center>&nbsp;<b>" + currNode.childNodes.item(i).text + "</b></td>";
						}
						
						strInnerHTML+="</tr>";

						break;
					case 4:
						//wiersz stopki
				}

			}

			strInnerHTML+="</table>";
			Result.innerHTML=strInnerHTML;
		}
</SCRIPT>

<XML id="raportdata" version="1.0" encoding="windows-1250">

@XML_NAVO@

</XML>

<table CELLPADDING="4" CELLSPACING="0" ALIGN="CENTER">
	<thead>
		<TR>
			<TH ROWSPAN="27" WIDTH="4"></TH>
			<TH CLASS="naglowek">Oferta</TH>
			<TH ROWSPAN="27" WIDTH="4"></TH>
		</TR>
	</thead>
	<tr>
		<td colspan=3 border=0>
			<table border=0 style="border: 0px outset">
				<tbody>
					<tr>
						<td>		
							<SPAN id="Result"></SPAN>
						</td>
					</tr>
				</tbody>
			</table>
		</td>
	</tr>
</table>

</BODY>
</HTML>















