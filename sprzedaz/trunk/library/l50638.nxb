	"isnull(jo.strSkrot,'') " +_
	"from vlist_n5dokmag_listpozycje vl_dm " +_
	"inner join gmop_by_dok_poz_cena_kwz gm on vl_dm.p_nnumoper = gm.gmo_nnumop and vl_dm.coll_lp = gm.gmo_nlp " +_
	"inner join n5produkt t_produkt on vl_dm.c_pProdukt = t_produkt.idobj " +_
