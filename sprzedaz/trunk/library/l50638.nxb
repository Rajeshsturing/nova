	"ltrim(rtrim(u.strNazwa)), " +_
	"right(vl_dm.p_strNrDok,4), " +_
	"isnull(jo.strSkrot,'') " +_
	"from vlist_n5dokmag_listpozycje vl_dm " +_
	"inner join gmop_by_dok_poz_cena gm on vl_dm.p_nnumoper = gm.gmo_nnumop and vl_dm.coll_lp = gm.gmo_nlp " +_
