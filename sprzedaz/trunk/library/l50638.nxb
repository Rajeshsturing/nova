	"isnull((select dDataWyst from n5dokmag where idobj = (select min(idobj) from n5dokmag where wrefDokHandl=vl_sp.p_idobj and wrefDokHandl_wrt=10129)),"+trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate())+"), " +_
