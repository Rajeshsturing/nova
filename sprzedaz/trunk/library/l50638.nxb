	"when vl_dm.p_wrefDokHandl_wrt=10176 then isnull((select strNrDok from n5zakup where idobj=vl_dm.p_wrefDokHandl),0) " +_
	"else '' " +_
	"end, " +_
	"case  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10129 then isnull((select dDataWyst from n5sprzedaz where idobj=vl_dm.p_wrefDokHandl),0)  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10176 then isnull((select dDataOtrzym from n5zakup where idobj=vl_dm.p_wrefDokHandl),0)  " +_
	"else "+trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate())+" " +_
	"end, " +_
	"'0', " +_
	"vl_dm.p_strUwagi, " +_
	"vl_dm.p_pDowodKsieg, " +_
	"gm.gmo_nnumop, " +_
	"'-', " +_
	"ltrim(rtrim(u.strNazwa)), " +_
	"right(vl_dm.p_strNrDok,4), " +_
	"isnull(jo.strSkrot,'') " +_
	"from vlist_n5dokmag_listpozycje vl_dm " +_
	"inner join gmop_by_dok_poz_cena gm on vl_dm.p_nnumoper = gm.gmo_nnumop and vl_dm.coll_lp = gm.gmo_nlp " +_
	"inner join n5produkt t_produkt on vl_dm.c_pProdukt = t_produkt.idobj " +_
	"inner join n5uzytkownik u on vl_dm.p_puzytrej = u.idobj " +_
	"inner join n5rejestrdok r on vl_dm.p_pRejestrDok = r.idobj " +_
	"left join n5_klient_jedn_org jo on vl_dm.p_pklient_jo = jo.idobj " +_
	"where gm.gmo_curIlosc < 0 and vl_dm.p_pMagZrod <> 2 and r.eTyp <> N5REJESTRDOK__KWZ "

	'-- 1. mnoznik-real
	'trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curMnoznikReal = (case when curIlosc <> 0.0 then curIloscKgReal / curIlosc else 0.0 end) where curIloscKgReal <> 0.0"
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curMnoznikReal = isnull((select curCenaBrutto6 from n5opakowanie_produktu where idobj=idOpak),0)" 'where curIloscKgReal = 0.0
	'-- 2. ilosc_kg_real
	'trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curIloscKgReal = curIlosc *  " +_
	'"isnull((select curCenaBrutto6 from n5opakowanie_produktu where idobj=idOpak),0) " +_
	'"where curIloscKgReal = 0.0 "
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curIloscKgReal = curIlosc * curMnoznikReal "
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curIloscKgReal = (-1) * curIloscKgReal where curIlosc < 0.0 and curIloscKgReal > 0.0"
	'-- 3. mnoznik-stat
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curMnoznikStat = isnull((select curCenaNetto6 from n5opakowanie_produktu where idobj=idOpak),0)"
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curMnoznikStat = curMnoznikReal where curMnoznikStat = 0.0"
	'-- 4. ilosc_kg_stat
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set curIloscKgStat = curIlosc * curMnoznikStat"
	'-- 5. grupy
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set idGrupa1 = (select pGrupaProd from n5produkt where idProdukt = idobj) "
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set idGrupa2 = " +_ 
                 "case isnull((select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa1),0) when 0 " +_
                 "then idGrupa1 else (select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa1) end "
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set idGrupa3 = " +_ 
                 "case isnull((select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa2),0) when 0 " +_
                 "then idGrupa2 else (select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa2) end "
	trans_.execsql "update TMP_AMPLUS_EXP_LINIJEK set idGrupa4 = " +_
                 "case isnull((select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa3),0) when 0 " +_
                 "then idGrupa3 else (select pGrupaNadrzedna from n5grupaproduktow where idobj = idGrupa3) end "

	end sub
	private Sub Class_Terminate()	'OK - discontinued support
		trans_.execsql "drop table TMP_AMPLUS_EXP_LINIJEK"
	end sub
end class

function buildNaglowek_linijki
  buildNaglowek_linijki = "Rd;Nd;Data;RokMc;HM;TypDok;Magazyn;Klient;KrajKlienta;WojKlienta;TypProd;Nazwa;Grupa1;Grupa2;Grupa3;GrupaOst;Jm;IleJm;" +_
                          "Mnoznik;IleKg;MnoznikStat;IleKgStat;Waluta;Kurs;CjnWal;WnWal;CjnPln;CjnKgPln;WnPln;Vat;WVat;WbPln;NrDokOryg;DataDokOryg;" +_
                          "NrDokPow;DataDokPow;Umowa;KrajPoch;NrDowKsieg;NrOper;Uwagi;Wprowadzil;SkrotNrDok"
end function

function buildRow_linijki(byref oRS) : buildRow_linijki = ""
	dim iter
	'liczba eksportowanych kolumn
	dim iColNr : iColNr = oRS.Fields.count
	for iter = 0 to iColNr - 1
		select case iter
			case 7
				if trim(CStr(oRS(iter + 36).value)) <> "" then
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter + 36).value)),vbLf," "),vbCr," ") + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"
				end if
			case 10
				if InStr(Ucase(Trim(CStr(oRS(iter + 1).value))),"KOSZT") > 0 then
					buildRow_linijki = buildRow_linijki + "K" + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"        
				end if  
			case 23,39
				if trim(CStr(oRS(iter).value)) = "0" then
					buildRow_linijki = buildRow_linijki + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"      
				end if
			case 17,19,21,24,25,26,27,28,30,31
				if UCase(CStr(oRS(5).value)) = "Z" then
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(-CCur(oRS(iter).value))),vbLf," "),vbCr," ") + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"
				end if
			case 29
				if trim(CStr(oRS(iter).value)) = "-2" then
					buildRow_linijki = buildRow_linijki + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"
				end if 
			case 33,35
				if trans_.afc.display.fulldate(oRS(iter).value) = "????-??-??" then
					buildRow_linijki = buildRow_linijki + ";"
				else
					buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"
				end if
			case 41
				buildRow_linijki = buildRow_linijki + strWprowadzil(CStr(oRS(iter).value)) + ";"
			case 42
				buildRow_linijki = buildRow_linijki + cutZero(CStr(oRS(iter).value)) + ";"
			case 43
				'nie wypisuj kolumny
			case else
				buildRow_linijki = buildRow_linijki + replace(replace(trim(CStr(oRS(iter).value)),vbLf," "),vbCr," ") + ";"
		end select   
	next
	'usuwamy średnik na końcu
	buildRow_linijki = Left(buildRow_linijki,Len(buildRow_linijki) - 1)  
end function

function strWprowadzil(byval strNazwa) : strWprowadzil = ""
  if strNazwa = "Administrator" then
    strNazwa = "Admin"
  end if
  dim iPos : iPos = InStr(strNazwa," ")
  if iPos > 0 then
    strWprowadzil = Left(strNazwa,1) + " " + Mid(strNazwa,iPos+1,Len(strNazwa)-iPos)
  else
    strWprowadzil = strNazwa
  end if
end function

function cutZero(byval strNr) : cutZero = ""
  dim iter
  for iter = 1 to Len(strNr)
    if Left(strNr,1) = "0" then
      strNr = Mid(strNr,2)
    else
      cutZero = strNr
      exit for
    end if
  next
end function