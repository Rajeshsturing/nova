	"where gm.gmo_curIlosc > 0 and vl_dm.p_pMagDocel <> 2 and r.etyp <> N5REJESTRDOK__KWZ"
  
	'-- 1.4. Tylko KWZ
	trans_.execsql "insert into TMP_AMPLUS_EXP_LINIJEK " +_
	"select " +_
	"vl_dm.p_pRejestrDok, " +_
