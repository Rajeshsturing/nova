	"'', " +_
	""+trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate())+", " +_
	"case  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10129 then (select strNrDok from n5sprzedaz where idobj=vl_dm.p_wrefDokHandl)  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10176 then (select strNrDok from n5zakup where idobj=vl_dm.p_wrefDokHandl) " +_
	"else '' " +_
	"end, " +_
	"case  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10129 then (select dDataWyst from n5sprzedaz where idobj=vl_dm.p_wrefDokHandl)  " +_
	"when vl_dm.p_wrefDokHandl_wrt=10176 then (select dDataOtrzym from n5zakup where idobj=vl_dm.p_wrefDokHandl)  " +_
	"else "+trans_.afc.convert.date2SQL(trans_.afc.globals.nulldate())+" " +_
	"end, " +_
	"'0', " +_
	"vl_dm.p_strUwagi, " +_
	"vl_dm.p_pDowodKsieg, " +_
	"gm.gmo_nnumop, " +_
	"vl_dm.c_strextra1, " +_
	"ltrim(rtrim(u.strNazwa)), " +_
