'---------------------------------------------------------------
' zwraca opis string zawierajacy slowny opis podanej stawki
' nVATCode - wartosc predefiniowana(enum) okreslajaca stawke
'---------------------------------------------------------------
Public Function vat2name(nVATCode)
    Select Case nVATCode
        Case STAWKA_VAT_0:
            vat2name = "0%"
        Case STAWKA_VAT_ZWOLNIONY
            vat2name = "zwolniony"
        Case STAWKA_VAT_NIE_PODLEGA
            vat2name = "nie podlega"
        Case STAWKA_VAT_3
            vat2name = "3%"
        Case STAWKA_VAT_7
            vat2name = "7%"
        Case STAWKA_VAT_22
            vat2name = "22%"
        Case STAWKA_VAT_2
            vat2name = "2%"
        Case STAWKA_VAT_4
            vat2name = "4%"
        Case STAWKA_VAT_12
            vat2name = "12%"
        Case STAWKA_VAT_17
            vat2name = "17%"
        Case STAWKA_VAT_5
            vat2name = "5%"
        Case STAWKA_VAT_6
            vat2name = "6%"
        Case STAWKA_VAT_8
            vat2name = "8%"
        Case STAWKA_VAT_23
            vat2name = "23%" 
        Case STAWKA_VAT_23_OO
            vat2name = "o.o."                                                
        Case Else
            vat2name = "Nieznany"
    End Select
End Function

'---------------------------------------------------------------
' zwraca wartosc liczbowa stawki potrzebna do obliczen arytmetycznych
' nVATCode - wartosc predefiniowana(enum) okreslajaca stawke
'---------------------------------------------------------------
Public Function vat2val(nVATCode)
    Select Case nVATCode
        Case STAWKA_VAT_0:
            vat2val = 0.00
        Case STAWKA_VAT_ZWOLNIONY
            vat2val = 0.00
        Case STAWKA_VAT_NIE_PODLEGA
            vat2val = 0.00
        Case STAWKA_VAT_3
            vat2val = 0.03
        Case STAWKA_VAT_7
            vat2val = 0.07
        Case STAWKA_VAT_22
            vat2val = 0.22
        Case STAWKA_VAT_2
            vat2val = 0.02
        Case STAWKA_VAT_12
            vat2val = 0.12
        Case STAWKA_VAT_17
            vat2val = 0.17
        Case STAWKA_VAT_4
            vat2val = 0.04
        Case STAWKA_VAT_5
            vat2val = 0.05
        Case STAWKA_VAT_6
            vat2val = 0.06
        Case STAWKA_VAT_8
            vat2val = 0.08
        Case STAWKA_VAT_23
            vat2val = 0.23 
        Case STAWKA_VAT_23_OO
            vat2val = 0.23                                                
        Case Else
			if nVATCode >= 100 then
				vat2val = ccur(nVATCode) / 10000
				trans_.message 6501, 0, "vat2val=" + cstr(nVATCode) + "=>" + cstr(vat2val)
			else
				vat2val = 0.00
			end if
    End Select
End Function

'---------------------------------------------------------------
' Wylicza VAT z wartosci brutto
'---------------------------------------------------------------
Public Function brutto2vat(ByVal curBrutto, ByVal eKODVat)
    brutto2vat = brutto2vat_ex(curBrutto, eKODVat, false)
End Function

'---------------------------------------------------------------
' Wylicza VAT z wartosci brutto z przelacznikiem bez Vat
'---------------------------------------------------------------
Public Function brutto2vat_ex(ByVal curBrutto, ByVal eKODVat, ByVal bWithoutVat)
    Dim curStawkaVAT : curStawkaVAT = vat2val(eKODVat)
	if bWithoutVat then
		curStawkaVAT = ccur(0.00)
	end if
    brutto2vat_ex = trans_.afc.convert.round2(curBrutto * curStawkaVAT / (1 + curStawkaVAT))
End Function

'---------------------------------------------------------------
' Wylicza VAT z wartosci netto
'---------------------------------------------------------------
Public Function netto2vat(ByVal curNetto, ByVal eKODVat)
    netto2vat = netto2vat_ex(curNetto, eKODVat, false)
End Function

'---------------------------------------------------------------
' Wylicza VAT z wartosci netto z przelacznikiem bez Vat
'---------------------------------------------------------------
Public Function netto2vat_ex(ByVal curNetto, ByVal eKODVat, ByVal bWithoutVat)
    Dim curStawkaVAT : curStawkaVAT = vat2val(eKODVat)
	if bWithoutVat then
		curStawkaVAT = ccur(0.00)
	end if
    netto2vat_ex = trans_.afc.convert.round2(curNetto * curStawkaVAT)
End Function

'---------------------------------------------------------------
' Wylicza z wartosci brutto wartosc netto
'---------------------------------------------------------------
Public Function brutto2netto(ByVal curBrutto, ByVal eKODVat)
    brutto2netto = brutto2netto_ex(curBrutto, eKODVat, false)
End Function

'-----------------------------------------------------------------
' Wylicza z wartosci brutto wartosc netto z przelacznikiem bez Vat
'-----------------------------------------------------------------
Public Function brutto2netto_ex(ByVal curBrutto, ByVal eKODVat, ByVal bWithoutVat)
    brutto2netto_ex = curBrutto - brutto2vat_ex(curBrutto, eKODVat, bWithoutVat)
End Function

'---------------------------------------------------------------
' Wylicza brutto z netto
'---------------------------------------------------------------
Public Function netto2brutto(ByVal curNetto, ByVal eKODVat)
    netto2brutto = netto2brutto_ex(curNetto, eKODVat, false)
End Function

'---------------------------------------------------------------
' Wylicza brutto z netto z przelacznikiem bez Vat
'---------------------------------------------------------------
Public Function netto2brutto_ex(ByVal curNetto, ByVal eKODVat, ByVal bWithoutVat)
    netto2brutto_ex = curNetto + netto2vat_ex(curNetto, eKODVat, bWithoutVat)
End Function

'---------------------------------------------------------------
' Wylicza wartosc z uwzglednieniem rabatu
'---------------------------------------------------------------
Public Function rabat(ByVal curValue, ByVal curRabatProc, ByVal nPrecision)
    rabat = trans_.afc.convert.roundn(curValue - curValue * curRabatProc / 100, nPrecision)
End Function
'==========================================================================================



#comment '------------------------------------------------------------------------
#comment ' specjalne 'zaokraglanie' do liczenia liczby opakowan ('kartonow')
#comment '------------------------------------------------------------------------
function navo_ceil_ex(byval curValue, byval iPrecision)						
	if iPrecision = 2 then			
		curValue = curValue * ccur(100.0)			
	end if											
	dim curTmp : curTmp = fix(curValue)				
	if curTmp <> curValue then						
	  curTmp = curTmp + ccur(1.0)					
	end if											
	if iPrecision = 2 then			
		navo_ceil_ex = ccur(curTmp/100.0)				
	else											
		navo_ceil_ex = ccur(curTmp)					
	end if											
end function
#comment '------------------------------------------------------------------------


#define STATUS_ZAM_OBCE_DO_REALIZACJI	"Do realizacji"
#define STATUS_ZAM_OBCE_BUFOR			"Bufor"
#define STATUS_ZAM_OBCE_ZREALIZOWANE	"Zrealizowane"
#define STATUS_ZAM_OBCE_W_REALIZACJI	"W realizacji"

'--------------------------------------------------------
'Ustawia domyslny status na zamowieniu obcym (Abakosteel)
'--------------------------------------------------------
function set_default_status_zam_obce()
	set set_default_status_zam_obce = get_status_zam_obce_by_name(STATUS_ZAM_OBCE_DO_REALIZACJI)
end function

'----------------------------------------------------------
'Wyszukuje status na zamówieniu obcym wg nazwy (Abakosteel)
'----------------------------------------------------------
function get_status_zam_obce_by_name(byval strStatusNazwa)
	set get_status_zam_obce_by_name = nothing
	dim idDokStatus: idDokStatus = trans_.findobjid(TYPEID_N5DOKSTATUS,"dcs_strNazwa='" + strStatusNazwa + "'")
	if idDokStatus > 0 then
		dim oStatus: set oStatus = trans_.getobj(TYPEID_N5DOKSTATUS,idDokStatus)
		if Mid(oStatus.dcs_strTypDok,9,1) = "1" then
			set get_status_zam_obce_by_name = oStatus
		end if
	end if	
end function

'------------------------------------------------------------
'Ustawia status na zamówieniu obcym wg zrealizowanych pozycji
'------------------------------------------------------------
function set_status_zam_obce()
	set set_status_zam_obce = nothing
	
	dim iloscPoz: iloscPoz = n5zamowienie_get_niezreal_pozcount()
	if iloscPoz = 0 then
		set set_status_zam_obce = get_status_zam_obce_by_name(STATUS_ZAM_OBCE_ZREALIZOWANE)
	else
		set set_status_zam_obce = get_status_zam_obce_by_name(STATUS_ZAM_OBCE_DO_REALIZACJI)
	end if	
end function


#endif


