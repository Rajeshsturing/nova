#ifndef LIBRARY_50523
#define LIBRARY_50523

#include "50203"
#include "h1203.h"
#include "h1231.h"

#comment '------------------------------------------------------------------------
#comment ' Funkcja przelicza jedna walute na inna po odszukanym kursie
#comment '
#comment ' curCurrencyIn - kwota do zamiany podana w walucie wejscia pJednIn
#comment ' pJednIn - okresla walute kwoty do zamiany - waluta wejscia
#comment '
#comment ' pJednOut - waluta na jaka ma byc przeliczona kwota do zamiany
#comment '
#comment ' dDataOper - maksymalna data obowiazywania kursu
#comment ' eKurs - jakiego kursu uzyc - kupna czy sprzedazy 
#comment '		  (N5KURSWALUT_KUPNA/N5KURSWALUT_SPRZEDAZY)
#comment '
#comment ' curCurrencyOut - wynik - kwota w walucie pJednOut wyliczona z waluty wejscia
#comment ' bOption - true (kurs w dniu dData), false (kurs <= dData)
#comment '
#comment ' REZULTAT: TRUE lub FALSE gdy sie udało wyliczc lub nie
#comment '------------------------------------------------------------------------
function kantor_ex(byval curCurrencyIn, byref pJednIn, byref pJednOut, _
	byval dDataOper, byval eKurs, byref curCurrencyOut, byval bOption): kantor_ex = false



	if pJednIn is nothing or pJednOut is nothing then
		exit function
	end if

	if (pJednIn.idobj = pJednOut.idobj) then
		curCurrencyOut = CCur(curCurrencyIn)
		kantor_ex = true
		exit function
	end if
	
	dim strZnak: strZnak = "<"
	if bOption then
		strZnak = "="
	end if
	
	dim strWhere
	strWhere = trans_.afc.convert.Formatter("pWalZ=%1 and pWalN=%2 and dData " + strZnak + " %3") _
		.Add(pJednIn.idobj) _
		.Add(pJednOut.idobj) _
		.Add(trans_.afc.convert.date2SQL(dDataOper)) _
		.Done

	dim pCursor
	set pCursor = trans_.createrawcursor(TYPEID_N5KURSWALUT,strWhere,"dData desc" , "")


	if (not pCursor.exists(1)) then
		exit function
	end if

	dim pKurs
	set pKurs = pCursor.get(1)

	dim curCurs : curCurs = ccur(0.0)
	
	select case eKurs
		case N5KURSWALUT_KUPNA
			curCurs = pKurs.curKupnoWal
		case N5KURSWALUT_SPRZEDAZY
			'before DB14:
			'curCurs = pKurs.curSprzedWal

			curCurs = pKurs.curAverageWal
	end select

	if (pKurs.curMnoznik=0) then
		exit function
	end if

	curCurrencyOut = trans_.afc.convert.roundn(( (CCur(curCurrencyIn) * curCurs) / (pKurs.curMnoznik) ),4) 'wylicz 4 miejsca po przecinku

	kantor_ex = true
end function

function kantor(byval curCurrencyIn, byref pJednIn, byref pJednOut, _
	byval dDataOper, byval eKurs, byref curCurrencyOut): kantor = false
	kantor = kantor_ex(curCurrencyIn, pJednIn, pJednOut, dDataOper, eKurs, curCurrencyOut, false)
end function	

#comment '------------------------------------------------------------------------
#comment ' Funkcja przelicza walute wejsciowa na walute wyjsciawa jedynie
#comment ' na podstawie dostarczonego kursu waluty
#comment '------------------------------------------------------------------------
function przelicz_walute(byval curInCurrency, byval dblKurs)
	przelicz_walute = trans_.afc.convert.round2(CCur(curInCurrency) * dblKurs)
end function

function przelicz_walute_n(byval curInCurrency, byval dblKurs,byval nPrec)
	przelicz_walute_n = trans_.afc.convert.roundn(CCur(curInCurrency) * dblKurs,nPrec)
end function

#comment '------------------------------------------------------------------------
#comment ' TWORZENIE, POBIERANIE ROZLICZENIA VAT
#comment '------------------------------------------------------------------------

private function vat_where_rozliczenie(byval dData)
	vat_where_rozliczenie = "vat7_dDataOd <=" + trans_.afc.convert.date2sql(dData) + " and vat7_dDataDo >= " + trans_.afc.convert.date2sql(dData)
end function

private function vat_lookup_rozliczenie(byval dData)
	vat_lookup_rozliczenie = trans_.findobjid(TYPEID_N5ROZLVAT, vat_where_rozliczenie(dData) )
end function

private function vat_create_rozliczenie(byval dData)
	dim idRozlVAT : idRozlVAT = vat_lookup_rozliczenie(dData)
	if idRozlVAT > 0 then
		vat_create_rozliczenie = idRozlVAT
		exit function
	end if
	'--create new --
	idRozlVAT =  clng(0)
	dim pRozlVAT : set pRozlVAT = nothing
	dim pSubTrans
	set pSubTrans = trans_.createsubtran()
		set pRozlVAT = trans_.newobj(TYPEID_N5ROZLVAT)
		with pRozlVAT
			.vat7_dDataOd = dateserial(year(dData) , month(dData) , 1)
			.vat7_dDataDo = dateserial(year(dData) , month(dData) + 1 , 1) - 1
		end with
		idRozlVAT = pRozlVAT.idobj
		if not trans_.saveobjects then
			vat_create_rozliczenie =  clng(0)
			exit function
		end if
		trans_.autorollback false
		set pRozlVAT = nothing
	set pSubTrans = nothing
	trans_.autorollback true
	vat_create_rozliczenie = idRozlVAT
end function




private function where_raport_kasowy(byval dData,byval idRejDok)
	where_raport_kasowy = "raka_dDataOd <=" + trans_.afc.convert.date2sql(dData) + " and raka_dDataDo >= " + trans_.afc.convert.date2sql(dData) +_
		" and raka_pRejestrDok = " + cstr(idRejDok)
end function


private function lookup_raport_kasowy(byref pPlatnosc)
	lookup_raport_kasowy = trans_.findobjid(TYPEID_N5RAPKAS, where_raport_kasowy(pPlatnosc.dDataOper,pPlatnosc.pRejestrDok.idobj) )
end function

private function create_raport_kasowy_ex(byval dDataOper, byval idRej)
	create_raport_kasowy_ex = 0

	dim idRaport : idRaport = trans_.findobjid(TYPEID_N5RAPKAS, where_raport_kasowy(dDataOper, idRej))
	if idRaport > 0 then	
		create_raport_kasowy_ex = idRaport
		exit function
	end if

	dim oRejestDok : set oRejestDok = trans_.getobj(TYPEID_N5REJESTRDOK, idRej)
	dim eZasadaRapKas:eZasadaRapKas = oRejestDok.rejdok_eZasadaRapKas
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = idRej
	dim dData:dData = dDataOper

	dim pRapKas
	dim pSubTrans
	dim dDataOd,dDataDo

	set pSubTrans = trans_.createsubtran()
		set pRapKas = trans_.newobj(TYPEID_N5RAPKAS)		
		compute_dates_for_rapkas eZasadaRapKas , dData , dDataOd , dDataDo
		with pRapKas
			.raka_dDataOd = dDataOd
			.raka_dDataDo = dDataDo
			idRaport = .idobj
		end with
		if not trans_.saveobjects() then 
			create_raport_kasowy_ex =  clng(0)
			exit function
		end if
		set pRapKas = nothing

	set pSubTrans = nothing

	create_raport_kasowy_ex = idRaport
end function

private function create_raport_kasowy(byval platnosc):create_raport_kasowy = 0
	dim idRapKas : idRapKas = lookup_raport_kasowy(platnosc)
	if idRapKas > 0 then	
		create_raport_kasowy = 	idRapKas
		exit function
	end if

	dim eZasadaRapKas:eZasadaRapKas = platnosc.pRejestrDok.rejdok_eZasadaRapKas
	trans_.var(APPVAR_REJESTR_DOKUMENTOW) = platnosc.pRejestrDok.idobj
	dim dData:dData = platnosc.dDataOper

	dim pRapKas
	dim pSubTrans
	dim dDataOd,dDataDo
	set pSubTrans = trans_.createsubtran()
		set pRapKas = trans_.newobj(TYPEID_N5RAPKAS)		
		compute_dates_for_rapkas eZasadaRapKas , dData , dDataOd , dDataDo
		with pRapKas
			.raka_dDataOd = dDataOd
			.raka_dDataDo = dDataDo
			idRapKas = .idobj
		end with
		if not trans_.save then 
			create_raport_kasowy =  clng(0)
			exit function
		end if
		trans_.autorollback false
		set pRapKas = nothing

	set pSubTrans = nothing

	trans_.autorollback true
	create_raport_kasowy = idRapKas
		
end function


private function compute_dates_for_rapkas(byval eZasada , byval dDataOper , byref dDataOd , byref dDataDo)
	select case eZasada
		case N5REJESTRDOK_ZASADA_RAPKAS_CODZIENNIE
			dDataOd = dDataOper
			dDataDo = dDataOper
		case N5REJESTRDOK_ZASADA_RAPKAS_COTYDZIEN
			dDataOd = dateserial(year(dDataOper) , month(dDataOper) , day(dDataOper) )	-  (weekday(dDataOper,vbMonday) - 1)
			dDataDo = dDataOd + 6
		case N5REJESTRDOK_ZASADA_RAPKAS_CO10DNI
			if day(dDataOper) < 11 then
				dDataOd = dateserial(year(dDataOper) , month(dDataOper) , 1)	
				dDataDo = dateserial(year(dDataOper) , month(dDataOper) , 10)	
			end if

			if day(dDataOper) > 10 and day(dDataOper) < 21 then
				dDataOd = dateserial(year(dDataOper) , month(dDataOper) , 11)	
				dDataDo = dateserial(year(dDataOper) , month(dDataOper) , 20)	
			end if

			if day(dDataOper) > 20 then
				dDataOd = dateserial(year(dDataOper) , month(dDataOper) , 21)
				dDataDo = dateserial(year(dDataOper) , month(dDataOper) + 1 , 1) - 1		
			end if

		case N5REJESTRDOK_ZASADA_RAPKAS_COMIESIAC
			dDataOd = dateserial(year(dDataOper) , month(dDataOper) , 1)
			dDataDo = dateserial(year(dDataOper) , month(dDataOper) + 1 , 1) - 1		
	end select 
end function


