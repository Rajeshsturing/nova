function show_long_msg(byval strTitle,byref strText):show_long_msg = true
	dim pPage:set pPage = doc_.getmodule(PAGE_FORM_VIEW_LONG_MESSAGE)	
	pPage.init_form strTitle,strText
	pPage.domodalauto()
end function
