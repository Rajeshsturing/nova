'-----------------------------------------------------------------------
' Klasa reprezentuje jeden rekord do zapisania w bazie NE
'
'
'VOID begin_object(byval nType, byval nIdObj)
'VARIANT fields(byval strFieldName) = VARIANT
'VOID fieldref(byval strFieldName, byval nTypeId) = LONG
'OBJECT fieldByName(byval strFldName)
'OBJECT infoByName(byval strFldName)
'-----------------------------------------------------------------------
class CImportStream
	
	public idobj		'idobj tego obiektu
	public unique_str	'string wyznaczjacy unikalnosc na podstawie wartosci pol
	public typeid		'typeid obiektu
	public name
	private pObjectInfo 'wsk. na stos z informacja o tym obiekcie
						'informacja o obiekcie z ktorego eksportujemy

	private pFieldInfo		'dictionary informacji o polach
	private pFieldsValue	'dictionary wartosci pol
	public  pSetFields		'tablica ustawionych pol
	private pObjectsStack	'tylko do eksportu
	private pExtraData		'tablica dodatkowych pol (extra) przenoszonych
							'podczas eksportu
	public bAfterShouldContinue 'czy jestesmy juz za ShouldContinue

	private sub class_initialize()
		idobj = 0
		typeid = 0
		name = ""
		unique_str = ""

		set pFieldsValue = CreateObject("Scripting.Dictionary")
		set pFieldInfo = nothing
		set pSetFields = doc_.afc.new_navoarray()
		set pExtraData = doc_.afc.new_navoarray()

		set pObjectInfo = nothing
		set pObjectsStack = nothing
		bAfterShouldContinue = false
	end sub

	
	private sub class_terminate()   'OK
		set pFieldsValue = nothing
		set pObjectInfo = nothing
	end sub


	public function getInfo()
		set getInfo = pObjectInfo
	end function


	public function setInfo(byref pNewInfo)
		set pObjectInfo = pNewInfo
	end function


	public function KindOf()
		KindOf = "CImportStream"
	end function
	

	'----------------------------------------------------------------
	' Wolane przez manager'a exportu
	'----------------------------------------------------------------
	public function internal_init(byref pObjectInformation, byval nIdObj, byref pCurrentObjectStack)
		'dodaj wsk. na stos z informacja o obiektach
		'danego typu
		set pObjectInfo = pObjectInformation
		set pObjectsStack = pCurrentObjectStack
		pObjectInfo.idobj = nIdObj
	end function

	'----------------------------------------------------------------
	'Uzywana by zaznaczyc, ze obiekt jest typu child - nie dla importu
	'w Navo Enterprise
	'----------------------------------------------------------------
	public function as_child_non_ne()
		pObjectInfo.child = true

		dim pParentInfo
		set pParentInfo = pObjectsStack.value( pObjectsStack.count() - 2 )

		pObjectInfo.parenttypeid = pParentInfo.typeid
		pObjectInfo.parentidobj = pParentInfo.idobj
	end function

	'----------------------------------------------------------------
	'Uzywana by zaznaczyc, ze obiekt jest typu child - nie dla importu
	'w Navo Enterprise
	'----------------------------------------------------------------
	public function as_child(byval strParentFieldName)
		pObjectInfo.child = true

		dim pParentInfo
		'rerepopo = 0
		set pParentInfo = pObjectsStack.value( pObjectsStack.count() - 2 )

		pObjectInfo.parenttypeid = pParentInfo.typeid
		pObjectInfo.parentidobj = pParentInfo.idobj
		pObjectInfo.setparentfld strParentFieldName
	end function

	'----------------------------------------------------------------
	' Rozpocznij obiekt ale nie wchodzacy do NE
	'----------------------------------------------------------------
	public function begin_object_name(byval strObjectName, byval nType, byval bSprzedaz)
		'tego nie ma
		pObjectInfo.typeid = nType
		typeid = nType
		idobj = 0
		
		'Ustawiamy nazwe obiektu
		name = strObjectName
		pObjectInfo.strDestName = name

		if (bSprzedaz) then
			extra("SPRZEDAZ") = "yes"
		end if
	end function

	'----------------------------------------------------------------
	' Rozpocznij obiekt o podanym TYPEID i IdObj
	'----------------------------------------------------------------
	public function begin_object_id(byval nType, byval nIdObj)
		idobj = nIdObj
		typeid = nType

		dim pObjDef
		set pObjDef = doc_.stdobjdef.getobjdef( nType )

		name = pObjDef.tablename

		if (not pObjectInfo is nothing) then
			pObjectInfo.typeid = nType
			pObjectInfo.strDestName = name
		end if

		if (not pFieldsInfoCache.exists(cstr(nType))) then
		
			'wypelnij informacje o polach tego obiektu
			'wypelniaj informacje o polach w danym obiekcie

			set pFieldInfo = CreateObject("Scripting.Dictionary")

			dim pObjField, nCounter: nCounter = 0
			for each pObjField in pObjDef

				if (nCounter>0) then

					dim pField
					set pField = new CObjectField

					pField.typeid = pObjField.type
					pField.strName = pObjField.name
					
					if (pObjField.type=RELT_REF) then
						pField.reftypeid = pObjField.reftypeid
					end if

					pField.sqltype = pObjField.sqltype
					pField.nIndex = nCounter
					pField.fldtype = pObjField.type

					'dodaj do mapy informacji o polach
					pFieldInfo.add pField.strName, pField

				end if 'nCounter>0

				nCounter = nCounter + 1

			next

			pFieldsInfoCache.add cstr(nType), pFieldInfo

		else

			set pFieldInfo = pFieldsInfoCache.item(cstr(nType))

		end if 'cached
	end function

	'----------------------------------------------------------------
	' Rozpocznij obiekt o podanym TYPEID i IdObj. Wolane z funkcji
	' zdarzen
	'----------------------------------------------------------------
	public function begin_object(byval nType)
		begin_object = begin_object_id(nType, pObjectInfo.idobj)
	end function


	'----------------------------------------------------------------
	' Zwraca pole pobrane z nazwy pola
	'----------------------------------------------------------------
	public function fieldByName(byval strFldName): set fieldByName = nothing
		if (pFieldsValue.exists(strFldName)) then
			set fieldByName = pFieldsValue.Item(strFldName)
		end if
	end function


	'----------------------------------------------------------------
	' Pobieramy informacje o podanym polu na podstawie nazwy
	'----------------------------------------------------------------
	public function infoByName(byval strFldName): set infoByName = nothing
		if (pFieldInfo.exists(strFldName)) then
			set infoByName = pFieldInfo.item( strFldName )
		end if
	end function


	private function add2unique(byval strNewValue)
		if (not bAfterShouldContinue) then
			if (unique_str<>"") then
				unique_str = unique_str + "="
			end if
			unique_str = unique_str + CStr(strNewValue)
		end if
	end function

	'----------------------------------------------------------------
	' Ustawienia i pobieranie wartości pól
	'----------------------------------------------------------------
	public property let fields(byval strFieldName, byval varValue)
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName
		end if

		'konwersja podstawienia do odpowiedniego typu
		select case infoByName(strFieldName).sqltype

			case SQLlong
				pField.varValue = CLng(varValue)

			case SQLdate
				pField.varValue = CDate(varValue)

			case SQLcurrency, SQLqty
				pField.varValue = CCur(varValue)

			case SQLtime
				pField.varValue = CLng(varValue)

			case SQLc1
				pField.varValue = left(trim(CStr(varValue)), 1)

			case SQLc4
				pField.varValue = left(trim(CStr(varValue)), 4)
			
			case SQLc8
				pField.varValue = left(trim(CStr(varValue)), 8)
			
			case SQLc20
				pField.varValue = left(trim(CStr(varValue)), 20)

			case SQLc24
				pField.varValue = left(trim(CStr(varValue)), 24)
			
			case SQLc32
				pField.varValue = left(trim(CStr(varValue)), 32)

			case SQLc64
				pField.varValue = left(trim(CStr(varValue)), 64)

			case SQLc128
				pField.varValue = left(trim(CStr(varValue)), 128)

			case SQLvc4
				pField.varValue = left(trim(CStr(varValue)), 4)

			case SQLvc8
				pField.varValue = left(trim(CStr(varValue)), 8)

			case SQLvc20
				pField.varValue = left(trim(CStr(varValue)), 20)

			case SQLvc32
				pField.varValue = left(trim(CStr(varValue)), 32)

			case SQLvc64
				pField.varValue = left(trim(CStr(varValue)), 64)

			case SQLvc96
				pField.varValue = left(trim(CStr(varValue)), 96)

			case SQLvc128
				pField.varValue = left(trim(CStr(varValue)), 128)

			case SQLvc256
				pField.varValue = left(trim(CStr(varValue)), 256)

			case SQLvc512
				pField.varValue = left(trim(CStr(varValue)), 512)

			case SQLvc1024
				pField.varValue = left(trim(CStr(varValue)), 1024)

			case SQLvc7900
				pField.varValue = left(trim(CStr(varValue)), 7900)

			case else
				pField.varValue = varValue
				'todo:spiko Nie eksportować pól opcjonalnych
				IMPTRACE("STREAM: Nie udało się przekonwertować dla sqltype=" + CStr(infoByName(strFieldName).sqltype) + " dla pola " + strFieldName)
						
		end select

		add2unique CStr(pField.varValue)
	end property

	'----------------------------------------------------------------
	' Ustawia do pola wartośc typu STRING
	' Uzywane dla importu nie do Navo Enterprise
	'----------------------------------------------------------------
	public function fieldsSTRING(byval strFieldName, byval nStrLen, byval varValue): fieldsSTRING = false
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName

			'todo:spiko Sprawdzenie konwersji
			pField.varValue = Mid(Trim(CStr(varValue)), 1, nStrLen)
		end if

		fieldsSTRING = true
	end function

	'----------------------------------------------------------------
	' Ustawia do pola wartośc typu Long
	' Uzywane dla importu nie do Navo Enterprise
	'----------------------------------------------------------------
	public function fieldsLONG(byval strFieldName, byval varValue): fieldsLONG = false
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName

			'todo:spiko Sprawdzenie konwersji
			pField.varValue = CLng(varValue)
		end if

		fieldsLONG = true
	end function

	'----------------------------------------------------------------
	' Ustawia do pola wartośc typu Object
	' Uzywane dla importu nie do Navo Enterprise
	'----------------------------------------------------------------
	public function fieldsOBJ(byval strFieldName, byval varValue): fieldsOBJ = false
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName

			'todo:spiko Sprawdzenie konwersji
			set pField.varValue = varValue
		end if

		fieldsOBJ = true
	end function

	'----------------------------------------------------------------
	' Ustawia do pola wartośc typu CURRENCY
	' Uzywane dla importu nie do Navo Enterprise
	'----------------------------------------------------------------
	public function fieldsCURRENCY(byval strFieldName, byval varValue): fieldsCURRENCY = false
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName

			'todo:spiko Sprawdzenie konwersji
			pField.varValue = CCur(varValue)
		end if

		fieldsCURRENCY = true
	end function


	'----------------------------------------------------------------
	' Ustawia do pola wartośc typu DATE
	' Uzywane dla importu nie do Navo Enterprise
	'----------------------------------------------------------------
	public function fieldsDATE(byval strFieldName, byval varValue): fieldsDATE = false
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			
			if (not bAfterShouldContinue) then
				'jezeli nie jestesmy za ShouldContinue oznacza to,ze
				'pole wyznacza unikalnosc
				pField.bunique = true
			end if

			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName

			'todo:spiko Sprawdzenie konwersji
			pField.varValue = CDate(varValue)
		end if

		fieldsDATE = true
	end function


	public property get fields(byval strFieldName)
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			exit property
		end if

		if (isObject(pField.varValue)) then
			set fields = pField.varValue
		else
			fields = pField.varValue
		end if
	end property


	'----------------------------------------------------------------
	' Reczne skojarzenie pole z referencja - uzywane dla dzikich
	' referencje - zwykle ida z automatu
	'----------------------------------------------------------------
	public property let fieldref(byval strFieldName, byval nTypeId, byval varValueId)
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName
		end if

		pField.varValue = CLng( varValueId )
		add2unique CStr(varValueId) + "." + CStr(nTypeId)
		
		infoByName(strFieldName).reftypeid = CLng( nTypeId )
	end property

	public property let virtualfieldref(byval strFieldName, byval nTypeId, byval strValueId)
		dim pField
		set pField = fieldByName( strFieldName )

		if (pField is nothing) then
			set pField = new CImportFldValue
			pFieldsValue.add strFieldName, pField

			'dodaj do tablicy pol jakie zostaly ustawione
			pSetFields.add strFieldName
		end if

		'pFldInfo.rerepopo = 10
		
		pField.varValue = ucase(trim(CStr( strValueId )))
		add2unique CStr( strValueId ) + "." + CStr(nTypeId)

		dim pFldInfo
		set pFldInfo = infoByName(strFieldName)

		pFldInfo.reftypeid = CLng( nTypeId )
		pFldInfo.virtual = true
		'pFldInfo.rerepopo = 10
	end property


	public property let extra(byval strFieldName, byval varValue)
		dim pExtraDataValue
		set pExtraDataValue = nothing

		dim i
		for i = 0 to (pExtraData.count() - 1)
			if (pExtraData.value(i).strName = strFieldName) then
				set pExtraDataValue = pExtraData.value(i)
				exit for
			end if
		next

		if (pExtraDataValue is nothing) then
			set pExtraDataValue = new CExtraData
			pExtraDataValue.strName = strFieldName
			pExtraData.Add pExtraDataValue
		end if

		pExtraDataValue.varValue = varValue
			
	end property

	public property get extra(byval strFieldName)
		dim i
		for i = 0 to (pExtraData.count() - 1)
			if (pExtraData.value(i).strName = strFieldName) then
				extra = pExtraData.value(i).varValue
			end if
		next
	end property

	public function extraExists(byval strFieldName): extraExists = false
		dim i
		for i = 0 to (pExtraData.count() - 1)
			if (pExtraData.value(i).strName = strFieldName) then
				extraExists = true
				exit function
			end if
		next
	end function

	public function extraCopy2(byref pDestStream)
		dim i
		for i = 0 to (pExtraData.count() - 1)
			pDestStream.extra(pExtraData.value(i).strName) = pExtraData.value(i).varValue
		next
	end function

end class

#endif
