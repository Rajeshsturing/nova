end function

'---------------------------------------------
'zwraca true gdy ustawiony rok 2011 (nowy VAT)
'---------------------------------------------
private function isYear2011() : isYear2011 = false
	if getCurrentDate() >= DateSerial(2011,1,1) then
		isYear2011 = true
	end if
end function

'-------------------------------------------------
'zwraca true gdy ustawiony rok 2014 (VAT 23% o.o.)
'-------------------------------------------------
private function isYear2014() : isYear2014 = false
	if getCurrentDate() >= DateSerial(2014,1,1) then
		isYear2014 = true
	end if
end function

'-------------------------------
'JEDNOSTKA ORGANIZACYJNA
'-------------------------------

private function getCurrentJOID(): getCurrentJOID=CLng(0)
	if (trans_.isvar(GVAR_CURR_JO)) then
		getCurrentJOID=CLng(trans_.var(GVAR_CURR_JO))
	end if
end function

private function getCurrentJO():set getCurrentJO=nothing
	dim nJOIdObj
	nJOIdObj = getCurrentJOID()

	if (nJOIdObj > 0) then
		set getCurrentJO = trans_.getobj(TYPEID_N5JEDN_ORG, nJOIdObj)
	end if
end function

private function getCentrala() : set getCentrala = nothing
	dim pFirma : set pFirma = getCurrentFirma()
	if not pFirma is nothing then 
		set getCentrala = pFirma.pMainJO
	end if
end function

'-------------------------------
'FIRMA
'-------------------------------
'-------------------------------
'pobiera obiekt aktywanej firmy
'-------------------------------
private function getCurrentFirma():set getCurrentFirma=nothing
	dim idFirma:idFirma=getCurrentFirmaID()

	if (idFirma>0) then
		set getCurrentFirma=trans_.getobj(TYPEID_N5FIRMA, idFirma)
	end if
end function

'-------------------------------
'pobiera obiekt aktywanej firmy - założenie jest takie iz w tablicy 
'n5 firma moze istnieć tylko jedna firma
'-------------------------------
private function getCurrentFirmaID():getCurrentFirmaID=CLng(0)
	dim IdFirmy:IdFirmy = clng(0)
	
	if (trans_.isvar(GVAR_FIRMA)) then
		IdFirmy = trans_.var(GVAR_FIRMA)
	end if
		
	if IdFirmy = clng(0) then
		IdFirmy = trans_.findobjid(TYPEID_N5FIRMA, "")
	end if

	trans_.var(GVAR_FIRMA) = IdFirmy
	getCurrentFirmaID = IdFirmy
end function



'-------------------------------
'PROFILE
'-------------------------------

'-------------------------------
' zwraca wartosc profilu dla biezacego uzytkownika
'-------------------------------
private function getuserprofile(byval iIndex)
	getuserprofile = nx_get_current_userprofile_value(iIndex)
end function
'-------------------------------
'zwraca wartość profilu dla podanego użytkownika
'-------------------------------
private function getuserprofileByID(byval Index, byval IdUser)
	getuserprofileByID = nx_get_userprofile_value(Index,IdUser)
end function


'-------------------------------
'zwraca obiekt profilu dla bieżącego użytkownika
'-------------------------------
private function getuserprofileObj(byval Index)
	dim pUserProfileObj
	set pUserProfileObj = nx_get_userprofile_obj(Index,trans_.var(GVAR_USER))
    If pUserProfileObj Is Nothing Then
		set pUserProfileObj = trans_.newobj(TYPEID_USERPROFILE)
		set pUserProfileObj.pn5user = trans_.getobj(TYPEID_N5UZYTKOWNIK, trans_.var(GVAR_USER))
		pUserProfileObj.Indeks = clng(Index)
	end if 
	set getuserprofileObj = pUserProfileObj
end function


'-------------------------------
'podobne jak getuserprofile tylko, ze zwraca 0 jezeli nie istnieje profil
'lub wartosc w profilu nie jest liczba calkowita - uzywamy tylko dla
'liczb calkowitych
'-------------------------------
private function getuserprofileLong(byval Index):	getuserprofileLong=CLng(0)
	dim strResult
	strResult=getuserprofile(Index)

	if isNumeric(strResult) then
		getuserprofileLong=CLng(strResult)
	end if

end function

'-------------------------------
'funckje do pamietania wartości typu BOOL w profilach
'-------------------------------
private function setuserprofileBOOL(byval Index, byval bValue)
	dim strValue: strValue="0"
	
	if (bValue) then
		strValue="1"
	end if
	
	setuserprofile Index, strValue
end function

'REV:KB:DONE:
'---------------------------------------------------------------------------
' Funkcja konwertuje wartość profilu do BOOL.
' Jezlie profilu pusty lub = "1" to zwraca TRUE
'---------------------------------------------------------------------------
private function getuserprofileBOOL(byval Index): getuserprofileBOOL=false
	dim strResult
	strResult=getuserprofile(Index)

	if (strResult="1" or strResult="") then
		getuserprofileBOOL=true
	end if
end function

'-------------------------------
'ustawia wartość profilu dla bieżącego użytkownika
'-------------------------------
private sub setuserprofile(byval Index,byval newValue)
	getuserprofileObj(Index).Wartosc = cstr(newValue)
end sub

private sub setuserprofileByID(byval Index,byval newValue, byval idUser)
	dim pUserProfileObj
	set pUserProfileObj = nx_get_userprofile_obj(Index,idUser)
    If pUserProfileObj Is Nothing Then
		set pUserProfileObj = trans_.newobj(TYPEID_USERPROFILE)
		set pUserProfileObj.pn5user = trans_.getobj(TYPEID_N5UZYTKOWNIK, idUser)
		pUserProfileObj.Indeks = clng(Index)
	end if 
	pUserProfileObj.Wartosc = newValue
end sub

'-------------------------------
'zwraca wartość globalnego profilu
'-------------------------------
private function getglobprofile(byval Index)
	getglobprofile = nx_get_globprofile_value(Index)
end function

private function getglobprofileLong(byval Index):getglobprofileLong=CLng(0)
	dim strProf : strProf=getglobprofile(Index)
	if isNumeric(strProf) then
		getglobprofileLong=CLng(strProf)
	end if
end function

private function getglobprofileObj(byval iIndeks): set getglobprofileObj=nothing
	dim pGlobProfileObj : set pGlobProfileObj = nx_get_globprofile_obj(iIndeks)
	if pGlobProfileObj is nothing then
		set pGlobProfileObj = trans_.newobj(TYPEID_GLOBPROFILE)
		pGlobProfileObj.indeks=clng(iIndeks)
	end if
	set getglobprofileObj = pGlobProfileObj
end function

'---------------------------------------------------------------------------
' Funkcja konwertuje wartość profilu do BOOL.
' Jezlie profilu pusty lub = "1" to zwraca TRUE
'---------------------------------------------------------------------------
private function getglobprofileBOOL(byval Index): getglobprofileBOOL=false
	dim strResult
	strResult=getglobprofile(Index)

	if (strResult="1" or strResult="") then
		getglobprofileBOOL=true
	end if
end function

'-------------------------------
'ustawia wartość globalnego profilu
'-------------------------------
private sub setglobprofile(byval Index,byval newValue)
	getglobprofileObj(Index).Wartosc = cstr(newValue)
end sub


private function IsWykonawcaOfCurrUser(pWyk)	
	IsWykonawcaOfCurrUser = getCurrentWykonawcaID() = pWyk.idobj
end function

