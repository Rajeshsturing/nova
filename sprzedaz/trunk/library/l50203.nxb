#comment '-------------------------------
#comment ' NX Profile
#comment '-------------------------------
#comment '-------------------------------
#comment 'zwraca obiekt profilu dla podanego użytkownika
#comment 'lub nothing gdy nie istnieje
#comment '-------------------------------
private function nx_get_userprofile_obj(byval iIndeks,byval iIdUser)
	Set nx_get_userprofile_obj = Nothing
	
	dim idprof : idprof = nx_.slot0.profile_id_cache.get_idobj_for_inx(iIdUser,iIndeks)
	
	if idprof = 0 then
		idProf = trans_.findobjid(TYPEID_USERPROFILE, "pn5user=" + CStr(iIdUser) + " and Indeks=" + CStr(iIndeks))
	end if
	
	If idProf < 0 Then
		Err.Raise 1, "getprofileobj_user", "Zduplikowany profil #" + CStr(iIndeks) + " dla użytkownika id=" + CStr(iIdUser)
	else
		if idProf > 0 then
			nx_.slot0.profile_id_cache.set_idobj_for_inx iIdUser,iIndeks,idprof
			set nx_get_userprofile_obj = trans_.getobj(TYPEID_USERPROFILE, idProf)
		end if
	End If
end function

#comment '--------------------------------------------------------------
#comment 'zwraca wartość profilu dla podanego użytkownika
#comment 'lub pusty napis gdy nie istnieje
#comment '--------------------------------------------------------------
private function nx_get_userprofile_value(byval iIndeks,byval iIdUser)
	dim pUserProfileObj : set pUserProfileObj = nx_get_userprofile_obj(iIndeks,iIdUser)
    if pUserProfileObj Is nothing then
        nx_get_userprofile_value = ""
    else
        nx_get_userprofile_value = pUserProfileObj.Wartosc
    end if
end function

#comment '--------------------------------------------------------------
#comment 'zwraca wartość profilu dla biezacego użytkownika
#comment 'lub pusty napis gdy nie istnieje
#comment '--------------------------------------------------------------
private function nx_get_current_userprofile_value(byval iIndex)
	nx_get_current_userprofile_value = nx_get_userprofile_value(iIndex,trans_.var(GVAR_USER))
end function

#comment '--------------------------------------------------------------
#comment 'zwraca obiekt globalnego profilu
#comment 'lub nothing gdy nie istnieje
#comment '--------------------------------------------------------------
private function nx_get_globprofile_obj(byval iIndeks)
	set nx_get_globprofile_obj = nothing
#ifdef _ABAS_INWESTYCJE
	dim idprof : idprof = 0
#else
	dim idprof : idprof = nx_.slot0.profile_id_cache.get_idobj_for_inx(0,iIndeks)
#endif
	if idprof = 0 then
		idprof=trans_.findobjid(TYPEID_GLOBPROFILE,"Indeks=" + CStr(iIndeks))
	end if

	if idprof < 0 then
		err.raise 1,"getglobprof","Zduplikowany profil globalny #" + CStr(iIndeks)
		exit function
	else
		if idprof > 0 then
			nx_.slot0.profile_id_cache.set_idobj_for_inx 0,iIndeks,idprof
			set nx_get_globprofile_obj = trans_.getobj(TYPEID_GLOBPROFILE,idprof)
		end if
	end if

end function

#comment '--------------------------------------------------------------
#comment 'zwraca wartość globalnego profilu
#comment 'lub pusty napis gdy nie istnieje
#comment '--------------------------------------------------------------
private function nx_get_globprofile_value(byval iIndeks)
	dim pGlobProfileObj : set pGlobProfileObj = nx_get_globprofile_obj(iIndeks)
    if pGlobProfileObj is nothing then
        nx_get_globprofile_value = ""
    else
        nx_get_globprofile_value = pGlobProfileObj.Wartosc
    end if
end function

'-------------------------------
dim g_navo_cocoon_version : g_navo_cocoon_version = "?"
private function get_navo_cocoon_version()
	if g_navo_cocoon_version <> "?" then
		get_navo_cocoon_version =	g_navo_cocoon_version
		exit function
	end if

	g_navo_cocoon_version = ""

	on error resume next

	Err.Clear
	g_navo_cocoon_version = nx_.features.get_cocoon_version()
	on error goto 0 
	
	get_navo_cocoon_version =	g_navo_cocoon_version
	'trans_.message 0,0,"found navo.cocoon version " + g_navo_cocoon_version
end function

dim g_nxm_jse_mode : g_nxm_jse_mode = "?"

private function nxm_jse_mode()

#ifdef APPCONFIG_ALLOW_NXM_JSE

#ifndef GLOBPROF_NXM_JSE_MODE
#define GLOBPROF_NXM_JSE_MODE					1157
#endif

	if g_nxm_jse_mode = "?" then
		g_nxm_jse_mode = getglobprofile(GLOBPROF_NXM_JSE_MODE)
	end if

	nxm_jse_mode = g_nxm_jse_mode

#else
	nxm_jse_mode = false
#endif

end function

'-------------------------------
private function has_nxm_feature(strFeature)
	
	dim oNXMFeatures
	set oNXMFeatures = nothing
	
	on error resume next
	Err.Clear
	set oNXMFeatures = nx_.nxm_features
	on error goto 0 
		
	if oNXMFeatures is nothing then
		has_nxm_feature = false
	else
		has_nxm_feature = nx_.nxm_features.has_feature(strFeature)
	end if

end function
'-------------------------------
'UZYTKOWNICY
'-------------------------------

'-------------------------------
'pobiera obiekt zalogowanego user'a
'-------------------------------
private function getCurrentUser():set getCurrentUser=nothing
	if (trans_.var(GVAR_USER)<>0) then
		set getCurrentUser=trans_.getobj(TYPEID_N5UZYTKOWNIK, trans_.var(GVAR_USER))
	end if
end function

'-------------------------------
'zwraca id zalogowanego user'a
'-------------------------------
private function getCurrentUserID():getCurrentUserID=CLng(0)
	getCurrentUserID=CLng(trans_.var(GVAR_USER))
end function

private function getCurrentWykonawca(): set getCurrentWykonawca=nothing
	dim pUser
	set pUser=getCurrentUser()

	if (pUser is nothing) then
		exit function
	end if

	set getCurrentWykonawca=pUser.pWykonawca
end function

private function getCurrentWykonawcaID(): getCurrentWykonawcaID=0
	dim pWykonawca
	set pWykonawca=getCurrentWykonawca()

	if (pWykonawca is nothing) then
		exit function
	end if

	getCurrentWykonawcaID=pWykonawca.IdObj
end function


private function GetAdminID():GetAdminID=0
	dim nAdmin
	nAdmin=trans_.findobjid(TYPEID_N5UZYTKOWNIK, "strLogin='" + ADMIN_LOGIN + "'")
	if (nAdmin>0) then
		GetAdminID=nAdmin
	end if
end function


'-------------------------------
'uruchamia konfiguracje uzytkownika
'-------------------------------
private function ConfigureUser(byval idUser)
	dim pNewHli
	set pNewHli=doc_.createhlistr("varCmd=CMD_OPEN_RECORD_PAGE varDestPage=20144 varModalRes4=" + CStr(idUser))
	dim pPage:set pPage=doc_.getpagehli(pNewHli)
	if pPage is nothing then
		exit function
	end if
	ConfigureUser=pPage.domodalauto()
end function


'-------------------------------
'DATA
'-------------------------------

private function getCurrentDate()
	getCurrentDate = trans_.var(GVAR_TODAY)
end function

'------------------------------------------------------------
'true  => gdy ustawiony jest tryb ze stawkami VAT na 2011 rok
'false => gdy ustawiony jest tryb ze stawkami VAT na 2010 rok
'domyślnie przestawiony na true w dniu 2019-08-21
'------------------------------------------------------------
private function isModeVAT2011() : isModeVAT2011 = true
