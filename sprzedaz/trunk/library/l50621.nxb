dim g_fldnr_parent_list_fld##_nr_		\
dim g_fldnr_child_prod_fld##_nr_		\
dim g_fldnr_prod_inx_fld##_nr_			\
sub init_fld_nrs_std##_nr_()																		\
	dim pStdObjDef : set pStdObjDef = doc_.stdobjdef.getobjdef(_typeid_parent_)			\
	g_fldnr_parent_list_fld##_nr_ = pStdObjDef.getfieldindex("_list_")						\
	set pStdObjDef = doc_.stdobjdef.getobjdef(_typeid_child_)							\
	g_fldnr_child_prod_fld##_nr_ = pStdObjDef.getfieldindex("_prod_fld_")						\
	set pStdObjDef = doc_.stdobjdef.getobjdef(TYPEID_N5PRODUKT)							\
	g_fldnr_prod_inx_fld##_nr_ = pStdObjDef.getfieldindex("strNazwa")						\
end sub