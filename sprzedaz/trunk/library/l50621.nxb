#ifdef APPCONFIG_FIND_EAN_AND_INDEKS

#macro VBG_PRODUKT_INDEKS_CUSTOM_PODPO(_ctrl_,_list_,_prod_fld_,_crsr_,_nr_,_bzam_)								\
	VBG_PRODUKT_INDEKS_CUSTOM_PODPO_EX(_ctrl_,_list_,_prod_fld_,_crsr_,_nr_,_bzam_, curIloscOpak, pOpak)

#macro VBG_PRODUKT_INDEKS_CUSTOM_PODPO_EX(_ctrl_,_list_,_prod_fld_,_crsr_,_nr_,_bzam_,_ilosc_fld_, _opak_fld)								\
function c##_ctrl_##_ondataentered(pCtrl,nRow, strEntered) : c##_ctrl_##_ondataentered = true	\
	dim pSuggCustomizer : set pSuggCustomizer = new CSuggInxCustomizer							\
	pSuggCustomizer.setup pCtrl.ident															\
	pSuggCustomizer.find_zamiennik	_bzam_						\
	 if strEntered<>"" then  \
	  	    dim rs:set rs = trans_.createadors("select p_idobj,c_curilosc,coll_lp from vlist_n5produkt_listOpakowania where c_strEan = '"+ trans_.afc.convert.str2SQL(strEntered)+"'")\
	dim idobj_pr,coll_lp,ilosc_op								\
	if not rs.eof then									\
				idobj_pr = clng(rs.fields("p_idobj").value)		\
				coll_lp = clng(rs.fields("coll_lp").value)		\
				ilosc_op = clng(rs.fields("c_curilosc").value)	\
				'idProd = trans_.findobjid(TYPEID_N5PRODUKT,"idobj ="+cstr(idobj_pr))	\
			dim pElement, idProd														\
			  if page_.root._list_.exists(nrow) then								\				
					set pElement = page_.root._list_.get(nrow)						\
			  else																		\
				set pElement = page_.root._list_.AddNew()							\
			  end if																	\		
				set pElement._prod_fld_ = trans_.getobj(TYPEID_N5PRODUKT,idobj_pr)							\
				set pElement._opak_fld = pElement._prod_fld_.listOpakowania.get(coll_lp)			\
				pElement._ilosc_fld_ = ccur(ilosc_op)													\
				strEntered = pElement._prod_fld_.strIndeks  \
	else																						\
		if len(strEntered)>12 then strEntered = left(strEntered,12)								\
	end if	\
	end if\	
		if false = _bzam_ then																	\
			std_lrs_dataentered_n pCtrl,strEntered,g_fldnr_parent_list_fld##_nr_,nRow, _						\
				g_fldnr_child_prod_fld##_nr_,TYPEID_N5PRODUKT,g_fldnr_prod_inx_fld##_nr_,_crsr_,pSuggCustomizer	\
		else		\
			std_lrs_dataentered_n_zammiennik pCtrl,strEntered,g_fldnr_parent_list_fld##_nr_,nRow, _						\
				g_fldnr_child_prod_fld##_nr_,TYPEID_N5PRODUKT,g_fldnr_prod_inx_fld##_nr_,_crsr_,pSuggCustomizer	\
		end if	\
end function																										\
function c##_ctrl_##_ongetdata(byref pCtrl,nRow)											\
	std_lrs_getdata_n pCtrl,g_fldnr_parent_list_fld##_nr_,nRow,g_fldnr_child_prod_fld##_nr_, _			\
		g_fldnr_prod_inx_fld##_nr_																\
	dim strTip : strTip = ""																\
	if page_.root._list_.exists(nRow) then													\
		if not page_.root._list_.get(nRow)._prod_fld_ is nothing then						\
			strTip = page_.root._list_.get(nRow)._prod_fld_.strNazwa						\
		end if																				\
	end if																					\
	pCtrl.tip = strTip																		\
end function																				\				
function c##CTRLID_GRID_PRODUKT_INDEKS##_onlostfocus(byref pCtrl,nRow,idGotFocus)			\					
	c##CTRLID_GRID_PRODUKT_INDEKS##_onlostfocus = std_rs_lostfocus(pCtrl,idGotFocus)		\
	if idGotFocus <> -1 then																\
		'inna komorka w tym samym wierszu													\
		if page_.ctrl(idGotFocus).parent.parent.ident = pCtrl.parent.parent.ident then		\
			nRow = pCtrl.parent.parent.parent.dr2tr(nRow)									\
			if pCtrl.parent.parent.parent.count = nRow then									\
				pCtrl.parent.parent.parent.datarowcount = nRow + 1							\
			end if																			\
			if nRow+1 > pCtrl.parent.parent.parent.count then								\
				nRow = nRow - 1																\
			end if																			\	
			pCtrl.parent.parent.parent.row(nRow+1).cell(COLUMN_INDEX).element(2).focus=true	\
		end if																				\
	end if																					\
end function

