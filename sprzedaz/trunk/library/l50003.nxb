#macro COMMAND(_name_,_command_,_cmdid_)	\
	<node>							\
		<cmdiid>_cmdid_</cmdiid>	\
		<label>_name_</label>		\
		<hli>_command_</hli>		\
	</node>



#macro OPEN_FORM(_name_,_form_,_cmdid_,_picid_,_extra_)									\
	<node>															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli>varCmd=CMD_OPEN_STATIC_PAGE varDestPage=_form_ varNewThread=1 _extra_</hli>	\
	</node>


#macro OPEN_FORM_NOMENU(_name_,_form_,_cmdid_,_picid_,_extra_)									\
	<node nomenu='true'>															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli>varCmd=CMD_OPEN_STATIC_PAGE varDestPage=_form_ varNewThread=1 _extra_</hli>	\
	</node>



#macro OPEN_OBJECT_FORM(_name_,_cmdid_,_picid_,_typeid_,_cursor_)	\
	<node>															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli> OPEN_FORM_PROXY_HLI(_typeid_,0) varCursor=_cursor_ </hli>	\
	</node>


#comment te makra nie ma varFormUsage - w³¹cz do _extra_ !!
#macro OPEN_OBJECT_FORM_EX(_name_,_cmdid_,_picid_,_typeid_,_cursor_,_extra_)	\
	<node >															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli>varCmd=CMD_OPEN_STATIC_PAGE varDestPage=PAGE_OPEN_FORM_PROXY varTypeId=_typeid_ varObject=0 varCursor=_cursor_ varNewThread=1 _extra_ </hli>	\
	</node>


#macro OPEN_OBJECT_FORM_EX_NOMENU(_name_,_cmdid_,_picid_,_typeid_,_cursor_,_extra_)	\
	<node nomenu='true'>															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli>varCmd=CMD_OPEN_STATIC_PAGE varDestPage=PAGE_OPEN_FORM_PROXY varTypeId=_typeid_ varObject=0 varCursor=_cursor_ varNewThread=1 _extra_ </hli>	\
	</node>


#macro OPEN_OBJECT_FORM_REJTYP(_name_,_cmdid_,_picid_,_typeid_,_rejtyp_,_cursor_)	\
	OPEN_OBJECT_FORM_REJTYP_USAGE(_name_,_cmdid_,_picid_,_typeid_,_rejtyp_,_cursor_, 0)

#macro OPEN_OBJECT_FORM_REJTYP_USAGE(_name_,_cmdid_,_picid_,_typeid_,_rejtyp_,_cursor_,_usage_)	\
	<node>															\
		<cmdiid>_cmdid_</cmdiid>									\
		<icon>_picid_</icon>										\
		<label>_name_</label>										\
		<hli> OPEN_FORM_PROXY_HLI_USAGE(_typeid_,0,_usage_) appvar_rejestr_typ=_rejtyp_ varCursor=_cursor_ </hli>	\
	</node>

#macro OPEN_OBJECT_FORM_NOMENU(_name_,_cmdid_,_picid_,_typeid_,_cursor_)	\
	<node  nomenu='true'>													\
		<cmdiid>_cmdid_</cmdiid>											\
		<icon>_picid_</icon>												\
		<label>_name_</label>												\
		<hli> OPEN_FORM_PROXY_HLI(_typeid_,0) varCursor=_cursor_ </hli>	\
	</node>

#macro OPEN_OBJECT_FORM_CRSR_DEF(_name_,_cmdid_,_picid_,_typeid_)	\
	OPEN_OBJECT_FORM(_name_,_cmdid_,_picid_,_typeid_,CRSR_DEFAULT)

#macro OPEN_OBJECT_FORM_EX_CRSR_DEF(_name_,_cmdid_,_picid_,_typeid_,_extra_)	\
	OPEN_OBJECT_FORM_EX(_name_,_cmdid_,_picid_,_typeid_,CRSR_DEFAULT,_extra_)


#macro OPEN_OBJECT_FORM_REJTYP_CRSR_DEF(_name_,_cmdid_,_picid_,_typeid_,_rejtyp_)	\
	OPEN_OBJECT_FORM_REJTYP(_name_,_cmdid_,_picid_,_typeid_,_rejtyp_,CRSR_DEFAULT)

#macro OPEN_OBJECT_FORM_NOMENU_CRSR_DEF(_name_,_cmdid_,_picid_,_typeid_)		\
	OPEN_OBJECT_FORM_NOMENU(_name_,_cmdid_,_picid_,_typeid_,CRSR_DEFAULT)


