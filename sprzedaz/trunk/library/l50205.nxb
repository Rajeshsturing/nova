			end if
			IdWaluty = trans_.findobjid(TYPEID_N5JEDNOSTKA, "strSkrot='" + waluta + "' and eTyp=2")
			'pExpMan.fromVirtualObject "XLSWaluty", waluta, pRecord, pStream
			opak.pWaluta = trans_.getobj(TYPEID_N5JEDNOSTKA, IdWaluty)
			'---------------------------------------------------------------------------
			netto = getValue(pExpMan, pRecord, "CenaNetto2", true)
			brutto = getValue(pExpMan, pRecord, "CenaBrutto2", true)
