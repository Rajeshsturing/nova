function eksport_XLSMiejscowosc(byref pExpMan, byval strWhere)
	if (strWhere<>"") then
		strWhere = " where (" + strWhere + ")"
	end if	

	eksport_XLSMiejscowosc = pExpMan.fromRecordset("select * from [Miejscowosci$]" + strWhere, "XLSMiejscowosc")
end function

