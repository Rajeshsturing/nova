function XLSOpakowanie_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSOpakowanie_SaveStream = pExpMan.container().import( pStream )
end function



'.........................
' KONTA
'.........................

function XLSKonto_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSKonto_Convert2Stream = false
	pStream.begin_object TYPEID_N5KONTO

	pStream.extra("UPDATE") = true

	XLS_FIELD_REQ(strNazwa, NazwaKonta)
	XLS_FIELD_REQ(strSymbol, SymbolKonta)

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim pWaluta
	pWaluta = getValue(pExpMan, pRecord, "SkrotWaluty", false)
	if (isEmpty(pWaluta)) then
		exit function
	end if
	pExpMan.fromVirtualObject "XLSWaluty", pWaluta, pRecord, nothing
	pStream.virtualfieldref("pJednostka", TYPEID_N5JEDNOSTKA) = pWaluta

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if


	dim strKontoNadrzedne
	strKontoNadrzedne = getValue(pExpMan, pRecord, "KontoNadrzedne", true)

	if (not isEmpty(strKontoNadrzedne)) then
		if (strKontoNadrzedne<>"") then
			pStream.virtualfieldref("pKontoNadrz", TYPEID_N5KONTO) = strKontoNadrzedne
		end if
	end if


	dim strAS
	strAS = getValue(pExpMan, pRecord, "Analityczne(T/N)", true)
	if (UCase(pRecord.fields("Analityczne(T/N)").value)="T") then
		pStream.fields("eAnalit") = clng(N5KONTO_ANALITYCZNE)
	else
		pStream.fields("eAnalit") = clng(N5KONTO_SYNTETYCZNE)
	end if




	dim strBilans
	strBilans = getValue(pExpMan, pRecord, "Bilansowe(T/N)", true)
	if (UCase(pRecord.fields("Bilansowe(T/N)").value)="T") then
		pStream.fields("eBilans") = clng(N5KONTO_BILANSOWE)
	else
		pStream.fields("eBilans") = clng(N5KONTO_POZABILANSOWE)
	end if



	dim strAkt
	strAkt = getValue(pExpMan, pRecord, "Aktywne(T/N)", true)
	if (UCase(pRecord.fields("Aktywne(T/N)").value)="T") then
		pStream.fields("eAktywne") = clng(N5KONTO_AKTYWNE)
	else
		pStream.fields("eAktywne") = clng(N5KONTO_NIEAKTYWNE)
	end if


	XLSKonto_Convert2Stream = true
end function


function XLSKonto_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSKonto_SaveStream = pExpMan.container().import( pStream )
end function








