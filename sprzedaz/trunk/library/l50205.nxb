'-----------------------------------------------------------------------
'
'                OBSLUGA IMPORTU OBIEKTOW(tłumaczenie)
'
'-----------------------------------------------------------------------

#macro XLS_FIELD(_ne_field_name, _xls_field_name, _xls_opt)	\
	'== macro xls_field ==	\
	dim _ne_field_name	\
	_ne_field_name = getValue(pExpMan, pRecord, "_xls_field_name", _xls_opt)	\
	if (isEmpty(_ne_field_name)) then	\
		if (not _xls_opt) then	\
			exit function	\
		end if	\
	else \
		pStream.fields("_ne_field_name") = _ne_field_name \	
	end if	\
	'== end of macro ==

#macro XLS_FIELD_REQ(_ne_field_name, _xls_field_name) \
	XLS_FIELD(_ne_field_name, _xls_field_name, false)

#macro XLS_FIELD_OPT(_ne_field_name, _xls_field_name) \
	XLS_FIELD(_ne_field_name, _xls_field_name, true)


'.........................
' MIEJSCOWOSC
'.........................
function XLSMiejscowosc_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSMiejscowosc_Convert2Stream = false
	pStream.begin_object TYPEID_N5MIEJSCOWOSC

	'Nazwa miejscowości wymagana
	XLS_FIELD_REQ(strNazwa, Nazwa)

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("eWielkosc") = 7

	'Wojewodztwo jako referencja
	dim strWojewodztwo: strWojewodztwo = getValue(pExpMan, pRecord, "Wojewodztwo", false)

	if (isEmpty(strWojewodztwo)) then
		exit function
	end if

	pExpMan.fromVirtualObject "WojewodztwoXLS", strWojewodztwo, pRecord, nothing
	pStream.virtualfieldref("pWojewodztwo", TYPEID_N5WOJEWODZTWO) = strWojewodztwo

	XLSMiejscowosc_Convert2Stream = true
end function

function XLSMiejscowosc_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSMiejscowosc_SaveStream = pExpMan.container().import( pStream )
end function

