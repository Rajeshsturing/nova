				nx_.trace.error "Błąd w zakładce PRODUKTY", "W produkcie o indeksie " + pStream.fields("strIndeks") + " ceny (curCenaNatto6 i curCenaBrutto6) wypełnione"
			end if
			if not isEmpty(waluta) then
				IdWaluty = trans_.findobjid(TYPEID_N5JEDNOSTKA, "strSkrot='" + waluta + "' and eTyp=2")
				if IdWaluty < 1 then
					waluta = "PLN" 'jesli nie ma podanej waluty, domyslnie przyjmujemy PLN
				end if
			else
				waluta = "PLN" 'jesli nie ma podanej waluty, domyslnie przyjmujemy PLN
			end if
			pStream.extra("nazwaPolaWaluty") = "WalutaCeny6"
			pExpMan.fromVirtualObject "XLSWaluty", waluta, pRecord, pStream
			pStream.virtualfieldref("opak_pWaluta6", TYPEID_N5JEDNOSTKA) = waluta
			'---------------------------------------------------------------------------
			XLSOpakowanie_Convert2Stream = true
	else
		
			'********************************************************************
			'wczytanie nazwy opakowania
			'********************************************************************
			nazwaOpakowania = getValue(pExpMan, pRecord, "Nazwa opakowania", true)
			if isEmpty(nazwaOpakowania) then
				opak.strNazwa = "Podstawowe"
			else
				opak.strNazwa = nazwaOpakowania
			end if
			'wczytanie nazwy miedzynarodowej
			
			nazwaMiedzyOpakowania = getValue(pExpMan, pRecord, "Nazwa miedzynarodowa opakowania", true)
			if not isEmpty(nazwaMiedzyOpakowania) then
				opak.strNazwaMiedzynarodowa = nazwaMiedzyOpakowania
			end if
			
			
			'********************************************************************
			'wczytanie elementu listy opakowan (nowego opakowania)
			'********************************************************************
			'dim prodIndeks
			'dim produkt
			'dim prodId
