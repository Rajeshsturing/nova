'.........................
' JEDNOSTKI
'.........................
function XLSJednostki_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSJednostki_Convert2Stream = false
	'rerepopo = 0
	pStream.begin_object TYPEID_N5JEDNOSTKA

	XLS_FIELD_REQ(strSkrot, SkrotJednostki)

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	XLS_FIELD_OPT(strNazwa, NazwaJednostki)
	if (isEmpty(strNazwa)) then
		pStream.fields("strNazwa") = strSkrot
	end if

	XLS_FIELD_OPT(nDokladnosc, Dokladnosc)


	pStream.fields("eTyp") = N5JEDNOSTKA_MIARY

	XLSJednostki_Convert2Stream = true
end function

function XLSJednostki_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSJednostki_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' WALUTY
'.........................
function XLSWaluty_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSWaluty_Convert2Stream = false
	pStream.begin_object TYPEID_N5JEDNOSTKA

	dim strSkrot
	'rerepopo = 0
	if IsEmpty(pStream.extra("nazwaPolaWaluty")) then
		strSkrot = getValue(pExpMan, pRecord, "SkrotWaluty", false)
		pStream.fields("strSkrot") = strSkrot
	else
		strSkrot = getValue(pExpMan, pRecord, pStream.extra("nazwaPolaWaluty"), true)
		if isEmpty(strSkrot) or strSkrot="" then
			strSkrot = "PLN"
		end if
		pStream.fields("strSkrot") = strSkrot
	end if
	
	'aaa=0
	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	XLS_FIELD_OPT(strNazwa, NazwaWaluty)
	if (isEmpty(strNazwa)) then
		pStream.fields("strNazwa") = strSkrot
	end if

	pStream.fields("eTyp") = N5JEDNOSTKA_WALUTA

	XLSWaluty_Convert2Stream = true
end function

function XLSWaluty_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSWaluty_SaveStream = pExpMan.container().import( pStream )
end function



'.........................
' KRAJE
'.........................
function XLSKraje_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSKraje_Convert2Stream = false
	pStream.begin_object TYPEID_N5KRAJ

	XLS_FIELD_REQ(strSkrot, SkrotKraju)
	XLS_FIELD_REQ(strNazwa, Nazwa)

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim pWaluta
	'rerepopo = 0
	if isEmpty(pStream.extra("importKraju")) then
		pWaluta = getValue(pExpMan, pRecord, "SkrotWaluty", false)
		if (isEmpty(pWaluta)) then
			exit function
		end if
		pExpMan.fromVirtualObject "XLSWaluty", pWaluta, pRecord, nothing
		pStream.virtualfieldref("pWaluta", TYPEID_N5JEDNOSTKA) = pWaluta
	elseif not pStream.extra("importKraju") then
		pWaluta = getValue(pExpMan, pRecord, "SkrotWaluty", true)
	end if

	'rerepopo = 0
	'pStream.extra("nazwaPolaWaluty") =

	XLSKraje_Convert2Stream = true
end function

function XLSKraje_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSKraje_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' TYPY DOKUMENTOW
'.........................
function XLSTypDokumentu_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): XLSTypDokumentu_Convert2Stream = false
	pStream.begin_object TYPEID_N5TYPDOKUMENTU

	XLS_FIELD_REQ(strNazwa, Nazwa)
	XLS_FIELD_REQ(eRodzaj, Rodzaj)
	
	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	dim strTypNadrzedny
	strTypNadrzedny = getValue(pExpMan, pRecord, "TypNadrzedny", true)

	if (not isEmpty(strTypNadrzedny)) then
		if (strTypNadrzedny<>"") then
			pStream.virtualfieldref("pTypNadrzedny", TYPEID_N5TYPDOKUMENTU) = strTypNadrzedny
		end if
	end if

	XLSTypDokumentu_Convert2Stream = true
end function

function XLSTypDokumentu_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	XLSTypDokumentu_SaveStream = pExpMan.container().import( pStream )
end function


'.........................
' BANK KLIENTA
'.........................
function KlientBankXLS_Convert2Stream(byref pExpMan, byref pRecord, byref pStream): KlientBankXLS_Convert2Stream = false
	pStream.begin_object TYPEID_N5BANK

	dim strBankNr
	strBankNr = CStr(pStream.extra("BankNr"))

	pStream.fields("strNazwa") = pRecord.fields("Bank" + strBankNr).value
	pStream.fields("strSkrot") = pRecord.fields("Bank" + strBankNr).value
	pStream.fields("strOddzial") = "<podaj oddział>"
	pStream.fields("strKodRach") = "<podaj kod rachunku>"

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	KlientBankXLS_Convert2Stream = true
end function

function KlientBankXLS_SaveStream(byref pExpMan, byref pStream, byref pRecord)
	KlientBankXLS_SaveStream = pExpMan.container().import( pStream )
end function


