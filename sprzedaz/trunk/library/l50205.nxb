	XLS_FIELD_REQ(strNazwa, Miejscowosc)

	if (not pExpMan.shouldContinue( pStream )) then
		exit function
	end if

	pStream.fields("eWielkosc") = 7

	MiejscowoscBezWojXLS_Convert2Stream = true
end function

