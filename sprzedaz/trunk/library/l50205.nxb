'-----------------------------------------------------------------------
' Kontener importu z Excel'a
'-----------------------------------------------------------------------

dim importowano

class CExcelExpContainer
	
	public pImport
	public pExport

	private sub class_initialize()
		set pImport = new CImportManager
		set pExport = nothing
		
		set m_oExtraInfo = nothing
	end sub

	'--------------------------------------------------------------
	' Importuj dany strumień eksportowy
	'--------------------------------------------------------------
	public function import(byref pImportStream)
		import = pImport.import( pImportStream )
		if (not import) then
			pImport.cancelImport
			pExport.cancelExport
		end if
	end function

	'--------------------------------------------------------------
	'Podłączymy się do odpowidniego pliku Excela
	'--------------------------------------------------------------
	public function logon(byval strFileName, byref pExportManager)
		logon = pExportManager.connectExcel( strFileName )
	end function

	'--------------------------------------------------------------
	' Pobieramy import manager
	'--------------------------------------------------------------
	public function getImportManager()
		set getImportManager = pImport
	end function

	'--------------------------------------------------------------
	' Zapisz wszystko i zakoncz import
	'--------------------------------------------------------------
	public function end_import(): end_import = false
		if (pImport.isCanceled()) then
			exit function
		end if

		if (pExport.isCanceled()) then
			exit function
		end if

		end_import = pImport.end_import()
	end function

	'--------------------------------------------------------------
	' Ustaw export manager
	'--------------------------------------------------------------
	public function setExport(byref pNewExportManager)
		set pExport = pNewExportManager
	end function
	'--------------------------------------------------------------
	' extra info
	'--------------------------------------------------------------
	public m_oExtraInfo
end class


'-----------------------------------------------------------------------
' Podejmuje probe pobrania wartosci pola z rekordu
'-----------------------------------------------------------------------
function getValue(byref pExpMan, byref pRecord, byval strFieldName, byval bOptional)
	dim varValue: varValue = Empty
	on error resume next
	varValue = pRecord.fields(strFieldName).value
	on error goto 0

	if (not bOptional) then
		if (isNull(varValue) or isEmpty(varValue)) then
			
			if (isEmpty(varValue)) then
				view_message1 6305, 0, strFieldName
			else
				view_message1 6306, 0, strFieldName
				getValue = Empty
			end if

			pExpMan.cancelExport
			exit function
		end if
	else
		if (isNull(varValue)) then
			varValue = Empty
		end if
	end if

	getValue = varValue
end function

