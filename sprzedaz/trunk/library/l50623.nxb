'-----------------------------------------------------------------------
' Wybór stringa:
'
' strShrorcutName - nazwa skrótu zanim zostanie jeszcze dokonany wybór
' strConnector2
' bOptional - Czy param wymagany
'-----------------------------------------------------------------------
private function CHOICE_STRING2(byval strShrorcutName, byval strConnector2, byval bOptional)

	dim strOptional: strOptional = "0"
	if (bOptional) then
		strOptional = "1"
	end if

	CHOICE_STRING2 = DELIMITER_LEVEL_1 + DELIMITER_LEVEL_2 + _
		strShrorcutName + DELIMITER_LEVEL_3 + TYPE_CHOICE_STRING + DELIMITER_LEVEL_3 + strOptional + DELIMITER_LEVEL_3 + strConnector2 + _
		DELIMITER_LEVEL_1
