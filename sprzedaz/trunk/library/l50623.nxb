'-----------------------------------------------------------------------
private function CHOICE_CURRENCY_CONTINUE2(byval strShrorcutName, byval strConnector, byval strConnector2)
	CHOICE_CURRENCY_CONTINUE2 = DELIMITER_LEVEL_1 + DELIMITER_LEVEL_2 + _
		strShrorcutName + DELIMITER_LEVEL_3 + TYPE_CHOICE_CURRENCY_CONTINUE + DELIMITER_LEVEL_3 + strConnector2 + DELIMITER_LEVEL_3 + strConnector + _
