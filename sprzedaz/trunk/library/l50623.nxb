'-----------------------------------------------------------------------
private function CHOICE_CURRENCY_CONTINUE(byval strShrorcutName, byval strConnector)
	CHOICE_CURRENCY_CONTINUE = CHOICE_CURRENCY_CONTINUE2(strShrorcutName, strConnector, "")
