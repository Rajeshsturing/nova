'-----------------------------------------------------------------------
' Wybór stringa:
'
' strShrorcutName - nazwa skrótu zanim zostanie jeszcze dokonany wybór
' strConnector - co mo¿e oddzielaæ poszczególne wybory - separator ;
' strConnector2 - co mo¿e oddzielaæ poszczególne wybory - separator ;
'-----------------------------------------------------------------------
private function CHOICE_STRING_CONTINUE2(byval strShrorcutName, byval strConnector, byval strConnector2)
	CHOICE_STRING_CONTINUE2 = DELIMITER_LEVEL_1 + DELIMITER_LEVEL_2 + _
		strShrorcutName + DELIMITER_LEVEL_3 + TYPE_CHOICE_STRING_CONTINUE + DELIMITER_LEVEL_3 + strConnector2 + DELIMITER_LEVEL_3 + strConnector + _
		DELIMITER_LEVEL_1
end function

'-----------------------------------------------------------------------
' Wybór stringa:
'
' strShrorcutName - nazwa skrótu zanim zostanie jeszcze dokonany wybór
' strConnector - co mo¿e oddzielaæ poszczególne wybory - separator ;
'-----------------------------------------------------------------------
private function CHOICE_STRING_CONTINUE(byval strShrorcutName, byval strConnector)
	CHOICE_STRING_CONTINUE = CHOICE_STRING_CONTINUE2(strShrorcutName, strConnector, "")
end function


'************************************************************************
'*
'* str(Optional)Description -> HLI
'*
'* Tworzenie shortcut dla danego stringa wygenerowanego przez w/w funckje,
'* tzn. powi¹zanie parametrów ze stringa "Description" z odpowiednimi
'* prop w przekazywanym dalej HLI
'************************************************************************

'-----------------------------------------------------------------------
' Tworzy skrot dla dostarczonego parametru. pChoiceElement wynika ze
' zdefiniowanego stringa (jest z niego wydobywany) i rezprezentuje
' jeden parametr z mo¿liwoœci¹ wyboru.
'-----------------------------------------------------------------------
private function Rules_CreateShorcut(byref pChoiceElement, byval nParamPosition): set Rules_CreateShorcut = nothing
	'Ze wzgledu na typ skotu ustawiamy rozne property
	'i rozne nazwy funkcji

	dim pShortCut
	set pShortCut = doc_.createhli()

	'Pozycja w tablicy parametrów wype³nionych
	pShortCut.prop(FUNCTION_ARRAY_POS) = CLng(nParamPosition)

	dim strChoiceType
	strChoiceType = pChoiceElement.value(1)
	
	select case strChoiceType
		case TYPE_CHOICE_OBJECT, TYPE_CHOICE_OBJECT_CONTINUE

			dim nTypeId
			nTypeId = CLng(pChoiceElement.value(2))

			dim strFieldName
			strFieldName = CStr(pChoiceElement.value(3))
			
			pShortCut.prop(GVAR_FUNCTIONHLI) = "Rules_ChoiceObject"
			pShortCut.prop(FUNCTION_TYPEID) = nTypeId
			pShortCut.prop(FUNCTION_FLDNAME) = strFieldName

			'Zanzaczamy ze jest lub nie ma mozliwoœci kontynuacji
			if (pChoiceElement.value(1) = TYPE_CHOICE_OBJECT_CONTINUE) then
				pShortCut.prop(FUNCTION_CONNECTOR) = pChoiceElement.value(pChoiceElement.UpperIndex())
				pShortCut.prop(FUNCTION_CONNECTOR2) = pChoiceElement.value(pChoiceElement.UpperIndex()-1)
			else
				pShortCut.prop(FUNCTION_CONNECTOR) = ""
			end if

			if (pChoiceElement.value(4)<>"") then
				pShortCut.prop(FUNCTION_OPTIONAL) = pChoiceElement.value(4)
				pShortCut.prop(FUNCTION_WHERE) = pChoiceElement.value(5)
			end if

			set Rules_CreateShorcut = pShortCut

		case TYPE_CHOICE_CURRENCY, TYPE_CHOICE_CURRENCY_CONTINUE
			pShortCut.prop(GVAR_FUNCTIONHLI) = "Rules_ChoiceCurrency"

			'Zanzaczamy ze jest lub nie ma mozliwoœci kontynuacji
			if (pChoiceElement.value(1) = TYPE_CHOICE_CURRENCY_CONTINUE) then
				pShortCut.prop(FUNCTION_CONNECTOR) = pChoiceElement.value(pChoiceElement.UpperIndex())
				pShortCut.prop(FUNCTION_CONNECTOR2) = pChoiceElement.value(pChoiceElement.UpperIndex()-1)
			else
				pShortCut.prop(FUNCTION_CONNECTOR) = ""
				pShortCut.prop(FUNCTION_OPTIONAL) = pChoiceElement.value(pChoiceElement.UpperIndex()-1)
				pShortCut.prop(FUNCTION_CONNECTOR2) = pChoiceElement.value(pChoiceElement.UpperIndex())

				if (strChoiceType=TYPE_CHOICE_CURRENCY) then
					pShortCut.prop(FUNCTION_NO_CONTINUE) = CLng(1)
				end if

			end if

			set Rules_CreateShorcut = pShortCut

		case TYPE_CHOICE_DATE, TYPE_CHOICE_DATE_CONTINUE
			pShortCut.prop(GVAR_FUNCTIONHLI) = "Rules_ChoiceDate"

			'Zanzaczamy ze jest lub nie ma mozliwoœci kontynuacji
			if (pChoiceElement.value(1) = TYPE_CHOICE_DATE_CONTINUE) then
				pShortCut.prop(FUNCTION_CONNECTOR) = pChoiceElement.value(pChoiceElement.UpperIndex())
			else
				pShortCut.prop(FUNCTION_CONNECTOR) = ""
			end if

			set Rules_CreateShorcut = pShortCut

		case TYPE_CHOICE_STRING, TYPE_CHOICE_STRING_CONTINUE
			pShortCut.prop(GVAR_FUNCTIONHLI) = "Rules_ChoiceString"

			'Zanzaczamy ze jest lub nie ma mozliwoœci kontynuacji
			if (pChoiceElement.value(1) = TYPE_CHOICE_STRING_CONTINUE) then
				pShortCut.prop(FUNCTION_CONNECTOR) = pChoiceElement.value(pChoiceElement.UpperIndex())
				pShortCut.prop(FUNCTION_CONNECTOR2) = pChoiceElement.value(pChoiceElement.UpperIndex()-1)
			else
				pShortCut.prop(FUNCTION_CONNECTOR) = ""

				pShortCut.prop(FUNCTION_OPTIONAL) = pChoiceElement.value(pChoiceElement.UpperIndex()-1)
				pShortCut.prop(FUNCTION_CONNECTOR2) = pChoiceElement.value(pChoiceElement.UpperIndex())

				if (strChoiceType=TYPE_CHOICE_STRING) then
					pShortCut.prop(FUNCTION_NO_CONTINUE) = CLng(1)
				end if

			end if

			set Rules_CreateShorcut = pShortCut
			
	end select

end function
