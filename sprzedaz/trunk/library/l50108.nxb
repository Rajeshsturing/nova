function page_GoFirst(strMessage)	
	if not page_.cursoriter is nothing then
		if page_.cursoriter.isempty() then
			page_GoFirst = false
			trans_.message 1002 , 0 , strMessage
			exit function
		else
			page_.root.ignore=true
			silent_ffirst()				
		end if
	end if
	page_GoFirst = true
end function