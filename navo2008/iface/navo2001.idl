	HRESULT GetCacheInfoGUID
	(
		[in] LPCSTR lpFullServerPath,
		[out] GUID * pGUID
	);
	[helpstring("makes FTS query")]
	HRESULT FTSQuery
	(
		[in] LPCSTR lpFullServerPath,
		[in] LPCSTR lpQuery,
		[out] ISimpleEnumId ** ppSimpleEnumFileId
	);
	[helpstring("options")]
	HRESULT SetOptions
	(
		[in] long nOptions
	);
	[helpstring("store data object")]
	HRESULT StoreDataObject
	(
		[in] LPCSTR lpFullServerPath,
		[in] long nTypeId,
		[in] long nIdObj,
		[in] long nVersion,
		[in] long nDataLength,
		[unique, in, size_is(nDataLength)] byte * pData
	);
	[helpstring("get data object")]
