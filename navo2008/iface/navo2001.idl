///////////////////////////////////////////////////////////////////////
// INavoErrorInfo - error information storage
///////////////////////////////////////////////////////////////////////
const long UNIOPTIONS_COMPRESS_TRAFFIC_TO_CLIENT = 0x00000001;


[
	object,
	pointer_default (unique),
	uuid(188cb14d-82a4-4498-87d0-ebd8d9a00fb8)
]
interface INavoErrorInfo : IUnknown
{
	[helpstring("retrieves error information")]
	HRESULT RetrieveError
	(
		[out] long *pDataLength,
		[out, size_is(, *pDataLength)] byte ** lpBinaryData
	);
	[helpstring("retrieves error information")]
	HRESULT RetrieveError2
	(
		[out] LPSTR * ppcErrors
	);
};

///////////////////////////////////////////////////////////////////////
// INotificationManager - notification manager
///////////////////////////////////////////////////////////////////////

typedef enum tag_notifysinkclass
{
	nsc_document,
}
notifysinkclass;

typedef enum tag_objaction
{
	obj_insert,
	obj_update,
	obj_delete
} objaction;

typedef struct
{
	char		m_bCompressed;
	char		m_cExt[4];
} navostreaminfo;

[
	object,
	pointer_default (unique),
